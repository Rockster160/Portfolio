#!/usr/bin/env bash
# Subscribes to Portfolio MonitorChannel and exits 0 when the "deploy"
# monitor reports status=success. Exits 1 on status=failed. Auto-reconnects
# with exponential backoff on any drop.
#
# Usage:
#   bin/wait_for_deploy [channel_id]
#
# Args:
#   channel_id  Monitor id to watch (default: "deploy")
#
# Env:
#   PORTFOLIO_LOCAL_APIKEY  Bearer API key (auto-sourced from .env if unset)
#   PORTFOLIO_CABLE_URL     Override wss://ardesian.com/cable
#   DEPLOY_WAIT_DEBUG=1     Print verbose connect/subscribe/resync logs

set -euo pipefail

# Flip to 1 (or export DEPLOY_WAIT_DEBUG=1) to keep the timestamped debug
# stream visible alongside the status dot.
: "${DEPLOY_WAIT_DEBUG:=0}"

if [[ -z "${PORTFOLIO_LOCAL_APIKEY:-}" && -f "$(dirname "$0")/../.env" ]]; then
  PORTFOLIO_LOCAL_APIKEY="$(grep -E '^PORTFOLIO_LOCAL_APIKEY=' "$(dirname "$0")/../.env" | head -1 | cut -d= -f2- | tr -d '"'"'")"
  export PORTFOLIO_LOCAL_APIKEY
fi

: "${PORTFOLIO_LOCAL_APIKEY:?PORTFOLIO_LOCAL_APIKEY must be set}"

CHANNEL_ID="${1:-deploy}"
CABLE_URL="${PORTFOLIO_CABLE_URL:-wss://ardesian.com/cable}"

exec node --experimental-websocket --no-warnings - \
  "$CABLE_URL" "$PORTFOLIO_LOCAL_APIKEY" "$CHANNEL_ID" "$DEPLOY_WAIT_DEBUG" <<'JS'
const [,, cableUrl, apiKey, channelId, debugFlag] = process.argv;
const DEBUG = debugFlag === "1";
const url = `${cableUrl}?Authorization=${encodeURIComponent(`Bearer ${apiKey}`)}`;
const identifier = JSON.stringify({ channel: "MonitorChannel" });
const resyncData = JSON.stringify({ action: "resync", id: channelId, channel: channelId });

// Baseline of the deploy monitor state at the moment we started watching.
// null until the first broadcast lands (from our initial resync). Any later
// broadcast whose sha or timestamp differs is treated as a new deploy —
// including a resync response after reconnect, which is how we detect a
// deploy that finished while the socket was down.
let baseline = null;
let attempt = 0;
let ws = null;
let reconnectAt = null;
const startedAt = Date.now();

// First few retries use a fixed short delay — a dropped socket almost
// always comes right back. Only escalate to exponential backoff if we
// keep failing (server actually down / restart mid-deploy).
const FAST_RETRIES = 5;
const FAST_RETRY_MS = 3000;

function formatElapsed(ms) {
  const total = Math.round(ms / 1000);
  const h = Math.floor(total / 3600);
  const m = Math.floor((total % 3600) / 60);
  const s = total % 60;
  if (h) return `${h}h ${m}m ${s}s`;
  if (m) return `${m}m ${s}s`;
  return `${s}s`;
}

const isTTY = process.stderr.isTTY;
const c = {
  green:  isTTY ? "\x1b[32m" : "",
  red:    isTTY ? "\x1b[31m" : "",
  dim:    isTTY ? "\x1b[2m"  : "",
  grey:   isTTY ? "\x1b[90m" : "",
  reset:  isTTY ? "\x1b[0m"  : "",
};

function greyText(s) {
  return c.grey + s + c.reset;
}

function log(msg) {
  if (!DEBUG) return;
  const prefix = isTTY ? "\r\x1b[2K" : "";
  process.stderr.write(`${prefix}[${new Date().toISOString()}] ${msg}\n`);
  redraw();
}

let currentStatus = { dot: c.dim + "●" + c.reset, text: greyText("Connecting...") };

function status(dot, text) {
  currentStatus = { dot, text };
  redraw();
}

function redraw() {
  if (!isTTY) return;
  let { dot, text } = currentStatus;
  if (reconnectAt !== null) {
    const remaining = Math.max(1, Math.ceil((reconnectAt - Date.now()) / 1000));
    text = greyText(`Reconnecting in ${remaining}s...`);
  }
  const elapsed = greyText(` (${formatElapsed(Date.now() - startedAt)})`);
  process.stderr.write(`\r\x1b[2K${dot} ${text}${elapsed}`);
}

function finalize(dot, text) {
  const prefix = isTTY ? "\r\x1b[2K" : "";
  process.stderr.write(`${prefix}${dot} ${text}\n`);
}

function scheduleReconnect() {
  const delay = (
    attempt <= FAST_RETRIES
      ? FAST_RETRY_MS
      : Math.min(30000, 3000 * 2 ** (attempt - FAST_RETRIES))
  );
  log(`reconnecting in ${delay}ms (attempt ${attempt})`);

  reconnectAt = Date.now() + delay;
  currentStatus = { dot: c.red + "●" + c.reset, text: "" };
  redraw();

  setTimeout(() => {
    reconnectAt = null;
    connect();
  }, delay);
}

function terminal(kind, data) {
  log(`${kind} sha=${data.sha || "?"} ${data.message || ""}`);
  try { ws.close(); } catch {}
  const elapsed = greyText(` (${formatElapsed(Date.now() - startedAt)})`);
  if (kind === "success") {
    finalize(c.green + "✔" + c.reset, "Deploy Success!" + elapsed);
    process.exit(0);
  } else {
    finalize(c.red + "✘" + c.reset, "Deploy Failed!" + elapsed);
    process.exit(1);
  }
}

function connect() {
  attempt++;
  log(`connect (attempt ${attempt}) → ${cableUrl}`);
  status(c.dim + "●" + c.reset, greyText("Connecting..."));

  ws = new WebSocket(url);

  ws.addEventListener("open", () => log("open"));

  ws.addEventListener("message", (ev) => {
    let msg;
    try { msg = JSON.parse(ev.data); } catch { return; }

    if (msg.type === "welcome") {
      attempt = 0;
      ws.send(JSON.stringify({ command: "subscribe", identifier }));
      return;
    }

    if (msg.type === "confirm_subscription") {
      log(`subscribed → MonitorChannel (watching id=${channelId})`);
      status(c.green + "●" + c.reset, greyText("Waiting for deploy..."));
      ws.send(JSON.stringify({ command: "message", identifier, data: resyncData }));
      return;
    }

    if (msg.type) return; // ping / disconnect / reject

    const payload = msg.message;
    if (!payload || payload.id !== channelId) return;

    const data = payload.data || {};
    const sha = data.sha || null;
    const ts = payload.timestamp || 0;

    if (!baseline) {
      baseline = { sha, ts };
      log(`baseline sha=${sha || "?"} ts=${ts} status=${data.status || "?"}`);
      return;
    }

    const isNew = (sha && sha !== baseline.sha) || (ts && ts > baseline.ts);
    if (!isNew) return;

    if (data.status === "success") return terminal("success", data);
    if (data.status === "failed")  return terminal("failed",  data);
  });

  ws.addEventListener("close", (ev) => {
    log(`close code=${ev.code} reason=${ev.reason || ""}`);
    status(c.red + "●" + c.reset, greyText("Disconnected"));
    scheduleReconnect();
  });

  ws.addEventListener("error", (ev) => {
    log(`error ${ev.message || ""}`);
  });
}

redraw();
setInterval(redraw, 1000).unref();

process.on("SIGINT",  () => process.exit(130));
process.on("SIGTERM", () => process.exit(143));

if (isTTY) {
  process.stderr.write(greyText("(Ctrl+C to stop waiting — deploy will continue on the server)") + "\n");
}
connect();
JS
