#!/usr/bin/env zsh

## check syntax error with `sc`
# bundle exec cap production deploy "$@"

branch=$(git rev-parse --abbrev-ref HEAD)
if [[ "$branch" != "master" ]]; then
  echo "deploy: refusing to run on branch '$branch' (must be master)"
  exit 1
fi

source ~/.zshrc

push_output=$(gpo 2>&1)
push_status=$?
print -r -- "$push_output"
if (( push_status != 0 )); then
  exit $push_status
fi
if [[ "$push_output" == *"up-to-date"* || "$push_output" == *"up to date"* ]]; then
  print -P "%F{yellow}⚠ Nothing to deploy — origin/master already matches HEAD.%f"
  exit 0
fi

"$(dirname "$0")/wait_for_deploy" deploy || exit $?

if (( $# == 0 )); then
  # No-op- gets hit if there are no scripts to run after the deploy.
else
  for script in "$@"; do
    prodExec "$script" || exit $?
  done
fi
