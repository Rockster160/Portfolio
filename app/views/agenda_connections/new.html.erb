<%= meta_title "Connect Google Calendar", include_name: false %>

<div class="agenda-connect-container">
  <header class="agendas-index-header">
    <a href="<%= manage_agenda_path %>" class="agendas-index-back" aria-label="Back to agenda"><i class="fa fa-chevron-left"></i></a>
    <h1 class="agendas-index-title">Connect Google Calendar</h1>
  </header>

  <% if @needs_auth %>
    <p class="agenda-connect-intro">
      Connect a Google account to bring its calendars into your agenda. You'll
      pick which calendars to include on the next step.
    </p>
    <p>
      <a href="<%= start_google_agenda_connection_path %>" class="agenda-connect-cta">
        <i class="fa fa-google"></i> Sign in with Google
      </a>
    </p>
    <p class="agenda-connect-note">
      You can disconnect any calendar at any time.
    </p>
  <% else %>
    <p class="agenda-connect-intro">
      Each Google calendar can be connected as its own agenda. Connected
      agendas appear on /agenda/manage with their notification settings.
      Disconnect to remove the agenda + its synced items.
    </p>

    <ul class="agenda-connect-list">
      <% @calendars.each do |cal| %>
        <% existing = @connected_by_external_id[cal[:external_id]] %>
        <li class="agenda-connect-row" style="--option-color: <%= cal[:color] || Agenda::DEFAULT_COLOR %>;">
          <span class="agenda-pick-dot" aria-hidden="true"></span>
          <span class="agenda-connect-name">
            <i class="fa fa-google agenda-connect-source-icon" aria-hidden="true"></i>
            <%= cal[:name].presence || cal[:external_id] %>
            <% if cal[:primary] %><small class="agenda-connect-tag">primary</small><% end %>
            <% if existing %><small class="agenda-connect-tag agenda-connect-tag-success">connected</small><% end %>
          </span>
          <% if existing %>
            <%= button_to "Disconnect",
                disconnect_agenda_connection_calendar_path,
                method: :delete,
                params: { external_id: cal[:external_id] },
                class:  "af-btn af-btn-danger",
                data:   { confirm: "Disconnect this calendar? Its synced items will be removed." } %>
          <% else %>
            <%= button_to "Connect",
                connect_agenda_connection_calendar_path,
                method: :post,
                params: {
                  external_id: cal[:external_id],
                  name:        cal[:name],
                  color:       cal[:color],
                },
                class: "af-btn af-btn-primary" %>
          <% end %>
        </li>
      <% end %>
    </ul>

    <div class="agenda-connect-actions">
      <%= button_to "Disconnect Google entirely",
          agenda_connection_path,
          method: :delete,
          class:  "af-btn af-btn-danger",
          data:   { confirm: "Sign out of Google + remove all synced calendars?" } %>
    </div>
  <% end %>
</div>
