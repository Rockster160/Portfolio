<%= meta_title "Connect Google Calendar", include_name: false %>

<div class="agenda-connect-container">
  <header class="agendas-index-header">
    <a href="<%= manage_agenda_path %>" class="agendas-index-back" aria-label="Back to agenda"><i class="fa fa-chevron-left"></i></a>
    <h1 class="agendas-index-title">Connect Google Calendar</h1>
  </header>

  <% if @needs_auth %>
    <p class="agenda-connect-intro">
      Connect a Google account to bring its calendars into your agenda. You
      can connect multiple Google accounts.
    </p>
    <p>
      <a href="<%= start_google_agenda_connection_path %>" class="agenda-connect-cta">
        <i class="fa fa-google"></i> Sign in with Google
      </a>
    </p>
    <p class="agenda-connect-note">
      You can disconnect any calendar at any time.
    </p>
  <% else %>
    <p class="agenda-connect-intro">
      Each Google calendar can be connected as its own agenda. Connected
      agendas appear on /agenda/manage with their notification settings.
    </p>

    <% @account_sections.each do |section| %>
      <% account = section[:account] %>
      <section class="agenda-connect-account <%= "is-disconnected" if section[:disconnected] %>">
        <header class="agenda-connect-account-head">
          <span class="agenda-connect-account-label">Google Account</span>
          <span class="agenda-connect-account-email">
            <i class="fa fa-google agenda-connect-source-icon" aria-hidden="true"></i>
            <%= account.email %>
            <% if section[:disconnected] %><small class="agenda-connect-tag agenda-connect-tag-warn">disconnected</small><% end %>
          </span>
          <% unless section[:disconnected] %>
            <%= button_to "Disconnect account",
                agenda_connection_path,
                method:     :delete,
                params:     { google_account_id: account.id },
                form_class: "basic agenda-connect-row-form",
                class:      "af-btn af-btn-secondary",
                data:       { confirm: "Disconnect this Google account? All its synced calendars will be removed." } %>
          <% end %>
        </header>

        <% if section[:needs_reauth] || section[:load_error] %>
          <div class="agenda-connect-reauth">
            <p class="agenda-connect-note agenda-connect-note-warn">
              <% if section[:disconnected] %>
                <strong><%= account.email %></strong> was disconnected. Reconnect to re-add its calendars.
              <% elsif section[:load_error] %>
                Couldn't load <strong><%= account.email %></strong>'s calendars — the OAuth tokens have expired or been revoked.
              <% else %>
                <strong><%= account.email %></strong> needs to be reconnected.
              <% end %>
            </p>
            <a href="<%= start_google_agenda_connection_path %>" class="agenda-connect-cta">
              <i class="fa fa-google"></i> Reconnect <%= account.email %>
            </a>
          </div>
        <% else %>
          <h4 class="agenda-connect-calendars-heading">Available calendars</h4>
          <ul class="agenda-connect-list">
            <% section[:calendars].each do |cal| %>
              <% existing = section[:connected][cal[:external_id]] %>
              <li class="agenda-connect-row" style="--option-color: <%= cal[:color] || Agenda::DEFAULT_COLOR %>;">
                <span class="agenda-pick-dot" aria-hidden="true"></span>
                <span class="agenda-connect-name">
                  <%= cal[:name].presence || cal[:external_id] %>
                  <% if cal[:primary] %><small class="agenda-connect-tag">primary</small><% end %>
                  <% if existing %><small class="agenda-connect-tag agenda-connect-tag-success">connected</small><% end %>
                </span>
                <% if existing %>
                  <%= button_to "Disconnect",
                      disconnect_agenda_connection_calendar_path,
                      method:     :delete,
                      params:     { google_account_id: account.id, external_id: cal[:external_id] },
                      form_class: "basic agenda-connect-row-form",
                      class:      "af-btn af-btn-danger",
                      data:       { confirm: "Disconnect this calendar? Its synced items will be removed." } %>
                <% else %>
                  <%= button_to "Connect",
                      connect_agenda_connection_calendar_path,
                      method:     :post,
                      params:     {
                        google_account_id: account.id,
                        external_id:       cal[:external_id],
                        name:              cal[:name],
                        color:             cal[:color],
                      },
                      form_class: "basic agenda-connect-row-form",
                      class:      "af-btn af-btn-primary" %>
                <% end %>
              </li>
            <% end %>
          </ul>
        <% end %>
      </section>
    <% end %>

    <div class="agenda-connect-actions">
      <a href="<%= start_google_agenda_connection_path %>" class="agenda-connect-cta">
        <i class="fa fa-google"></i> Connect another account
      </a>
      <%= button_to "Disconnect everything",
          agenda_connection_path,
          method:     :delete,
          form_class: "basic",
          class:      "af-btn af-btn-danger",
          data:       { confirm: "Sign out of every Google account + remove all synced calendars?" } %>
    </div>
  <% end %>

  <%# Local copy of the confirm modal — the agenda.js bundle isn't loaded
      on this page, so we render the modal here and run a tiny inline
      controller below. Keeps the same look/feel as the in-app confirms. %>
  <div id="agenda-connect-confirm" class="modal hidden" role="dialog" aria-modal="true">
    <div class="modal-content agenda-confirm-content">
      <h3 class="agenda-confirm-title"></h3>
      <p class="agenda-confirm-body"></p>
      <div class="agenda-confirm-actions">
        <button type="button" class="af-btn af-btn-secondary agenda-confirm-cancel">Cancel</button>
        <button type="button" class="af-btn af-btn-danger agenda-confirm-ok">Disconnect</button>
      </div>
    </div>
  </div>
</div>

<% content_for :after_body do %>
  <script>
    (function () {
      // Connect / Disconnect buttons are `button_to` <form>s. On submit:
      //   * Disable the button (double-click + accidental double-submit guard)
      //   * Swap label for "Connecting…" + spinner so the slow happy-path
      //     doesn't look frozen (Connect kicks off a sync; Google calendarList
      //     can take a second).
      document.querySelectorAll(".agenda-connect-row-form, form").forEach((form) => {
        form.addEventListener("submit", () => {
          const btn = form.querySelector("button, input[type=submit]");
          if (!btn || btn.disabled) return;
          btn.disabled = true;
          btn.dataset.originalLabel = btn.textContent;
          const isConnect = btn.classList.contains("af-btn-primary");
          btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> ' + (isConnect ? "Connecting…" : "Working…");
        });
      });

      // Replace Rails UJS native data-confirm with our modal. Intercept the
      // click before UJS fires its `confirm:` callback; show the modal; on
      // OK, strip `data-confirm` and re-submit the form.
      const modal = document.getElementById("agenda-connect-confirm");
      const titleEl = modal?.querySelector(".agenda-confirm-title");
      const bodyEl  = modal?.querySelector(".agenda-confirm-body");
      const okBtn   = modal?.querySelector(".agenda-confirm-ok");
      const cancelBtn = modal?.querySelector(".agenda-confirm-cancel");

      function show(msg, onConfirm) {
        if (!modal) { if (window.confirm(msg)) onConfirm(); return; }
        // Two-line UX: first sentence becomes the title, the rest the body.
        const parts = (msg || "Are you sure?").split(/[.?!]\s+/, 2);
        if (titleEl) titleEl.textContent = (parts[0] || "Are you sure?").replace(/[?]+$/, "?");
        if (bodyEl)  bodyEl.textContent  = parts.slice(1).join(" ");
        modal.classList.remove("hidden");
        modal.classList.add("shown");

        const cleanup = (result) => {
          okBtn.removeEventListener("click", onOk);
          cancelBtn.removeEventListener("click", onCancel);
          document.removeEventListener("keydown", onKey);
          modal.classList.add("hidden");
          modal.classList.remove("shown");
          if (result) onConfirm();
        };
        const onOk     = () => cleanup(true);
        const onCancel = () => cleanup(false);
        const onKey    = (e) => { if (e.key === "Escape") cleanup(false); };
        okBtn.addEventListener("click", onOk);
        cancelBtn.addEventListener("click", onCancel);
        document.addEventListener("keydown", onKey);
      }

      // Capture-phase: run before Rails UJS so we own the prompt.
      document.addEventListener("click", (e) => {
        const trigger = e.target.closest("[data-confirm]");
        if (!trigger) return;
        e.preventDefault();
        e.stopPropagation();
        const msg = trigger.getAttribute("data-confirm");
        show(msg, () => {
          // Re-submit without re-prompting: clear the attribute first.
          trigger.removeAttribute("data-confirm");
          if (trigger.form) trigger.form.requestSubmit(trigger);
          else trigger.click();
        });
      }, true);
    })();
  </script>
<% end %>
