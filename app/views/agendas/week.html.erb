<%= meta_title "Agenda", include_name: false %>
<% content_for(:favicon) { render "agendas/favicon" } %>

<div class="agenda-page agenda-week-page"
     data-current-date="<%= @date.iso8601 %>">

  <header class="agenda-page-header">
    <h1 class="agenda-page-title">Agenda</h1>
    <span class="agenda-pending-badge hidden" aria-live="polite" title="Pending sync"><i class="fa fa-refresh"></i><span class="agenda-pending-badge-count"></span></span>
    <%= render "agendas/filter", agendas: @agendas %>
    <button type="button" class="agenda-add-btn" data-modal="#agenda-add-modal" aria-label="Add to agenda"><i class="fa fa-plus"></i></button>
    <a href="<%= manage_agenda_path %>" class="agenda-page-cog" aria-label="Manage agendas"><i class="fa fa-cog"></i></a>
  </header>

  <% if @date != Date.current %>
    <div class="agenda-jump-row">
      <a class="agenda-jump-today" href="<%= week_path %>">Jump to Today</a>
    </div>
  <% end %>

  <nav class="agenda-date-bar">
    <a class="date-nav prev" href="<%= week_path(date: (@date - 1).iso8601) %>" aria-label="Previous day"><i class="fa fa-chevron-left"></i></a>
    <span class="date-label"><%= @date.strftime("%a, %b %-d, %Y") %></span>
    <a class="date-nav next" href="<%= week_path(date: (@date + 1).iso8601) %>" aria-label="Next day"><i class="fa fa-chevron-right"></i></a>
  </nav>

  <div class="cal-view-toggle">
    <a href="<%= day_path %>" class="cal-toggle-btn">Day</a>
    <a href="<%= week_path %>" class="cal-toggle-btn active">Week</a>
    <a href="<%= calendar_path %>" class="cal-toggle-btn">Month</a>
  </div>

  <div class="agenda-error hidden">Disconnected — changes will sync when reconnected.</div>
  <div class="agenda-error agenda-error-dropped hidden" role="alert">
    Some changes couldn't be saved<span class="agenda-error-dropped-count"></span>.
    <button type="button" class="agenda-error-dismiss">Dismiss</button>
  </div>

  <% if @agendas.empty? %>
    <div class="agenda-empty">
      No agendas yet. <a href="<%= new_agenda_path %>">Create your first one.</a>
    </div>
  <% else %>
    <% if @carry_over.any? && (@date..@date + 7.days).cover?(Date.current) %>
      <section class="agenda-section section-carry">
        <header class="section-header">Carry over <span class="section-count"><%= @carry_over.size %></span></header>
        <div class="agenda-items">
          <% @carry_over.each do |item| %>
            <%= render "agenda_items/item", item: item %>
          <% end %>
        </div>
      </section>
    <% end %>

    <% (0..7).each do |offset| %>
      <% day = @date + offset.days %>
      <% items_today = (@items_by_date[day] || []).select { |i| i.visible_on?(day) } %>
      <% preview = (offset.positive?) %>
      <% label = if offset == 0
                   @date == Date.current ? "Today" : day.strftime("%A, %b %-d")
                 elsif offset == 1 && @date == Date.current
                   "Tomorrow"
                 else
                   day.strftime("%A, %b %-d")
                 end %>
      <section class="agenda-section <%= preview ? 'section-tomorrow' : 'section-today' %>" data-section-day="<%= offset %>">
        <header class="section-header"><%= label %></header>
        <div class="agenda-items <%= 'preview' if preview %>" data-section="day-<%= offset %>">
          <% if items_today.empty? %>
            <div class="agenda-empty <%= 'muted' if preview %>">Nothing scheduled<%= preview ? " yet." : "." %></div>
          <% end %>
          <% items_today.each do |item| %>
            <%= render "agenda_items/item", item: item, preview: preview %>
          <% end %>
        </div>
      </section>
    <% end %>

    <%= render "agenda_items/add_modal", agendas: @agendas, date: @date %>
    <%= render "agenda_items/edit_modal", agendas: @agendas %>
    <%= render "agenda_items/follow_up_modal" %>
    <%= render "agenda_items/details_modal" %>
    <%= render "agenda_items/confirm_modal" %>
  <% end %>
</div>
