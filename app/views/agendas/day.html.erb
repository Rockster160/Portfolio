<%= meta_title "Agenda", include_name: false %>
<% content_for(:favicon) { render "agendas/favicon" } %>

<%# Day view — empty shell. Items are rendered client-side by
    `agenda/day_view.js` from the shared AgendaStore (boots via
    `/agenda/sync/bootstrap` + localStorage hydrate). The agenda LIST
    pages (day/week) and the cal_month/cal_week PWA all draw from the
    same cache now; the only per-view code is the layout pass. %>
<div class="agenda-page agenda-day-page"
     data-current-date="<%= @date.iso8601 %>"
     data-today="<%= current_user.perceived_today.iso8601 %>">

  <header class="agenda-page-header">
    <h1 class="agenda-page-title">Agenda</h1>
    <span class="agenda-pending-badge hidden" aria-live="polite" title="Pending sync"><i class="fa fa-refresh"></i><span class="agenda-pending-badge-count"></span></span>
    <%= render "agendas/filter", agendas: @agendas %>
    <button type="button" class="agenda-add-btn" data-modal="#agenda-quick-add" aria-label="Add to agenda"><i class="fa fa-plus"></i></button>
    <a href="<%= manage_agenda_path %>" class="agenda-page-cog" aria-label="Manage agendas"><i class="fa fa-cog"></i></a>
  </header>

  <nav class="agenda-date-bar">
    <a class="date-nav prev" href="<%= day_path(date: (@date - 1).iso8601) %>" aria-label="Previous day"><i class="fa fa-chevron-left"></i></a>
    <span class="date-label"><%= @date.strftime("%a, %b %-d, %Y") %></span>
    <a class="date-nav next" href="<%= day_path(date: (@date + 1).iso8601) %>" aria-label="Next day"><i class="fa fa-chevron-right"></i></a>
  </nav>

  <%# Placed BELOW the nav so the prev/next/date-label row holds a
      fixed position whether or not we're on today. Always rendered —
      `list_view.js` toggles the `.hidden` class on client-side nav, and
      `querySelector` returns null if the node isn't already in the
      DOM. Without this, navigating away from today after a fresh page
      load (which started on today) leaves the affordance gone for the
      rest of the session. %>
  <div class="agenda-jump-row <%= "hidden" if @date == Date.current %>">
    <a class="agenda-jump-today" href="<%= day_path %>">Jump to Today</a>
  </div>

  <div class="cal-view-toggle">
    <a href="<%= day_path %>" class="cal-toggle-btn active">Day</a>
    <a href="<%= week_path %>" class="cal-toggle-btn">Week</a>
    <a href="<%= cal_month_path %>" class="cal-toggle-btn">Month</a>
  </div>

  <div class="agenda-error hidden">Disconnected — changes will sync when reconnected.</div>
  <%# Permanent-failure banner: lit when one or more changes were rejected
      by the server (4xx) so we can't keep retrying. The count is a hint;
      "Dismiss" clears the local record after the user has read it. %>
  <div class="agenda-error agenda-error-dropped hidden" role="alert">
    Some changes couldn't be saved<span class="agenda-error-dropped-count"></span>.
    <button type="button" class="agenda-error-dismiss">Dismiss</button>
  </div>

  <% if @agendas.empty? %>
    <div class="agenda-empty">
      No agendas yet. <a href="<%= new_agenda_path %>">Create your first one.</a>
    </div>
  <% else %>
    <%# Carry-over section — hidden until the JS finds items to fill it
        (incomplete tasks past their start_at, today view only). %>
    <section class="agenda-section section-carry hidden">
      <header class="section-header">Carry over <span class="section-count"></span></header>
      <div class="agenda-items" data-section="carry"></div>
    </section>

    <% is_today = (@date == Date.current) %>
    <% primary_label   = is_today ? "Today"    : @date.strftime("%A, %b %-d") %>
    <% secondary_label = is_today ? "Tomorrow" : (@date + 1).strftime("%A, %b %-d") %>

    <section class="agenda-section section-today" data-section-day="0">
      <header class="section-header"><%= primary_label %></header>
      <div class="agenda-items" data-section="day-0"></div>
      <div class="agenda-empty agenda-section-empty hidden">Nothing scheduled.</div>
    </section>

    <section class="agenda-section section-tomorrow" data-section-day="1">
      <header class="section-header"><%= secondary_label %></header>
      <div class="agenda-items preview" data-section="day-1"></div>
      <div class="agenda-empty agenda-section-empty muted hidden">Nothing scheduled yet.</div>
    </section>

    <%# Template the JS clones per item — see `agenda_item_renderer.js`. %>
    <%= render "agenda_items/template" %>

    <%# Picker includes Google agendas — new items mirror to Google via
        events.insert, but kind is locked to Event in the form. %>
    <%= render "agenda_items/quick_add_modal", agendas: @agendas %>
    <%= render "agenda_items/add_modal", agendas: @agendas, date: @date %>
    <%= render "agenda_items/edit_modal", agendas: @agendas %>
    <%= render "agenda_items/follow_up_modal" %>
    <%= render "agenda_items/details_modal" %>
    <%= render "agenda_items/confirm_modal" %>
    <%= render "agenda_items/pending_queue_modal" %>
  <% end %>
</div>
