<%= meta_title "Manage agendas", include_name: false %>

<div class="agendas-index-container">
  <header class="agendas-index-header">
    <a href="<%= agenda_path %>" class="agendas-index-back" aria-label="Back to agenda"><i class="fa fa-chevron-left"></i></a>
    <h1 class="agendas-index-title">My Agendas</h1>
    <a href="<%= new_agenda_path %>" class="agendas-index-new" aria-label="New agenda"><i class="fa fa-plus"></i></a>
  </header>

  <ul class="agendas-list">
    <% @agendas.each do |agenda| %>
      <% mine = (agenda.user_id == current_user.id) %>
      <li class="agenda-card" style="--card-color: <%= agenda.color %>;">
        <span class="agenda-card-swatch" aria-hidden="true"></span>
        <span class="agenda-card-main">
          <span class="agenda-card-name"><%= agenda.name %></span>
          <span class="agenda-card-meta">
            <%= pluralize(agenda.agenda_items.where(start_at: Date.current.all_day).count, "item") %> today
            <% unless mine %>
              · <span class="agenda-card-shared">shared by <%= agenda.user.username %></span>
            <% end %>
          </span>
        </span>
        <% if mine %>
          <a href="<%= edit_agenda_path(agenda) %>" class="agenda-card-edit" aria-label="Edit <%= agenda.name %>"><i class="fa fa-pencil"></i></a>
        <% end %>
      </li>
    <% end %>
    <% if @agendas.empty? %>
      <li class="agenda-empty">
        No agendas yet. <a href="<%= new_agenda_path %>">Create your first one.</a>
      </li>
    <% end %>
  </ul>
</div>
