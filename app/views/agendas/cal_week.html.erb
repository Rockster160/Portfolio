<%= meta_title @week_start.strftime("Week of %b %-d"), include_name: false %>
<% content_for(:favicon) { render "agendas/cal_favicon" } %>
<% content_for(:body_classes) { "agenda-cal-body" } %>

<%# `agenda-page` triggers shared init in agenda.js (filter, modals,
    monitor, item-edit). The time-grid, drag-to-create, and current-time
    line are wired up in src/agenda_cal/agenda_cal.js, keyed on
    `agenda-cal-week-page`. %>
<div class="agenda-page agenda-cal-page agenda-cal-week-page"
     data-current-date="<%= @date.iso8601 %>"
     data-today="<%= Date.current.iso8601 %>"
     data-week-start="<%= @week_start.iso8601 %>"
     data-week-end="<%= @week_end.iso8601 %>">

  <%# Condensed single-row toolbar — sticks to the top of the viewport
      so the title, navigation, view toggle, and per-page actions stay
      visible while the user scrolls through the time grid below. %>
  <% prev_week = (@week_start - 7.days).iso8601 %>
  <% next_week = (@week_start + 7.days).iso8601 %>
  <header class="cal-toolbar">
    <div class="cal-toolbar-left">
      <span class="agenda-error cal-error-dot hidden" role="status" aria-live="polite" title="Disconnected — changes will sync when reconnected."></span>
      <h1 class="cal-toolbar-title"><%= @focus_date.strftime("%B %Y") %></h1>
      <div class="cal-toolbar-toggle cal-view-toggle cal-pwa-toggle">
        <a href="<%= cal_month_path %>" class="cal-toggle-btn">Month</a>
        <a href="<%= cal_week_path %>" class="cal-toggle-btn active">Week</a>
      </div>
    </div>

    <nav class="cal-toolbar-nav" aria-label="Week navigation">
      <a class="date-nav prev" href="<%= cal_week_path(date: prev_week) %>" aria-label="Previous week"><i class="fa fa-chevron-left"></i></a>
      <a class="cal-today-btn" href="<%= cal_week_path %>">Today</a>
      <a class="date-nav next" href="<%= cal_week_path(date: next_week) %>" aria-label="Next week"><i class="fa fa-chevron-right"></i></a>
    </nav>

    <div class="cal-toolbar-actions">
      <span class="agenda-pending-badge hidden" aria-live="polite" title="Pending sync"><i class="fa fa-refresh"></i><span class="agenda-pending-badge-count"></span></span>
      <%= render "agendas/filter", agendas: @agendas %>
      <button type="button" class="agenda-add-btn" data-modal="#agenda-add-modal" aria-label="Add event"><i class="fa fa-plus"></i></button>
      <a href="<%= manage_agenda_path %>" class="agenda-page-cog" aria-label="Manage agendas"><i class="fa fa-cog"></i></a>
    </div>
  </header>

  <%# `data-day-start-hour` mirrors `User#perceived_today`'s rollover so a
      2am event renders on the *previous* logical day (matching the user's
      mental model of "still last night"). %>
  <div class="cal-week-grid"
       data-week-start="<%= @week_start.iso8601 %>"
       data-week-end="<%= @week_end.iso8601 %>"
       data-px-per-hour="20"
       data-snap-min="15"
       data-day-start-hour="3">

    <div class="cal-week-header">
      <div class="cal-week-header-gutter"></div>
      <div class="cal-week-header-days">
        <% (0..6).each do |offset| %>
          <% day = @week_start + offset.days %>
          <% is_today = (day == Date.current) %>
          <div class="cal-week-header-day <%= 'is-today' if is_today %>" data-date="<%= day.iso8601 %>">
            <span class="cal-week-header-dow"><%= day.strftime("%a") %></span>
            <span class="cal-week-header-day-num"><%= day.day %></span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="cal-week-allday">
      <div class="cal-week-allday-gutter" title="all-day">all-day</div>
      <div class="cal-week-allday-cells" data-allday-cells>
        <% (0..6).each do |offset| %>
          <% day = @week_start + offset.days %>
          <div class="cal-week-allday-cell <%= 'is-today' if day == Date.current %>"
               data-date="<%= day.iso8601 %>"
               data-weekday="<%= offset %>"></div>
        <% end %>
      </div>
    </div>

    <%# Single 8-col grid: hour gutter + 7 day columns as direct children.
        The earlier wrapper (.cal-week-columns) was disappearing or
        sizing to 0 in some browsers — sidestepping it entirely by
        promoting the day columns one level up so the body's own grid
        template owns the horizontal layout. %>
    <div class="cal-week-body" data-week-body>
      <div class="cal-week-hours">
        <%# 24 rows starting at the logical day-start (3am). The first
            row's label is omitted (would clip against the grid top) —
            handled with an `unless` guard rather than `next` so the
            enclosing div/span both get closed properly. ERB's `next`
            inside an open tag silently drops the closing tags, which
            cascaded the rest of the body into the unclosed gutter row. %>
        <% day_start = 3 %>
        <% (0..23).each do |i| %>
          <% h = (day_start + i) % 24 %>
          <div class="cal-week-hour" data-hour="<%= h %>">
            <% unless i == 0 %>
              <% display_h = h % 12 %>
              <% display_h = 12 if display_h == 0 %>
              <span class="cal-week-hour-label"><%= "#{display_h} #{h < 12 ? 'AM' : 'PM'}" %></span>
            <% end %>
          </div>
        <% end %>
      </div>
      <% (0..6).each do |offset| %>
        <% day = @week_start + offset.days %>
        <div class="cal-week-column <%= 'is-today' if day == Date.current %>"
             data-date="<%= day.iso8601 %>"
             data-weekday="<%= offset %>">
          <%# 24 hour-row backgrounds for visual grid lines. Sized purely
              by CSS — JS doesn't touch these. %>
          <% (0..23).each do |h| %>
            <div class="cal-week-hour-bg" data-hour="<%= h %>"></div>
          <% end %>
          <%# Drag-selection element, shown while user is creating. %>
          <div class="cal-week-drag-sel hidden" aria-hidden="true"></div>
          <%# Thin left-edge gutter where agenda_cal.js paints a colored
              line per hidden event so the user knows something is there.
              Empty until paintHiddenGutters runs. %>
          <div class="cal-week-hidden-gutter" data-hidden-gutter aria-hidden="true"></div>
        </div>
      <% end %>
      <%# Current-time line, positioned absolutely inside the body grid
          by JS. Only visible when today is in the visible week. %>
      <div class="cal-week-now-line hidden" aria-hidden="true">
        <span class="cal-week-now-dot"></span>
        <span class="cal-week-now-bar"></span>
      </div>
      <%# Gutter chip showing the current wall-clock time, positioned at
          the same Y as the now-line so the user has a precise readout
          on the left next to the hour ladder. %>
      <div class="cal-week-now-chip hidden" aria-hidden="true">
        <span class="cal-week-now-time"></span>
      </div>
    </div>

    <%# Event seeds are NO LONGER server-rendered. agenda_cal.js builds
        every .cal-week-event / .cal-week-allday-chip directly from
        AgendaStore (src/agenda_store/store.js), which hydrates from
        localStorage on page load and then refreshes from the
        /agenda/sync/bootstrap + /agenda/sync/delta endpoints.
        Leaving this empty <div> as the lookup anchor for
        per-render hydrated nodes (kept hidden — it's just a marker
        for buildWeekBlocks to know seeds USED to live here). %>
    <div class="cal-week-seeds hidden" data-week-seeds></div>
  </div>

  <%# Cold-start spinner — visible only on a true cold-boot (no
      localStorage cache AND no completed sync yet). agenda_cal.js
      hides this once the first authoritative payload lands. %>
  <div class="agenda-cold-start hidden" data-cold-start>
    <i class="fa fa-spinner fa-spin"></i>
    <span>Loading calendar…</span>
  </div>

  <%= render "agenda_items/add_modal", agendas: @agendas, date: @date %>
  <%= render "agenda_items/edit_modal", agendas: @agendas %>
  <%= render "agenda_items/follow_up_modal" %>
  <%= render "agenda_items/details_modal" %>
  <%= render "agenda_items/hidden_list_modal" %>
  <%= render "agenda_items/confirm_modal" %>
</div>
