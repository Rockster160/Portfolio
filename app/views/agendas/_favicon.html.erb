<%# PWA head bits for the Agenda. Rendered via content_for(:favicon) on
    every page within the Agenda surface — day, week, calendar, manage,
    edit/new — so navigation between them stays inside the installed app
    on iOS / Android. Mirrors lists/_favicon.html.erb structure. %>
<link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
<link rel="icon" type="image/png" href="/favicon/favicon-32x32.png" sizes="32x32">
<link rel="icon" type="image/png" href="/favicon/favicon-16x16.png" sizes="16x16">
<link rel="manifest" href="/agenda.webmanifest">
<link rel="mask-icon" href="/favicon/safari-pinned-tab.svg" color="#141a26">
<link rel="shortcut icon" href="/favicon/favicon.ico">
<meta name="msapplication-config" content="/favicon/browserconfig.xml">
<meta name="theme-color" content="#141a26">
<meta name="apple-mobile-web-app-title" content="Agenda">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
