<%# Read-only details modal for viewer-permission rows. %>
<%= render_modal("agenda-item-details", "Details", "modal-flat") do %>
  <div class="agenda-details">
    <div class="agenda-details-agenda">
      <span class="agenda-details-dot" data-agenda-color-target aria-hidden="true"></span>
      <span data-agenda-name-target></span>
    </div>
    <h2 class="agenda-details-name" data-name-target></h2>
    <div class="agenda-details-row" data-when-target></div>
    <div class="agenda-details-row hidden agenda-details-loc" data-loc-row>
      <i class="fa fa-map-marker"></i>
      <span class="agenda-details-loc-body" data-loc-target></span>
    </div>
    <div class="agenda-details-row hidden" data-recurring-row>
      <i class="fa fa-refresh"></i> <span data-recurring-target></span>
      <button type="button" class="agenda-details-hide-recurring hidden" data-toggle-hide-recurring
              aria-label="Hide this recurring event">
        <i class="fa fa-eye-slash" data-toggle-hide-recurring-icon></i>
        <span class="agenda-details-hide-recurring-text" data-toggle-hide-recurring-label>Hide</span>
      </button>
    </div>
    <div class="agenda-details-notes hidden" data-notes-row>
      <h4>Notes</h4>
      <p data-notes-target></p>
    </div>
    <div class="agenda-details-foot">
      <button type="button" class="af-btn af-btn-secondary" data-dismiss="#agenda-item-details">Close</button>
      <button type="button" class="af-btn af-btn-primary hidden" data-edit-from-details>Edit</button>
    </div>
  </div>
<% end %>
