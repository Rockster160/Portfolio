<%# Read-only details modal for viewer-permission rows. %>
<%= render_modal("agenda-item-details", "Details", "modal-flat") do %>
  <div class="agenda-details">
    <div class="agenda-details-agenda">
      <span class="agenda-details-dot" data-agenda-color-target aria-hidden="true"></span>
      <span data-agenda-name-target></span>
    </div>
    <h2 class="agenda-details-name" data-name-target></h2>
    <div class="agenda-details-row" data-when-target></div>
    <div class="agenda-details-row hidden agenda-details-loc" data-loc-row>
      <i class="fa fa-map-marker"></i>
      <div class="agenda-details-loc-stack">
        <span class="agenda-details-loc-body" data-loc-target></span>
        <span class="agenda-details-loc-resolved hidden" data-loc-resolved-target></span>
      </div>
    </div>
    <div class="agenda-details-row hidden agenda-details-travel" data-travel-row>
      <span class="agenda-details-leave-at" data-leave-at-target></span>
      <i class="fa fa-clock-o" data-arrive-early-icon hidden></i>
      <span data-arrive-early-target></span>
      <span class="agenda-details-travel-plus" data-travel-plus hidden>+</span>
      <i class="fa fa-car" data-travel-icon hidden></i>
      <span data-travel-target></span>
    </div>
    <div class="agenda-details-row hidden agenda-details-travel agenda-details-post-travel" data-post-travel-row>
      <i class="fa fa-car"></i>
      <span data-post-travel-target></span>
      <span class="agenda-details-arrive-at" data-post-arrive-at-target></span>
    </div>
    <div class="agenda-details-row hidden" data-recurring-row>
      <i class="fa fa-refresh"></i> <span data-recurring-target></span>
    </div>
    <div class="agenda-details-row agenda-details-hide-row">
      <button type="button" class="agenda-details-hide-recurring hidden" data-toggle-hide-recurring
              aria-label="Hide this event">
        <i class="fa fa-eye-slash" data-toggle-hide-recurring-icon></i>
        <span class="agenda-details-hide-recurring-text" data-toggle-hide-recurring-label>Hide</span>
      </button>
    </div>
    <div class="agenda-details-rsvp hidden" data-rsvp-row>
      <h4>Your response</h4>
      <div class="agenda-details-rsvp-buttons">
        <button type="button" class="af-btn rsvp-btn rsvp-accepted"  data-rsvp-action="accepted"><i class="fa fa-check"></i> Yes</button>
        <button type="button" class="af-btn rsvp-btn rsvp-tentative" data-rsvp-action="tentative"><i class="fa fa-question"></i> Maybe</button>
        <button type="button" class="af-btn rsvp-btn rsvp-declined"  data-rsvp-action="declined"><i class="fa fa-times"></i> No</button>
      </div>
      <p class="agenda-details-rsvp-feedback hidden" data-rsvp-feedback></p>
    </div>
    <div class="agenda-details-attendees hidden" data-attendees-row>
      <h4 data-attendees-heading>Guests</h4>
      <ul class="agenda-details-attendee-list" data-attendees-list></ul>
    </div>
    <div class="agenda-details-notes hidden" data-notes-row>
      <h4>Notes</h4>
      <p data-notes-target></p>
    </div>
    <div class="agenda-details-foot">
      <button type="button" class="af-btn af-btn-secondary" data-dismiss="#agenda-item-details">Close</button>
      <a class="af-btn af-btn-secondary hidden" data-go-to-date href="#">Go to date</a>
      <button type="button" class="af-btn af-btn-primary hidden" data-edit-from-details>Edit</button>
    </div>
  </div>
<% end %>
