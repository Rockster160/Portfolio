<% preview ||= false %>
<% local_start = item.start_at.in_time_zone(item.user.timezone) %>
<% local_end   = item.end_at&.in_time_zone(item.user.timezone) %>
<% item_url    = agenda_item_path(item.display_id) %>
<% classes     = ["agenda-item"] %>
<% classes << "kind-#{item.kind}" %>
<% classes << "crossed-out" if item.crossed_out? %>
<% classes << "recurring"   if item.recurring? %>
<% classes << "phantom"     if item.phantom? %>
<% classes << "preview"     if preview %>

<%# Row click priority (in order of frequency the user actually does them):
      1. Tap the body  → toggle complete (native <label for> link to checkbox).
         The label stretches to fill the row's full height (CSS) so the entire
         visible row hits the label — not just the narrow text band.
      2. Tap the pencil → open edit modal (only the pencil carries data-edit-item).
      3. Tap the checkbox → toggle complete (it's still there for state +
         keyboard accessibility).
      The row container has NO click handler of its own — touch scrolling
      stays a scroll, never an accidental edit. %>
<div class="<%= classes.join(" ") %>"
     style="--item-color: <%= item.display_color %>; --agenda-color: <%= item.agenda.color %>;"
     title="<%= item.agenda.name %>"
     data-item-id="<%= item.display_id %>"
     data-item-url="<%= item_url %>"
     data-phantom="<%= item.phantom? %>"
     data-recurring="<%= item.recurring? %>"
     data-kind="<%= item.kind %>"
     data-color="<%= item.display_color %>"
     data-agenda-id="<%= item.agenda_id %>"
     data-agenda-name="<%= item.agenda.name %>"
     data-agenda-color="<%= item.agenda.color %>"
     data-start-at="<%= item.start_at.iso8601 %>"
     data-end-at="<%= item.end_at&.iso8601 %>"
     data-name="<%= item.name %>"
     data-notes="<%= item.notes %>"
     data-location="<%= item.location %>"
     data-trigger-expression="<%= item.trigger_expression %>"
     data-schedule="<%= item.agenda_schedule&.serialize_for_edit&.to_json %>">

  <% unless preview %>
    <input type="checkbox"
           class="agenda-item-check"
           id="agenda_item_<%= item.display_id %>"
           <%= "checked" if item.completed? %>
           data-checked-url="<%= item_url %>">
  <% end %>

  <% if preview %>
    <div class="agenda-item-body">
  <% else %>
    <label for="agenda_item_<%= item.display_id %>" class="agenda-item-body">
  <% end %>
    <span class="agenda-item-dot" aria-hidden="true"></span>
    <span class="agenda-item-time">
      <% if item.event? && local_end %>
        <%= local_start.strftime("%-l:%M%P") %><span class="time-sep">–</span><%= local_end.strftime("%-l:%M%P") %>
      <% else %>
        <%= local_start.strftime("%-l:%M%P") %>
      <% end %>
    </span>
    <span class="agenda-item-name"><%= item.name %></span>
    <% if item.location.present? %>
      <span class="agenda-item-loc"><i class="fa fa-map-marker"></i> <%= item.location %></span>
    <% end %>
    <% if item.recurring? %>
      <span class="agenda-item-badge" title="Recurring"><i class="fa fa-refresh"></i></span>
    <% end %>
  <% if preview %>
    </div>
  <% else %>
    </label>
  <% end %>

  <% unless preview %>
    <button type="button" class="agenda-item-edit" data-edit-item aria-label="Edit"><i class="fa fa-pencil"></i></button>
  <% end %>
</div>
