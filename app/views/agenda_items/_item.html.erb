<%# Interaction model:
      .agenda-item-check-zone (full vertical strip on the left)
        → checkbox click area. Visually contains just the checkbox at top.
        Disabled when the item kind / state cannot be completed; tooltip
        explains why.
      .agenda-item-body (name + time + location)
        → opens the read-only details modal on click (NOT edit).
      .agenda-item-edit pencil (rightmost)
        → opens the full edit modal.
    Preview / readonly rows hide the checkbox + pencil.
%>
<% preview ||= false %>
<%# Time displays are hydrated client-side from integer epoch seconds so
    every render uses the viewer's browser-local timezone, never the
    server's. See `app/javascript/src/agenda/time_hydration.js`. %>
<% start_epoch = item.start_at.to_i %>
<% end_epoch   = item.end_at&.to_i %>
<% item_url    = agenda_item_path(item.display_id) %>
<%# Google items ARE editable now — edits mirror to Google. An editor can
    rename/move/cancel a Google event through the pencil; the controller
    syncs the change upstream via events.patch / events.delete. %>
<% editable    = !preview && item.agenda.editable_by?(current_user) %>
<% readonly    = !preview && !editable %>
<% classes     = ["agenda-item"] %>
<% classes << "kind-#{item.kind}" %>
<% classes << "all-day"     if item.all_day? %>
<% classes << item.status if item.tentative? || item.cancelled? %>
<% classes << "crossed-out" if item.crossed_out? %>
<% classes << "recurring"   if item.recurring? %>
<% classes << "phantom"     if item.phantom? %>
<% classes << "preview"     if preview %>
<% classes << "readonly"    if readonly %>
<% id_title = item.phantom? ? "Agenda ##{item.agenda_id}" : "Item ##{item.id}" %>

<%# Completion model:
      All kinds are completable by the user. The checkbox is NEVER
      checked or unchecked automatically — it reflects an explicit user
      action via `completed_at`. The visual strikethrough (`.crossed-out`)
      can apply independently for time-passed events / triggers.
      A user marking a trigger complete BEFORE its start_at skips the
      firing entirely (FireDueAgendaTriggersWorker filters `.incomplete`).
%>
<% can_check = true %>
<% check_disabled = preview || !item.agenda.editable_by?(current_user) %>
<% check_reason = (
  if preview
    "Tap forward to today to check this off."
  elsif !item.agenda.editable_by?(current_user)
    "Read-only — only editors can change this."
  end
) %>

<div class="<%= classes.join(" ") %>"
     style="--item-color: <%= item.display_color %>; --agenda-color: <%= item.agenda.color %>;"
     title="<%= item.agenda.name %> · <%= id_title %>"
     <%= "data-readonly" if readonly %>
     data-item-id="<%= item.display_id %>"
     data-item-url="<%= item_url %>"
     data-phantom="<%= item.phantom? %>"
     data-recurring="<%= item.recurring? %>"
     data-detached="<%= item.detached? %>"
     data-kind="<%= item.kind %>"
     data-color="<%= item.display_color %>"
     data-agenda-id="<%= item.agenda_id %>"
     data-agenda-name="<%= item.agenda.name %>"
     data-agenda-color="<%= item.agenda.color %>"
     data-agenda-source="<%= item.agenda.source %>"
     data-start-at="<%= start_epoch %>"
     data-end-at="<%= end_epoch %>"
     data-all-day="<%= item.all_day? %>"
     data-end-date="<%= item.end_date&.to_time&.to_i %>"
     data-name="<%= item.name %>"
     data-notes="<%= item.notes %>"
     data-location="<%= item.location %>"
     data-trigger-expression="<%= item.trigger_expression %>"
     data-schedule="<%= item.agenda_schedule&.serialize_for_edit&.to_json %>">

  <%# Full-strip checkbox click zone — always rendered so every item has
      a consistent visual + the right-of-it body always aligns. Disabled
      state on the input communicates non-markable; tooltip explains. %>
  <label class="agenda-item-check-zone"
         <%= check_reason && "title=\"#{check_reason}\"".html_safe %>>
    <%# `checked` reflects explicit user action only — `completed?`. The
        `.crossed-out` class on the wrapping row covers the visual
        strike-through for events / triggers whose time has passed. %>
    <input type="checkbox"
           class="agenda-item-check"
           id="agenda_item_<%= item.display_id %>"
           <%= "checked"  if item.completed? %>
           <%= "disabled" if check_disabled %>
           <%= check_disabled ? nil : "data-checked-url=\"#{item_url}\"".html_safe %>>
  </label>

  <button type="button" class="agenda-item-body" data-open-details>
    <span class="agenda-item-time"
          data-time-hydrate
          data-start-epoch="<%= start_epoch %>"
          data-end-epoch="<%= end_epoch %>"
          data-all-day="<%= item.all_day? %>"
          data-format="<%= item.all_day? ? :day : (item.event? && end_epoch ? :range : :time) %>"
    ><%# JS hydrates this on connect; SSR fallback is empty (better than a
         wrong-zone string flashing in for a frame). %></span>
    <span class="agenda-item-text">
      <span class="agenda-item-name"><%= item.name %></span>
      <% if item.location.present? %>
        <span class="agenda-item-loc"><i class="fa fa-map-marker"></i> <%= item.location %></span>
      <% end %>
    </span>
  </button>

  <%# Fixed-width icon strip on the right — each slot is always present so
      icons line up vertically across rows regardless of which ones the
      item happens to expose. Empty slots reserve space silently. %>
  <span class="agenda-item-icons">
    <span class="agenda-item-icon-slot agenda-item-recurring-slot">
      <% if item.recurring? %>
        <span class="agenda-item-badge" title="Recurring"><i class="fa fa-refresh"></i></span>
      <% end %>
    </span>
    <span class="agenda-item-icon-slot agenda-item-edit-slot">
      <% if editable %>
        <button type="button" class="agenda-item-edit" data-edit-item aria-label="Edit" title="<%= id_title %>"><i class="fa fa-pencil"></i></button>
      <% end %>
    </span>
  </span>
</div>
