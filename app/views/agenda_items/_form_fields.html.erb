<%# Locals:
    - agendas             (required) array for the picker
    - default_agenda_id   (optional) preselected in :add mode
    - mode                :add | :edit
    - default_date        ISO date string (initial Date input value in :add)
%>

<% mode ||= :add %>
<% default_date_value = local_assigns[:default_date].presence || Date.current.iso8601 %>
<% default_agenda_id ||= local_assigns[:default_agenda_id] || agendas.first&.id %>
<% default_color = (agendas.find { |a| a.id == default_agenda_id } || agendas.first)&.color || Agenda::DEFAULT_COLOR %>

<% if mode == :edit %>
  <input type="hidden" class="add-item-id">
<% end %>

<%# Custom dropdown — Safari ignores backgrounds in native <option>s. %>
<% picked = agendas.find { |a| a.id == default_agenda_id } || agendas.first %>
<div class="ff agenda-pick" style="--picked-agenda-color: <%= picked&.color || Agenda::DEFAULT_COLOR %>;">
  <button type="button" class="agenda-pick-toggle" aria-haspopup="listbox" aria-expanded="false">
    <span class="agenda-pick-dot" aria-hidden="true"></span>
    <span class="agenda-pick-label"><%= picked&.name %></span>
    <i class="fa fa-caret-down agenda-pick-caret" aria-hidden="true"></i>
  </button>
  <ul class="agenda-pick-menu hidden" role="listbox">
    <% agendas.each do |a| %>
      <li role="option"
          data-id="<%= a.id %>"
          data-color="<%= a.color %>"
          data-name="<%= a.name %>"
          data-source="<%= a.source %>"
          style="--option-color: <%= a.color %>;"
          <%= "aria-selected='true' class='selected'" if a.id == picked&.id %>>
        <span class="agenda-pick-dot" aria-hidden="true"></span>
        <% if a.google? %><i class="fa fa-google agenda-pick-source-icon" aria-hidden="true"></i><% end %>
        <span class="agenda-pick-name"><%= a.name %></span>
      </li>
    <% end %>
  </ul>
  <input type="hidden" class="add-agenda-id" value="<%= picked&.id %>">
</div>

<div class="ff">
  <label>Name</label>
  <input type="text" class="add-name" placeholder="Event Name" autocomplete="off" required>
</div>

<div class="ff add-trigger-field hidden">
  <label>Trigger expression</label>
  <input type="text" class="add-trigger-expression" placeholder="goodMorning or scope:key:value" autocomplete="off">
  <small class="trigger-hint">
    Fires a Jil scope: <code>scope</code> or <code>scope:key:value</code>. Quote segments with spaces.<br>
    Run a Jarvis command instead: <code>command:"Remind me to wash dishes"</code>.<br>
    Outer quotes protect colons: <code>command:"Remind me at 9:00am to do X"</code>.<br>
    Inner quotes survive verbatim: <code>command:Remind me to "add water to plants"</code>.
  </small>
</div>

<div class="ff-pair">
  <div class="ff">
    <label>Kind</label>
    <div class="kind-toggle">
      <button type="button" class="kind-btn" data-kind="task">Task</button>
      <button type="button" class="kind-btn active" data-kind="event">Event</button>
      <button type="button" class="kind-btn" data-kind="trigger">Trigger</button>
    </div>
  </div>
  <div class="ff">
    <label>Color</label>
    <%# Styled wrapper for the visual; the native input sits invisibly on
        top so taps still open the OS color picker. %>
    <div class="color-row">
      <span class="color-swatch" style="background: <%= default_color %>;">
        <input type="color" class="add-color" value="<%= default_color %>">
      </span>
      <%# Normalise to uppercase so the visible hex matches the JS .toUpperCase()
          updates after the user picks a different color. %>
      <span class="color-hex color-hex-preview"><%= default_color&.upcase %></span>
    </div>
  </div>
</div>

<%# All-day toggle: hides time fields + swaps the single Date input for a
    Date / End-date pair. Only meaningful for kind=event. %>
<div class="ff add-allday-field hidden">
  <label class="add-allday-toggle">
    <input type="checkbox" class="add-allday-input">
    <span>All day</span>
  </label>
</div>

<div class="ff">
  <label>Date</label>
  <input type="date" class="add-date" value="<%= default_date_value %>">
</div>

<div class="ff add-allday-end-field hidden">
  <label>End date</label>
  <input type="date" class="add-allday-end" value="<%= default_date_value %>">
</div>

<div class="ff-pair add-time-fields">
  <div class="ff">
    <label>Start</label>
    <input type="time" class="add-start" value="09:00">
  </div>
  <div class="ff add-end-field hidden">
    <label>End</label>
    <input type="time" class="add-end" value="10:00">
  </div>
</div>

<div class="ff-pair">
  <div class="ff">
    <label>Location</label>
    <input type="text" class="add-location" autocomplete="off">
  </div>
  <div class="ff add-arrive-early-field">
    <label>Min early</label>
    <input type="number" class="add-arrive-early" min="0" step="1" inputmode="numeric" value="0">
  </div>
</div>

<div class="ff">
  <label>Notes</label>
  <textarea class="add-notes" rows="3"></textarea>
</div>

<% if mode == :edit %>
  <%# Default to "this and all future" — the common case for recurring
      events (rename / move a daily standup, propagate to the whole series).
      The HTML default matches what JS sets at modal-open time so the user
      visually sees the same scope that submit() will read. Detached
      occurrences hide the series option entirely (see openModal in agenda.js)
      because they have no series to apply to. %>
  <div class="ff add-scope-field hidden">
    <label>Apply changes to</label>
    <div class="scope-radios">
      <label class="scope-occurrence-label"><input type="radio" name="scope" value="occurrence"> This occurrence</label>
      <label class="scope-series-label"><input type="radio" name="scope" value="series" checked> This and all future</label>
    </div>
  </div>
<% end %>

<%= render "agenda_items/schedule_fields", scope_name: "month-mode" %>
