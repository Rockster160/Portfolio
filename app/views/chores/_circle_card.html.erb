<%# Locals: chore (Chore), done_count (Integer), last_completion (ChoreCompletion?), hot (Integer?). %>
<%
  hot ||= nil
  done_count ||= 0
  last_completion ||= nil
  cooldown_seconds = chore.threshold_seconds.to_i
  # Render the cooldown elements whenever the chore HAS a cooldown
  # configured, regardless of whether the timer is currently running.
  # JS fills the countdown text + ring offset based on
  # `data-last-completed-at`; CSS `:empty` hides the badge when there's
  # no active cooldown. This way tapping a chore can immediately show
  # the cooldown without waiting for a server round-trip to re-render
  # the partial.
  has_fixed_cooldown    = cooldown_seconds.positive? && cooldown_seconds != Chore::THRESHOLD_DAY_RESET
  has_day_reset_cooldown = cooldown_seconds == Chore::THRESHOLD_DAY_RESET
  has_any_cooldown      = has_fixed_cooldown || has_day_reset_cooldown
%>
<div class="chore-circle <%= "done" if done_count > 0 %> <%= "hot" if hot %>"
     data-chore-id="<%= chore.id %>"
     data-chore-name="<%= chore.name %>"
     data-chore-short="<%= chore.short_name %>"
     data-chore-aliases="<%= chore.aliases_array.join("|") %>"
     data-chore-reward="<%= chore.reward_pebbles %>"
     data-chore-icon="<%= chore.icon %>"
     data-chore-cooldown="<%= cooldown_seconds %>"
     data-chore-sharing-mode="<%= chore.sharing_mode %>"
     data-chore-assigned-to-user-id="<%= chore.assigned_to_user_id %>"
     data-chore-show-on-daily-view="<%= chore.show_on_daily_view %>"
     data-chore-recurrence='<%= chore.recurrence.to_json.html_safe %>'
     data-chore-starts-on="<%= chore.starts_on %>"
     data-chore-updated-at="<%= chore.updated_at.iso8601(3) %>"
     data-last-completed-at="<%= last_completion&.completed_at&.iso8601 %>"
     data-done-count="<%= done_count %>"
     data-chore-one-off="<%= chore.one_off %>">
  <% if hot %><div class="hot-badge"><%= format_multiplier(hot) %>×</div><% end %>
  <div class="circle-inner">
    <% if has_fixed_cooldown %>
      <svg class="circle-ring" viewBox="0 0 100 100" aria-hidden="true">
        <circle class="ring-bg" cx="50" cy="50" r="46" />
        <circle class="ring-progress" cx="50" cy="50" r="46" data-ring-progress />
      </svg>
    <% end %>
    <span class="circle-reward"><%= chore.reward_label %></span>
    <div class="icon" data-icon><%= chore_icon_inline(chore, fallback: chore.one_off ? "📝" : true) %></div>
    <% if has_any_cooldown %>
      <span class="circle-countdown" data-circle-countdown
            data-cooldown-end="<%= has_day_reset_cooldown ? "day-end" : "" %>"></span>
    <% end %>
    <div class="count-slot" data-count-slot>
      <% if done_count > 1 %><span class="count-badge" data-count-badge>×<%= done_count %></span><% end %>
    </div>
  </div>
  <div class="title"><%= chore.display_short_name %></div>
</div>
