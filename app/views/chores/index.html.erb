<% content_for :title, "Chores" %>
<% content_for :head do %>
  <link rel="manifest" href="/chores.webmanifest">
  <meta name="theme-color" content="#00102B">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <script src="/chores_sortable.js" defer></script>
<% end %>

<div class="chores-page" data-chores-root data-mode="grid">
  <%= render "header", balance: @balance, scope: :total %>

  <%= render "hot_strip", hot_picks: @hot_picks, chores: @chores %>

  <%= render "toolbar", search_placeholder: "Search chores..." %>

  <div class="chores-grid" data-chores-grid>
    <% @chores.each do |chore| %>
      <%= render "grid_card",
                 chore: chore,
                 done_count: @completions_today[chore.id].to_i,
                 last_completion: @last_completions[chore.id],
                 hot: @hot_picks[chore.id] %>
    <% end %>
  </div>
  <%= render "modals" %>
</div>

<% content_for :after_body do %>
  <%= render "page_script", mode: "grid" %>
<% end %>
