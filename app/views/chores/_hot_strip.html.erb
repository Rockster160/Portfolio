<%# Locals: hot_picks (Hash chore_id => multiplier), chores (Array<Chore>) %>
<% hot_chores = chores.select { |c| hot_picks.key?(c.id) } %>
<% if hot_chores.any? %>
  <%# Each chip IS a real chore-circle — same partial as Today —
    wrapped in `.hot-strip-cell` to anchor the multiplier badge above
    the circle. bindCardClicks treats them as live cards (tap to
    complete, long-press to undo, multiplier-mode supported). %>
  <div class="hot-strip" data-chores-hot-strip>
    <% hot_chores.sort_by { |c| -hot_picks[c.id] }.each do |c| %>
      <div class="hot-strip-cell">
        <div class="hot-mult"><%= format_multiplier(hot_picks[c.id]) %>×</div>
        <%= render "circle_card",
                   chore: c,
                   done_count: @completions_today[c.id].to_i,
                   last_completion: @last_completion_by_chore[c.id],
                   hot: nil %>
      </div>
    <% end %>
  </div>
<% end %>
