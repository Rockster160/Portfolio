<% content_for :title, "Chores · Balance" %>

<div class="chores-page" data-chores-root data-mode="balance">
  <%= render "header", balance: @balance, scope: :total %>

  <div class="balance-card">
    <div class="balance-label">Pebbles available</div>
    <%# This shows the LIFETIME balance and must NOT share the
        `data-balance` hook with the header pill — the header pill is
        always "earned today". Distinct attribute = no JS handler can
        cross-write them. %>
    <div class="balance-amount"><span data-lifetime-balance><%= format_count(@balance) %></span>p</div>
  </div>

  <div class="balance-section-heading">
    <h3>Goals</h3>
    <button class="btn" data-add-goal>+ Add Goal</button>
  </div>
  <div data-goals-list>
    <p data-goals-empty style="color:var(--chores-muted); <%= "display:none;" if @goals.any? %>">No goals yet.</p>
    <div data-goals-cards>
      <% @goals.each do |goal| %>
        <%= render "goal_row", goal: goal %>
      <% end %>
    </div>
  </div>

  <div class="balance-section-heading" style="margin-top:24px;">
    <h3>Streak Bonuses</h3>
    <button class="btn" data-add-streak-bonus>+ Add</button>
  </div>
  <div data-streak-bonuses-list>
    <p data-streak-bonuses-empty style="color:var(--chores-muted); <%= "display:none;" if @streak_bonuses.any? %>">No streak bonuses configured yet.</p>
    <div class="multiplier-cards" data-streak-bonuses-cards>
      <% @streak_bonuses.each do |bonus| %>
        <%= render "streak_bonus_card", bonus: bonus %>
      <% end %>
    </div>
  </div>

  <h3 style="margin-top:24px;">Withdraw</h3>
  <form class="basic" data-withdraw-form>
    <fieldset data-withdraw-fieldset style="border:0;padding:0;margin:0;display:flex;gap:8px;align-items:center;" <%= "disabled" if @balance.to_i <= 0 %>>
      <input type="number" name="amount_pebbles" placeholder="Amount" min="1" max="<%= [@balance.to_i, 1].max %>" autocomplete="off" style="flex:1;padding:8px 10px;border-radius:6px;border:1px solid #334155;background:#00102B;color:#ECF0F1;">
      <input type="text" name="note" placeholder="Note (optional)" autocomplete="off" style="flex:2;padding:8px 10px;border-radius:6px;border:1px solid #334155;background:#00102B;color:#ECF0F1;">
      <button class="btn" type="submit">Withdraw</button>
    </fieldset>
  </form>

  <h3 style="margin-top:24px;">Transfer</h3>
  <% if @transfer_recipients.empty? %>
    <p style="color:var(--chores-muted);font-size:13px;">
      No one to transfer to — add someone to your chore household first.
    </p>
  <% else %>
    <form class="basic" data-transfer-form>
      <fieldset data-transfer-fieldset style="border:0;padding:0;margin:0;display:flex;gap:8px;align-items:center;" <%= "disabled" if @balance.to_i <= 0 %>>
        <select name="to_user_id" required style="flex:1;height:38px;box-sizing:border-box;padding:0 10px;border-radius:6px;border:1px solid #334155;background:#00102B;color:#ECF0F1;font:inherit;">
          <% @transfer_recipients.each do |u| %>
            <option value="<%= u.id %>"><%= u.username %></option>
          <% end %>
        </select>
        <input type="number" name="amount_pebbles" placeholder="Amount" min="1" max="<%= [@balance.to_i, 1].max %>" autocomplete="off" style="flex:1;padding:8px 10px;border-radius:6px;border:1px solid #334155;background:#00102B;color:#ECF0F1;">
        <input type="text" name="note" placeholder="Note (optional)" autocomplete="off" style="flex:2;padding:8px 10px;border-radius:6px;border:1px solid #334155;background:#00102B;color:#ECF0F1;">
        <button class="btn" type="submit">Transfer</button>
      </fieldset>
    </form>
  <% end %>

  <div class="section-heading">
    <h3>Recent History</h3>
    <button type="button" class="section-reload" data-recent-history-reload
            title="Reload recent history" aria-label="Reload recent history">
      <i class="fa fa-refresh" aria-hidden="true"></i>
    </button>
  </div>
  <div data-recent-history>
    <div class="history-row history-loading" data-recent-loading>
      <span class="dim">Loading recent history…</span>
    </div>
  </div>
  <div data-recent-history-cta hidden style="text-align:center;margin-top:8px;">
    <%= link_to "Full history →", chores_history_path, class: "btn ghost" %>
  </div>
  <%= render "modals" %>
</div>

<% content_for :after_body do %>
  <%= render "page_script", mode: "balance" %>
<% end %>
