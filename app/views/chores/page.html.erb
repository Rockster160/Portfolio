<% content_for :title, @active_view == :today ? "Chores · Today" : "Chores" %>
<% content_for :head do %>
  <link rel="manifest" href="/chores.webmanifest">
  <meta name="theme-color" content="#00102B">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <script src="/chores_sortable.js" defer></script>
<% end %>
<% content_for :viewport_tag do %>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
<% end %>

<%# Both Grid + Today render together. JS toggles `data-active-view`
  on this root to swap which one is visible without a page navigation.
  Header / toolbar / hot strip / modals are shared between the two. %>
<div class="chores-page" data-chores-root
     data-active-view="<%= @active_view %>"
     data-day-key="<%= @day.iso8601 %>"
     data-cutoff-hour="<%= ChoreDay::CUTOFF_HOURS %>"
     data-balance-total="<%= @balance_total %>"
     data-balance-today="<%= @balance_today %>">
  <div class="chores-sticky-top">
    <%= render "header", balance: @balance, scope: @active_view == :today ? :today : :total %>
    <%= render "hot_strip", hot_picks: @hot_picks, chores: @chores %>
    <%= render "toolbar" %>
  </div>

  <%= render "view_grid",  chores: @chores %>
  <%= render "view_today", chores: @scheduled_today, lookahead: @lookahead %>

  <%= render "modals" %>
</div>

<% content_for :after_body do %>
  <%= render "page_script" %>
<% end %>
