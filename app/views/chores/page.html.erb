<% content_for :title, @active_view == :today ? "Chores · Today" : "Chores" %>
<% content_for :head do %>
  <link rel="manifest" href="/chores.webmanifest">
  <meta name="theme-color" content="#00102B">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <script src="/chores_sortable.js" defer></script>
<% end %>
<% content_for :viewport_tag do %>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
<% end %>

<%# The page is intentionally lightweight: empty containers + a
  bootstrap <script type="application/json"> that the JS picks up on
  load. ALL card rendering happens client-side from the JSON store +
  template literals — there is no server-side card HTML anywhere.
  This is the single source of truth that fixed the cache/sync drift
  that the previous HTML-shipping architecture kept introducing. %>
<div class="chores-page" data-chores-root
     data-active-view="<%= @active_view %>"
     data-day-key="<%= @day.iso8601 %>"
     data-cutoff-hour="<%= @cutoff_hour %>"
     data-balance-total="<%= @balance_total %>"
     data-balance-today="<%= @balance_today %>"
     data-viewer-username="<%= current_user.username %>">
  <%= render "header", balance: @balance, scope: :today %>
  <div class="hot-strip" data-chores-hot-strip hidden></div>
  <%= render "toolbar" %>

  <div class="chores-view view-grid" data-view="grid">
    <div class="chores-grid" data-chores-grid></div>
  </div>

  <div class="chores-view view-today" data-view="today">
    <section class="chores-section chores-dailies-section">
      <h3 class="chores-section-heading">Dailies</h3>
      <div class="chores-circles-wrap">
        <div class="chores-circles" data-chores-dailies></div>
      </div>
    </section>
    <section class="chores-section chores-overdue-section">
      <h3 class="chores-section-heading">Scheduled</h3>
      <div class="chores-circles-wrap">
        <div class="chores-circles" data-chores-overdue></div>
      </div>
    </section>
    <div class="chores-lookahead" data-chores-lookahead></div>
  </div>

  <%= render "modals" %>

  <script type="application/json" id="chores-bootstrap">
    <%== {
      chores: @chores_json,
      lookahead: @lookahead_json,
      daily_ids: @daily_ids,
      server_ts: Time.current.iso8601(3),
      day_key: @day.iso8601,
      balance: @balance_total,
      today_earnings: @balance_today,
    }.to_json %>
  </script>
</div>

<% content_for :after_body do %>
  <%= render "page_script" %>
<% end %>
