    }
    streakBonusForm.querySelector('[data-level-rows]').appendChild(node);
  }
  streakBonusForm?.querySelector('[data-add-level]')?.addEventListener("click", () => addLevelRow());
  streakBonusForm?.querySelector('[data-level-rows]')?.addEventListener("click", e => {
    const rm = e.target.closest("[data-remove-level]");
    if (rm) rm.closest(".multiplier-level-row")?.remove();
