<%# Unified chores page script — JSON-store-driven, no server HTML.
   Architecture:
     * ChoreStore (Map<id, ChoreData>) is the single source of truth.
     * Templates are pure (data → DOM) functions.
     * Views subscribe to store changes and re-render affected cards.
     * Mutations apply optimistic patches, then reconcile with server JSON.
%>
<script>
  window.__currentUserId = <%= current_user.id.to_json.html_safe %>;
</script>
<script type="module">
  // ============================================================
  // bootstrap + constants
  // ============================================================
  const CSRF = document.querySelector('meta[name="csrf-token"]')?.content || "";
  const root = document.querySelector('[data-chores-root]');
  const DAY_KEY = root?.dataset.dayKey || "";
  const CUTOFF_HOUR = parseInt(root?.dataset.cutoffHour || "4", 10);
  const VIEWER_USERNAME = root?.dataset.viewerUsername || "";
  const TAB_ID = (window.crypto?.randomUUID?.() || String(Date.now() + Math.random()));

  // Active view — `data-active-view` only exists on the unified Grid/
  // Today page. Balance and History also include this script for the
  // SW/offline-queue/modal infrastructure but skip view + store logic.
  let MODE = root?.dataset.activeView || "grid";
  const unifiedPage = !!(root && root.dataset.activeView);

  // Bootstrap JSON inline-shipped by the page — instant first paint
  // without a network round-trip.
  let bootstrap = { chores: [], lookahead: {}, daily_ids: [], server_ts: null };
  const bootstrapEl = document.getElementById("chores-bootstrap");
  if (bootstrapEl) {
    try { bootstrap = JSON.parse(bootstrapEl.textContent || "{}"); }
    catch (e) { console.warn("Chores bootstrap JSON parse failed:", e); }
  }

  // localClickTs: per-chore most-recent local click epoch ms. Used to
  // discard server payloads captured before that click — protects
  // optimistic state from being clobbered by a race-stale broadcast or
  // out-of-order POST response.
  const localClickTs = new Map();
  const inFlight = new Set();

  // ============================================================
  // helpers
  // ============================================================
  function esc(s) {
    if (s == null) return "";
    return String(s).replace(/[&<>"']/g, c => (
      { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]
    ));
  }
  function formatMultiplier(n) {
    if (n == null) return "";
    const f = Number(n);
    return f === Math.floor(f) ? String(Math.floor(f)) : String(f);
  }
  // Thousands delimiter for any visible count (balance pill, etc.).
  // Mirrors Rails `number_with_delimiter` in the views so the JS-
  // updated balance never desynces visually from a server-rendered
  // page (1,234p in HTML, 1,234p after applyBalance).
  function formatCount(n) {
    if (n == null) return "";
    const f = Number(n);
    if (!Number.isFinite(f)) return "";
    return f.toLocaleString();
  }
  async function api(url, method, body) {
    const res = await fetch(url, {
      method,
      credentials: "same-origin",
      headers: { "Content-Type": "application/json", "Accept": "application/json", "X-CSRF-Token": CSRF },
      body: body ? JSON.stringify(body) : undefined,
    });
    if (!res.ok) {
      const text = await res.text();
      const err = new Error(`${res.status}: ${text}`);
      err.status = res.status;
      throw err;
    }
    return res.status === 204 ? null : res.json();
  }
  // Anything we should retry rather than surface as a "failed" flash:
  // network errors, 429 (rate-limit), 502/503/504 (upstream). The
  // offline-queue's `classify` already keeps these — this is the
  // direct-mutation path's mirror.
  function isTransientError(err) {
    if (!navigator.onLine) return true;
    if (/Failed to fetch|NetworkError/i.test(err.message || "")) return true;
    const s = err.status || parseInt(String(err.message).split(":")[0], 10);
    return s === 429 || s === 502 || s === 503 || s === 504;
  }
  function flash(msg, type = "ok") {
    const el = document.createElement("div");
    el.className = "chores-flash " + (type === "error" ? "error" : (type === "warn" ? "warn" : ""));
    el.textContent = msg;
    document.body.appendChild(el);
    requestAnimationFrame(() => el.classList.add("show"));
    setTimeout(() => { el.classList.remove("show"); setTimeout(() => el.remove(), 250); }, 2400);
  }
  // Disable a submit-style button and show the centered .loading
  // spinner (defined in chores.scss) while an async action runs.
  // Re-entrant clicks are dropped because the button is disabled.
  async function withSavingState(btn, fn) {
    if (!btn || btn.disabled) return;
    btn.disabled = true;
    btn.classList.add("loading");
    try { return await fn(); }
    finally {
      btn.disabled = false;
      btn.classList.remove("loading");
    }
  }

  // ============================================================
  // ChoreStore — the data model. Every read derives from here.
  //
  // Persistence contract:
  //   * The store NEVER drops chores on its own. The only paths that
  //     remove a chore from the store are explicit `remove(id)` calls
  //     and `archived_chore_ids` deltas from the server.
  //   * `bootstrap` is ADDITIVE — it merges fresh data into the existing
  //     store, never clears it. A stale/empty cached shell can never
  //     wipe a populated UI; the worst case is "we already had these
  //     chores and now we still do."
  //   * Every mutation persists to localStorage so a fresh page load
  //     with an empty inline shell can hydrate from local first, then
  //     merge whatever the network eventually returns.
  // ============================================================
  const STORE_LS_KEY = "chores:store:v1";
  const ChoreStore = (() => {
    const map = new Map();
    let lookahead = {};
    // Ordered list of chore ids the viewer has pinned to their Dailies
    // section on Today. Independent of `today_visible` — items here are
    // purely user-curated, not derived from show_on_daily_view.
    let dailyIds = [];
    let dailyIdSet = new Set();
    const subs = new Set();
    function notify(kind, id) { subs.forEach(fn => { try { fn(kind, id); } catch (e) { console.error(e); } }); }
    function rebuildDailySet() { dailyIdSet = new Set(dailyIds.map(n => parseInt(n, 10))); }
    function persist() {
      try {
        localStorage.setItem(STORE_LS_KEY, JSON.stringify({
          chores: Array.from(map.values()),
          lookahead,
          dailyIds,
        }));
      } catch (e) { /* storage full or unavailable — non-fatal */ }
    }
    // Pull last-known state from localStorage. Returns the payload or
    // null. Caller decides whether to merge it (used when the inline
    // shell JSON is empty / stale and we'd otherwise paint nothing).
    function loadPersisted() {
      try {
        const raw = localStorage.getItem(STORE_LS_KEY);
        if (!raw) return null;
        return JSON.parse(raw);
      } catch (e) { return null; }
    }
    return {
      // Additive merge — NEVER clears the map. Bootstrap is just "here
      // is the latest known data," and removals are handled separately
      // (`remove` / `archived_chore_ids`). Emits a single "reconcile"
      // notify so subscribers can diff the DOM against the current store
      // without ever clearing containers in between.
      bootstrap(items, look, dailies) {
        (items || []).forEach(c => {
          if (!c || !c.id) return;
          const existing = map.get(c.id);
          map.set(c.id, { ...existing, ...c });
        });
        if (look && Object.keys(look).length > 0) lookahead = look;
        if (Array.isArray(dailies)) {
          // Daily pins come from the server when present. An empty
          // array IS authoritative — user could have unpinned everything
          // — but a missing/undefined `dailies` arg means "don't touch
          // the existing list" (e.g. a partial bootstrap path).
          dailyIds = dailies.map(n => parseInt(n, 10)).filter(Boolean);
          rebuildDailySet();
        }
        persist();
        notify("reconcile");
      },
      hydrateFromLocal() {
        const p = loadPersisted();
        if (!p) return false;
        (p.chores || []).forEach(c => {
          if (!c || !c.id) return;
          if (!map.has(c.id)) map.set(c.id, c);
        });
        if (p.lookahead && Object.keys(lookahead).length === 0) lookahead = p.lookahead;
        if (Array.isArray(p.dailyIds) && dailyIds.length === 0) {
          dailyIds = p.dailyIds.map(n => parseInt(n, 10)).filter(Boolean);
          rebuildDailySet();
        }
        return true;
      },
      setDailyIds(ids) {
        dailyIds = (ids || []).map(n => parseInt(n, 10)).filter(Boolean);
        rebuildDailySet();
        persist();
        notify("dailies");
      },
      pinDaily(id) {
        const n = parseInt(id, 10);
        if (!n || dailyIdSet.has(n)) return;
        dailyIds.push(n);
        dailyIdSet.add(n);
        persist();
        notify("dailies");
      },
      unpinDaily(id) {
        const n = parseInt(id, 10);
        if (!dailyIdSet.has(n)) return;
        dailyIds = dailyIds.filter(x => x !== n);
        dailyIdSet.delete(n);
        persist();
        notify("dailies");
      },
      reorderDailies(ids) {
        const allowed = new Set(dailyIds);
        const next = [];
        (ids || []).forEach(id => {
          const n = parseInt(id, 10);
          if (allowed.has(n) && !next.includes(n)) next.push(n);
        });
        // Preserve any pin not present in the supplied order so we
        // don't silently drop dailies a stale client didn't know about.
        dailyIds.forEach(id => { if (!next.includes(id)) next.push(id); });
        dailyIds = next;
        rebuildDailySet();
        persist();
        notify("dailies");
      },
      isDaily(id) { return dailyIdSet.has(parseInt(id, 10)); },
      dailyIds() { return dailyIds.slice(); },
      upsert(c, { optimistic = false } = {}) {
        if (!c || !c.id) return false;
        const existing = map.get(c.id);
        if (!optimistic && existing?.updated_at && c.updated_at && existing.updated_at > c.updated_at) {
          // Newer local copy wins; don't overwrite.
          return false;
        }
        map.set(c.id, { ...existing, ...c });
        persist();
        notify("upsert", c.id);
        return true;
      },
      patch(id, fields) {
        const existing = map.get(id);
        if (!existing) return;
        map.set(id, { ...existing, ...fields });
        persist();
        notify("upsert", id);
      },
      remove(id) {
        if (!map.has(id)) return;
        map.delete(id);
        const n = parseInt(id, 10);
        if (dailyIdSet.has(n)) {
          dailyIds = dailyIds.filter(x => x !== n);
          dailyIdSet.delete(n);
        }
        persist();
        notify("remove", id);
      },
      // Rebuild the map in the supplied id order so any view that reads
      // chores in iteration order (Grid, Today) reflects the new sort.
      // Unknown ids are skipped; chores not in `ids` are appended in
      // their current order so they don't vanish from the views.
      reorder(ids) {
        const next = new Map();
        ids.forEach(id => {
          const key = parseInt(id, 10);
          if (map.has(key)) { next.set(key, map.get(key)); map.delete(key); }
        });
        map.forEach((v, k) => next.set(k, v));
        map.clear();
        next.forEach((v, k) => map.set(k, v));
      },
      get(id) { return map.get(id); },
      all() { return Array.from(map.values()); },
      // Items pinned to Dailies, in the user's curated order. A pinned
      // chore stays here regardless of today_visible — only archival
      // hides it.
      dailiesList() {
        const out = [];
        dailyIds.forEach(id => {
          const c = map.get(id);
          if (c && !c.archived) out.push(c);
        });
        return out;
      },
      // Items that today_visible filtering would have put on the old
      // Today screen, minus anything the user has already pinned to
      // Dailies. Same semantics as the previous Today view, sourced
      // from the same `today_visible` server field.
      overdueList() {
        return this.all().filter(c => c.today_visible && !c.archived && !dailyIdSet.has(c.id));
      },
      activeForGrid() { return this.all().filter(c => !c.archived); },
      hotPicks() {
        return this.all()
          .filter(c => c.hot_multiplier != null && !c.archived)
          .sort((a, b) => (b.hot_multiplier - a.hot_multiplier));
      },
      lookahead() { return lookahead; },
      setLookahead(l) { lookahead = l || {}; persist(); notify("lookahead"); },
      subscribe(fn) { subs.add(fn); return () => subs.delete(fn); },
    };
  })();

  // ============================================================
  // Templates — pure HTML strings (sensitive fields escaped via esc()).
  // ============================================================

  // Determine which way the icon should render. Mirrors the server's
  // `icon_kind` so future divergence stays minimal.
  function iconHTML(c, { large = false } = {}) {
    const placeholderFallback = c.one_off ? "📝" : "🧹";
    const v = (c.icon || "").trim();
    if (!v) {
      return `<span class="icon-placeholder">${esc(placeholderFallback)}</span>`;
    }
    if (v.startsWith("data:image/") || v.startsWith("http://") || v.startsWith("https://")) {
      return `<img class="icon-img" src="${esc(v)}" alt="" loading="lazy" draggable="false">`;
    }
    if (v.startsWith("<svg")) {
      // Safe-ish: we only allow inline SVG that the user explicitly
      // pasted as their own icon. Browser will sanitize at parse.
      return v;
    }
    return `<span class="icon-glyph">${esc(v)}</span>`;
  }

  function hasCooldown(c) { return c.cooldown_kind === "fixed" || c.cooldown_kind === "day_reset"; }

  function gridCardHTML(c) {
    const doneClass = (c.done_count_today > 0) ? " done-today" : "";
    const hotClass  = (c.hot_multiplier != null) ? " hot" : "";
    const hot = (c.hot_multiplier != null) ?
      `<div class="hot-badge">${esc(formatMultiplier(c.hot_multiplier))}×</div>` : "";
    const streak = (c.streak_multiplier != null && c.streak_multiplier > 1) ?
      `<div class="streak-badge">${esc(formatMultiplier(c.streak_multiplier))}×</div>` : "";
    const countBadge = (c.done_count_today > 1) ?
      `<span class="count-badge" data-count-badge>×${c.done_count_today}</span>` : "";
    const cd = hasCooldown(c) ?
      `<span class="circle-countdown" data-circle-countdown data-cooldown-end="${c.cooldown_kind === "day_reset" ? "day-end" : ""}"></span>` : "";
    const actorAttr = c.last_actor_username ? ` data-actor="${esc(c.last_actor_username)}"` : "";
    return `
      <div class="chore-card${doneClass}${hotClass}" data-chore-id="${c.id}"${actorAttr}>
        ${hot}
        ${streak}
        <div class="icon" data-icon>
          <span class="card-reward">${esc(c.reward_label)}</span>
          ${iconHTML(c)}
          ${cd}
        </div>
        <span class="card-count-slot" data-count-slot>${countBadge}</span>
        <div class="title">${esc(c.name)}</div>
        <div class="ago-row" data-ago-row></div>
      </div>
    `;
  }

  function circleCardHTML(c, { animate = true } = {}) {
    const isDone = (c.done_count_today || 0) > 0;
    const doneClass = isDone ? (animate ? " done" : " done no-animate") : "";
    const hotClass  = (c.hot_multiplier != null) ? " hot" : "";
    const hot = (c.hot_multiplier != null) ?
      `<div class="hot-badge">${esc(formatMultiplier(c.hot_multiplier))}×</div>` : "";
    const streak = (c.streak_multiplier != null && c.streak_multiplier > 1) ?
      `<div class="streak-badge">${esc(formatMultiplier(c.streak_multiplier))}×</div>` : "";
    const countBadge = (c.done_count_today > 1) ?
      `<span class="count-badge" data-count-badge>×${c.done_count_today}</span>` : "";
    const ring = (c.cooldown_kind === "fixed") ? `
      <svg class="circle-ring" viewBox="0 0 100 100" aria-hidden="true">
        <circle class="ring-bg" cx="50" cy="50" r="46" />
        <circle class="ring-progress" cx="50" cy="50" r="46" data-ring-progress />
      </svg>
    ` : "";
    const cd = hasCooldown(c) ?
      `<span class="circle-countdown" data-circle-countdown data-cooldown-end="${c.cooldown_kind === "day_reset" ? "day-end" : ""}"></span>` : "";
    const actorAttr = c.last_actor_username ? ` data-actor="${esc(c.last_actor_username)}"` : "";
    return `
      <div class="chore-circle${doneClass}${hotClass}" data-chore-id="${c.id}"${actorAttr}>
        ${hot}
        ${streak}
        <div class="circle-inner">
          ${ring}
          <svg class="done-ring" viewBox="0 0 100 100" aria-hidden="true">
            <circle cx="50" cy="50" r="48" pathLength="100" />
          </svg>
          <span class="circle-reward">${esc(c.reward_label)}</span>
          <div class="icon" data-icon>${iconHTML(c)}</div>
          ${cd}
          <div class="count-slot" data-count-slot>${countBadge}</div>
        </div>
        <div class="title">${esc(c.short_name)}</div>
      </div>
    `;
  }

  function hotCellHTML(c, { animate = true } = {}) {
    return `<div class="hot-strip-cell">${circleCardHTML(c, { animate })}</div>`;
  }

  function nodeFrom(html) {
    const t = document.createElement("template");
    t.innerHTML = (html || "").trim();
    return t.content.firstElementChild;
  }

  // ============================================================
  // Per-chore data attribute hydration — JS reads these for cooldowns
  // + last_completed_at without re-reading the store on every tick.
  // We set them in addition to the visible HTML so existing ticker
  // code stays cheap.
  // ============================================================
  function hydrateDataAttrs(el, c) {
    el.dataset.choreCooldown = c.threshold_seconds || 0;
    el.dataset.choreOneOff = String(!!c.one_off);
    el.dataset.lastCompletedAt = c.last_completed_at || "";
    el.dataset.doneCount = c.done_count_today || 0;
    el.dataset.choreName = c.name || "";
    el.dataset.choreShort = c.short_name || "";
    el.dataset.choreIcon = c.icon || "";
    el.dataset.choreReward = c.reward_pebbles || 0;
    el.dataset.choreShowOnDailyView = c.show_on_daily_view || "when_scheduled";
    el.dataset.choreSharingMode = c.sharing_mode || "personal";
    el.dataset.choreAssignedToUserId = c.assigned_to_user_id || "";
    el.dataset.choreStartsOn = c.starts_on || "";
    el.dataset.choreRecurrence = JSON.stringify(c.recurrence || {});
    el.dataset.choreAliases = (c.aliases || []).join("|");
    if (c.last_actor_username) el.dataset.actor = c.last_actor_username;
    else delete el.dataset.actor;
  }

  // Done-ring animation bookkeeping. The keyframe runs on every fresh
  // .done element, so:
  //   * `seenDone` tracks chores we've already shown as done; re-renders
  //     of those skip the animation via the `no-animate` class so an
  //     incoming server upsert doesn't restart the draw.
  //   * `ringAnimating` blocks upsertOne while a draw is in flight so
  //     the SVG can complete; updates that arrived during the window
  //     get parked in `ringDeferred` and replayed when it ends.
  const RING_ANIM_MS = 550;
  const seenDone = new Set();
  const ringAnimating = new Set();
  const ringDeferred = new Map();

  function shouldAnimateDone(c) {
    const sid = String(c.id);
    if ((c.done_count_today || 0) === 0) {
      seenDone.delete(sid);
      return false;
    }
    if (seenDone.has(sid)) return false;
    seenDone.add(sid);
    return true;
  }

  function noteRingAnimation(id) {
    const sid = String(id);
    ringAnimating.add(sid);
    setTimeout(() => {
      ringAnimating.delete(sid);
      if (ringDeferred.has(sid)) {
        const pending = ringDeferred.get(sid);
        ringDeferred.delete(sid);
        Views.upsertOne(pending);
      }
    }, RING_ANIM_MS);
  }

  function renderGridCard(c)   { const el = nodeFrom(gridCardHTML(c));   hydrateDataAttrs(el, c); return el; }
  function renderCircleCard(c) {
    const animate = shouldAnimateDone(c);
    const el = nodeFrom(circleCardHTML(c, { animate }));
    hydrateDataAttrs(el, c);
    if (animate) noteRingAnimation(c.id);
    return el;
  }
  function renderHotCell(c)    {
    const animate = shouldAnimateDone(c);
    const wrap = nodeFrom(hotCellHTML(c, { animate }));
    const card = wrap.querySelector("[data-chore-id]");
    if (card) hydrateDataAttrs(card, c);
    if (animate) noteRingAnimation(c.id);
    return wrap;
  }

  // Patch-in-place updates. Replacing the DOM on every upsert blinks
  // the card (and resets the done-ring SVG mid-animation); these
  // patchers only touch the bits that actually change. If a structural
  // attribute changes (icon, cooldown threshold), they fall back to a
  // full re-render — but they preserve the existing done-ring element
  // so the animation state survives the swap.
  function structuralChange(el, c) {
    return el.dataset.choreIcon !== (c.icon || "") ||
           String(el.dataset.choreCooldown || "0") !== String(c.threshold_seconds || 0);
  }
  function preserveDoneRing(oldEl, newEl) {
    const oldRing = oldEl.querySelector(".done-ring");
    const newRingWrap = newEl.querySelector(".circle-inner");
    if (!oldRing || !newRingWrap) return;
    const newRing = newRingWrap.querySelector(".done-ring");
    if (newRing) newRing.replaceWith(oldRing);
  }
  function patchCornerBadge(el, c, { className, value }) {
    let badge = null;
    for (const child of el.children) {
      if (child.classList?.contains(className)) { badge = child; break; }
    }
    const visible = value != null && (className === "hot-badge" || value > 1);
    if (visible) {
      const text = `${formatMultiplier(value)}×`;
      if (badge) {
        if (badge.textContent !== text) badge.textContent = text;
      } else {
        el.insertAdjacentHTML("afterbegin", `<div class="${className}">${esc(text)}</div>`);
      }
    } else if (badge) {
      badge.remove();
    }
  }
  function patchHotBadge(el, c)    { patchCornerBadge(el, c, { className: "hot-badge",    value: c.hot_multiplier }); }
  function patchStreakBadge(el, c) { patchCornerBadge(el, c, { className: "streak-badge", value: c.streak_multiplier }); }
  function patchCountSlot(el, c) {
    if (!el) return;
    if ((c.done_count_today || 0) > 1) {
      const want = `<span class="count-badge" data-count-badge>×${c.done_count_today}</span>`;
      if (el.innerHTML !== want) el.innerHTML = want;
    } else if (el.innerHTML !== "") {
      el.innerHTML = "";
    }
  }
  function patchText(el, text) {
    if (!el) return;
    const want = text || "";
    if (el.textContent !== want) el.textContent = want;
  }
  function patchCircleCard(el, c) {
    if (structuralChange(el, c)) {
      const fresh = renderCircleCard(c);
      preserveDoneRing(el, fresh);
      el.replaceWith(fresh);
      return;
    }
    const wasDone = el.classList.contains("done");
    const isDone = (c.done_count_today || 0) > 0;
    if (isDone) {
      el.classList.add("done");
      if (wasDone) {
        el.classList.add("no-animate");
      } else {
        const animate = shouldAnimateDone(c);
        el.classList.toggle("no-animate", !animate);
        if (animate) noteRingAnimation(c.id);
      }
    } else {
      el.classList.remove("done", "no-animate");
      shouldAnimateDone(c);
    }
    el.classList.toggle("hot", c.hot_multiplier != null);
    patchHotBadge(el, c);
    patchStreakBadge(el, c);
    patchText(el.querySelector(".circle-reward"), c.reward_label);
    patchCountSlot(el.querySelector("[data-count-slot]"), c);
    patchText(el.querySelector(":scope > .title"), c.short_name);
    hydrateDataAttrs(el, c);
  }
  function patchGridCard(el, c) {
    if (structuralChange(el, c)) {
      el.replaceWith(renderGridCard(c));
      return;
    }
    el.classList.toggle("done-today", (c.done_count_today || 0) > 0);
    el.classList.toggle("hot", c.hot_multiplier != null);
    patchHotBadge(el, c);
    patchStreakBadge(el, c);
    patchText(el.querySelector(".card-reward"), c.reward_label);
    patchCountSlot(el.querySelector("[data-count-slot]"), c);
    patchText(el.querySelector(":scope > .title"), c.name);
    hydrateDataAttrs(el, c);
  }
  function patchHotCell(cell, c) {
    const inner = cell.querySelector(".chore-circle");
    if (inner) patchCircleCard(inner, c);
  }

  // ============================================================
  // Views — render from store. Subscribers handle granular updates.
  // ============================================================
  const Views = (() => {
    const grid       = () => document.querySelector("[data-chores-grid]");
    const dailies    = () => document.querySelector("[data-chores-dailies]");
    const overdue    = () => document.querySelector("[data-chores-overdue]");
    const hot        = () => document.querySelector("[data-chores-hot-strip]");
    const emptyDay   = () => document.querySelector("[data-empty-dailies]");
    const emptyOver  = () => document.querySelector("[data-empty-overdue]");
    const lookCt     = () => document.querySelector("[data-chores-lookahead]");

    function appendTo(el, node) { if (el && node) el.appendChild(node); }

    // Diff a container's children against a desired list of items.
    // NEVER calls innerHTML="" — chores already on screen stay on
    // screen, even if a sync is mid-flight or failed. The only writes
    // are: patch existing nodes in place, move existing nodes to their
    // new order, append truly-new nodes, remove nodes that the store
    // says should no longer be visible.
    function reconcileSection(container, items, opts) {
      if (!container) return;
      const { keyFor, renderer, patcher } = opts;
      const desiredById = new Map(items.map(c => [c.id, c]));
      const existingByKey = new Map();
      Array.from(container.children).forEach(child => {
        const key = keyFor(child);
        if (key == null || !desiredById.has(key)) {
          // Item is no longer in this section (archived, unpinned,
          // filter flipped). Explicit DOM remove — never a clear-all.
          child.remove();
        } else {
          existingByKey.set(key, child);
        }
      });
      let cursor = container.firstElementChild;
      for (const item of items) {
        const existing = existingByKey.get(item.id);
        if (cursor && cursor === existing) {
          // Already where it belongs — patch in place.
          patcher(cursor, item);
          cursor = cursor.nextElementSibling;
        } else if (existing) {
          // Lives in this container but in the wrong position. Move it
          // to the cursor's slot (insertBefore moves rather than dupes
          // when the node is already a child).
          container.insertBefore(existing, cursor);
          patcher(existing, item);
        } else {
          // Truly new — insert at the cursor position.
          const node = renderer(item);
          if (node) container.insertBefore(node, cursor);
        }
      }
    }

    const cardKey   = el => { const v = parseInt(el?.dataset?.choreId, 10); return Number.isFinite(v) ? v : null; };
    // Hot cells wrap a chore-circle whose data-chore-id is on the
    // inner element; key by that.
    const hotKey    = el => {
      const inner = el?.querySelector?.("[data-chore-id]");
      const v = parseInt(inner?.dataset?.choreId, 10);
      return Number.isFinite(v) ? v : null;
    };
    const patchHot  = (cell, c) => {
      const inner = cell.querySelector(".chore-circle");
      if (inner) patchCircleCard(inner, c);
    };

    function renderGrid() {
      reconcileSection(grid(), ChoreStore.activeForGrid(), {
        keyFor: cardKey, renderer: renderGridCard, patcher: patchGridCard,
      });
    }
    function renderDailies() {
      const c = dailies();
      reconcileSection(c, ChoreStore.dailiesList(), {
        keyFor: cardKey, renderer: renderCircleCard, patcher: patchCircleCard,
      });
      if (emptyDay()) emptyDay().hidden = (c?.children.length || 0) > 0;
    }
    function renderOverdue() {
      const c = overdue();
      reconcileSection(c, ChoreStore.overdueList(), {
        keyFor: cardKey, renderer: renderCircleCard, patcher: patchCircleCard,
      });
      if (emptyOver()) emptyOver().hidden = (c?.children.length || 0) > 0;
    }
    function renderHot() {
      const c = hot();
      if (!c) return;
      const picks = ChoreStore.hotPicks();
      reconcileSection(c, picks, {
        keyFor: hotKey,
        renderer: item => nodeFrom(hotCellHTML(item)),
        patcher: patchHot,
      });
      // Section visibility — hide when no picks, show otherwise. Note
      // we DON'T innerHTML="" on the hidden branch; if picks come back
      // later we re-reveal the same DOM (or reconcile adds new cells).
      c.hidden = (c.children.length === 0);
    }
    function renderLookahead() {
      const c = lookCt();
      if (!c) return;
      const data = ChoreStore.lookahead() || {};
      const keys = Object.keys(data).sort();
      if (!keys.length) { c.hidden = true; return; }
      c.hidden = false;
      const parts = [`<h3 class="lookahead-heading">Upcoming</h3>`];
      keys.forEach(day => {
        const ids = data[day] || [];
        const dayObj = new Date(day + "T00:00:00");
        const dayLabel = dayObj.toLocaleDateString(undefined, { weekday: "short", month: "short", day: "numeric" });
        // Empty days are rendered with a muted placeholder so the
        // user can't mistake the next non-empty day for "tomorrow".
        const body = ids.length
          ? ids.map(id => {
              const c = ChoreStore.get(id);
              if (!c) return "";
              return `<span class="day-chip">${iconHTML(c)} ${esc(c.short_name)} <strong>${esc(c.reward_label)}</strong></span>`;
            }).join("")
          : `<span class="day-chip day-chip-empty">Nothing scheduled</span>`;
        const emptyClass = ids.length ? "" : " lookahead-day-empty";
        parts.push(`<div class="lookahead-day${emptyClass}"><div class="day-label">${esc(dayLabel)}</div><div class="day-items">${body}</div></div>`);
      });
      // Only write the DOM when the markup actually changed — the
      // section never flickers when the lookahead arg comes back
      // identical to what we already rendered.
      const want = parts.join("");
      if (c.innerHTML !== want) c.innerHTML = want;
    }

    function upsertOne(c) {
      // While the done-ring animation is drawing for this chore, park
      // the update so the SVG can finish; the animation timer replays
      // the latest deferred upsert when it fires.
      const sid = String(c.id);
      if (ringAnimating.has(sid)) {
        ringDeferred.set(sid, c);
        return;
      }

      const g = grid()?.querySelector(`[data-chore-id="${c.id}"]`);
      if (g) patchGridCard(g, c);
      else appendTo(grid(), renderGridCard(c));

      // The chore belongs to exactly ONE of the two Today sections:
      //   * Dailies if the viewer has pinned it (regardless of today_visible)
      //   * Overdue if it's today_visible AND not pinned
      // Anything else gets removed from both sections so a flipped
      // today_visible doesn't leave a stale card behind.
      const isDaily = ChoreStore.isDaily(c.id) && !c.archived;
      const isOverdue = c.today_visible && !c.archived && !isDaily;
      placeInSection(c, dailies(), isDaily);
      placeInSection(c, overdue(), isOverdue);
      refreshTodayEmptyStates();

      // Hot strip — membership rotates at the 4am day boundary, so when
      // an upsert flips a chore in or out of the hot set, recompute the
      // whole strip; otherwise just patch the existing cell.
      const hotEl = hot();
      const hotCell = hotEl?.querySelector(`[data-chore-id="${c.id}"]`)?.closest(".hot-strip-cell");
      const shouldBeHot = c.hot_multiplier != null && !c.archived;
      if (hotCell && shouldBeHot) {
        patchHotCell(hotCell, c);
      } else if (hotCell || shouldBeHot) {
        renderHot();
      }
    }
    function removeOne(id) {
      document.querySelectorAll(`[data-chore-id="${id}"]`).forEach(el => {
        const cell = el.closest(".hot-strip-cell");
        (cell || el).remove();
      });
      refreshTodayEmptyStates();
    }
    function placeInSection(c, container, shouldBeIn) {
      if (!container) return;
      const existing = container.querySelector(`:scope > [data-chore-id="${c.id}"]`);
      if (shouldBeIn) {
        if (existing) patchCircleCard(existing, c);
        else appendTo(container, renderCircleCard(c));
      } else if (existing) {
        existing.remove();
      }
    }
    function refreshTodayEmptyStates() {
      if (emptyDay())  emptyDay().hidden  = (dailies()?.children.length || 0) > 0;
      if (emptyOver()) emptyOver().hidden = (overdue()?.children.length || 0) > 0;
    }
    function renderAll() {
      renderGrid();
      renderDailies();
      renderOverdue();
      renderHot();
      renderLookahead();
    }
    return {
      renderAll, renderGrid, renderDailies, renderOverdue, renderHot, renderLookahead,
      upsertOne, removeOne, refreshTodayEmptyStates,
    };
  })();

  ChoreStore.subscribe((kind, id) => {
    // "reconcile" replaces the old destructive "bootstrap" event.
    // Views.renderAll() now diffs the DOM against the current store
    // instead of clearing containers, so a fresh sync that overlaps
    // with what's already on screen produces no flicker and an empty
    // sync produces no blank.
    if (kind === "reconcile") Views.renderAll();
    else if (kind === "lookahead") Views.renderLookahead();
    else if (kind === "dailies") {
      Views.renderDailies();
      Views.renderOverdue();
      refreshEditModalPin();
    }
    else if (kind === "remove") Views.removeOne(id);
    else if (kind === "upsert") {
      const c = ChoreStore.get(id);
      if (!c) return;
      Views.upsertOne(c);
    }
  });

  // ============================================================
  // ticker — countdown + ago row driven by data attributes
  // ============================================================
  const RING_CIRC = 2 * Math.PI * 46;

  function secondsUntilNextChoreDay(now) {
    const d = new Date(now);
    const next = new Date(d);
    next.setHours(CUTOFF_HOUR, 0, 0, 0);
    if (next.getTime() <= d.getTime()) next.setDate(next.getDate() + 1);
    return Math.max(0, Math.floor((next.getTime() - d.getTime()) / 1000));
  }
  // Local chore-day in iso format. Mirrors `ChoreDay.current` on the
  // server (shift by CUTOFF_HOUR, then take the date). Used to spot
  // SW-cached bootstrap that was generated before the 4am rollover.
  function currentChoreDayIso(now = Date.now()) {
    const shifted = new Date(now - CUTOFF_HOUR * 3600 * 1000);
    const y = shifted.getFullYear();
    const m = String(shifted.getMonth() + 1).padStart(2, "0");
    const d = String(shifted.getDate()).padStart(2, "0");
    return `${y}-${m}-${d}`;
  }

  function formatRemaining(seconds) {
    if (seconds <= 0) return "";
    const s = Math.ceil(seconds);
    if (s < 60) return ":" + String(s).padStart(2, "0") + "s";
    if (s < 5 * 60) {
      const mins = Math.floor(s / 60);
      const secs = Math.ceil(s % 60);
      return secs === 60 ? `${mins + 1}:00` : `${mins}:${String(secs).padStart(2, "0")}`;
    }
    if (s < 50 * 60) return Math.ceil(s / 60) + "m";
    if (s < 16 * 60 * 60) return Math.ceil(s / 3600) + "h";
    if (s < 28 * 86400) return Math.ceil(s / 86400) + "d";
    if (s < 23 * 30 * 86400) return Math.ceil(s / (30 * 86400)) + "M";
    return Math.ceil(s / (365 * 86400)) + "y";
  }

  function formatAgo(isoString, now = Date.now()) {
    if (!isoString) return "";
    const t = new Date(isoString).getTime();
    if (Number.isNaN(t)) return "";
    const sec = Math.max(0, Math.floor((now - t) / 1000));
    if (sec < 60) return "<1m ago";
    if (sec < 3600) return `${Math.floor(sec / 60)}m ago`;
    if (sec < 86400) {
      const h = Math.floor(sec / 3600);
      const m = Math.floor((sec % 3600) / 60);
      return m > 0 ? `${h}h ${m}m ago` : `${h}h ago`;
    }
    const d = new Date(t);
    const today = new Date(now);
    const startOfToday = new Date(today.getFullYear(), today.getMonth(), today.getDate()).getTime();
    const dayDiff = Math.floor((startOfToday - new Date(d.getFullYear(), d.getMonth(), d.getDate()).getTime()) / 86400000);
    if (dayDiff === 1) return "Yesterday";
    if (dayDiff >= 2 && dayDiff <= 6) {
      return ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"][d.getDay()];
    }
    const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
    return `${months[d.getMonth()]} ${d.getDate()}, '${String(d.getFullYear() % 100).padStart(2, "0")}`;
  }

  function updateRings(now) {
    document.querySelectorAll('[data-chore-id][data-chore-cooldown]').forEach(card => {
      const cooldown = parseInt(card.dataset.choreCooldown, 10);
      if (!cooldown) return;
      const last = card.dataset.lastCompletedAt;
      const ring = card.querySelector('[data-ring-progress]');
      const label = card.querySelector('[data-circle-countdown]');
      if (!label && !ring) return;
      if (ring) ring.setAttribute("stroke-dasharray", RING_CIRC);

      if (cooldown === -1) {
        if (!label) return;
        // Day-reset cooldown is only ACTIVE when the most recent
        // completion is in TODAY's chore-day. Completions from any
        // prior day have already crossed the 4am boundary, so the
        // cooldown has elapsed — the ticker must leave the label
        // empty (CSS `:empty` then hides the pill entirely). Without
        // this guard, a chore completed at 5pm yesterday would tick
        // down to tomorrow's 4am and render a phantom "1d" cooldown.
        const lastMs = last ? new Date(last).getTime() : 0;
        const stillInCooldown = lastMs &&
          currentChoreDayIso(lastMs) === currentChoreDayIso(now);
        if (!stillInCooldown) {
          label.textContent = "";
          label.classList.add("elapsed");
          return;
        }
        const remainSec = secondsUntilNextChoreDay(now);
        label.classList.toggle("elapsed", remainSec === 0);
        label.textContent = remainSec === 0 ? "" : formatRemaining(remainSec);
        return;
      }

      if (!last) {
        if (ring) { ring.setAttribute("stroke-dashoffset", RING_CIRC); ring.classList.add("elapsed"); }
        if (label) { label.classList.add("elapsed"); label.textContent = ""; }
        return;
      }
      const lastMs = new Date(last).getTime();
      const remainSec = Math.max(0, Math.ceil((lastMs + cooldown * 1000 - now) / 1000));
      if (ring) {
        const progress = remainSec === 0 ? 0 : remainSec / cooldown;
        ring.setAttribute("stroke-dashoffset", RING_CIRC * (1 - progress));
        ring.classList.toggle("elapsed", remainSec === 0);
      }
      if (label) {
        label.classList.toggle("elapsed", remainSec === 0);
        label.textContent = remainSec === 0 ? "" : formatRemaining(remainSec);
      }
    });
  }
  function updateAgoRows(now) {
    document.querySelectorAll("[data-ago-row]").forEach(row => {
      const card = row.closest("[data-chore-id]");
      if (!card) return;
      const iso = card.dataset.lastCompletedAt;
      row.textContent = iso ? formatAgo(iso, now) : "";
    });
  }
  function startTicker() {
    const tick = () => {
      const now = Date.now();
      updateRings(now);
      updateAgoRows(now);
    };
    tick();
    setInterval(tick, 1000);
  }

  // ============================================================
  // gestures — tap to complete, long-press to undo, edit-mode tap to edit
  // ============================================================
  let editModeActive = false;

  function bindCardClicks() {
    [
      document.querySelector("[data-chores-grid]"),
      document.querySelector("[data-chores-dailies]"),
      document.querySelector("[data-chores-overdue]"),
      document.querySelector("[data-chores-hot-strip]"),
    ].filter(Boolean).forEach(bindOne);
  }
  function bindOne(container) {
    const MOVE_THRESHOLD = 8, LONG_MS = 550;
    const s = { pointerId: null, card: null, startX: 0, startY: 0, startedAt: 0, moved: false, longPressFired: false, timer: null };
    function reset() {
      if (s.timer) clearTimeout(s.timer);
      s.pointerId = null; s.card = null; s.startX = 0; s.startY = 0; s.startedAt = 0;
      s.moved = false; s.longPressFired = false; s.timer = null;
    }
    container.addEventListener("pointerdown", e => {
      if (s.pointerId !== null) return;
      const card = e.target.closest("[data-chore-id]");
      if (!card) return;
      const inEditMode = editModeActive;
      if (!inEditMode) {
        const usesCircleHitbox = container.matches("[data-chores-dailies], [data-chores-overdue], [data-chores-hot-strip]");
        if (usesCircleHitbox && !e.target.closest(".circle-inner")) return;
      }

      s.pointerId = e.pointerId; s.card = card; s.startX = e.clientX; s.startY = e.clientY;
      s.startedAt = performance.now(); s.moved = false; s.longPressFired = false;
      s.timer = setTimeout(() => {
        if (!s.card || s.moved) return;
        s.longPressFired = true;
        if (inEditMode) openChoreHistoryModal(s.card.dataset.choreId);
        else undoLastCompletion(s.card.dataset.choreId);
      }, LONG_MS);
    });
    container.addEventListener("pointermove", e => {
      if (s.pointerId !== e.pointerId) return;
      if (Math.hypot(e.clientX - s.startX, e.clientY - s.startY) > MOVE_THRESHOLD) {
        s.moved = true;
        if (s.timer) { clearTimeout(s.timer); s.timer = null; }
      }
    });
    container.addEventListener("pointerup", e => {
      if (s.pointerId !== e.pointerId) return;
      const card = s.card;
      const isShortTap = !s.moved && !s.longPressFired && (performance.now() - s.startedAt) < LONG_MS;
      reset();
      if (!card) return;
      if (!isShortTap) { card.dataset.suppressClick = "1"; return; }
      // In edit mode every short tap means "edit"; the click handler
      // opens the edit modal. Never auto-complete from edit mode.
      if (editModeActive) return;
      if (multiplierActive) { openMultiplierModal(card); return; }
      if (e.shiftKey) { openEditModal(card); return; }
      completeChore(card.dataset.choreId);
    });
    ["pointercancel", "pointerleave"].forEach(evt =>
      container.addEventListener(evt, e => { if (s.pointerId === e.pointerId) reset(); }));
    container.addEventListener("click", e => {
      const card = e.target.closest("[data-chore-id]");
      if (!card) return;
      // A long-press already opened a modal (history in edit mode, undo
      // otherwise) — swallow the trailing click so the edit modal doesn't
      // also pop open behind it.
      if (card.dataset.suppressClick === "1") {
        delete card.dataset.suppressClick;
        e.preventDefault(); e.stopPropagation();
        return;
      }
      if (editModeActive) { e.preventDefault(); e.stopPropagation(); openEditModal(card); return; }
    }, true);
    container.addEventListener("contextmenu", e => {
      const card = e.target.closest("[data-chore-id]");
      if (!card) return;
      e.preventDefault();
      openEditModal(card);
    });
  }

  // ============================================================
  // Dailies — pin toggle (on the edit modal) + per-section drag reorder
  // ============================================================
  // The pin button lives in the edit modal head (left of the title), so
  // users can pin/unpin from anywhere the modal opens (Today, Grid,
  // search, history). `bindEditModalPin` wires a single listener that
  // operates on whichever chore the modal is currently editing.
  function bindEditModalPin() {
    const btn = document.querySelector("[data-edit-pin-toggle]");
    if (!btn) return;
    btn.addEventListener("click", e => {
      e.preventDefault();
      e.stopPropagation();
      const id = parseInt(currentChoreId, 10);
      if (!id || btn.dataset.busy === "1") return;
      togglePinDaily(id, btn);
    });
  }

  // Sync the modal pin button to the chore the modal is currently
  // editing. Called from openEditModal and from the `dailies` store
  // notify path so a broadcast that lands while the modal is open
  // keeps the button in sync.
  function refreshEditModalPin() {
    const btn = document.querySelector("[data-edit-pin-toggle]");
    if (!btn) return;
    const id = parseInt(currentChoreId, 10);
    if (!id) { btn.hidden = true; return; }
    btn.hidden = false;
    const pinned = ChoreStore.isDaily(id);
    btn.classList.toggle("pinned", pinned);
    const label = pinned ? "Remove from Dailies" : "Pin to Dailies";
    btn.setAttribute("aria-label", label);
    btn.setAttribute("title", label);
  }

  async function togglePinDaily(id, btn) {
    const wasPinned = ChoreStore.isDaily(id);
    btn.dataset.busy = "1";
    // Optimistic — flip the store immediately so the card moves to the
    // right section as soon as the user dismisses the modal. We don't
    // roll back on transient error; the queue + sync will reconcile.
    if (wasPinned) ChoreStore.unpinDaily(id);
    else           ChoreStore.pinDaily(id);
    refreshEditModalPin();
    const url = `/chores/items/${id}/dailies`;
    const method = wasPinned ? "DELETE" : "POST";
    try {
      const data = await api(url, method, { tab_id: TAB_ID });
      if (data && Array.isArray(data.daily_ids)) ChoreStore.setDailyIds(data.daily_ids);
    } catch (err) {
      if (isTransientError(err)) {
        flash("Saved locally — will sync", "warn");
      } else {
        // Hard error: revert the optimistic flip.
        if (wasPinned) ChoreStore.pinDaily(id);
        else           ChoreStore.unpinDaily(id);
        refreshEditModalPin();
        flash("Couldn't update Dailies: " + err.message, "error");
      }
    } finally {
      delete btn.dataset.busy;
    }
  }

  let dailiesSortable = null;
  function bindDailiesSortable() {
    if (typeof window.Sortable === "undefined") {
      setTimeout(bindDailiesSortable, 200);
      return;
    }
    const container = document.querySelector("[data-chores-dailies]");
    if (!container || dailiesSortable) return;
    dailiesSortable = window.Sortable.create(container, {
      animation: 150,
      ghostClass: "sortable-ghost",
      chosenClass: "sortable-chosen",
      dragClass: "sortable-drag",
      forceFallback: true,
      fallbackOnBody: true,
      fallbackTolerance: 0,
      delay: 250,
      delayOnTouchOnly: true,
      touchStartThreshold: 6,
      onEnd: persistDailiesOrder,
    });
  }

  async function persistDailiesOrder() {
    const container = document.querySelector("[data-chores-dailies]");
    if (!container) return;
    const ids = Array.from(container.children)
      .map(el => parseInt(el.dataset.choreId, 10))
      .filter(Boolean);
    // Local store keeps the user-visible order in sync with the DOM
    // immediately. Server confirms via the response below.
    ChoreStore.reorderDailies(ids);
    try {
      const data = await api("/chores/dailies/order", "PATCH", { ids, tab_id: TAB_ID });
      if (data && Array.isArray(data.daily_ids)) ChoreStore.setDailyIds(data.daily_ids);
    } catch (err) {
      flash("Couldn't save Dailies order: " + err.message, "error");
    }
  }

  // ============================================================
  // Chore history modal — opened by long-press in edit mode. Reads
  // the per-chore /chores/items/:id/history endpoint, which scopes
  // household-shared chores to the whole household.
  // ============================================================
  const choreHistoryModal = document.querySelector('[data-chore-history-modal]');
  const choreHistoryBody  = document.querySelector('[data-chore-history-body]');
  const choreHistoryTitle = document.querySelector('[data-chore-history-title]');
  async function openChoreHistoryModal(id) {
    if (!choreHistoryModal) return;
    const c = ChoreStore.get(parseInt(id, 10));
    if (choreHistoryTitle) choreHistoryTitle.textContent = c ? c.name : "Chore History";
    if (choreHistoryBody) choreHistoryBody.innerHTML = '<p style="color:var(--chores-muted);">Loading…</p>';
    choreHistoryModal.classList.remove("hidden");
    try {
      const data = await api(`/chores/items/${parseInt(id, 10)}/history`, "GET");
      renderChoreHistory(data);
    } catch (e) {
      if (choreHistoryBody) choreHistoryBody.innerHTML = `<p style="color:#DC2626;">${esc(e.message || "Failed to load")}</p>`;
    }
  }
  function renderChoreHistory(data) {
    if (!choreHistoryBody) return;
    const entries = data?.entries || [];
    if (entries.length === 0) {
      choreHistoryBody.innerHTML = '<p style="color:var(--chores-muted);">No history yet.</p>';
      return;
    }
    const rows = entries.map(e => {
      const actor = e.actor_username ? `<span class="chore-history-actor">${esc(e.actor_username)}</span>` : "";
      const skipped = e.payout_skipped ? ' <span class="history-tag skipped">skipped</span>' : "";
      const mults = [];
      if (e.hot_multiplier != null && e.hot_multiplier > 1) {
        mults.push(`<span class="history-mult hot">Hot ${esc(formatMultiplier(e.hot_multiplier))}×</span>`);
      }
      if (e.streak_multiplier != null && e.streak_multiplier > 1) {
        mults.push(`<span class="history-mult streak">Streak ${esc(formatMultiplier(e.streak_multiplier))}×</span>`);
      }
      const multBlock = mults.length ? `<div class="chore-history-mults">${mults.join("")}</div>` : "";
      const note = e.note ? `<div class="chore-history-note">${esc(e.note)}</div>` : "";
      return `
        <div class="chore-history-row" data-actor="${esc(e.actor_username || '')}">
          <div class="chore-history-when">${esc(e.when_label)}${skipped}</div>
          <div class="chore-history-paid">${esc(formatCount(e.paid_pebbles))}p</div>
          ${actor}
          ${multBlock}
          ${note}
        </div>
      `;
    }).join("");
    choreHistoryBody.innerHTML = rows;
  }
  // Dismiss wiring (including the drag-from-inside-to-outside fix) is
  // applied to every `.chores-modal-backdrop` in the Balance section.

  // ============================================================
  // mutations — go through the store
  // ============================================================
  // Snapshot of the chore-side fields the History page needs to render
  // a pending push without a server round-trip. Stored alongside the
  // queued POST/DELETE in localStorage; never sent to the server.
  function queueMetaFor(c) {
    if (!c) return null;
    return {
      chore_id: c.id,
      chore_name: c.short_name || c.name,
      icon: c.icon || "",
      icon_kind: c.icon_kind || "empty",
      one_off: !!c.one_off,
      base_pebbles: c.reward_pebbles || 0,
    };
  }
  // Parses a chore's `notes_template` into a static-text + field-token
  // sequence plus a deduped field list. Placeholder syntax:
  //   {Label}                       → text input
  //   {Label:Numeric}               → number input
  //   {Label:Date}                  → date input
  //   {Label:Select [a, b, "c, d"]} → select; quoted options keep commas
  // Same-labeled placeholders collapse to one field; the value substitutes
  // at every occurrence in the saved note.
  function parseNoteTemplate(template) {
    const tokens = [];
    const fields = [];
    const seen = new Set();
    if (!template) return { tokens, fields };
    const re = /\{([^{}]+)\}/g;
    let last = 0, m;
    while ((m = re.exec(template)) !== null) {
      if (m.index > last) tokens.push({ kind: "text", text: template.slice(last, m.index) });
      const spec = parseNoteFieldSpec(m[1]);
      if (!seen.has(spec.key)) { seen.add(spec.key); fields.push(spec); }
      tokens.push({ kind: "field", key: spec.key });
      last = re.lastIndex;
    }
    if (last < template.length) tokens.push({ kind: "text", text: template.slice(last) });
    return { tokens, fields };
  }
  function parseNoteFieldSpec(inner) {
    const colon = inner.indexOf(":");
    let label, type = "text", options = null;
    if (colon === -1) {
      label = inner.trim();
    } else {
      label = inner.slice(0, colon).trim();
      const rest = inner.slice(colon + 1).trim();
      const lb = rest.indexOf("[");
      if (lb >= 0) {
        type = rest.slice(0, lb).trim().toLowerCase();
        const optsStr = rest.slice(lb + 1).replace(/\]\s*$/, "");
        options = parseNoteOptionList(optsStr);
      } else {
        type = rest.toLowerCase();
      }
    }
    return { key: label, label: label, type: type || "text", options: options };
  }
  function parseNoteOptionList(s) {
    const out = []; let cur = ""; let q = false;
    for (let i = 0; i < s.length; i++) {
      const ch = s[i];
      if (ch === '"') { q = !q; continue; }
      if (ch === "," && !q) { const v = cur.trim(); if (v) out.push(v); cur = ""; continue; }
      cur += ch;
    }
    const tail = cur.trim(); if (tail) out.push(tail);
    return out;
  }
  function interpolateNoteTemplate(parsed, values) {
    return parsed.tokens.map(t => {
      if (t.kind === "text") return t.text;
      const v = values[t.key];
      return v == null ? "" : String(v);
    }).join("");
  }

  // Note-prompt modal — appears on tap for any chore whose
  // notes_template carries `{...}` placeholders. Runs entirely client-
  // side; submit calls doCompleteChore so the same offline-safe queue
  // path handles the resulting POST.
  const notePromptModal  = document.querySelector('[data-note-prompt-modal]');
  const notePromptForm   = notePromptModal?.querySelector('[data-note-prompt-form]');
  const notePromptFields = notePromptModal?.querySelector('[data-note-prompt-fields]');
  const notePromptTitle  = notePromptModal?.querySelector('[data-note-prompt-title]');
  let activeNotePrompt = null;

  function renderNotePromptField(f, i) {
    const id = `note-prompt-field-${i}`;
    const keyAttr = esc(f.key);
    const typeAttr = esc(f.type || "text");
    const label = `<label class="field-label" for="${id}">${esc(f.label)}</label>`;
    let input;
    if (f.type === "select" && f.options && f.options.length) {
      const opts = ['<option value=""></option>']
        .concat(f.options.map(o => `<option value="${esc(o)}">${esc(o)}</option>`))
        .join("");
      input = `<select id="${id}" data-prompt-key="${keyAttr}" data-prompt-type="${typeAttr}">${opts}</select>`;
    } else if (f.type === "numeric" || f.type === "number") {
      input = `<input id="${id}" type="number" inputmode="decimal" data-prompt-key="${keyAttr}" data-prompt-type="${typeAttr}" autocomplete="off">`;
    } else if (f.type === "date") {
      input = `<input id="${id}" type="date" data-prompt-key="${keyAttr}" data-prompt-type="${typeAttr}" autocomplete="off">`;
    } else {
      input = `<input id="${id}" type="text" data-prompt-key="${keyAttr}" data-prompt-type="${typeAttr}" autocomplete="off">`;
    }
    return `<div class="form-section">${label}${input}</div>`;
  }
  // Map a raw form value to the type implied by the placeholder.
  // Empty strings become null so the server stores `null` rather than
  // `""` (or `NaN`/0 for numerics) — the template still interpolates
  // to an empty string at the display layer.
  function coerceNoteValue(raw, type) {
    if (raw == null || raw === "") return null;
    if (type === "numeric" || type === "number") {
      const n = Number(raw);
      return Number.isFinite(n) ? n : null;
    }
    return String(raw);
  }
  function openNotePromptModal(chore, parsed) {
    if (!notePromptModal || !notePromptForm || !notePromptFields) return;
    activeNotePrompt = { chore, parsed };
    if (notePromptTitle) notePromptTitle.textContent = chore.short_name || chore.name || "Notes";
    notePromptFields.innerHTML = parsed.fields.map((f, i) => renderNotePromptField(f, i)).join("");
    notePromptModal.classList.remove("hidden");
    scrollModalToTop(notePromptModal);
    const first = notePromptFields.querySelector("input, select, textarea");
    first?.focus();
  }
  function closeNotePrompt() {
    notePromptModal?.classList.add("hidden");
    activeNotePrompt = null;
    if (notePromptFields) notePromptFields.innerHTML = "";
  }
  notePromptForm?.addEventListener("submit", e => {
    e.preventDefault();
    if (!activeNotePrompt) { closeNotePrompt(); return; }
    const { chore, parsed } = activeNotePrompt;
    const values = {};
    notePromptFields.querySelectorAll("[data-prompt-key]").forEach(el => {
      values[el.dataset.promptKey] = coerceNoteValue(el.value, el.dataset.promptType);
    });
    const note = interpolateNoteTemplate(parsed, values);
    closeNotePrompt();
    doCompleteChore(chore, { note: note, noteValues: values });
  });
  wireModalDismiss(notePromptModal, { onCancel: closeNotePrompt, onBackdrop: closeNotePrompt });

  function completeChore(id) {
    const c = ChoreStore.get(parseInt(id, 10));
    if (!c) return;
    const template = (c.notes_template || "").toString();
    if (template) {
      const parsed = parseNoteTemplate(template);
      if (parsed.fields.length > 0) {
        openNotePromptModal(c, parsed);
        return;
      }
      // Template with no placeholders — store the literal text verbatim.
      doCompleteChore(c, { note: template, noteValues: null });
      return;
    }
    doCompleteChore(c, { note: null, noteValues: null });
  }

  async function doCompleteChore(c, opts) {
    const note = opts && opts.note;
    const noteValues = opts && opts.noteValues;
    const sid = String(c.id);
    const clickAt = new Date().toISOString();
    localClickTs.set(sid, Date.now());

    ChoreStore.patch(c.id, {
      done_count_today: (c.done_count_today || 0) + 1,
      last_completed_at: clickAt,
      last_actor_username: VIEWER_USERNAME || c.last_actor_username,
    });

    const body = { client_completed_at: clickAt, tab_id: TAB_ID };
    const overrides = {};
    if (note != null && note !== "") overrides.note = note;
    if (noteValues && Object.keys(noteValues).length > 0) overrides.note_values = noteValues;
    if (Object.keys(overrides).length > 0) body.chore_completion = overrides;

    if (!navigator.onLine || reloadPending) {
      enqueue({ url: `/chores/items/${c.id}/completion`, method: "POST",
                body: body, meta: queueMetaFor(c) });
      return;
    }

    inFlight.add(sid);
    try {
      const data = await api(`/chores/items/${c.id}/completion`, "POST", body);
      reconcile(data);
      if (data.skipped) flash(data.skipped_reason || "Cooldown — no payout", "warn");
      else if (data.paid) flash(`+${formatCount(data.paid)}p`);
      (data.achieved_goals || []).forEach(g => {
        const tail = g.pebbles ? ` +${formatCount(g.pebbles)}p` : "";
        flash(`🏆 ${g.name}${tail}`, "ok");
      });
    } catch (err) {
      if (isTransientError(err)) {
        // Network / rate-limit / upstream-503: queue so the next flush
        // (online event, Monitor reconnect, scheduled retry) sends it.
        // User never sees an "Error" flash — their tap was accepted
        // locally and will sync.
        enqueue({ url: `/chores/items/${c.id}/completion`, method: "POST",
                  body: body, meta: queueMetaFor(c) });
        setConnDot("syncing");
        scheduleQueueRetry();
      } else {
        flash("Couldn't complete: " + err.message, "error");
      }
    } finally { inFlight.delete(sid); }
  }

  // Back-off retry for the offline queue when we hit a soft failure
  // (429 / 5xx). We don't burn the CPU polling; one timer per active
  // back-off, with growing intervals capped at 60s.
  let queueRetryTimer = null;
  let queueRetryDelay = 2000;
  function scheduleQueueRetry() {
    if (queueRetryTimer) return;
    if (reloadPending) return;
    queueRetryTimer = setTimeout(async () => {
      queueRetryTimer = null;
      await flushQueue();
      if (loadQueue().length === 0) {
        queueRetryDelay = 2000;
      } else {
        queueRetryDelay = Math.min(queueRetryDelay * 2, 60000);
        scheduleQueueRetry();
      }
    }, queueRetryDelay);
  }

  async function undoLastCompletion(id) {
    const c = ChoreStore.get(parseInt(id, 10));
    if (!c) return;
    const sid = String(id);
    const priorDoneCount = c.done_count_today || 0;
    ChoreStore.patch(c.id, {
      done_count_today: Math.max(0, priorDoneCount - 1),
    });
    localClickTs.set(sid, Date.now());
    if (!navigator.onLine || reloadPending) {
      enqueue({ url: `/chores/items/${c.id}/completion`, method: "DELETE",
                meta: queueMetaFor(c) });
      return;
    }
    inFlight.add(sid);
    try {
      const data = await api(`/chores/items/${c.id}/completion`, "DELETE");
      reconcile(data);
      flash("Undone", "warn");
    } catch (err) {
      if (isTransientError(err)) {
        enqueue({ url: `/chores/items/${c.id}/completion`, method: "DELETE",
                  meta: queueMetaFor(c) });
        setConnDot("syncing");
        scheduleQueueRetry();
      } else {
        ChoreStore.patch(c.id, { done_count_today: priorDoneCount });
        flash("Nothing to undo", "warn");
      }
    } finally { inFlight.delete(sid); }
  }

  // Apply a server payload to the store. Two shapes:
  //   * { chore: {...}, ... } — full chore JSON (mutation responses).
  //   * { chores: [...], archived_chore_ids: [...], lookahead: {...} } — sync.
  function reconcile(data) {
    if (!data) return;
    if (data.chore) {
      const id = data.chore.id;
      const localMs = localClickTs.get(String(id)) || 0;
      const serverMs = data.server_ts ? new Date(data.server_ts).getTime() : Date.now();
      if (!localMs || serverMs >= localMs) ChoreStore.upsert(data.chore);
    }
    if (Array.isArray(data.chores)) {
      data.chores.forEach(c => {
        const localMs = localClickTs.get(String(c.id)) || 0;
        const serverMs = data.server_ts ? new Date(data.server_ts).getTime() :
                         c.updated_at ? new Date(c.updated_at).getTime() : Date.now();
        if (!localMs || serverMs >= localMs) ChoreStore.upsert(c);
      });
    }
    if (Array.isArray(data.archived_chore_ids)) {
      data.archived_chore_ids.forEach(id => ChoreStore.remove(id));
    }
    if (data.lookahead) ChoreStore.setLookahead(data.lookahead);
    if (Array.isArray(data.daily_ids)) ChoreStore.setDailyIds(data.daily_ids);
    if (data.archived_chore_id) ChoreStore.remove(data.archived_chore_id);

    if (data.today_earnings != null) setTodayEarnings(data.today_earnings);
    if (data.balance != null) setLifetimeBalance(data.balance);
  }

  function updateBalancePill() {
    const el = document.querySelector("[data-balance]");
    if (!el) return;
    const v = root?.dataset.balanceToday;
    if (v != null) el.textContent = formatCount(v);
  }
  // Single, intentional writer for the header pill. EVERY page shows
  // today_earnings here — never lifetime. Any handler that wants to
  // update the pill must funnel through this so the next refactor
  // can't accidentally pass lifetime back in.
  function setTodayEarnings(value) {
    if (value == null) return;
    if (root) root.dataset.balanceToday = value;
    const el = document.querySelector("[data-balance]");
    if (el) el.textContent = formatCount(value);
  }
  // Separate writer for the Balance page's lifetime card. NEVER
  // touches `[data-balance]`.
  function setLifetimeBalance(value) {
    if (value == null) return;
    if (root) root.dataset.balanceTotal = value;
    const el = document.querySelector("[data-lifetime-balance]");
    if (el) el.textContent = formatCount(value);
  }

  // ============================================================
  // sync — diff endpoint, cold boot + reconnect
  // ============================================================
  const SYNC_TS_KEY = "chores:lastSyncTs:v1";
  const SYNC_DAY_KEY = "chores:lastSyncDay:v1";
  let syncInFlight = false;
  async function fullSync({ force = false } = {}) {
    if (syncInFlight || !navigator.onLine || reloadPending) return;
    syncInFlight = true;
    setSyncBadge(true);
    try {
      const since = !force ? (localStorage.getItem(SYNC_TS_KEY) || "") : "";
      const lastDay = localStorage.getItem(SYNC_DAY_KEY);
      const localDay = currentChoreDayIso();
      // If the last successful sync was on a prior chore-day, skip
      // `since` so the server returns the full set (hot picks,
      // today_visible, done_count_today all need a clean slate).
      // The server has the same defense, but doing it client-side
      // shaves a round-trip's worth of stale-render flicker.
      const useSince = since && lastDay === localDay;
      const url = useSince ? `/chores/sync?since=${encodeURIComponent(since)}` : "/chores/sync";
      const data = await api(url, "GET");
      reconcile(data);
      if (data.server_ts) localStorage.setItem(SYNC_TS_KEY, data.server_ts);
      if (data.day_key) localStorage.setItem(SYNC_DAY_KEY, data.day_key);
      setSyncBadge(false);
      // Pair every successful sync with a shell refresh: the server
      // may have changed the underlying HTML (a new chore in the
      // bootstrap JSON, an asset URL bump, a layout tweak) and we
      // never want the cached shell lagging behind. Without this the
      // user could see the live data update but the offline-reopen
      // experience would still serve yesterday's shell.
      pingSwRefresh();
      // Off-screen views may want to re-render after a fresh sync —
      // mirror the Monitor path's bus event so any mounted view
      // reacts identically to local resyncs and remote broadcasts.
      broadcastRemoteChange("full_sync");
    } catch (e) { setSyncBadge(false, true); }
    finally { syncInFlight = false; }
  }

  // ============================================================
  // search — works against the store, both views
  // ============================================================
  function score(needle, name, aliases) {
    if (!needle) return 1;
    const n = needle.toLowerCase();
    const fields = [
      { text: (name || "").toLowerCase(), weight: 1.0 },
      ...((aliases || []).map(a => ({ text: a.toLowerCase(), weight: 0.5 }))),
    ];
    let best = 0;
    for (const { text, weight } of fields) {
      if (!text) continue;
      const idx = text.indexOf(n);
      let local = 0;
      if (idx === 0) local = 1.0;
      else if (idx > 0) local = 0.7 - Math.min(idx, 10) * 0.02;
      else if (fuzzyMatch(n, text)) local = 0.3;
      else continue;
      best = Math.max(best, local * weight);
    }
    return best;
  }
  function fuzzyMatch(needle, hay) {
    let i = 0, j = 0;
    while (i < needle.length && j < hay.length) {
      if (needle[i] === hay[j]) i++;
      j++;
    }
    return i === needle.length;
  }
  function applySearch(q) {
    [
      document.querySelector("[data-chores-grid]"),
      document.querySelector("[data-chores-circles]"),
    ].filter(Boolean).forEach(container => {
      const cards = Array.from(container.children);
      if (!q) { cards.forEach(c => c.style.display = ""); return; }
      cards.forEach(card => {
        const c = ChoreStore.get(parseInt(card.dataset.choreId, 10));
        if (!c) return;
        const s = score(q, c.short_name || c.name, c.aliases || []);
        card.style.display = s > 0 ? "" : "none";
      });
    });
  }
  document.querySelector('[data-chores-search]')?.addEventListener("input",
    e => applySearch(e.target.value.trim()));
  // Wire any input that has a sibling `[data-search-clear]` button: show
  // the × while the field has text, clear + refocus on click. Used by
  // the toolbar search and the History filter.
  function wireSearchClear(scope = document) {
    scope.querySelectorAll("[data-search-clear]").forEach(btn => {
      const wrap = btn.parentElement;
      const input = wrap?.querySelector("input");
      if (!input) return;
      const sync = () => { btn.hidden = !input.value; };
      sync();
      input.addEventListener("input", sync);
      btn.addEventListener("click", () => {
        input.value = "";
        input.dispatchEvent(new Event("input", { bubbles: true }));
        input.focus();
        sync();
      });
    });
  }
  wireSearchClear();

  // ============================================================
  // multiplier toggle + modal
  // ============================================================
  let multiplierActive = false;
  let multiplierTargetCard = null;
  const multiplierBtn = document.querySelector('[data-multiplier-toggle]');
  const multiplierModal = document.querySelector('[data-multiplier-modal]');
  multiplierBtn?.addEventListener("click", () => {
    multiplierActive = !multiplierActive;
    multiplierBtn.classList.toggle("active", multiplierActive);
  });
  function openMultiplierModal(card) {
    if (!multiplierModal) return;
    multiplierTargetCard = card;
    multiplierModal.querySelector('[data-multiplier-label]').textContent =
      card.dataset.choreShort || card.dataset.choreName;
    multiplierModal.querySelector('[data-multiplier-input]').value = 2;
    multiplierModal.classList.remove("hidden");
  }
  function closeMultiplierModal() {
    multiplierModal?.classList.add("hidden");
    multiplierTargetCard = null;
    multiplierActive = false;
    multiplierBtn?.classList.remove("active");
  }
  wireModalDismiss(multiplierModal, {
    onCancel:   closeMultiplierModal,
    onBackdrop: closeMultiplierModal,
  });
  multiplierModal?.querySelectorAll('[data-mult]').forEach(btn =>
    btn.addEventListener("click", () => { multiplierModal.querySelector('[data-multiplier-input]').value = btn.dataset.mult; }));
  multiplierModal?.querySelector('[data-multiplier-submit]')?.addEventListener("click", async () => {
    const n = Math.max(1, Math.min(50, parseInt(multiplierModal.querySelector('[data-multiplier-input]').value, 10) || 1));
    const card = multiplierTargetCard;
    closeMultiplierModal();
    if (!card) return;
    for (let i = 0; i < n; i++) await completeChore(card.dataset.choreId);
  });

  // ============================================================
  // edit modal
  // ============================================================
  const editModal = document.querySelector("[data-chore-modal]");
  const editForm  = editModal?.querySelector('[data-chores-form]');
  function setField(name, value) {
    const el = editForm?.querySelector(`[data-field="${name}"]`);
    if (el == null) return;
    el.value = value ?? "";
  }
  function getField(name) { return editForm?.querySelector(`[data-field="${name}"]`)?.value; }

  let currentChoreId = null;
  let modalLockedFor = null;
  const WDAY_KEYS = ["sun", "mon", "tue", "wed", "thu", "fri", "sat"];

  function setPillValue(groupKey, value) {
    const group = editForm.querySelector(`[data-pill-group="${groupKey}"]`);
    if (!group) return;
    group.querySelectorAll(".pill").forEach(p => {
      p.classList.toggle("active", String(p.dataset.value) === String(value ?? ""));
    });
    const input = editForm.querySelector(`[data-field="${groupKey}"]`);
    if (input) input.value = value ?? "";
  }
  function bindPillGroups() {
    editForm.querySelectorAll(".pill-group[data-pill-group]").forEach(group => {
      const key = group.dataset.pillGroup;
      group.addEventListener("click", e => {
        const pill = e.target.closest(".pill");
        if (!pill || pill.classList.contains("chip-day")) return;
        e.preventDefault();
        if (key === "freq") {
          if (pill.dataset.value === "weekdays") {
            setPillValue("freq", "weekly");
            syncWeekdayChips(["mon", "tue", "wed", "thu", "fri"]);
            syncFreqRow();
            return;
          }
          setPillValue("freq", pill.dataset.value);
          syncFreqRow();
          return;
        }
        if (key === "threshold_preset") {
          setPillValue("threshold_preset", pill.dataset.value);
          syncCooldownRow();
          return;
        }
        setPillValue(key, pill.dataset.value);
      });
    });
    editForm.querySelector('[data-reward-quicks]')?.addEventListener("click", e => {
      const pill = e.target.closest("[data-reward]");
      if (!pill) return;
      e.preventDefault();
      const v = pill.dataset.reward;
      editForm.querySelectorAll('[data-reward-quicks] .pill').forEach(p => p.classList.remove("active"));
      pill.classList.add("active");
      const custom = editForm.querySelector('.reward-custom');
      if (v === "custom") { custom?.classList.remove("hidden"); custom?.focus(); }
      else { custom?.classList.add("hidden"); if (custom) custom.value = v; }
    });
    editForm.querySelector('[data-weekday-chips]')?.addEventListener("click", e => {
      const btn = e.target.closest('[data-day]');
      if (!btn) return;
      e.preventDefault();
      btn.classList.toggle("active");
      syncWeekdaysHelperHighlight();
    });
    editForm.querySelector('[data-month-day-pane]')?.addEventListener("click", e => {
      const btn = e.target.closest('[data-day]');
      if (!btn) return;
      e.preventDefault();
      btn.classList.toggle("active");
    });
    editForm.querySelector('[data-month-mode-tabs]')?.addEventListener("click", e => {
      const btn = e.target.closest('[data-month-mode]');
      if (!btn) return;
      e.preventDefault();
      const mode = btn.dataset.monthMode;
      editForm.querySelectorAll('[data-month-mode-tabs] .pill').forEach(p =>
        p.classList.toggle("active", p.dataset.monthMode === mode));
      editForm.querySelector('[data-month-day-pane]')?.classList.toggle("hidden", mode !== "day-of-month");
      editForm.querySelector('[data-month-nth-pane]')?.classList.toggle("hidden", mode !== "nth-weekday");
    });
    editForm.querySelector('[data-cooldown-amount]')?.addEventListener("input", syncCustomCooldown);
    editForm.querySelector('[data-cooldown-unit]')?.addEventListener("change", syncCustomCooldown);
    editForm.querySelector('[data-field="one_off"]')?.addEventListener("change", syncSingleTask);
    editForm.querySelector('[data-field="starts_on"]')?.addEventListener("change", syncStartsOnDependents);
  }
  function isSingleTask() { return editForm.querySelector('[data-field="one_off"]')?.checked === true; }
  function syncSingleTask() {
    const on = isSingleTask();
    editForm.querySelectorAll('[data-recurring-only]').forEach(el => el.classList.toggle("hidden", on));
    if (on) ensureStartsOnSet();
  }
  // Fill starts_on with today's date IFF it's currently blank. Called
  // whenever the user opts into something date-bearing — a recurrence
  // freq or Single Task — so the field isn't silently empty.
  function ensureStartsOnSet() {
    const startsField = editForm.querySelector('[data-field="starts_on"]');
    if (startsField && !startsField.value) startsField.value = todayIso();
  }
  function syncCooldownRow() {
    const preset = editForm.querySelector('[data-field="threshold_preset"]')?.value || "";
    const customRow = editForm.querySelector('[data-cooldown-custom-row]');
    const hidden = editForm.querySelector('[data-field="threshold_seconds"]');
    if (preset === "custom") { customRow?.classList.remove("hidden"); syncCustomCooldown(); }
    else if (preset === "day-end") { customRow?.classList.add("hidden"); hidden.value = "-1"; }
    else { customRow?.classList.add("hidden"); hidden.value = preset || ""; }
  }
  function syncCustomCooldown() {
    const amt = parseInt(editForm.querySelector('[data-cooldown-amount]')?.value, 10) || 0;
    const unit = editForm.querySelector('[data-cooldown-unit]')?.value || "second";
    const factor = { second: 1, minute: 60, hour: 3600, day: 86400, week: 604800 }[unit] || 1;
    const seconds = Math.max(0, amt) * factor;
    const hidden = editForm.querySelector('[data-field="threshold_seconds"]');
    if (hidden) hidden.value = String(seconds);
  }
  function setCooldownSeconds(seconds) {
    if (seconds === -1) { setPillValue("threshold_preset", "day-end"); syncCooldownRow(); return; }
    const presets = [0, 3600, 10800, 21600, 43200, 86400, 172800, 604800];
    if (presets.includes(seconds)) {
      setPillValue("threshold_preset", seconds === 0 ? "" : String(seconds));
      syncCooldownRow();
    } else {
      setPillValue("threshold_preset", "custom");
      const { amount, unit } = bestCooldownDecomposition(seconds);
      const amtEl = editForm.querySelector('[data-cooldown-amount]');
      const unitEl = editForm.querySelector('[data-cooldown-unit]');
      if (amtEl) amtEl.value = amount;
      if (unitEl) unitEl.value = unit;
      syncCooldownRow();
    }
  }
  function bestCooldownDecomposition(seconds) {
    if (seconds % 604800 === 0) return { amount: seconds / 604800, unit: "week" };
    if (seconds % 86400 === 0)  return { amount: seconds / 86400,  unit: "day" };
    if (seconds % 3600 === 0)   return { amount: seconds / 3600,   unit: "hour" };
    if (seconds % 60 === 0)     return { amount: seconds / 60,     unit: "minute" };
    return { amount: seconds, unit: "second" };
  }
  function syncFreqRow() {
    const freq = getField("freq") || "never";
    // Picking ANY recurrence auto-fills starts_on with today (only
    // when blank — never overwrites a user-chosen date).
    if (freq !== "never") ensureStartsOnSet();
    editForm.querySelector('[data-weekly-wrap]')?.classList.toggle("hidden", freq !== "weekly");
    editForm.querySelector('[data-monthly-wrap]')?.classList.toggle("hidden", freq !== "monthly");
    editForm.querySelector('[data-yearly-wrap]')?.classList.toggle("hidden", freq !== "yearly");
    editForm.querySelector('[data-interval-wrap]')?.classList.toggle("hidden",
      freq !== "custom" && freq !== "relative");
    editForm.querySelector('[data-weekdays-wrap]')?.classList.add("hidden");
    if (freq === "weekly") {
      const chips = Array.from(editForm.querySelectorAll('[data-weekday-chips] .chip-day.active'));
      if (chips.length === 0) {
        const d = parseStartsOn();
        if (d) syncWeekdayChips([WDAY_KEYS[d.getDay()]]);
      }
    }
    if (freq === "monthly") {
      const anyActive = editForm.querySelector('[data-month-day-pane] .md-chip.active');
      if (!anyActive) {
        const d = parseStartsOn();
        if (d) editForm.querySelector(`[data-month-day-pane] [data-day="${d.getDate()}"]`)?.classList.add("active");
      }
    }
    syncStartsOnDependents();
    syncWeekdaysHelperHighlight();
  }
  function syncWeekdaysHelperHighlight() {
    const weekdaysPill = editForm.querySelector('[data-pill-group="freq"] [data-value="weekdays"]');
    if (!weekdaysPill) return;
    const freq = getField("freq");
    const sel = collectWeekdays();
    const SET = ["mon", "tue", "wed", "thu", "fri"];
    weekdaysPill.classList.toggle("active",
      freq === "weekly" && sel.length === 5 && SET.every(d => sel.includes(d)));
  }
  function syncStartsOnDependents() {
    const d = parseStartsOn();
    if (!d) return;
    const monthLabel = editForm.querySelector('[data-month-day-label]');
    if (monthLabel) monthLabel.textContent = d.getDate();
    const setPos = editForm.querySelector('[data-month-set-pos]');
    if (setPos && !setPos.dataset.userTouched) setPos.value = String(Math.floor((d.getDate() - 1) / 7) + 1);
    const wday = editForm.querySelector('[data-month-wday]');
    if (wday && !wday.dataset.userTouched) wday.value = WDAY_KEYS[d.getDay()];
    const yearlyLabel = editForm.querySelector('[data-yearly-label]');
    if (yearlyLabel) {
      const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
      yearlyLabel.textContent = `${months[d.getMonth()]} ${d.getDate()}`;
    }
  }
  function parseStartsOn() {
    const v = editForm.querySelector('[data-field="starts_on"]')?.value;
    if (!v) return null;
    const parts = v.split("-").map(Number);
    if (parts.length !== 3) return null;
    return new Date(parts[0], parts[1] - 1, parts[2]);
  }
  function syncWeekdayChips(days) {
    const wrap = editForm.querySelector('[data-weekday-chips]');
    if (!wrap) return;
    Array.from(wrap.children).forEach(btn => btn.classList.toggle("active", days.includes(btn.dataset.day)));
  }
  function collectWeekdays() {
    const wrap = editForm.querySelector('[data-weekday-chips]');
    return Array.from(wrap?.querySelectorAll('[data-day].active') || []).map(b => b.dataset.day);
  }
  function selectRewardPill(amount) {
    editForm.querySelectorAll('[data-reward-quicks] .pill').forEach(p => p.classList.remove("active"));
    const exact = editForm.querySelector(`[data-reward-quicks] [data-reward="${amount}"]`);
    if (exact) {
      exact.classList.add("active");
      editForm.querySelector('.reward-custom')?.classList.add("hidden");
    } else {
      editForm.querySelector('[data-reward-quicks] [data-reward="custom"]')?.classList.add("active");
      const custom = editForm.querySelector('.reward-custom');
      if (custom) { custom.classList.remove("hidden"); custom.value = amount; }
    }
  }
  function todayIso() {
    const d = new Date();
    const pad = n => String(n).padStart(2, "0");
    return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`;
  }
  function scrollModalToTop(modal) {
    if (!modal) return;
    modal.scrollTop = 0;
    modal.querySelector(".chores-modal")?.scrollTo?.(0, 0);
  }

  // Icon picker — single contenteditable block + corner upload.
  // Form-agnostic icon uploader. Reads & writes the canonical icon
  // value from a hidden `[data-icon-hidden]` (or legacy
  // `[data-field="icon"]`) inside the stack. The same widget covers:
  //   * type one emoji directly into the preview
  //   * paste an image / image URL / SVG XML / data: URL
  //   * drag-drop an image file
  //   * tap the upload chip to open the file picker
  //
  // Callers wire it once per form via `bindIconUploader(form)`. The
  // setter is exposed on `stack.__setIconValue` so `fillFromExisting`
  // logic in each form can hydrate it after `form.reset()`.
  function bindIconUploader(form) {
    const stack = form?.querySelector("[data-icon-stack]");
    if (!stack) return;
    const preview   = stack.querySelector("[data-icon-preview]");
    const uploadBtn = stack.querySelector("[data-icon-upload]");
    const fileInput = stack.querySelector("[data-icon-file]");
    // The chore form uses `data-field="icon"`; the goal form uses
    // `data-icon-hidden` (it doesn't share the chore form's field
    // convention). Either is fine.
    const hidden = stack.querySelector('[data-icon-hidden]')
                || stack.querySelector('[data-field="icon"]');
    function setIconValue(v, { renderFromValue = true } = {}) {
      if (hidden) hidden.value = v || "";
      if (!renderFromValue || !preview) return;
      if (!v) { preview.innerHTML = ""; return; }
      if (v.startsWith("data:image/") || v.startsWith("http://") || v.startsWith("https://")) {
        preview.innerHTML = `<img src="${esc(v)}" alt="" loading="lazy" draggable="false">`;
      } else if (v.startsWith("<svg")) {
        preview.innerHTML = v;
      } else {
        preview.textContent = v;
      }
    }
    stack.__setIconValue = setIconValue;

    // Typed input is constrained to ONE grapheme cluster (one emoji-ish
    // glyph). Without this, typing letters into the preview showed them
    // at the preview's font-size — huge scribbles that looked broken.
    // Image / SVG / URL strings always come in via the paste/drop/file
    // path, never through typing, so clipping to one glyph is safe.
    const segmenter = (typeof Intl !== "undefined" && Intl.Segmenter)
      ? new Intl.Segmenter(undefined, { granularity: "grapheme" }) : null;
    function firstGrapheme(s) {
      if (!s) return "";
      if (segmenter) {
        for (const piece of segmenter.segment(s)) return piece.segment;
        return "";
      }
      return Array.from(s)[0] || "";
    }
    function placeCaretAtEnd(el) {
      const range = document.createRange();
      range.selectNodeContents(el);
      range.collapse(false);
      const sel = window.getSelection();
      sel?.removeAllRanges();
      sel?.addRange(range);
    }
    preview?.addEventListener("input", () => {
      const raw = (preview.textContent || "").trim();
      // Pasted SVG / URL strings are caught by the paste handler with
      // preventDefault — they never reach `input`. So anything we see
      // here is intentional keyboard typing of an emoji-or-letter glyph.
      const glyph = firstGrapheme(raw);
      if (raw !== glyph) {
        preview.textContent = glyph;
        placeCaretAtEnd(preview);
      }
      setIconValue(glyph, { renderFromValue: false });
    });
    preview?.addEventListener("paste", async e => {
      const items = Array.from(e.clipboardData?.items || []);
      const imageItem = items.find(it => it.type.startsWith("image/"));
      if (imageItem) {
        e.preventDefault();
        const file = imageItem.getAsFile();
        if (file) { const v = await readFileAsValue(file); if (v) setIconValue(v); }
        return;
      }
      const text = (e.clipboardData?.getData?.("text/plain") || "").trim();
      if (!text) return;
      if (text.startsWith("<svg") || text.startsWith("http://") || text.startsWith("https://") || text.startsWith("data:image/")) {
        e.preventDefault();
        setIconValue(text);
      }
    });
    ["dragover", "drop"].forEach(evt => preview?.addEventListener(evt, async e => {
      e.preventDefault();
      if (evt !== "drop") return;
      const file = Array.from(e.dataTransfer?.files || []).find(f => f.type.startsWith("image/"));
      if (file) { const v = await readFileAsValue(file); if (v) setIconValue(v); }
    }));
    uploadBtn?.addEventListener("click", e => { e.preventDefault(); fileInput?.click(); });
    fileInput?.addEventListener("change", async () => {
      const file = fileInput.files?.[0];
      if (!file) return;
      const v = await readFileAsValue(file);
      if (v) setIconValue(v);
      fileInput.value = "";
    });
  }
  function readFileAsValue(file) {
    return new Promise(resolve => {
      if (!file || !file.type.startsWith("image/")) return resolve(null);
      const reader = new FileReader();
      reader.onload = () => resolve(reader.result || null);
      reader.onerror = () => resolve(null);
      if (file.type === "image/svg+xml") reader.readAsText(file);
      else reader.readAsDataURL(file);
    });
  }
  function setIconField(v) {
    const stack = editForm?.querySelector("[data-icon-stack]");
    if (stack?.__setIconValue) stack.__setIconValue(v || "");
  }

  function openCreateModal(opts = {}) {
    if (!editModal) return;
    if (modalLockedFor !== "__create__") {
      currentChoreId = null;
      editForm.reset();
      setIconField("");
      if (opts.prefillName) setField("name", opts.prefillName);
      selectRewardPill(1);
      setField("reward_pebbles", 1);
      // Intentionally leave starts_on blank — it auto-fills with today
      // when the user picks a recurrence freq OR toggles Single Task on
      // (see ensureStartsOnSet). New chores with no schedule get no
      // implicit date attached.
      setField("starts_on", "");
      setCooldownSeconds(0);
      setPillValue("freq", "never");
      setPillValue("show_on_daily_view", "when_scheduled");
      setPillValue("sharing_mode", "household");
      const oneOffCb = editForm.querySelector('[data-field="one_off"]');
      if (oneOffCb) oneOffCb.checked = !!opts.oneOff;
      syncSingleTask();
      editForm.querySelectorAll('[data-month-day-pane] .md-chip').forEach(c => c.classList.remove("active"));
      editForm.querySelector('[data-month-mode-tabs] [data-month-mode="day-of-month"]')?.click();
      syncFreqRow();
      syncWeekdayChips([]);
      syncWeekdaysHelperHighlight();
      modalLockedFor = "__create__";
    }
    editModal.querySelector('[data-modal-title]').textContent = "Add Chore";
    // No chore exists yet — nothing to pin to Dailies.
    const createPin = editModal.querySelector('[data-edit-pin-toggle]');
    if (createPin) createPin.hidden = true;
    editForm.querySelector('[data-action="archive"]')?.classList.add("hidden");
    editModal.classList.remove("hidden");
    scrollModalToTop(editModal);
    const nameField = editForm.querySelector('[data-field="name"]');
    if (nameField && !nameField.value) { nameField.focus(); nameField.select?.(); }
  }
  function openEditModal(card) {
    if (!editModal) return;
    const id = card.dataset.choreId;
    if (modalLockedFor === id) {
      currentChoreId = id;
      editModal.classList.remove("hidden");
      scrollModalToTop(editModal);
      return;
    }
    const c = ChoreStore.get(parseInt(id, 10));
    if (!c) return;
    currentChoreId = id;
    modalLockedFor = id;
    editModal.querySelector('[data-modal-title]').textContent = "Edit Chore";
    refreshEditModalPin();
    editForm.reset();
    setField("name", c.name);
    setField("short_name", c.short_name === c.name ? "" : c.short_name);
    setIconField(c.icon || "");
    setField("aliases_csv", (c.aliases || []).join(", "));
    setField("notes_template", c.notes_template || "");
    const reward = c.reward_pebbles || 0;
    selectRewardPill(reward);
    setField("reward_pebbles", reward);
    const oneOffCb = editForm.querySelector('[data-field="one_off"]');
    if (oneOffCb) oneOffCb.checked = !!c.one_off;
    setPillValue("sharing_mode", c.sharing_mode || "household");
    setField("assigned_to_user_id", c.assigned_to_user_id || "");
    setPillValue("show_on_daily_view", c.show_on_daily_view || "when_scheduled");
    setCooldownSeconds(c.threshold_seconds || 0);
    setField("starts_on", c.starts_on || "");
    const rec = c.recurrence || {};
    setPillValue("freq", rec.freq || "never");
    syncSingleTask();
    syncFreqRow();
    syncWeekdayChips(rec.by_day || []);
    editForm.querySelectorAll('[data-month-day-pane] .md-chip').forEach(c => c.classList.remove("active"));
    if (rec.freq === "monthly") {
      if (rec.by_set_pos != null) {
        editForm.querySelector('[data-month-mode-tabs] [data-month-mode="nth-weekday"]')?.click();
        const setPos = editForm.querySelector('[data-month-set-pos]');
        if (setPos) { setPos.value = String(rec.by_set_pos); setPos.dataset.userTouched = "1"; }
        const wday = editForm.querySelector('[data-month-wday]');
        if (wday && rec.by_day?.[0]) { wday.value = rec.by_day[0]; wday.dataset.userTouched = "1"; }
      } else {
        editForm.querySelector('[data-month-mode-tabs] [data-month-mode="day-of-month"]')?.click();
        Array.isArray(rec.by_month_day) && rec.by_month_day.forEach(d => {
          editForm.querySelector(`[data-month-day-pane] [data-day="${d}"]`)?.classList.add("active");
        });
      }
    }
