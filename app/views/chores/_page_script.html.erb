        const res = id
          ? await api(`/chores/streak_bonuses/${id}`, "PATCH", payload)
          : await api("/chores/streak_bonuses", "POST", payload);
        if (streakBonusCards && res?.html) {
          const existing = streakBonusCards.querySelector(`[data-streak-bonus-id="${res.id}"]`);
          if (existing) existing.outerHTML = res.html;
          else streakBonusCards.insertAdjacentHTML("beforeend", res.html);
