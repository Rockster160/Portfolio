  // Hydrate the Balance page's "Recent History" block. Per the
  // architecture spec: NEVER cached — every visit, every broadcast,
  // every refocus dumps the current content, shows a spinner, and
  // fetches fresh. Stale rows are worse here than a brief spinner
  // because this list is audit-style and people use it to verify
  // their balance.
  function renderRecentHistory(data) {
    const container = document.querySelector("[data-recent-history]");
    if (!container) return;
    const cta = document.querySelector("[data-recent-history-cta]");
    const entries = Array.isArray(data?.entries) ? data.entries : [];
    if (entries.length === 0) {
      container.innerHTML = `<div class="history-row"><span class="dim">No recent activity.</span></div>`;
      if (cta) cta.setAttribute("hidden", "");
      return;
    }
    container.innerHTML = entries.map(recentHistoryRowHTML).join("");
    if (cta) cta.removeAttribute("hidden");
    // Header pill is ALWAYS today_earnings — never balance.
    if (data.today_earnings != null) setTodayEarnings(data.today_earnings);
    if (data.balance != null) setLifetimeBalance(data.balance);
  }
  function showRecentHistorySpinner() {
    const container = document.querySelector("[data-recent-history]");
    if (!container) return;
    container.innerHTML = `<div class="history-row history-loading"><i class="fa fa-spinner fa-pulse"></i> <span class="dim">Loading recent history…</span></div>`;
  }
  async function hydrateRecentHistory() {
    const container = document.querySelector("[data-recent-history]");
    if (!container) return;
    showRecentHistorySpinner();
    try {
      const data = await api("/chores/recent_history", "GET");
      renderRecentHistory(data);
    } catch (e) {
      container.innerHTML = `<div class="history-row history-loading"><span class="dim">Offline — recent history will load when you're back.</span></div>`;
    }
  }
  function recentHistoryRowHTML(entry) {
    if (entry.kind === "completion") {
      const amt = entry.payout_skipped
        ? `<span style="color:#9CA3AF;">(skipped)</span>`
        : `<span style="color:#34D399;">+${formatCount(entry.paid_pebbles)}p</span>`;
      const note = entry.note ?
        `<span class="history-note">— ${esc(truncate(entry.note, 120))}</span>` : "";
      const hotPill = (entry.hot_multiplier > 1) ?
        `<span class="history-mult hot">Hot ${esc(formatMultiplier(entry.hot_multiplier))}×</span>` : "";
      const streakPill = (entry.streak_multiplier > 1) ?
        `<span class="history-mult streak">Streak ${esc(formatMultiplier(entry.streak_multiplier))}×</span>` : "";
      return `
        <div class="history-row">
          <span>
            ${esc(entry.when_label)} ·
            <span class="history-icon">${recentIconHTML(entry.chore)}</span>
            <strong>${esc(entry.chore.short_name || entry.chore.name)}</strong>
            ${hotPill}
            ${streakPill}
            ${note}
          </span>
          ${amt}
        </div>`;
    }
    if (entry.kind === "transfer") {
      // Outgoing reads "Sent to <name>" with a red minus; incoming
      // reads "From <name>" with a green plus. Same icon + colour
      // palette as withdrawals on the loss side so the at-a-glance
      // scan stays consistent.
      const outgoing = entry.direction === "outgoing";
      const peer = entry.counterparty_username || "someone";
      const verb = outgoing ? `Sent to ${peer}` : `From ${peer}`;
      const sign = outgoing ? "−" : "+";
      const colour = outgoing ? "#FCA5A5" : "#34D399";
      const note = entry.note ?
        `<span class="history-note">— ${esc(truncate(entry.note, 120))}</span>` : "";
      return `
        <div class="history-row">
          <span>
            ${esc(entry.when_label)} ·
            🤝 <strong>${esc(verb)}</strong>
            ${note}
          </span>
          <span style="color:${colour};">${sign}${formatCount(entry.amount_pebbles)}p</span>
        </div>`;
    }
    const note = entry.note ?
      `<span class="history-note">— ${esc(truncate(entry.note, 120))}</span>` : "";
    return `
      <div class="history-row">
        <span>
          ${esc(entry.when_label)} ·
          🪙 <strong>Withdraw</strong>
          ${note}
        </span>
        <span style="color:#FCA5A5;">−${formatCount(entry.amount_pebbles)}p</span>
      </div>`;
  }
  function recentIconHTML(chore) {
    const v = (chore.icon || "").trim();
    const kind = chore.icon_kind;
    if (!v || kind === "empty") return `<span class="icon-placeholder">🧹</span>`;
    if (kind === "image")   return `<img class="icon-img" src="${esc(v)}" alt="" loading="lazy">`;
    if (kind === "svg")     return v;
    if (kind === "ti_icon") return `<i class="ti ${esc(v)} icon-ti" aria-hidden="true"></i>`;
    return `<span class="icon-glyph">${esc(v)}</span>`;
  }
  function truncate(s, n) { return s.length > n ? s.slice(0, n - 3) + "..." : s; }
  if (root?.dataset.mode === "balance") {
    // Recent History loads ONCE per page navigation, then stays
    // static. Live-update triggers (Monitor broadcast, focus, online)
    // were too aggressive: people noticed re-renders happening
    // mid-keystroke while typing a withdrawal note. The reload
    // button next to the heading is the explicit refresh path.
    hydrateRecentHistory();
    document.querySelector("[data-recent-history-reload]")
      ?.addEventListener("click", () => hydrateRecentHistory());
  }

  document.querySelector("[data-withdraw-form]")?.addEventListener("submit", async e => {
    e.preventDefault();
    const form = e.target;
    const submitBtn = form.querySelector('button[type="submit"]');
    const fd = new FormData(form);
    const entries = Object.fromEntries(fd.entries());
    const amount = parseInt(entries.amount_pebbles, 10);
    if (Number.isNaN(amount) || amount <= 0) { flash("Enter a positive amount", "warn"); return; }
    await withSavingState(submitBtn, async () => {
      try {
        const data = await api("/chores/withdrawals", "POST", { chore_withdrawal: entries });
        flash(`Withdrew ${formatCount(data.amount_pebbles)}p`);
        // Apply the server's new totals directly (header pill +
        // lifetime card) and refresh the Recent History block so the
        // new row shows up — no full page reload, no auto-refresh.
        // This is the one trigger besides navigation + the manual
        // reload button that's allowed to refetch the history.
        if (data.balance != null) setLifetimeBalance(data.balance);
        if (data.today_earnings != null) setTodayEarnings(data.today_earnings);
        reconcileGoalsFromPayload(data);
        form.reset();
        hydrateRecentHistory();
      } catch (err) { flash("Withdraw failed: " + err.message, "error"); }
    });
  });

  document.querySelector("[data-transfer-form]")?.addEventListener("submit", async e => {
    e.preventDefault();
    const form = e.target;
    const submitBtn = form.querySelector('button[type="submit"]');
    const fd = new FormData(form);
    const entries = Object.fromEntries(fd.entries());
    const amount = parseInt(entries.amount_pebbles, 10);
    if (Number.isNaN(amount) || amount <= 0) { flash("Enter a positive amount", "warn"); return; }
    if (!entries.to_user_id) { flash("Pick a recipient", "warn"); return; }
    await withSavingState(submitBtn, async () => {
      try {
        const data = await api("/chores/transfers", "POST", { chore_transfer: entries });
        const recipientLabel = form.querySelector(`[name="to_user_id"] option[value="${entries.to_user_id}"]`)?.textContent?.trim() || "recipient";
        flash(`Transferred ${formatCount(data.amount_pebbles)}p to ${recipientLabel}`);
        if (data.balance != null) setLifetimeBalance(data.balance);
        if (data.today_earnings != null) setTodayEarnings(data.today_earnings);
        reconcileGoalsFromPayload(data);
        // Reset amount + note but leave the recipient pinned — the
        // common pattern is multiple transfers to the same person.
        form.querySelector('[name="amount_pebbles"]').value = "";
        form.querySelector('[name="note"]').value = "";
        hydrateRecentHistory();
      } catch (err) { flash("Transfer failed: " + err.message, "error"); }
    });
  });

  // ============================================================
  // connection + offline queue
  // ============================================================
  const QUEUE_KEY = "chores:offline_queue:v2";
  let queueCsrf = CSRF;
  let queueBlockedReason = null;
  function loadQueue() { try { return JSON.parse(localStorage.getItem(QUEUE_KEY) || "[]"); } catch (e) { return []; } }
  function saveQueue(q) { localStorage.setItem(QUEUE_KEY, JSON.stringify(q)); }
  function enqueue(item) {
    const q = loadQueue();
    item.queued_at = item.queued_at || new Date().toISOString();
    q.push(item);
    saveQueue(q);
    updatePendingBadge(q.length);
  }
  function updatePendingBadge(n) {
    const el = document.querySelector("[data-pending-badge]");
    if (!el) return;
    if (n > 0) {
      el.textContent = queueBlockedReason ? `${n} pending · ${queueBlockedReason}` : `${n} pending`;
      el.classList.remove("hidden");
      el.classList.toggle("blocked", !!queueBlockedReason);
    } else {
      el.classList.add("hidden");
      el.classList.remove("blocked");
    }
  }
  function setConnDot(state) {
    const dot = document.querySelector("[data-conn-dot]");
    if (!dot) return;
    dot.classList.remove("offline", "syncing");
    if (state === "offline") dot.classList.add("offline");
    if (state === "syncing") dot.classList.add("syncing");
    dot.title = state === "offline" ? "Offline" : state === "syncing" ? "Syncing..." : "Online";
  }
  async function refreshCsrf() {
    try {
      const res = await fetch("/chores/csrf", { credentials: "same-origin", headers: { Accept: "application/json" }, redirect: "manual" });
      if (!res.ok) return null;
      const data = await res.json();
      if (data?.token) {
        queueCsrf = data.token;
        const meta = document.querySelector('meta[name="csrf-token"]');
        if (meta) meta.content = data.token;
        return data.token;
      }
    } catch (e) {}
    return null;
  }
  async function postQueueItem(item, csrf) {
    return fetch(item.url, {
      method: item.method, credentials: "same-origin",
      headers: { "Content-Type": "application/json", "Accept": "application/json", "X-CSRF-Token": csrf },
      body: item.body ? JSON.stringify(item.body) : undefined,
      redirect: "manual",
    });
  }
  function classify(res) {
    if (!res) return "keep";
    if (res.ok) return "ok";
    if (res.type === "opaqueredirect" || res.status === 0) return "auth_needed";
    if (res.status === 401 || res.status === 403) return "auth_needed";
    if (res.status === 422) return "csrf_stale";
    // 429 (rate-limit) and 5xx — keep + back off. Source of 429 is
    // unclear (not our Rails app — likely a CDN/proxy), but the
    // contract is the same: try later, don't drop the user's tap.
    if (res.status === 429 || (res.status >= 500 && res.status <= 599)) return "keep";
    return "keep";
  }
  async function flushQueue() {
    let q = loadQueue();
    if (!q.length) { queueBlockedReason = null; setConnDot("online"); updatePendingBadge(0); return; }
    if (!navigator.onLine) { setConnDot("offline"); return; }
    if (reloadPending) { updatePendingBadge(q.length); return; }
    // History view: the user is editing/triaging pending items. Do
    // NOT send them while they're being curated — they'd race the
    // user. Monitor still subscribes (so live updates flow into the
    // store), but outbound flushes are paused until they navigate
    // away. The next page load (or focus event) will resume.
    if (root?.dataset.mode === "history") {
      setConnDot(navigator.onLine ? "online" : "offline");
      updatePendingBadge(q.length);
      return;
    }
    setConnDot("syncing");
    queueBlockedReason = null;
    let csrf = queueCsrf;
    let csrfRefreshedThisFlush = false;
    const remaining = [];
    let halted = false;
    for (let i = 0; i < q.length; i++) {
      const item = q[i];
      if (halted) { remaining.push(item); continue; }
      let res;
      try { res = await postQueueItem(item, csrf); }
      catch (e) { remaining.push(...q.slice(i)); halted = true; setConnDot("offline"); break; }
      let action = classify(res);
      if (action === "csrf_stale" && !csrfRefreshedThisFlush) {
        const fresh = await refreshCsrf();
        csrfRefreshedThisFlush = true;
        if (fresh) {
          csrf = fresh;
          try { res = await postQueueItem(item, csrf); action = classify(res); }
          catch (e) { remaining.push(...q.slice(i)); halted = true; setConnDot("offline"); break; }
        } else { action = "auth_needed"; }
      }
      if (action === "ok") {
        try {
          const data = await res.json();
          if (data) reconcile(data);
        } catch (e) {}
        continue;
      }
      if (action === "auth_needed") {
        remaining.push(...q.slice(i));
        queueBlockedReason = "needs re-auth";
        halted = true;
        flash("Sign-in expired — your changes are saved and will sync after you sign back in.", "warn");
        break;
      }
      remaining.push(item);
    }
    saveQueue(remaining);
    updatePendingBadge(remaining.length);
    setConnDot(remaining.length === 0 ? "online" : (queueBlockedReason ? "offline" : "syncing"));
    if (remaining.length === 0) queueBlockedReason = null;
    // Any leftover items (transient errors, not auth-blocked) get a
    // back-off retry — covers the 429 case where the rate-limiter
    // needs a moment.
    if (remaining.length > 0 && !queueBlockedReason) scheduleQueueRetry();
  }
  window.addEventListener("online", () => { setConnDot("syncing"); flushQueue(); });
  window.addEventListener("offline", () => setConnDot("offline"));
  updatePendingBadge(loadQueue().length);
  if (!navigator.onLine) setConnDot("offline");

  // ============================================================
  // sw + monitor
  // ============================================================
  function pingSwRefresh() {
    if (!navigator.onLine || reloadPending) return;
    navigator.serviceWorker?.controller?.postMessage({ action: "refresh_shells" });
  }
  function subscribeMonitor() {
    if (typeof window.Monitor === "undefined") { setTimeout(subscribeMonitor, 200); return; }
    window.Monitor.subscribe("chores", {
      connected() { setConnDot("online"); flushQueue(); pingSwRefresh(); if (unifiedPage) fullSync(); broadcastRemoteChange("connected"); },
      disconnected() { setConnDot("offline"); },
      received(data) {
        pingSwRefresh();
        const payload = data?.data || {};
        const actorTab = payload.actor_tab_id;
        if (payload.reason === "order_changed") {
          if (actorTab && String(actorTab) === TAB_ID) return;
          if (Array.isArray(payload.ids)) applyOrderToDom(payload.ids);
          return;
        }
        if (payload.reason === "dailies_changed") {
          // Personal broadcast: only this user's other tabs care. Apply
          // the new ordered set; renderDailies/renderOverdue refresh
          // both sections in place.
          if (actorTab && String(actorTab) === TAB_ID) return;
          if (Array.isArray(payload.daily_ids)) ChoreStore.setDailyIds(payload.daily_ids);
          return;
        }
        if (actorTab && String(actorTab) === TAB_ID) return;
        // Hot picks rotation creates chore_hot_picks rows but doesn't
        // bump chore.updated_at or completion timestamps, so a diff
        // sync (since=last) returns nothing and the strip stays empty.
        // Force a full sync so today's picks are pulled fresh.
        if (payload.reason === "hot_picks_refreshed") {
          if (unifiedPage) fullSync({ force: true });
          broadcastRemoteChange("monitor", payload);
          return;
        }
        // Cheap: just re-fetch the chore that changed.
        const choreId = payload.chore_id;
        if (choreId && unifiedPage) {
          api(`/chores/items/${choreId}/state`, "GET").then(reconcile).catch(() => {});
        } else if (unifiedPage) {
          fullSync();
        }
        // Notify off-screen views so the History or Balance content
        // refetches in place. Per spec: History + Balance recent rows
        // are NEVER cached client-side — they always reload fresh on
        // visit and on broadcast. The "data already there" guarantee
        // applies to chores (ChoreStore / store-driven views), not to
        // the audit-style history feeds.
        broadcastRemoteChange("monitor", payload);
      },
    });
  }

  function broadcastRemoteChange(reason, payload) {
    window.dispatchEvent(new CustomEvent("chores:remote_change", {
      detail: { reason, payload: payload || null, at: Date.now() },
    }));
  }
  // Resync on every focus regardless of which chores view is mounted.
  // Closing/reopening the app, alt-tabbing back, returning from a
  // sleep — each lands on a visible page that needs fresh data.
  document.addEventListener("visibilitychange", () => {
    if (document.visibilityState === "visible") {
      pingSwRefresh();
      if (unifiedPage) fullSync();
    }
  });
  // Tracked at boot so a controllerchange can be classified as
  // "deploy update" (was-controlled → now-controlled-by-new-SW) vs
  // "first install" (uncontrolled → controlled). Only the former
  // means the running JS is now behind what's cached.
  const wasControlledAtLoad = !!navigator.serviceWorker?.controller;
  let reloadPending = false;
  let verificationInFlight = false;
  let verificationRetryArmed = false;
  function performReload() { location.reload(); }
  function requestReloadVerification() {
    if (reloadPending || verificationInFlight) return;
    const ctrl = navigator.serviceWorker?.controller;
    if (!ctrl) { armVerificationRetry(); return; }
    verificationInFlight = true;
    const channel = new MessageChannel();
    let settled = false;
    const finish = (ok) => {
      if (settled) return;
      settled = true;
      verificationInFlight = false;
      try { channel.port1.close(); } catch (e) {}
      if (ok) showReloadPending();
      else armVerificationRetry();
    };
    channel.port1.onmessage = (evt) => finish(!!evt.data?.ok);
    // Belt-and-suspenders: if the SW never responds (uncaught throw,
    // gone), don't deadlock the verification flag — retry on next focus.
    setTimeout(() => finish(false), 10000);
    try { ctrl.postMessage({ action: "verify_ready" }, [channel.port2]); }
    catch (e) { finish(false); }
  }
  function armVerificationRetry() {
    if (verificationRetryArmed || reloadPending) return;
    verificationRetryArmed = true;
    const onVisible = () => {
      if (document.visibilityState !== "visible") return;
      document.removeEventListener("visibilitychange", onVisible);
      verificationRetryArmed = false;
      requestReloadVerification();
    };
    document.addEventListener("visibilitychange", onVisible);
  }
  function showReloadPending() {
    if (reloadPending) return;
    reloadPending = true;
    const btn = document.querySelector("[data-reload-pending]");
    if (btn) {
      btn.classList.remove("hidden");
      btn.addEventListener("click", performReload);
    }
    // Drop the live status — the page is frozen against a stale shell.
    setSyncBadge(false);
    setConnDot("online");
    // Cancel any in-flight back-off so a queued retry doesn't fire
    // during the wait. Pending writes survive in localStorage and flush
    // on the next boot under the new SW.
    if (queueRetryTimer) { clearTimeout(queueRetryTimer); queueRetryTimer = null; }
  }
  if ("serviceWorker" in navigator) {
    navigator.serviceWorker
      .register("/chores_worker.js", { scope: "/chores", updateViaCache: "none" })
      .then(reg => reg.update())
      .catch(e => console.warn("Chores SW register failed:", e));
    // A new SW claiming control mid-session means a deploy shipped:
    // the cached shell + assets are now ahead of what this tab is
    // running. Don't show the indicator yet — ask the new SW to
    // verify EVERY shell + EVERY referenced asset is present in the
    // cache first. Only on a clean verification do we expose the
    // reload button. This guarantees the user can never tap reload
    // and land on a half-cached deploy (missing CSS/JS → black
    // screen). First-time install (uncontrolled → controlled) is
    // excluded — nothing is stale yet.
    navigator.serviceWorker.addEventListener("controllerchange", () => {
      if (wasControlledAtLoad) requestReloadVerification();
    });
    // Subtle "vNN" badge of the active SW's cache name. ALWAYS
    // displays the last-known version, even when the worker is
    // momentarily unreachable or the page is uncontrolled — that's the
    // whole signal: "this tab is still running on vNN; if the worker
    // has moved on, the badge will go .stale and you know the page
    // itself is behind." Cleared from stale only by an actual
    // broadcast from the active SW; we use broadcast rather than a
    // transferred MessagePort because port-based replies from a SW
    // silently drop in some iOS PWA contexts.
    const SW_VERSION_KEY = "chores:sw_version:v1";
    function paintSwVersion(v, stale) {
      const el = document.querySelector("[data-sw-version]");
      if (!el) return;
      el.textContent = v || "—";
      el.classList.toggle("stale", !!stale && !!v);
    }
    paintSwVersion(localStorage.getItem(SW_VERSION_KEY), true);
    function requestSwVersion() {
      const ctrl = navigator.serviceWorker.controller;
      if (!ctrl) return;
      try { ctrl.postMessage({ action: "get_version" }); } catch (e) {}
    }
    navigator.serviceWorker.addEventListener("message", evt => {
      if (evt.data?.kind === "shell_synced") setSyncBadge(false);
      if (evt.data?.kind === "shell_sync_failed") setSyncBadge(false, true);
      if (evt.data?.kind === "sw_version" && evt.data?.cache) {
        const v = String(evt.data.cache).replace(/^chores-/, "");
        localStorage.setItem(SW_VERSION_KEY, v);
        paintSwVersion(v, false);
      }
    });
    requestSwVersion();
    navigator.serviceWorker.addEventListener("controllerchange", requestSwVersion);
  }
  setSyncBadge(true);
  function setSyncBadge(syncing, failed = false) {
    const dot = document.querySelector("[data-conn-dot]");
    if (!dot) return;
    dot.classList.remove("syncing", "offline");
    if (syncing) dot.classList.add("syncing");
    if (failed) dot.classList.add("offline");
    dot.title = syncing ? "Syncing..." : failed ? "Offline — using cached data" : "Up to date";
  }

  // ============================================================
  // view toggle (Grid ↔ Today) — pushState, no navigation
  // ============================================================
  function setActiveView(view, { push = true } = {}) {
    if (!unifiedPage) return;
    if (!["grid", "today"].includes(view)) view = "grid";
    if (MODE === view && root.dataset.activeView === view) return;
    MODE = view;
    root.dataset.activeView = view;
    if (push) {
      const url = view === "today" ? "/chores/today" : "/chores";
      if (location.pathname !== url) history.pushState({ view }, "", url);
    }
    document.title = view === "today" ? "Chores · Today" : "Chores";
    document.querySelectorAll(".chores-nav a").forEach(a => {
      const href = a.getAttribute("href");
      if (href === "/chores" || href === "/chores/today") {
        a.classList.toggle("active", href === (view === "today" ? "/chores/today" : "/chores"));
      }
    });
  }
  if (unifiedPage) {
    document.querySelectorAll(".chores-nav a").forEach(link => {
      const href = link.getAttribute("href");
      if (href === "/chores")            link.addEventListener("click", e => { e.preventDefault(); setActiveView("grid"); });
      else if (href === "/chores/today") link.addEventListener("click", e => { e.preventDefault(); setActiveView("today"); });
    });
    window.addEventListener("popstate", () => {
      const path = location.pathname;
      if (path === "/chores")            setActiveView("grid",  { push: false });
      else if (path === "/chores/today") setActiveView("today", { push: false });
    });
  }

  // ============================================================
  // boot
  // ============================================================
  if (unifiedPage) {
    // Order matters: hydrate from localStorage FIRST so we have a
    // baseline even when the inline bootstrap JSON is empty (cached
    // shell that was rendered during an error, fresh-installed PWA
    // with no network, etc). Then merge the inline shell — which
    // wins on any chore it contains because bootstrap is additive
    // and per-chore updated_at gates overwrites in `upsert`.
    // Net effect: a stale-empty shell can never blank the UI; the
    // worst-case is "we already had these chores and we still do."
    ChoreStore.hydrateFromLocal();
    // INVARIANT: the bootstrap chore list IS the canonical accessible
    // set for this viewer. Anything in our local cache that isn't in
    // it has either been archived or become inaccessible (assignment
    // change, household change), and should be dropped — server-side
    // queries like the reorder controller's `accessible_chores` will
    // silently ignore them too. ONE caveat: an empty list is NEVER
    // valid. A real existing user always has *something* (otherwise
    // they wouldn't be looking at this page), so empty payloads can
    // only come from a stale cached shell, a render error, or a parse
    // failure. Treat empty as untrusted and skip the prune.
    if (Array.isArray(bootstrap.chores) && bootstrap.chores.length > 0) {
      const activeIds = new Set(bootstrap.chores.map(c => c.id));
      ChoreStore.all().forEach(c => {
        if (!activeIds.has(c.id)) ChoreStore.remove(c.id);
      });
    }
    ChoreStore.bootstrap(bootstrap.chores, bootstrap.lookahead, bootstrap.daily_ids);
    if (bootstrap.day_key) localStorage.setItem(SYNC_DAY_KEY, bootstrap.day_key);
    // Persist server_ts only when the cached HTML is from today;
    // otherwise the next sync's incremental `since=` would skip the
    // full reset the day rollover needs.
    const cachedDay = bootstrap.day_key;
    const localDay  = currentChoreDayIso();
    if (bootstrap.server_ts && cachedDay && cachedDay === localDay) {
      localStorage.setItem(SYNC_TS_KEY, bootstrap.server_ts);
    } else {
      localStorage.removeItem(SYNC_TS_KEY);
    }
  }
  bindCardClicks();
  bindEditModalPin();
  bindEditModalMarkDue();
  bindEditModalHotRotate();
  bindEditModalAnonymousComplete();
  bindAnonymousCompletionForm();
  bindNotificationSettings();
  bindDailiesSortable();
  startTicker();
  // Day rollover watcher: a tab left open across 4am needs a fresh
  // sync regardless of which chore view is mounted. The store updates
  // either way so navigating to Grid/Today post-rollover never paints
  // yesterday's hot picks. Cheap (one Date compare per minute).
  let watchedDay = currentChoreDayIso();
  setInterval(() => {
    const now = currentChoreDayIso();
    if (now !== watchedDay) {
      watchedDay = now;
      fullSync({ force: true });
    }
  }, 60 * 1000);
  subscribeMonitor();
  flushQueue();
  // Only the Grid/Today views read the chores store, so only those
  // need the fullSync round-trip on boot. Skipping it on Balance/
  // History eliminates a heavy /chores/sync hit that those pages
  // never display, making navigation to them noticeably faster.
  // Grid/Today still resync on their own boot, so navigating in from
  // those pages sees fresh data.
  if (unifiedPage) fullSync();
  pingSwRefresh();
  // Reconnect after offline: re-sync the chores store, re-ping the
  // shell cache. Monitor's `connected` callback also fires fullSync
  // when the WS reattaches; running both is cheap (fullSync no-ops
  // if one is in flight) and covers the case where the WS lags the
  // window `online` event.
  window.addEventListener("online", () => { if (unifiedPage) fullSync(); pingSwRefresh(); });
  if (unifiedPage) {
    setActiveView(MODE, { push: false });
  }
</script>
