      // distribution. Wider ranges → pieces cover most of the
      // screen. Left-launched pieces with dx up to 0.85 vw fly all
      // the way across; combined with right-launched pieces there's
      // coverage across the full width, with peak density near
      // center-top.
      const vyPeak = -(0.50 + Math.random() * 0.40) * vh;
      const dx = (0.20 + Math.random() * 0.65) * vw * (fromLeft ? 1 : -1);

      // Longer than a projectile arc: since the descent phase is
      // constant-velocity terminal drift and the fall distance is
      // ~85% of vh, a 4.5–6s duration keeps the drift rate in
      // paper-drift territory rather than plummeting.
      const duration = `${(4.5 + Math.random() * 1.5).toFixed(2)}s`;
      const delay = `${(Math.random() * 0.15).toFixed(2)}s`;
      x.style.setProperty("--dx", `${dx.toFixed(1)}px`);
      x.style.animationDuration = duration;
      x.style.animationDelay = delay;
      y.style.setProperty("--vy-peak", `${vyPeak.toFixed(1)}px`);
      y.style.animationDuration = duration;
      y.style.animationDelay = delay;
      r.style.setProperty("--rot", `${(Math.random() * 720 - 360).toFixed(0)}deg`);
      r.style.animationDuration = duration;
      r.style.animationDelay = delay;
      overlay.appendChild(x);
    }

    if (supportsPopover) {
      try { overlay.showPopover(); } catch (_) { /* already open / detached */ }
    }
    setTimeout(() => {
      try { if (supportsPopover) overlay.hidePopover(); } catch (_) { /* noop */ }
      overlay.remove();
    }, 6500);
  }
  window.showChoresConfetti = showConfetti;

  // ============================================================
  // sw + monitor
  // ============================================================
  // Shell refresh is a deploy-catching mechanism: it re-fetches every
  // /chores/* HTML shell and warms their assets. That's expensive
  // (one HTTP round-trip per shell plus every asset it references),
  // so it must NEVER fire per-broadcast — otherwise a household's
  // chore taps fan out into a request storm large enough to trip the
  // per-IP rate limit for every user on that IP. Throttle here caps
  // it to at most once per interval, regardless of caller.
  const SW_REFRESH_MIN_INTERVAL_MS = 5 * 60 * 1000;
  let lastSwRefreshAt = 0;
  function pingSwRefresh({ force = false } = {}) {
    if (!navigator.onLine || reloadPending) return;
    const now = Date.now();
    if (!force && now - lastSwRefreshAt < SW_REFRESH_MIN_INTERVAL_MS) return;
    lastSwRefreshAt = now;
    navigator.serviceWorker?.controller?.postMessage({ action: "refresh_shells" });
  }
  function subscribeMonitor() {
    if (typeof window.Monitor === "undefined") { setTimeout(subscribeMonitor, 200); return; }
    window.Monitor.subscribe("chores", {
      connected() {
        setConnDot("online");
        if (queueRetryTimer) { clearTimeout(queueRetryTimer); queueRetryTimer = null; }
        queueRetryDelay = 2000;
        flushQueue();
        pingSwRefresh();
        if (unifiedPage) fullSync();
        IconPool.syncCustomIfChanged();
        broadcastRemoteChange("connected");
      },
      disconnected() { setConnDot("offline"); },
      received(data) {
        // pingSwRefresh() intentionally NOT called here. Chore-data
        // broadcasts have no bearing on shell HTML freshness — the SW
        // catches deploys via connected() / visibilitychange only.
        // Prior code fanned out a 4-shell refresh per broadcast, which
        // is what tipped households into per-IP rate limits.
        const payload = data?.data || {};
        const actorTab = payload.actor_tab_id;
        // Goal-achieved: fire on every session for this user, including
        // the actor's own tab. Do NOT gate on actor_tab_id — the user
        // who hit the goal should see the celebration too. Confetti is
        // decoration; downstream refresh still runs via the general
        // ChoreBroadcaster fan-out that follows completion/withdrawal.
        if (payload.reason === "goal_achieved") {
          showConfetti();
          return;
        }
        if (payload.reason === "order_changed") {
          if (actorTab && String(actorTab) === TAB_ID) return;
          if (Array.isArray(payload.ids)) applyOrderToDom(payload.ids);
          return;
        }
        if (payload.reason === "dailies_changed") {
          // Personal broadcast: only this user's other tabs care. Apply
          // the new ordered set; renderDailies/renderOverdue refresh
          // both sections in place.
          if (actorTab && String(actorTab) === TAB_ID) return;
          if (Array.isArray(payload.daily_ids)) ChoreStore.setDailyIds(payload.daily_ids);
          return;
        }
        if (payload.reason === "icons_changed") {
          // Fired by HouseholdIconsController on create/update/destroy.
          // Refresh the picker's custom pool so remote uploads/renames
          // land immediately on this tab.
          if (actorTab && String(actorTab) === TAB_ID) return;
          IconPool.refreshCustom();
          return;
        }
        if (actorTab && String(actorTab) === TAB_ID) return;
        // Hot picks rotation creates chore_hot_picks rows but doesn't
        // bump chore.updated_at or completion timestamps, so a diff
        // sync (since=last) returns nothing and the strip stays empty.
        // Force a full sync so today's picks are pulled fresh.
        if (payload.reason === "hot_picks_refreshed") {
          if (unifiedPage) fullSync({ force: true });
          broadcastRemoteChange("monitor", payload);
          return;
        }
        // Cheap: re-fetch the changed chores in one shot. A sub-chore
        // tap coalesces parent + sub into one broadcast carrying both
        // ids — we fetch both in parallel (one broadcast, N cheap
        // state fetches, still no fullSync).
        const idsFromPayload = Array.isArray(payload.chore_ids) && payload.chore_ids.length
          ? payload.chore_ids
          : (payload.chore_id ? [payload.chore_id] : []);
        if (idsFromPayload.length && unifiedPage) {
          idsFromPayload.forEach(id => {
            api(`/chores/items/${id}/state`, "GET").then(reconcile).catch(() => {});
          });
        } else if (unifiedPage) {
          fullSync();
        }
        // Notify off-screen views so the History or Balance content
        // refetches in place. Per spec: History + Balance recent rows
        // are NEVER cached client-side — they always reload fresh on
        // visit and on broadcast. The "data already there" guarantee
        // applies to chores (ChoreStore / store-driven views), not to
        // the audit-style history feeds.
        broadcastRemoteChange("monitor", payload);
      },
    });
  }

  function broadcastRemoteChange(reason, payload) {
    window.dispatchEvent(new CustomEvent("chores:remote_change", {
      detail: { reason, payload: payload || null, at: Date.now() },
    }));
  }
  // Resync on every focus regardless of which chores view is mounted.
  // Closing/reopening the app, alt-tabbing back, returning from a
  // sleep — each lands on a visible page that needs fresh data.
  document.addEventListener("visibilitychange", () => {
    if (document.visibilityState === "visible") {
      pingSwRefresh();
      if (unifiedPage) fullSync();
      // Foreground after backgrounding: if any queue items survive,
      // surface the pending state and try to drain. Covers the
      // canonical "tapped chore on weak signal, walked away from app"
      // case — the in-flight fetch died with the page, but the queue
      // item persists and now flushes.
      onAppWake();
    }
  });
  // Tracked at boot so a controllerchange can be classified as
  // "deploy update" (was-controlled → now-controlled-by-new-SW) vs
  // "first install" (uncontrolled → controlled). Only the former
  // means the running JS is now behind what's cached.
  const wasControlledAtLoad = !!navigator.serviceWorker?.controller;
  let reloadPending = false;
  let verificationInFlight = false;
  let verificationRetryArmed = false;
  function performReload() { location.reload(); }
  function requestReloadVerification() {
    if (reloadPending || verificationInFlight) return;
    const ctrl = navigator.serviceWorker?.controller;
    if (!ctrl) { armVerificationRetry(); return; }
    verificationInFlight = true;
    const channel = new MessageChannel();
    let settled = false;
    const finish = (ok) => {
      if (settled) return;
      settled = true;
      verificationInFlight = false;
      try { channel.port1.close(); } catch (e) {}
      if (ok) showReloadPending();
      else armVerificationRetry();
    };
    channel.port1.onmessage = (evt) => finish(!!evt.data?.ok);
    // Belt-and-suspenders: if the SW never responds (uncaught throw,
    // gone), don't deadlock the verification flag — retry on next focus.
    setTimeout(() => finish(false), 10000);
    try { ctrl.postMessage({ action: "verify_ready" }, [channel.port2]); }
    catch (e) { finish(false); }
  }
  function armVerificationRetry() {
    if (verificationRetryArmed || reloadPending) return;
    verificationRetryArmed = true;
    const onVisible = () => {
      if (document.visibilityState !== "visible") return;
      document.removeEventListener("visibilitychange", onVisible);
      verificationRetryArmed = false;
      requestReloadVerification();
    };
    document.addEventListener("visibilitychange", onVisible);
  }
  function showReloadPending() {
    if (reloadPending) return;
    reloadPending = true;
    const btn = document.querySelector("[data-reload-pending]");
    if (btn) {
      btn.classList.remove("hidden");
      btn.addEventListener("click", performReload);
    }
    // Drop the live status — the page is frozen against a stale shell.
    setSyncBadge(false);
    setConnDot("online");
    // Cancel any in-flight back-off so a queued retry doesn't fire
    // during the wait. Pending writes survive in localStorage and flush
    // on the next boot under the new SW.
    if (queueRetryTimer) { clearTimeout(queueRetryTimer); queueRetryTimer = null; }
  }
  if ("serviceWorker" in navigator) {
    navigator.serviceWorker
      .register("/chores_worker.js", { scope: "/chores", updateViaCache: "none" })
      .then(reg => reg.update())
      .catch(e => console.warn("Chores SW register failed:", e));
    // A new SW claiming control mid-session means a deploy shipped:
    // the cached shell + assets are now ahead of what this tab is
    // running. Don't show the indicator yet — ask the new SW to
    // verify EVERY shell + EVERY referenced asset is present in the
    // cache first. Only on a clean verification do we expose the
    // reload button. This guarantees the user can never tap reload
    // and land on a half-cached deploy (missing CSS/JS → black
    // screen). First-time install (uncontrolled → controlled) is
    // excluded — nothing is stale yet.
    navigator.serviceWorker.addEventListener("controllerchange", () => {
      if (wasControlledAtLoad) requestReloadVerification();
    });
    // Subtle "vNN" badge of the active SW's cache name. ALWAYS
    // displays the last-known version, even when the worker is
    // momentarily unreachable or the page is uncontrolled — that's the
    // whole signal: "this tab is still running on vNN; if the worker
    // has moved on, the badge will go .stale and you know the page
    // itself is behind." Cleared from stale only by an actual
    // broadcast from the active SW; we use broadcast rather than a
    // transferred MessagePort because port-based replies from a SW
    // silently drop in some iOS PWA contexts.
    const SW_VERSION_KEY = "chores:sw_version:v1";
    function paintSwVersion(v, stale) {
      const el = document.querySelector("[data-sw-version]");
      if (!el) return;
      el.textContent = v || "—";
      el.classList.toggle("stale", !!stale && !!v);
    }
    paintSwVersion(localStorage.getItem(SW_VERSION_KEY), true);
    function requestSwVersion() {
      const ctrl = navigator.serviceWorker.controller;
      if (!ctrl) return;
      try { ctrl.postMessage({ action: "get_version" }); } catch (e) {}
    }
    navigator.serviceWorker.addEventListener("message", evt => {
      if (evt.data?.kind === "shell_synced") setSyncBadge(false);
      if (evt.data?.kind === "shell_sync_failed") setSyncBadge(false, true);
      if (evt.data?.kind === "sw_version" && evt.data?.cache) {
        const v = String(evt.data.cache).replace(/^chores-/, "");
        localStorage.setItem(SW_VERSION_KEY, v);
        paintSwVersion(v, false);
      }
    });
    requestSwVersion();
    navigator.serviceWorker.addEventListener("controllerchange", requestSwVersion);
  }
  setSyncBadge(true);
  function setSyncBadge(syncing, failed = false) {
    const dot = document.querySelector("[data-conn-dot]");
    if (!dot) return;
    dot.classList.remove("syncing", "offline");
    if (syncing) dot.classList.add("syncing");
    if (failed) dot.classList.add("offline");
    dot.title = syncing ? "Syncing..." : failed ? "Offline — using cached data" : "Up to date";
  }

  // ============================================================
  // SPA router — Grid ↔ Today ↔ Balance ↔ History, pushState only
  // ============================================================
  // Every /chores/* URL renders the same shell (all four view sections
  // are always in the DOM). Nav is pure DOM toggle + pushState + lazy
  // hydration of per-view data. No page reload, no re-parse of the
  // 6k-line module, no ChoreStore rehydrate.
  const VIEW_PATHS = {
    grid:    "/chores",
    today:   "/chores/today",
    balance: "/chores/balance",
    history: "/chores/history",
  };
  const VIEW_TITLES = {
    grid:    "Chores",
    today:   "Chores · Today",
    balance: "Chores · Balance",
    history: "Chores · History",
  };
  const VALID_VIEWS = Object.keys(VIEW_PATHS);
  function normalizeView(v) { return VALID_VIEWS.includes(v) ? v : "grid"; }
  function viewFromPath(path) {
    if (path.startsWith("/chores/today"))   return "today";
    if (path.startsWith("/chores/balance")) return "balance";
    if (path.startsWith("/chores/history")) return "history";
    return "grid";
  }

  // Balance view hydration — lazy, once per session unless force:true.
  // Uses the /chores/balance_data endpoint which ships pre-rendered
  // goal + streak-bonus card fragments (same partials the mutation
  // responses use) so there's ONE source of truth for that markup.
  let balanceHydrated = false;
  let balanceHydrating = false;
  async function hydrateBalanceView({ force = false } = {}) {
    if (balanceHydrating) return;
    if (balanceHydrated && !force) return;
    balanceHydrating = true;
    try {
      const data = await api("/chores/balance_data", "GET");
      if (!data) return;

      const goalsCards = document.querySelector("[data-goals-cards]");
      // ERB partials are the single source of truth for these card
      // shapes — the server renders them via render_to_string and we
      // splat them in as-is. The rule against JS-string HTML applies
      // to JS-authored markup; server-rendered fragments over the wire
      // are the sanctioned alternative pattern.
      if (goalsCards) goalsCards.innerHTML = data.goals_html || "";
      const goalsEmpty = document.querySelector("[data-goals-empty]");
      if (goalsEmpty) goalsEmpty.style.display = (data.goals_count > 0) ? "none" : "";

      const streakCards = document.querySelector("[data-streak-bonuses-cards]");
      if (streakCards) streakCards.innerHTML = data.streak_bonuses_html || "";
      const streakEmpty = document.querySelector("[data-streak-bonuses-empty]");
      if (streakEmpty) streakEmpty.style.display = (data.streak_bonuses_count > 0) ? "none" : "";

      const transferForm = document.querySelector("[data-transfer-form]");
      const transferEmpty = document.querySelector("[data-transfer-empty]");
      const recipients = data.transfer_recipients || [];
      if (recipients.length > 0) {
        if (transferForm)  transferForm.style.display = "";
        if (transferEmpty) transferEmpty.style.display = "none";
        const sel = transferForm?.querySelector('select[name="to_user_id"]');
        if (sel) {
          sel.replaceChildren();
          recipients.forEach(u => sel.appendChild(new Option(u.username, u.id)));
        }
        const fs = transferForm?.querySelector("[data-transfer-fieldset]");
        if (fs) {
          if (data.transfer_disabled) fs.setAttribute("disabled", "");
          else                        fs.removeAttribute("disabled");
        }
      } else {
        if (transferForm)  transferForm.style.display = "none";
        if (transferEmpty) transferEmpty.style.display = "";
      }

      // Route the balance number through the canonical setters so the
      // localStorage cache + negative-state class stay in step.
      if (data.balance != null) setLifetimeBalance(data.balance);
      if (data.today_earnings != null) setTodayEarnings(data.today_earnings);

      balanceHydrated = true;
      // Recent History widget lives on Balance and has its own once-
      // per-visit fetch; kick it if the container is still showing the
      // loading placeholder.
      hydrateRecentHistory();
    } catch (e) {
      // Silent fail — the empty containers stay visible with the
      // baseline "No goals yet" placeholders. User can retry via
      // navigating away and back, or via any explicit reload button.
    } finally {
      balanceHydrating = false;
    }
  }

  function setActiveView(view, { push = true } = {}) {
    if (!unifiedPage) return;
    view = normalizeView(view);
    const alreadyActive = (MODE === view && root.dataset.activeView === view);
    MODE = view;
    root.dataset.activeView = view;
    if (push) {
      const url = VIEW_PATHS[view];
      if (location.pathname !== url) history.pushState({ view }, "", url);
    }
    document.title = VIEW_TITLES[view];
    document.querySelectorAll(".chores-nav a").forEach(a => {
      const href = a.getAttribute("href") || "";
      // Match by the base path (History carries query params like
      // ?page=2 that shouldn't unset the active state).
      const linkBase = href.split("?")[0];
      a.classList.toggle("active", linkBase === VIEW_PATHS[view]);
    });
    if (alreadyActive) return;
    // Lazy-hydrate per-view data on activation. Grid/Today draw
    // straight from ChoreStore so no fetch is needed — ChoreStore
    // is populated at boot (hydrateFromLocal + fullSync).
    if (view === "balance") hydrateBalanceView();
    else if (view === "history") window.ChoresHistoryView?.hydrate();
  }
  if (unifiedPage) {
    // Intercept in-shell nav links. Any anchor with an href that
    // matches one of the view paths OR that carries data-nav-view
    // becomes a soft nav. External links / same-tab downloads / any
    // click with modifier keys are left alone so the browser handles
    // them normally.
    document.addEventListener("click", e => {
      const link = e.target.closest("a[href]");
      if (!link) return;
      if (e.defaultPrevented) return;
      if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
      if (link.target && link.target !== "" && link.target !== "_self") return;
      const href = link.getAttribute("href");
      if (!href) return;
      const dataView = link.dataset.navView;
      const targetView = dataView || (
        href === VIEW_PATHS.grid    ? "grid" :
        href === VIEW_PATHS.today   ? "today" :
        href === VIEW_PATHS.balance ? "balance" :
        href === VIEW_PATHS.history ? "history" :
        null
      );
      if (!targetView) return;
      e.preventDefault();
      setActiveView(targetView);
    });
    window.addEventListener("popstate", () => {
      setActiveView(viewFromPath(location.pathname), { push: false });
    });
  }

  // ============================================================
  // boot
  // ============================================================
  if (unifiedPage) {
    // The shell is data-free. Hydrate from localStorage and that's it
    // for the synchronous boot — no merge from inline JSON, no prune
    // against shell-shipped data. ChoreStore is updated ONLY by
    // validated /chores/sync responses inside reconcile(). This means:
    //   * A stale or empty shell can never modify localStorage.
    //   * A controller render that ships empty/partial data has no
    //     channel to wipe pins or chores — there's no inline data to
    //     read.
    //   * Empty results from a validated API response ARE authoritative
    //     ("you genuinely have no scheduled chores today") — but that
    //     judgement lives in reconcile/validateSyncPayload, not here.
    // hydrateFromLocal is also safe-by-design: it only fills entries
    // that aren't already in the map, so it can never overwrite a
    // newer in-memory state with stale localStorage.
    ChoreStore.hydrateFromLocal();
    hydrateBalanceFromLocal();
    showColdStartLoaderIfEmpty();
  }
  bindCardClicks();
  bindEditModalPin();
  bindEditModalMarkDue();
  bindEditModalHotRotate();
  bindEditModalAnonymousComplete();
  bindAnonymousCompletionForm();
  bindNotificationSettings();
  startTicker();
  // Day rollover watcher: a tab left open across 4am needs a fresh
  // sync regardless of which chore view is mounted. The store updates
  // either way so navigating to Grid/Today post-rollover never paints
  // yesterday's hot picks. Cheap (one Date compare per minute).
  let watchedDay = currentChoreDayIso();
  setInterval(() => {
    const now = currentChoreDayIso();
    if (now !== watchedDay) {
      watchedDay = now;
      fullSync({ force: true });
    }
  }, 60 * 1000);
  subscribeMonitor();
  flushQueue();
  // Only the Grid/Today views read the chores store, so only those
  // need the fullSync round-trip on boot. Skipping it on Balance/
  // History eliminates a heavy /chores/sync hit that those pages
  // never display, making navigation to them noticeably faster.
  // Grid/Today still resync on their own boot, so navigating in from
  // those pages sees fresh data.
  //
  // `force: true` is critical here: this is the page-load reset
  // point. It pulls the FULL chore set (no `since=`) and reconcile
  // applies it AUTHORITATIVELY — bypassing the updated_at guard so
  // any stuck localStorage from a prior session is overwritten with
  // server truth. Mirrors what the legacy inline-bootstrap merge
  // used to do (server always wins on page load). Without this two
  // devices diverge: each accumulates local edits that incremental
  // sync deltas can't repair.
  if (unifiedPage) fullSync({ force: true });
  pingSwRefresh();
  // Reconnect after offline: re-sync the chores store, re-ping the
  // shell cache. Monitor's `connected` callback also fires fullSync
  // when the WS reattaches; running both is cheap (fullSync no-ops
  // if one is in flight) and covers the case where the WS lags the
  // window `online` event.
  window.addEventListener("online", () => { if (unifiedPage) fullSync(); pingSwRefresh(); });
  if (unifiedPage) {
    setActiveView(MODE, { push: false });
  }

  // ============================================================
  // Cross-partial utility surface. History's inline script (and any
  // future chores partial) consumes utilities from here rather than
  // re-defining them, so there's exactly one implementation of `api`,
  // `flash`, template cloning, icon rendering, etc. Keep this list
  // minimal — expose only what's genuinely shared. New chore views
  // should live inside this same module rather than being separate
  // <script type="module"> islands.
  // ============================================================
  window.ChoresPWA = Object.freeze({
    esc, formatCount, formatMultiplier, truncate,
    api, flash, withSavingState,
    currentCsrf, refreshCsrf,
    cloneTemplate, buildIconNodeFromKind,
    loadQueue, saveQueue,
    QUEUE_KEY,
  });
</script>
