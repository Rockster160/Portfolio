  function readStreakBonusPayload() {
    const fd = new FormData(streakBonusForm);
    const levels = [];
    streakBonusForm.querySelectorAll('.multiplier-level-row').forEach(row => {
      levels.push({
        threshold:     row.querySelector('[name="config[levels][][threshold]"]').value,
        multiplier:    row.querySelector('[name="config[levels][][multiplier]"]').value,
        bonus_pebbles: row.querySelector('[name="config[levels][][bonus_pebbles]"]').value,
      });
    });
    return {
      chore_streak_bonus: {
        name:     fd.get("name"),
        kind:     fd.get("kind"),
        chore_id: fd.get("kind") === "chore_streak" ? fd.get("chore_id") : null,
