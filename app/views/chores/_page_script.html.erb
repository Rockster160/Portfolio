  // never disagree. `data-chore-id` lives on every render of a chore
  // (main grid card + hot strip cell child); set the attribute on all
  // so whichever surface the user is viewing shows the indicator.
  function renderPerCardPending(loud) {
    const choreIds = new Set();
    loud.forEach(it => { const cid = it.meta?.chore_id; if (cid != null) choreIds.add(String(cid)); });
    document.querySelectorAll("[data-chore-id]").forEach(el => {
      const cid = el.getAttribute("data-chore-id");
