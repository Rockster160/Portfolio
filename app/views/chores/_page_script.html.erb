  function updateStreakBonusKindUI() {
    if (!streakBonusForm) return;
    const k = streakBonusForm.elements["kind"].value;
    const shown = new Set(streakBonusKindFields[k] || []);
    streakBonusForm.querySelectorAll('[data-streak-bonus-field]').forEach(el => {
      el.hidden = !shown.has(el.dataset.streakBonusField);
    });
