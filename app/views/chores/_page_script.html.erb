      const y = document.createElement("div");
      y.className = "confetti-piece-y";
      const r = document.createElement("div");
      r.className = "confetti-piece-r";
      y.appendChild(r);
      x.appendChild(y);

      const fromLeft = Math.random() < 0.5;
      if (fromLeft) x.style.left = `${Math.random() * 40}px`;
      else x.style.right = `${Math.random() * 40}px`;
      x.style.bottom = "0px";
      r.style.background = colors[Math.floor(Math.random() * colors.length)];

      // Aim REGION centered on (50% vw, 10–15% from top) — not a
      // single point. Since X is held constant after 30%, pieces
      // stop wherever they peaked and rain straight down from
