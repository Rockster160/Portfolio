  function addLevelRow(values) {
    if (!levelRowTpl || !streakBonusForm) return;
    const node = levelRowTpl.content.firstElementChild.cloneNode(true);
    if (values) {
      node.querySelector('[name="config[levels][][threshold]"]').value = values.threshold ?? "";
      node.querySelector('[name="config[levels][][multiplier]"]').value = values.multiplier ?? 1;
