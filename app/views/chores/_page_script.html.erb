  });

  // ============================================================
  // Modal dismiss helper (Balance + global)
  // ============================================================
  // closeOnBackdropClick used to fire on any backdrop *click*, but the
  // click event resolves at the lowest common ancestor of mousedown +
  // mouseup. A text-selection drag that began inside the modal but
  // released on the backdrop would therefore fire `click` on the
  // backdrop and dismiss the modal mid-action. Gate dismissal on both
  // pointerdown AND pointerup landing on the backdrop itself.
  function openModal(el) { el?.classList.remove("hidden"); }
  function closeModal(el) { el?.classList.add("hidden"); }
  function wireModalDismiss(modal, opts = {}) {
    if (!modal) return;
    const onCancel   = opts.onCancel   || (() => closeModal(modal));
    const onBackdrop = opts.onBackdrop || (() => closeModal(modal));
    modal.querySelectorAll('[data-action="cancel"]').forEach(b =>
      b.addEventListener("click", onCancel));
    // Backdrop dismissal requires BOTH the pointer-down AND the
    // pointer-up to land on the backdrop itself — anything else (a
    // drag from inside out, a press on the backdrop that ends inside
    // the modal, a text-selection that crosses the edge) is rejected.
    let downOnBackdrop = false;
    let upOnBackdrop = false;
    modal.addEventListener("pointerdown", e => { downOnBackdrop = e.target === modal; });
    modal.addEventListener("pointerup",   e => { upOnBackdrop   = e.target === modal; });
    modal.addEventListener("click", e => {
      if (e.target === modal && downOnBackdrop && upOnBackdrop) onBackdrop();
      downOnBackdrop = false;
      upOnBackdrop = false;
    });
  }
  // Apply the safe dismiss pattern to every modal on the page. The
  // edit-chore and quick-multiplier modals need state-reset callbacks
  // on dismissal — those are bound explicitly below; everything else
  // gets the default "just hide" behavior here.
  const SPECIALIZED_MODAL_SELECTORS = ['[data-chore-modal]', '[data-multiplier-modal]', '[data-note-prompt-modal]'];
  document.querySelectorAll('.chores-modal-backdrop').forEach(m => {
    if (SPECIALIZED_MODAL_SELECTORS.some(sel => m.matches(sel))) return;

    wireModalDismiss(m);
  });

  // Escape → close the top-most open modal. We route through the
  // modal's own cancel button so any per-modal teardown (form reset,
  // cropper state, etc.) runs the same way it does on click.
  document.addEventListener("keydown", e => {
    if (e.key !== "Escape") return;
    const open = Array.from(document.querySelectorAll('.chores-modal-backdrop:not(.hidden)'));
    if (!open.length) return;
    // Top-most = highest z-index; ties resolved by DOM order (last wins).
    const top = open.reduce((a, b) => {
      const az = parseInt(getComputedStyle(a).zIndex, 10) || 0;
      const bz = parseInt(getComputedStyle(b).zIndex, 10) || 0;
      return bz >= az ? b : a;
    });
    e.preventDefault();
    const cancel = top.querySelector('[data-action="cancel"]');
    if (cancel) cancel.click(); else top.classList.add("hidden");
  });

  // ============================================================
  // Goals + Streak Bonuses management (Balance page)
  // ============================================================
  // ---------- Goals (now covers former achievements via kinds) ----------
  const goalModal     = document.querySelector('[data-goal-modal]');
  const goalForm      = goalModal?.querySelector('[data-goal-form]');
  const goalsCards    = document.querySelector('[data-goals-cards]');
  const goalsEmpty    = document.querySelector('[data-goals-empty]');
  bindIconUploader(goalForm); // shared widget — emoji / paste / SVG / file / URL

  // Replace each goal card from a `goals: [{id, html}, ...]` payload.
  // Used by the withdraw / transfer flows so the saved-pebbles goals
  // stay in sync with the balance header after a balance change.
  function reconcileGoalsFromPayload(data) {
    if (!goalsCards || !Array.isArray(data?.goals)) return;
    data.goals.forEach(g => {
      const existing = goalsCards.querySelector(`[data-goal-id="${g.id}"]`);
      if (existing && g.html) existing.outerHTML = g.html;
    });
  }

  // Per-kind config inputs that should be visible in the form. The
  // tracking_mode selector is only meaningful for the pebbles kind.
  const goalKindFields = {
    pebbles:           ["tracking_mode"],
    total_completions: [],
    chore_completions: ["chore_id"],
    chore_streak:      ["chore_id"],
  };
  const goalKindHints = {
    pebbles:           "Count of pebbles earned.",
    total_completions: "Count of all chores completed.",
    chore_completions: "Count of how many times a specific chore is completed.",
    chore_streak:      "Count of the current consecutive-day streak for one specific chore.",
  };
  const goalTargetLabels = {
    pebbles:           "Target pebbles",
    total_completions: "Target completions",
    chore_completions: "Target completions",
    chore_streak:      "Target streak (days)",
  };
  const goalScopeHints = {
    relative:   "Starts at 0. Only counts progress made after this goal was created.",
    cumulative: "Includes everything you've ever earned, even before this goal existed.",
  };
  const goalTrackingHints = {
    saved:   "Reflects the pebbles you actually have. Spending pebbles (withdrawals) lowers progress.",
    earned:  "Counts pebbles as they're earned. Spending pebbles never decreases progress.",
  };
  function updateGoalKindUI() {
    if (!goalForm) return;
    const k = goalForm.elements["kind"].value;
    const shown = new Set(goalKindFields[k] || []);
    goalForm.querySelectorAll('[data-goal-field]').forEach(el => {
      el.hidden = !shown.has(el.dataset.goalField);
    });
    const hint = goalForm.querySelector("[data-goal-kind-hint]");
    if (hint) hint.textContent = goalKindHints[k] || "";
    const targetLabel = goalForm.querySelector("[data-goal-target-label]");
    if (targetLabel) targetLabel.textContent = goalTargetLabels[k] || "Target";
  }
  function updateGoalScopeHint() {
    if (!goalForm) return;
    const v = goalForm.elements["scope_mode"]?.value;
    const hint = goalForm.querySelector("[data-goal-scope-hint]");
    if (hint) hint.textContent = goalScopeHints[v] || "";
  }
  function updateGoalTrackingHint() {
    if (!goalForm) return;
    const v = goalForm.elements["tracking_mode"]?.value;
    const hint = goalForm.querySelector("[data-goal-tracking-hint]");
    if (hint) hint.textContent = goalTrackingHints[v] || "";
  }
  // The scope/tracking pill groups carry their value in a hidden input
  // (set by the shared pill-group click handler in `bindPillGroups`,
  // but that handler is scoped to the chore-edit form). Wire a small
  // delegated click here so taps on the goal-form pills toggle the
  // active class, write the hidden value, and refresh the helper text.
  function setGoalPillValue(group, value) {
    group.querySelectorAll(".pill").forEach(p => {
      p.classList.toggle("active", String(p.dataset.value) === String(value));
    });
    const key = group.dataset.pillGroup;
    const input = goalForm.querySelector(`input[name="${key}"]`);
    if (input) input.value = value;
  }
  goalForm?.querySelectorAll('.pill-group[data-pill-group]').forEach(group => {
    group.addEventListener("click", e => {
      const pill = e.target.closest(".pill");
      if (!pill) return;
      e.preventDefault();
      setGoalPillValue(group, pill.dataset.value);
      if (group.dataset.pillGroup === "scope_mode") updateGoalScopeHint();
      if (group.dataset.pillGroup === "tracking_mode") updateGoalTrackingHint();
    });
  });
  goalForm?.elements["kind"]?.addEventListener("change", updateGoalKindUI);

  function applyGoalPills(scope, tracking) {
    const scopeGroup = goalForm.querySelector('[data-pill-group="scope_mode"]');
    const trackingGroup = goalForm.querySelector('[data-pill-group="tracking_mode"]');
    if (scopeGroup) setGoalPillValue(scopeGroup, scope || "cumulative");
