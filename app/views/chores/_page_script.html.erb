<%# Unified chores page script — JSON-store-driven, no server HTML.
   Architecture:
     * ChoreStore (Map<id, ChoreData>) is the single source of truth.
     * Templates are pure (data → DOM) functions.
     * Views subscribe to store changes and re-render affected cards.
     * Mutations apply optimistic patches, then reconcile with server JSON.
%>
<script>
  window.__currentUserId = <%= current_user.id.to_json.html_safe %>;
</script>
<script type="module">
  // ============================================================
  // bootstrap + constants
  // ============================================================
  const CSRF = document.querySelector('meta[name="csrf-token"]')?.content || "";
  const root = document.querySelector('[data-chores-root]');
  const DAY_KEY = root?.dataset.dayKey || "";
  const CUTOFF_HOUR = parseInt(root?.dataset.cutoffHour || "4", 10);
  const VIEWER_USERNAME = root?.dataset.viewerUsername || "";
  const TAB_ID = (window.crypto?.randomUUID?.() || String(Date.now() + Math.random()));

  // Active view — `data-active-view` only exists on the unified Grid/
  // Today page. Balance and History also include this script for the
  // SW/offline-queue/modal infrastructure but skip view + store logic.
  let MODE = root?.dataset.activeView || "grid";
  const unifiedPage = !!(root && root.dataset.activeView);

  // Bootstrap JSON inline-shipped by the page — instant first paint
  // without a network round-trip.
  let bootstrap = { chores: [], lookahead: {}, daily_ids: [], server_ts: null };
  const bootstrapEl = document.getElementById("chores-bootstrap");
  if (bootstrapEl) {
    try { bootstrap = JSON.parse(bootstrapEl.textContent || "{}"); }
    catch (e) { console.warn("Chores bootstrap JSON parse failed:", e); }
  }

  // localClickTs: per-chore most-recent local click epoch ms. Used to
  // discard server payloads captured before that click — protects
  // optimistic state from being clobbered by a race-stale broadcast or
  // out-of-order POST response.
  const localClickTs = new Map();
  const inFlight = new Set();

  // ============================================================
  // helpers
  // ============================================================
  function esc(s) {
    if (s == null) return "";
    return String(s).replace(/[&<>"']/g, c => (
      { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]
    ));
  }
  function formatMultiplier(n) {
    if (n == null) return "";
    const f = Number(n);
    return f === Math.floor(f) ? String(Math.floor(f)) : String(f);
  }
  // Thousands delimiter for any visible count (balance pill, etc.).
  // Mirrors Rails `number_with_delimiter` in the views so the JS-
  // updated balance never desynces visually from a server-rendered
  // page (1,234p in HTML, 1,234p after applyBalance).
  function formatCount(n) {
    if (n == null) return "";
    const f = Number(n);
    if (!Number.isFinite(f)) return "";
    return f.toLocaleString();
  }
  async function api(url, method, body) {
    const res = await fetch(url, {
      method,
      credentials: "same-origin",
      headers: { "Content-Type": "application/json", "Accept": "application/json", "X-CSRF-Token": CSRF },
      body: body ? JSON.stringify(body) : undefined,
    });
    if (!res.ok) {
      const text = await res.text();
      const err = new Error(`${res.status}: ${text}`);
      err.status = res.status;
      throw err;
    }
    return res.status === 204 ? null : res.json();
  }
  // Anything we should retry rather than surface as a "failed" flash:
  // network errors, 429 (rate-limit), 502/503/504 (upstream). The
  // offline-queue's `classify` already keeps these — this is the
  // direct-mutation path's mirror.
  function isTransientError(err) {
    if (!navigator.onLine) return true;
    if (/Failed to fetch|NetworkError/i.test(err.message || "")) return true;
    const s = err.status || parseInt(String(err.message).split(":")[0], 10);
    return s === 429 || s === 502 || s === 503 || s === 504;
  }
  function flash(msg, type = "ok") {
    const el = document.createElement("div");
    el.className = "chores-flash " + (type === "error" ? "error" : (type === "warn" ? "warn" : ""));
    el.textContent = msg;
    document.body.appendChild(el);
    requestAnimationFrame(() => el.classList.add("show"));
    setTimeout(() => { el.classList.remove("show"); setTimeout(() => el.remove(), 250); }, 2400);
  }
  // Disable a submit-style button and show the centered .loading
  // spinner (defined in chores.scss) while an async action runs.
  // Re-entrant clicks are dropped because the button is disabled.
  async function withSavingState(btn, fn) {
    if (!btn || btn.disabled) return;
    btn.disabled = true;
    btn.classList.add("loading");
    try { return await fn(); }
    finally {
      btn.disabled = false;
      btn.classList.remove("loading");
    }
  }

  // ============================================================
  // ChoreStore — the data model. Every read derives from here.
  //
  // Persistence contract:
  //   * The store NEVER drops chores on its own. The only paths that
  //     remove a chore from the store are explicit `remove(id)` calls
  //     and the `active_chore_ids` reconcile from /sync (anything
  //     locally cached but not in that authoritative id list).
  //   * `bootstrap` is ADDITIVE — it merges fresh data into the existing
  //     store, never clears it. A stale/empty cached shell can never
  //     wipe a populated UI; the worst case is "we already had these
  //     chores and now we still do."
  //   * Every mutation persists to localStorage so a fresh page load
  //     with an empty inline shell can hydrate from local first, then
  //     merge whatever the network eventually returns.
  // ============================================================
  const STORE_LS_KEY = "chores:store:v1";
  const ChoreStore = (() => {
    const map = new Map();
    let lookahead = {};
    // Ordered list of chore ids the viewer has pinned to their Dailies
    // section on Today. Independent of `today_visible` — items here are
    // purely user-curated, not derived from show_on_daily_view.
    let dailyIds = [];
    let dailyIdSet = new Set();
    const subs = new Set();
    function notify(kind, id) { subs.forEach(fn => { try { fn(kind, id); } catch (e) { console.error(e); } }); }
    function rebuildDailySet() { dailyIdSet = new Set(dailyIds.map(n => parseInt(n, 10))); }
    function persist() {
      try {
        localStorage.setItem(STORE_LS_KEY, JSON.stringify({
          chores: Array.from(map.values()),
          lookahead,
          dailyIds,
        }));
      } catch (e) { /* storage full or unavailable — non-fatal */ }
    }
    // Pull last-known state from localStorage. Returns the payload or
    // null. Caller decides whether to merge it (used when the inline
    // shell JSON is empty / stale and we'd otherwise paint nothing).
    function loadPersisted() {
      try {
        const raw = localStorage.getItem(STORE_LS_KEY);
        if (!raw) return null;
        return JSON.parse(raw);
      } catch (e) { return null; }
    }
    return {
      // Additive merge — NEVER clears the map. Bootstrap is just "here
      // is the latest known data," and removals are handled separately
      // (`remove` / `active_chore_ids` reconcile). Emits a single
      // "reconcile" notify so subscribers can diff the DOM against the
      // current store without ever clearing containers in between.
      bootstrap(items, look, dailies) {
        (items || []).forEach(c => {
          if (!c || !c.id) return;
          const existing = map.get(c.id);
          map.set(c.id, { ...existing, ...c });
        });
        if (look && Object.keys(look).length > 0) lookahead = look;
        if (Array.isArray(dailies)) {
          // Daily pins come from the server when present. An empty
          // array IS authoritative — user could have unpinned everything
          // — but a missing/undefined `dailies` arg means "don't touch
          // the existing list" (e.g. a partial bootstrap path).
          dailyIds = dailies.map(n => parseInt(n, 10)).filter(Boolean);
          rebuildDailySet();
        }
        persist();
        notify("reconcile");
      },
      hydrateFromLocal() {
        const p = loadPersisted();
        if (!p) return false;
        (p.chores || []).forEach(c => {
          if (!c || !c.id) return;
          if (!map.has(c.id)) map.set(c.id, c);
        });
        if (p.lookahead && Object.keys(lookahead).length === 0) lookahead = p.lookahead;
        if (Array.isArray(p.dailyIds) && dailyIds.length === 0) {
          dailyIds = p.dailyIds.map(n => parseInt(n, 10)).filter(Boolean);
          rebuildDailySet();
        }
        return true;
      },
      setDailyIds(ids) {
        dailyIds = (ids || []).map(n => parseInt(n, 10)).filter(Boolean);
        rebuildDailySet();
        persist();
        notify("dailies");
      },
      pinDaily(id) {
        const n = parseInt(id, 10);
        if (!n || dailyIdSet.has(n)) return;
        dailyIds.push(n);
        dailyIdSet.add(n);
        persist();
        notify("dailies");
      },
      unpinDaily(id) {
        const n = parseInt(id, 10);
        if (!dailyIdSet.has(n)) return;
        dailyIds = dailyIds.filter(x => x !== n);
        dailyIdSet.delete(n);
        persist();
        notify("dailies");
      },
      reorderDailies(ids) {
        const allowed = new Set(dailyIds);
        const next = [];
        (ids || []).forEach(id => {
          const n = parseInt(id, 10);
          if (allowed.has(n) && !next.includes(n)) next.push(n);
        });
        // Preserve any pin not present in the supplied order so we
        // don't silently drop dailies a stale client didn't know about.
        dailyIds.forEach(id => { if (!next.includes(id)) next.push(id); });
        dailyIds = next;
        rebuildDailySet();
        persist();
        notify("dailies");
      },
      isDaily(id) { return dailyIdSet.has(parseInt(id, 10)); },
      dailyIds() { return dailyIds.slice(); },
      upsert(c, { optimistic = false } = {}) {
        if (!c || !c.id) return false;
        const existing = map.get(c.id);
        if (!optimistic && existing?.updated_at && c.updated_at && existing.updated_at > c.updated_at) {
          // Newer local copy wins; don't overwrite.
          return false;
        }
        map.set(c.id, { ...existing, ...c });
        persist();
        notify("upsert", c.id);
        return true;
      },
      patch(id, fields) {
        const existing = map.get(id);
        if (!existing) return;
        map.set(id, { ...existing, ...fields });
        persist();
        notify("upsert", id);
      },
      remove(id) {
        if (!map.has(id)) return;
        map.delete(id);
        const n = parseInt(id, 10);
        if (dailyIdSet.has(n)) {
          dailyIds = dailyIds.filter(x => x !== n);
          dailyIdSet.delete(n);
        }
        persist();
        notify("remove", id);
      },
      // Rebuild the map in the supplied id order so any view that reads
      // chores in iteration order (Grid, Today) reflects the new sort.
      // Unknown ids are skipped; chores not in `ids` are appended in
      // their current order so they don't vanish from the views.
      reorder(ids) {
        const next = new Map();
        ids.forEach(id => {
          const key = parseInt(id, 10);
          if (map.has(key)) { next.set(key, map.get(key)); map.delete(key); }
        });
        map.forEach((v, k) => next.set(k, v));
        map.clear();
        next.forEach((v, k) => map.set(k, v));
      },
      get(id) { return map.get(id); },
      all() { return Array.from(map.values()); },
      // Items pinned to Dailies, in the user's curated order. A pinned
      // chore stays here regardless of today_visible — only archival
      // hides it.
      dailiesList() {
        const out = [];
        dailyIds.forEach(id => {
          const c = map.get(id);
          if (c && !c.archived) out.push(c);
        });
        return out;
      },
      // Items whose schedule actually fires today (or one-offs currently
      // on Today), minus dailies. Sits between Dailies and Scheduled and
      // is hidden when empty.
      todayList() {
        return this.all().filter(c => c.due_today && c.today_visible && !c.archived && !dailyIdSet.has(c.id));
      },
      // Items that today_visible filtering would have put on the old
      // Today screen, minus dailies AND minus the new "due today"
      // section. What's left is overdue carryovers and always-on items.
      overdueList() {
        return this.all().filter(c => c.today_visible && !c.archived && !dailyIdSet.has(c.id) && !c.due_today);
      },
      activeForGrid() { return this.all().filter(c => !c.archived); },
      hotPicks() {
        return this.all()
          .filter(c => c.hot_multiplier != null && !c.archived)
          .sort((a, b) => (b.hot_multiplier - a.hot_multiplier));
      },
      lookahead() { return lookahead; },
      setLookahead(l) { lookahead = l || {}; persist(); notify("lookahead"); },
      subscribe(fn) { subs.add(fn); return () => subs.delete(fn); },
    };
  })();

  // ============================================================
  // Templates — pure HTML strings (sensitive fields escaped via esc()).
  // ============================================================

  // Determine which way the icon should render. Mirrors the server's
  // `icon_kind` so future divergence stays minimal.
  function iconHTML(c, { large = false } = {}) {
    const placeholderFallback = c.one_off ? "📝" : "🧹";
    const v = (c.icon || "").trim();
    if (!v) {
      return `<span class="icon-placeholder">${esc(placeholderFallback)}</span>`;
    }
    if (v.startsWith("data:image/") || v.startsWith("http://") || v.startsWith("https://")) {
      return `<img class="icon-img" src="${esc(v)}" alt="" loading="lazy" draggable="false">`;
    }
    if (v.startsWith("<svg")) {
      // Safe-ish: we only allow inline SVG that the user explicitly
      // pasted as their own icon. Browser will sanitize at parse.
      return v;
    }
    if (v.startsWith("ti-")) {
      return `<i class="ti ${esc(v)} icon-ti" aria-hidden="true"></i>`;
    }
    return `<span class="icon-glyph">${esc(v)}</span>`;
  }

  function hasCooldown(c) { return c.cooldown_kind === "fixed" || c.cooldown_kind === "day_reset"; }

  // State-icon classification for Today + Scheduled circles. Mirrors the
  // server's `due_today` derivation: recurring-daily chores get a Sun,
  // anything else due today (one-offs, weekly/monthly matches) gets a
  // Clock, and carryover/overdue items get an Hourglass.
  function stateIconClass(c) {
    if (!c.today_visible || c.archived) return null;
    const freq = (c.recurrence && c.recurrence.freq) || "never";
    // No schedule = no schedule state to communicate. Pinned Dailies
    // (typically freq:never), Always-shown one-offs, and Available-on-
    // cooldown items all fall through here and stay icon-less.
    if (freq === "never") return null;
    if (freq === "daily") return "fa-sun-o";
    if (c.due_today)      return "fa-clock-o";
    return "fa-hourglass-half";
  }
  function stateIconHTML(c) {
    const cls = stateIconClass(c);
    if (!cls) return "";
    return `<i class="fa ${cls} circle-state-icon" aria-hidden="true" data-state-icon></i>`;
  }

  function gridCardHTML(c) {
    const doneClass = (c.done_count_today > 0) ? " done-today" : "";
    const hotClass  = (c.hot_multiplier != null) ? " hot" : "";
    const hot = (c.hot_multiplier != null) ?
      `<div class="hot-badge">${esc(formatMultiplier(c.hot_multiplier))}×</div>` : "";
    const streak = (c.streak_multiplier != null && c.streak_multiplier > 1) ?
      `<div class="streak-badge">${esc(formatMultiplier(c.streak_multiplier))}×</div>` : "";
    const countBadge = (c.done_count_today > 1) ?
      `<span class="count-badge" data-count-badge>×${c.done_count_today}</span>` : "";
    const cd = hasCooldown(c) ?
      `<span class="circle-countdown" data-circle-countdown data-cooldown-end="${c.cooldown_kind === "day_reset" ? "day-end" : ""}"></span>` : "";
    // The most-recent completion drives the ring color. An anonymous
    // completion paints the ring grey (work was done, but no household
    // member gets credit).
    const actorAttr = c.last_actor_anonymous
      ? ` data-actor-anonymous="true"`
      : (c.last_actor_username ? ` data-actor="${esc(c.last_actor_username)}"` : "");
    return `
      <div class="chore-card${doneClass}${hotClass}" data-chore-id="${c.id}"${actorAttr}>
        ${hot}
        ${streak}
        <div class="icon" data-icon>
          <span class="card-reward">${esc(c.reward_label)}</span>
          ${iconHTML(c)}
          ${cd}
        </div>
        <span class="card-count-slot" data-count-slot>${countBadge}</span>
        <div class="title">${esc(c.name)}</div>
        <div class="ago-row" data-ago-row></div>
      </div>
    `;
  }

  function circleCardHTML(c, { animate = true } = {}) {
    const isDone = (c.done_count_today || 0) > 0;
    const doneClass = isDone ? (animate ? " done" : " done no-animate") : "";
    const hotClass  = (c.hot_multiplier != null) ? " hot" : "";
    const hot = (c.hot_multiplier != null) ?
      `<div class="hot-badge">${esc(formatMultiplier(c.hot_multiplier))}×</div>` : "";
    const streak = (c.streak_multiplier != null && c.streak_multiplier > 1) ?
      `<div class="streak-badge">${esc(formatMultiplier(c.streak_multiplier))}×</div>` : "";
    const countBadge = (c.done_count_today > 1) ?
      `<span class="count-badge" data-count-badge>×${c.done_count_today}</span>` : "";
    const ring = (c.cooldown_kind === "fixed") ? `
      <svg class="circle-ring" viewBox="0 0 100 100" aria-hidden="true">
        <circle class="ring-bg" cx="50" cy="50" r="46" />
        <circle class="ring-progress" cx="50" cy="50" r="46" data-ring-progress />
      </svg>
    ` : "";
    const cd = hasCooldown(c) ?
      `<span class="circle-countdown" data-circle-countdown data-cooldown-end="${c.cooldown_kind === "day_reset" ? "day-end" : ""}"></span>` : "";
    // The most-recent completion drives the ring color. An anonymous
    // completion paints the ring grey (work was done, but no household
    // member gets credit).
    const actorAttr = c.last_actor_anonymous
      ? ` data-actor-anonymous="true"`
      : (c.last_actor_username ? ` data-actor="${esc(c.last_actor_username)}"` : "");
    return `
      <div class="chore-circle${doneClass}${hotClass}" data-chore-id="${c.id}"${actorAttr}>
        ${hot}
        ${streak}
        <div class="circle-inner">
          ${ring}
          <svg class="done-ring" viewBox="0 0 100 100" aria-hidden="true">
            <circle cx="50" cy="50" r="48" pathLength="100" />
          </svg>
          <span class="circle-reward">${esc(c.reward_label)}</span>
          <div class="icon" data-icon>${iconHTML(c)}</div>
          ${cd}
          ${stateIconHTML(c)}
          <div class="count-slot" data-count-slot>${countBadge}</div>
        </div>
        <div class="title">${esc(c.short_name)}</div>
      </div>
    `;
  }

  function hotCellHTML(c, { animate = true } = {}) {
    return `<div class="hot-strip-cell">${circleCardHTML(c, { animate })}</div>`;
  }

  function nodeFrom(html) {
    const t = document.createElement("template");
    t.innerHTML = (html || "").trim();
    return t.content.firstElementChild;
  }

  // ============================================================
  // Per-chore data attribute hydration — JS reads these for cooldowns
  // + last_completed_at without re-reading the store on every tick.
  // We set them in addition to the visible HTML so existing ticker
  // code stays cheap.
  // ============================================================
  function hydrateDataAttrs(el, c) {
    el.dataset.choreCooldown = c.threshold_seconds || 0;
    el.dataset.choreOneOff = String(!!c.one_off);
    el.dataset.lastCompletedAt = c.last_completed_at || "";
    el.dataset.doneCount = c.done_count_today || 0;
    el.dataset.choreName = c.name || "";
    el.dataset.choreShort = c.short_name || "";
    el.dataset.choreIcon = c.icon || "";
    el.dataset.choreReward = c.reward_pebbles || 0;
    el.dataset.choreShowOnDailyView = c.show_on_daily_view || "when_scheduled";
    el.dataset.choreSharingMode = c.sharing_mode || "personal";
    el.dataset.choreAssignedToUserId = c.assigned_to_user_id || "";
    el.dataset.choreStartsOn = c.starts_on || "";
    el.dataset.choreRecurrence = JSON.stringify(c.recurrence || {});
    el.dataset.choreAliases = (c.aliases || []).join("|");
    if (c.last_actor_anonymous) {
      el.dataset.actorAnonymous = "true";
      delete el.dataset.actor;
    } else {
      delete el.dataset.actorAnonymous;
      if (c.last_actor_username) el.dataset.actor = c.last_actor_username;
      else delete el.dataset.actor;
    }
  }

  // Done-ring animation bookkeeping. The keyframe runs on every fresh
  // .done element, so:
  //   * `seenDone` tracks chores we've already shown as done; re-renders
  //     of those skip the animation via the `no-animate` class so an
  //     incoming server upsert doesn't restart the draw.
  //   * `ringAnimating` blocks upsertOne while a draw is in flight so
  //     the SVG can complete; updates that arrived during the window
  //     get parked in `ringDeferred` and replayed when it ends.
  const RING_ANIM_MS = 550;
  const seenDone = new Set();
  const ringAnimating = new Set();
  const ringDeferred = new Map();

  function shouldAnimateDone(c) {
    const sid = String(c.id);
    if ((c.done_count_today || 0) === 0) {
      seenDone.delete(sid);
      return false;
    }
    if (seenDone.has(sid)) return false;
    seenDone.add(sid);
    return true;
  }

  function noteRingAnimation(id) {
    const sid = String(id);
    ringAnimating.add(sid);
    setTimeout(() => {
      ringAnimating.delete(sid);
      if (ringDeferred.has(sid)) {
        const pending = ringDeferred.get(sid);
        ringDeferred.delete(sid);
        Views.upsertOne(pending);
      }
    }, RING_ANIM_MS);
  }

  function renderGridCard(c)   { const el = nodeFrom(gridCardHTML(c));   hydrateDataAttrs(el, c); return el; }
  function renderCircleCard(c) {
    const animate = shouldAnimateDone(c);
    const el = nodeFrom(circleCardHTML(c, { animate }));
    hydrateDataAttrs(el, c);
    if (animate) noteRingAnimation(c.id);
    return el;
  }
  function renderHotCell(c)    {
    const animate = shouldAnimateDone(c);
    const wrap = nodeFrom(hotCellHTML(c, { animate }));
    const card = wrap.querySelector("[data-chore-id]");
    if (card) hydrateDataAttrs(card, c);
    if (animate) noteRingAnimation(c.id);
    return wrap;
  }

  // Patch-in-place updates. Replacing the DOM on every upsert blinks
  // the card (and resets the done-ring SVG mid-animation); these
  // patchers only touch the bits that actually change. If a structural
  // attribute changes (icon, cooldown threshold), they fall back to a
  // full re-render — but they preserve the existing done-ring element
  // so the animation state survives the swap.
  function structuralChange(el, c) {
    return el.dataset.choreIcon !== (c.icon || "") ||
           String(el.dataset.choreCooldown || "0") !== String(c.threshold_seconds || 0);
  }
  function preserveDoneRing(oldEl, newEl) {
    const oldRing = oldEl.querySelector(".done-ring");
    const newRingWrap = newEl.querySelector(".circle-inner");
    if (!oldRing || !newRingWrap) return;
    const newRing = newRingWrap.querySelector(".done-ring");
    if (newRing) newRing.replaceWith(oldRing);
  }
  function patchCornerBadge(el, c, { className, value }) {
    let badge = null;
    for (const child of el.children) {
      if (child.classList?.contains(className)) { badge = child; break; }
    }
    const visible = value != null && (className === "hot-badge" || value > 1);
    if (visible) {
      const text = `${formatMultiplier(value)}×`;
      if (badge) {
        if (badge.textContent !== text) badge.textContent = text;
      } else {
        el.insertAdjacentHTML("afterbegin", `<div class="${className}">${esc(text)}</div>`);
      }
    } else if (badge) {
      badge.remove();
    }
  }
  function patchHotBadge(el, c)    { patchCornerBadge(el, c, { className: "hot-badge",    value: c.hot_multiplier }); }
  function patchStreakBadge(el, c) { patchCornerBadge(el, c, { className: "streak-badge", value: c.streak_multiplier }); }
  function patchCountSlot(el, c) {
    if (!el) return;
    if ((c.done_count_today || 0) > 1) {
      const want = `<span class="count-badge" data-count-badge>×${c.done_count_today}</span>`;
      if (el.innerHTML !== want) el.innerHTML = want;
    } else if (el.innerHTML !== "") {
      el.innerHTML = "";
    }
  }
  function patchText(el, text) {
    if (!el) return;
    const want = text || "";
    if (el.textContent !== want) el.textContent = want;
  }
  function patchCircleCard(el, c) {
    if (structuralChange(el, c)) {
      const fresh = renderCircleCard(c);
      preserveDoneRing(el, fresh);
      el.replaceWith(fresh);
      return;
    }
    const wasDone = el.classList.contains("done");
    const isDone = (c.done_count_today || 0) > 0;
    if (isDone) {
      el.classList.add("done");
      if (wasDone) {
        el.classList.add("no-animate");
      } else {
        const animate = shouldAnimateDone(c);
        el.classList.toggle("no-animate", !animate);
        if (animate) noteRingAnimation(c.id);
      }
    } else {
      el.classList.remove("done", "no-animate");
      shouldAnimateDone(c);
    }
    el.classList.toggle("hot", c.hot_multiplier != null);
    patchHotBadge(el, c);
    patchStreakBadge(el, c);
    patchText(el.querySelector(".circle-reward"), c.reward_label);
    patchCountSlot(el.querySelector("[data-count-slot]"), c);
    patchStateIcon(el.querySelector(".circle-inner"), c);
    patchText(el.querySelector(":scope > .title"), c.short_name);
    hydrateDataAttrs(el, c);
  }
  function patchStateIcon(host, c) {
    if (!host) return;
    const existing = host.querySelector(":scope > [data-state-icon]");
    const cls = stateIconClass(c);
    if (!cls) {
      if (existing) existing.remove();
      return;
    }
    if (existing) {
      // Reset to the desired Font Awesome class without disturbing the
      // shared `fa circle-state-icon` baseline classes.
      existing.classList.remove("fa-sun-o", "fa-clock-o", "fa-hourglass-half");
      existing.classList.add(cls);
    } else {
      host.insertAdjacentHTML("beforeend", `<i class="fa ${cls} circle-state-icon" aria-hidden="true" data-state-icon></i>`);
    }
  }
  function patchGridCard(el, c) {
    if (structuralChange(el, c)) {
      el.replaceWith(renderGridCard(c));
      return;
    }
    el.classList.toggle("done-today", (c.done_count_today || 0) > 0);
    el.classList.toggle("hot", c.hot_multiplier != null);
    patchHotBadge(el, c);
    patchStreakBadge(el, c);
    patchText(el.querySelector(".card-reward"), c.reward_label);
    patchCountSlot(el.querySelector("[data-count-slot]"), c);
    patchText(el.querySelector(":scope > .title"), c.name);
    hydrateDataAttrs(el, c);
  }
  function patchHotCell(cell, c) {
    const inner = cell.querySelector(".chore-circle");
    if (inner) patchCircleCard(inner, c);
  }

  // ============================================================
  // Views — render from store. Subscribers handle granular updates.
  // ============================================================
  const Views = (() => {
    const grid       = () => document.querySelector("[data-chores-grid]");
    const dailies    = () => document.querySelector("[data-chores-dailies]");
    const today      = () => document.querySelector("[data-chores-today]");
    const todaySect  = () => document.querySelector("[data-chores-today-section]");
    const overdue    = () => document.querySelector("[data-chores-overdue]");
    const hot        = () => document.querySelector("[data-chores-hot-strip]");
    const emptyDay   = () => document.querySelector("[data-empty-dailies]");
    const emptyOver  = () => document.querySelector("[data-empty-overdue]");
    const lookCt     = () => document.querySelector("[data-chores-lookahead]");

    function appendTo(el, node) { if (el && node) el.appendChild(node); }

    // Diff a container's children against a desired list of items.
    // NEVER calls innerHTML="" — chores already on screen stay on
    // screen, even if a sync is mid-flight or failed. The only writes
    // are: patch existing nodes in place, move existing nodes to their
    // new order, append truly-new nodes, remove nodes that the store
    // says should no longer be visible.
    function reconcileSection(container, items, opts) {
      if (!container) return;
      const { keyFor, renderer, patcher } = opts;
      const desiredById = new Map(items.map(c => [c.id, c]));
      const existingByKey = new Map();
      Array.from(container.children).forEach(child => {
        const key = keyFor(child);
        if (key == null || !desiredById.has(key)) {
          // Item is no longer in this section (archived, unpinned,
          // filter flipped). Explicit DOM remove — never a clear-all.
          child.remove();
        } else {
          existingByKey.set(key, child);
        }
      });
      let cursor = container.firstElementChild;
      for (const item of items) {
        const existing = existingByKey.get(item.id);
        if (cursor && cursor === existing) {
          // Already where it belongs — patch in place.
          patcher(cursor, item);
          cursor = cursor.nextElementSibling;
        } else if (existing) {
          // Lives in this container but in the wrong position. Move it
          // to the cursor's slot (insertBefore moves rather than dupes
          // when the node is already a child).
          container.insertBefore(existing, cursor);
          patcher(existing, item);
        } else {
          // Truly new — insert at the cursor position.
          const node = renderer(item);
          if (node) container.insertBefore(node, cursor);
        }
      }
    }

    const cardKey   = el => { const v = parseInt(el?.dataset?.choreId, 10); return Number.isFinite(v) ? v : null; };
    // Hot cells wrap a chore-circle whose data-chore-id is on the
    // inner element; key by that.
    const hotKey    = el => {
      const inner = el?.querySelector?.("[data-chore-id]");
      const v = parseInt(inner?.dataset?.choreId, 10);
      return Number.isFinite(v) ? v : null;
    };
    const patchHot  = (cell, c) => {
      const inner = cell.querySelector(".chore-circle");
      if (inner) patchCircleCard(inner, c);
    };

    function renderGrid() {
      reconcileSection(grid(), ChoreStore.activeForGrid(), {
        keyFor: cardKey, renderer: renderGridCard, patcher: patchGridCard,
      });
    }
    function renderDailies() {
      const c = dailies();
      reconcileSection(c, ChoreStore.dailiesList(), {
        keyFor: cardKey, renderer: renderCircleCard, patcher: patchCircleCard,
      });
      if (emptyDay()) emptyDay().hidden = (c?.children.length || 0) > 0;
    }
    function renderToday() {
      const c = today();
      reconcileSection(c, ChoreStore.todayList(), {
        keyFor: cardKey, renderer: renderCircleCard, patcher: patchCircleCard,
      });
      const section = todaySect();
      if (section) section.hidden = (c?.children.length || 0) === 0;
    }
    function renderOverdue() {
      const c = overdue();
      reconcileSection(c, ChoreStore.overdueList(), {
        keyFor: cardKey, renderer: renderCircleCard, patcher: patchCircleCard,
      });
      if (emptyOver()) emptyOver().hidden = (c?.children.length || 0) > 0;
    }
    function renderHot() {
      const c = hot();
      if (!c) return;
      const picks = ChoreStore.hotPicks();
      reconcileSection(c, picks, {
        keyFor: hotKey,
        renderer: item => nodeFrom(hotCellHTML(item)),
        patcher: patchHot,
      });
      // Section visibility — hide when no picks, show otherwise. Note
      // we DON'T innerHTML="" on the hidden branch; if picks come back
      // later we re-reveal the same DOM (or reconcile adds new cells).
      c.hidden = (c.children.length === 0);
    }
    function renderLookahead() {
      const c = lookCt();
      if (!c) return;
      const data = ChoreStore.lookahead() || {};
      const keys = Object.keys(data).sort();
      if (!keys.length) { c.hidden = true; return; }
      c.hidden = false;
      const parts = [`<h3 class="lookahead-heading">Upcoming</h3>`];
      keys.forEach(day => {
        const ids = data[day] || [];
        const dayObj = new Date(day + "T00:00:00");
        const dayLabel = dayObj.toLocaleDateString(undefined, { weekday: "short", month: "short", day: "numeric" });
        // Empty days are rendered with a muted placeholder so the
        // user can't mistake the next non-empty day for "tomorrow".
        const body = ids.length
          ? ids.map(id => {
              const c = ChoreStore.get(id);
              if (!c) return "";
              return `<span class="day-chip">${iconHTML(c)} ${esc(c.short_name)} <strong>${esc(c.reward_label)}</strong></span>`;
            }).join("")
          : `<span class="day-chip day-chip-empty">Nothing scheduled</span>`;
        const emptyClass = ids.length ? "" : " lookahead-day-empty";
        parts.push(`<div class="lookahead-day${emptyClass}"><div class="day-label">${esc(dayLabel)}</div><div class="day-items">${body}</div></div>`);
      });
      // Only write the DOM when the markup actually changed — the
      // section never flickers when the lookahead arg comes back
      // identical to what we already rendered.
      const want = parts.join("");
      if (c.innerHTML !== want) c.innerHTML = want;
    }

    function upsertOne(c) {
      // While the done-ring animation is drawing for this chore, park
      // the update so the SVG can finish; the animation timer replays
      // the latest deferred upsert when it fires.
      const sid = String(c.id);
      if (ringAnimating.has(sid)) {
        ringDeferred.set(sid, c);
        return;
      }

      const g = grid()?.querySelector(`[data-chore-id="${c.id}"]`);
      if (g) patchGridCard(g, c);
      else appendTo(grid(), renderGridCard(c));

      // The chore belongs to exactly ONE of the three Today-tab sections:
      //   * Dailies  if the viewer has pinned it (regardless of today_visible)
      //   * Today    if it's due_today + today_visible AND not pinned
      //   * Overdue  if it's today_visible AND not pinned AND not due_today
      // Anything else gets removed from all three so a flipped
      // today_visible/due_today doesn't leave a stale card behind.
      const isDaily = ChoreStore.isDaily(c.id) && !c.archived;
      const isToday = !!c.due_today && c.today_visible && !c.archived && !isDaily;
      const isOverdue = c.today_visible && !c.archived && !isDaily && !isToday;
      placeInSection(c, dailies(), isDaily);
      placeInSection(c, today(), isToday);
      placeInSection(c, overdue(), isOverdue);
      refreshTodayEmptyStates();

      // Hot strip — membership rotates at the 4am day boundary, so when
      // an upsert flips a chore in or out of the hot set, recompute the
      // whole strip; otherwise just patch the existing cell.
      const hotEl = hot();
      const hotCell = hotEl?.querySelector(`[data-chore-id="${c.id}"]`)?.closest(".hot-strip-cell");
      const shouldBeHot = c.hot_multiplier != null && !c.archived;
      if (hotCell && shouldBeHot) {
        patchHotCell(hotCell, c);
      } else if (hotCell || shouldBeHot) {
        renderHot();
      }
    }
    function removeOne(id) {
      document.querySelectorAll(`[data-chore-id="${id}"]`).forEach(el => {
        const cell = el.closest(".hot-strip-cell");
        (cell || el).remove();
      });
      refreshTodayEmptyStates();
    }
    function placeInSection(c, container, shouldBeIn) {
      if (!container) return;
      const existing = container.querySelector(`:scope > [data-chore-id="${c.id}"]`);
      if (shouldBeIn) {
        if (existing) patchCircleCard(existing, c);
        else appendTo(container, renderCircleCard(c));
      } else if (existing) {
        existing.remove();
      }
    }
    function refreshTodayEmptyStates() {
      if (emptyDay())  emptyDay().hidden  = (dailies()?.children.length || 0) > 0;
      if (emptyOver()) emptyOver().hidden = (overdue()?.children.length || 0) > 0;
      const section = todaySect();
      if (section) section.hidden = (today()?.children.length || 0) === 0;
    }
    function renderAll() {
      renderGrid();
      renderDailies();
      renderToday();
      renderOverdue();
      renderHot();
      renderLookahead();
    }
    return {
      renderAll, renderGrid, renderDailies, renderToday, renderOverdue, renderHot, renderLookahead,
      upsertOne, removeOne, refreshTodayEmptyStates,
    };
  })();

  ChoreStore.subscribe((kind, id) => {
    // "reconcile" replaces the old destructive "bootstrap" event.
    // Views.renderAll() now diffs the DOM against the current store
    // instead of clearing containers, so a fresh sync that overlaps
    // with what's already on screen produces no flicker and an empty
    // sync produces no blank.
    if (kind === "reconcile") Views.renderAll();
    else if (kind === "lookahead") Views.renderLookahead();
    else if (kind === "dailies") {
      Views.renderDailies();
      Views.renderToday();
      Views.renderOverdue();
      refreshEditModalPin();
    }
    else if (kind === "remove") Views.removeOne(id);
    else if (kind === "upsert") {
      const c = ChoreStore.get(id);
      if (!c) return;
      Views.upsertOne(c);
      // Keep the open edit modal's mark-due button in sync when the
      // chore the user is editing gets stamped/cleared from another tab
      // or by a household member.
      if (parseInt(currentChoreId, 10) === id) refreshEditModalMarkDue();
    }
    // Re-apply the active search after any store change: newly-rendered
    // cells need their display: filter, and the extras list needs to
    // re-pick from the updated active-for-grid set.
    const q = currentSearchQuery();
    if (q) applySearch(q);
  });

  // ============================================================
  // ticker — countdown + ago row driven by data attributes
  // ============================================================
  const RING_CIRC = 2 * Math.PI * 46;

  function secondsUntilNextChoreDay(now) {
    const d = new Date(now);
    const next = new Date(d);
    next.setHours(CUTOFF_HOUR, 0, 0, 0);
    if (next.getTime() <= d.getTime()) next.setDate(next.getDate() + 1);
    return Math.max(0, Math.floor((next.getTime() - d.getTime()) / 1000));
  }
  // Local chore-day in iso format. Mirrors `ChoreDay.current` on the
  // server (shift by CUTOFF_HOUR, then take the date). Used to spot
  // SW-cached bootstrap that was generated before the 4am rollover.
  function currentChoreDayIso(now = Date.now()) {
    const shifted = new Date(now - CUTOFF_HOUR * 3600 * 1000);
    const y = shifted.getFullYear();
    const m = String(shifted.getMonth() + 1).padStart(2, "0");
    const d = String(shifted.getDate()).padStart(2, "0");
    return `${y}-${m}-${d}`;
  }

  function formatRemaining(seconds) {
    if (seconds <= 0) return "";
    const s = Math.ceil(seconds);
    if (s < 60) return ":" + String(s).padStart(2, "0") + "s";
    if (s < 5 * 60) {
      const mins = Math.floor(s / 60);
      const secs = Math.ceil(s % 60);
      return secs === 60 ? `${mins + 1}:00` : `${mins}:${String(secs).padStart(2, "0")}`;
    }
    if (s < 50 * 60) return Math.ceil(s / 60) + "m";
    if (s < 16 * 60 * 60) return Math.ceil(s / 3600) + "h";
    if (s < 28 * 86400) return Math.ceil(s / 86400) + "d";
    if (s < 23 * 30 * 86400) return Math.ceil(s / (30 * 86400)) + "M";
    return Math.ceil(s / (365 * 86400)) + "y";
  }

  function formatAgo(isoString, now = Date.now()) {
    if (!isoString) return "";
    const t = new Date(isoString).getTime();
    if (Number.isNaN(t)) return "";
    const sec = Math.max(0, Math.floor((now - t) / 1000));
    if (sec < 60) return "<1m ago";
    if (sec < 3600) return `${Math.floor(sec / 60)}m ago`;
    if (sec < 86400) {
      const h = Math.floor(sec / 3600);
      const m = Math.floor((sec % 3600) / 60);
      return m > 0 ? `${h}h ${m}m ago` : `${h}h ago`;
    }
    const d = new Date(t);
    const today = new Date(now);
    const startOfToday = new Date(today.getFullYear(), today.getMonth(), today.getDate()).getTime();
    const dayDiff = Math.floor((startOfToday - new Date(d.getFullYear(), d.getMonth(), d.getDate()).getTime()) / 86400000);
    if (dayDiff === 1) return "Yesterday";
    if (dayDiff >= 2 && dayDiff <= 6) {
      return ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"][d.getDay()];
    }
    const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
    return `${months[d.getMonth()]} ${d.getDate()}, '${String(d.getFullYear() % 100).padStart(2, "0")}`;
  }

  function updateRings(now) {
    document.querySelectorAll('[data-chore-id][data-chore-cooldown]').forEach(card => {
      const cooldown = parseInt(card.dataset.choreCooldown, 10);
      if (!cooldown) return;
      const last = card.dataset.lastCompletedAt;
      const ring = card.querySelector('[data-ring-progress]');
      const label = card.querySelector('[data-circle-countdown]');
      if (!label && !ring) return;
      if (ring) ring.setAttribute("stroke-dasharray", RING_CIRC);

      if (cooldown === -1) {
        if (!label) return;
        // Day-reset cooldown is only ACTIVE when the most recent
        // completion is in TODAY's chore-day. Completions from any
        // prior day have already crossed the 4am boundary, so the
        // cooldown has elapsed — the ticker must leave the label
        // empty (CSS `:empty` then hides the pill entirely). Without
        // this guard, a chore completed at 5pm yesterday would tick
        // down to tomorrow's 4am and render a phantom "1d" cooldown.
        const lastMs = last ? new Date(last).getTime() : 0;
        const stillInCooldown = lastMs &&
          currentChoreDayIso(lastMs) === currentChoreDayIso(now);
        if (!stillInCooldown) {
          label.textContent = "";
          label.classList.add("elapsed");
          return;
        }
        const remainSec = secondsUntilNextChoreDay(now);
        label.classList.toggle("elapsed", remainSec === 0);
        label.textContent = remainSec === 0 ? "" : formatRemaining(remainSec);
        return;
      }

      if (!last) {
        if (ring) { ring.setAttribute("stroke-dashoffset", RING_CIRC); ring.classList.add("elapsed"); }
        if (label) { label.classList.add("elapsed"); label.textContent = ""; }
        return;
      }
      const lastMs = new Date(last).getTime();
      const remainSec = Math.max(0, Math.ceil((lastMs + cooldown * 1000 - now) / 1000));
      if (ring) {
        const progress = remainSec === 0 ? 0 : remainSec / cooldown;
        ring.setAttribute("stroke-dashoffset", RING_CIRC * (1 - progress));
        ring.classList.toggle("elapsed", remainSec === 0);
      }
      if (label) {
        label.classList.toggle("elapsed", remainSec === 0);
        label.textContent = remainSec === 0 ? "" : formatRemaining(remainSec);
      }
    });
  }
  function updateAgoRows(now) {
    document.querySelectorAll("[data-ago-row]").forEach(row => {
      const card = row.closest("[data-chore-id]");
      if (!card) return;
      const iso = card.dataset.lastCompletedAt;
      row.textContent = iso ? formatAgo(iso, now) : "";
    });
  }
  function startTicker() {
    const tick = () => {
      const now = Date.now();
      updateRings(now);
      updateAgoRows(now);
    };
    tick();
    setInterval(tick, 1000);
  }

  // ============================================================
  // gestures — tap to complete, long-press to undo, edit-mode tap to edit
  // ============================================================
  let editModeActive = false;

  function bindCardClicks() {
    [
      document.querySelector("[data-chores-grid]"),
      document.querySelector("[data-chores-dailies]"),
      document.querySelector("[data-chores-today]"),
      document.querySelector("[data-chores-overdue]"),
      document.querySelector("[data-chores-search-extra]"),
      document.querySelector("[data-chores-hot-strip]"),
    ].filter(Boolean).forEach(bindOne);
  }
  function bindOne(container) {
    const MOVE_THRESHOLD = 8, LONG_MS = 550;
    const s = { pointerId: null, card: null, startX: 0, startY: 0, startedAt: 0, moved: false, longPressFired: false, timer: null };
    function reset() {
      if (s.timer) clearTimeout(s.timer);
      s.pointerId = null; s.card = null; s.startX = 0; s.startY = 0; s.startedAt = 0;
      s.moved = false; s.longPressFired = false; s.timer = null;
    }
    container.addEventListener("pointerdown", e => {
      if (s.pointerId !== null) return;
      const card = e.target.closest("[data-chore-id]");
      if (!card) return;
      const inEditMode = editModeActive;
      if (!inEditMode) {
        const usesCircleHitbox = container.matches("[data-chores-dailies], [data-chores-today], [data-chores-overdue], [data-chores-hot-strip]");
        if (usesCircleHitbox && !e.target.closest(".circle-inner")) return;
      }

      s.pointerId = e.pointerId; s.card = card; s.startX = e.clientX; s.startY = e.clientY;
      s.startedAt = performance.now(); s.moved = false; s.longPressFired = false;
      s.timer = setTimeout(() => {
        if (!s.card || s.moved) return;
        s.longPressFired = true;
        if (inEditMode) openChoreHistoryModal(s.card.dataset.choreId);
        else undoLastCompletion(s.card.dataset.choreId);
      }, LONG_MS);
    });
    container.addEventListener("pointermove", e => {
      if (s.pointerId !== e.pointerId) return;
      if (Math.hypot(e.clientX - s.startX, e.clientY - s.startY) > MOVE_THRESHOLD) {
        s.moved = true;
        if (s.timer) { clearTimeout(s.timer); s.timer = null; }
      }
    });
    container.addEventListener("pointerup", e => {
      if (s.pointerId !== e.pointerId) return;
      const card = s.card;
      const isShortTap = !s.moved && !s.longPressFired && (performance.now() - s.startedAt) < LONG_MS;
      reset();
      if (!card) return;
      if (!isShortTap) { card.dataset.suppressClick = "1"; return; }
      // In edit mode every short tap means "edit"; the click handler
      // opens the edit modal. Never auto-complete from edit mode.
      if (editModeActive) return;
      if (multiplierActive) { openMultiplierModal(card); return; }
      if (e.shiftKey) { openEditModal(card); return; }
      completeChore(card.dataset.choreId);
    });
    ["pointercancel", "pointerleave"].forEach(evt =>
      container.addEventListener(evt, e => { if (s.pointerId === e.pointerId) reset(); }));
    container.addEventListener("click", e => {
      const card = e.target.closest("[data-chore-id]");
      if (!card) return;
      // A long-press already opened a modal (history in edit mode, undo
      // otherwise) — swallow the trailing click so the edit modal doesn't
      // also pop open behind it.
      if (card.dataset.suppressClick === "1") {
        delete card.dataset.suppressClick;
        e.preventDefault(); e.stopPropagation();
        return;
      }
      if (editModeActive) { e.preventDefault(); e.stopPropagation(); openEditModal(card); return; }
    }, true);
    container.addEventListener("contextmenu", e => {
      const card = e.target.closest("[data-chore-id]");
      if (!card) return;
      e.preventDefault();
      openEditModal(card);
    });
  }

  // ============================================================
  // Dailies — pin toggle (on the edit modal) + per-section drag reorder
  // ============================================================
  // The pin button lives in the edit modal head (left of the title), so
  // users can pin/unpin from anywhere the modal opens (Today, Grid,
  // search, history). `bindEditModalPin` wires a single listener that
  // operates on whichever chore the modal is currently editing.
  function bindEditModalPin() {
    const btn = document.querySelector("[data-edit-pin-toggle]");
    if (!btn) return;
    btn.addEventListener("click", e => {
      e.preventDefault();
      e.stopPropagation();
      const id = parseInt(currentChoreId, 10);
      if (!id || btn.dataset.busy === "1") return;
      togglePinDaily(id, btn);
    });
  }

  // Mark-due button — sibling of pin. Stamps the chore as "needs to get
  // done" so it surfaces on Today (or Scheduled/overdue across days)
  // until any ChoreCompletion clears it.
  function bindEditModalMarkDue() {
    const btn = document.querySelector("[data-edit-mark-due-toggle]");
    if (!btn) return;
    btn.addEventListener("click", e => {
      e.preventDefault();
      e.stopPropagation();
      const id = parseInt(currentChoreId, 10);
      if (!id || btn.dataset.busy === "1") return;
      toggleMarkDue(id, btn);
    });
  }

  // Anonymous completion button (modal head). Opens the sub-modal
  // for timestamp + note. Visibility is wired in refreshEditModalHeadActions.
  function bindEditModalAnonymousComplete() {
    const btn = document.querySelector("[data-edit-anonymous-complete]");
    if (!btn) return;
    btn.addEventListener("click", e => {
      e.preventDefault();
      e.stopPropagation();
      const id = parseInt(currentChoreId, 10);
      if (!id) return;
      openAnonymousModal(id);
    });
  }

  const anonymousModal = document.querySelector('[data-anonymous-modal]');
  const anonymousForm  = anonymousModal?.querySelector('[data-anonymous-form]');
  const anonymousTitle = anonymousModal?.querySelector('[data-anonymous-title]');
  let anonymousTargetChoreId = null;

  function openAnonymousModal(choreId) {
    if (!anonymousModal) return;
    anonymousTargetChoreId = choreId;
    const c = ChoreStore.get(choreId);
    if (anonymousTitle && c) anonymousTitle.textContent = `${c.short_name || c.name} — done by someone else`;
    // Default the "completed at" field to NOW in local time (the input
    // expects a YYYY-MM-DDTHH:mm string without timezone).
    const tsField = anonymousModal.querySelector('[data-anonymous-completed-at]');
    if (tsField) {
      const d = new Date();
      const pad = n => String(n).padStart(2, "0");
      tsField.value = `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
    }
    const noteField = anonymousModal.querySelector('[data-anonymous-note]');
    if (noteField) noteField.value = "";
    anonymousModal.classList.remove("hidden");
  }
  function closeAnonymousModal() {
    anonymousModal?.classList.add("hidden");
    anonymousTargetChoreId = null;
  }
  wireModalDismiss(anonymousModal, { onCancel: closeAnonymousModal, onBackdrop: closeAnonymousModal });

  function bindAnonymousCompletionForm() {
    if (!anonymousForm) return;
    anonymousForm.addEventListener("submit", async e => {
      e.preventDefault();
      const submit = anonymousForm.querySelector('button[type="submit"]');
      const id = anonymousTargetChoreId;
      if (!id) { closeAnonymousModal(); return; }
      const tsStr = anonymousModal.querySelector('[data-anonymous-completed-at]')?.value || "";
      const note = anonymousModal.querySelector('[data-anonymous-note]')?.value || "";
      // Parse the local datetime-local string as a local-clock instant
      // (no implicit UTC interpretation) and serialize to ISO 8601.
      const dt = tsStr ? new Date(tsStr) : new Date();
      const iso = dt.toISOString();
      await withSavingState(submit, async () => {
        try {
          await api(`/chores/items/${id}/anonymous_completion`, "POST", {
            client_completed_at: iso, note, tab_id: TAB_ID,
          });
          flash("Marked done");
          closeAnonymousModal();
          dismissEditModalExplicit();
        } catch (err) {
          flash("Couldn't save: " + err.message, "error");
        }
      });
    });
  }

  // ============================================================
  // Notification settings (Balance page)
  // ============================================================
  // Subscribe / unsubscribe to the chores push channel + per-event
  // opt-out toggles. The SW is /chores_worker.js (already registered
  // for the offline shell); push events are handled there.
  const CHORES_VAPID_PUBLIC_KEY =
    "BO7gUf6gNtfyxWRaYVjmL38uqi8TGKZZ9Fw7tEKzxCosTAtTERuv2ohHEiNB21CBs7ue5eOWMe2p4jtZjZTTAFU=";

  function urlBase64ToUint8Array(base64String) {
    const padding = "=".repeat((4 - (base64String.length % 4)) % 4);
    const base64 = (base64String + padding).replace(/-/g, "+").replace(/_/g, "/");
    const raw = window.atob(base64);
    const out = new Uint8Array(raw.length);
    for (let i = 0; i < raw.length; i++) out[i] = raw.charCodeAt(i);
    return out;
  }

  async function getChoresPushSubscription() {
    if (!("serviceWorker" in navigator) || !("PushManager" in window)) return null;
    const reg = await navigator.serviceWorker.getRegistration("/chores_worker.js")
      || await navigator.serviceWorker.getRegistration("/chores");
    if (!reg) return null;
    return reg.pushManager.getSubscription();
  }

  async function subscribeChoresPush() {
    if (!("serviceWorker" in navigator) || !("PushManager" in window)) {
      throw new Error("Push isn't supported in this browser.");
    }
    if (Notification.permission === "denied") {
      throw new Error("Notifications are blocked — enable them in your browser settings.");
    }
    const reg = await navigator.serviceWorker.getRegistration("/chores_worker.js")
      || await navigator.serviceWorker.getRegistration("/chores");
    if (!reg) throw new Error("Service worker not registered yet — reload and try again.");

    const perm = await Notification.requestPermission();
    if (perm !== "granted") throw new Error("Permission not granted.");

    const sub = await reg.pushManager.subscribe({
      userVisibleOnly: true,
      applicationServerKey: urlBase64ToUint8Array(CHORES_VAPID_PUBLIC_KEY),
    });
    const body = sub.toJSON();
    body.channel = "chores";
    const res = await fetch("/push_notification_subscribe", {
      method: "POST",
      headers: { "Content-Type": "application/json", JarvisPushVersion: "2" },
      body: JSON.stringify(body),
      credentials: "same-origin",
    });
    if (!res.ok) {
      await sub.unsubscribe();
      throw new Error("Server refused the subscription.");
    }
    return sub;
  }

  async function unsubscribeChoresPush() {
    const sub = await getChoresPushSubscription();
    if (!sub) return;
    const body = sub.toJSON();
    body.channel = "chores";
    await fetch("/push_notification_unsubscribe", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
      credentials: "same-origin",
    }).catch(() => {});
    await sub.unsubscribe();
  }

  function bindNotificationSettings() {
    const modal = document.querySelector("[data-notifications-modal]");
    const openBtn = document.querySelector("[data-open-notifications]");
    if (!modal || !openBtn) return;
    const form = modal.querySelector("[data-notifications-form]");
    const statusEl = modal.querySelector("[data-notifications-status]");
    const subscribeBtn = modal.querySelector("[data-notifications-subscribe]");
    const unsubscribeBtn = modal.querySelector("[data-notifications-unsubscribe]");
    const kindInputs = Array.from(modal.querySelectorAll("[data-notify-kind]"));

    async function refreshStatus() {
      if (!("Notification" in window)) {
        statusEl.textContent = "Push isn't supported in this browser.";
        subscribeBtn.hidden = true;
        unsubscribeBtn.hidden = true;
        return;
      }
      const sub = await getChoresPushSubscription();
      if (sub) {
        statusEl.textContent = "Notifications are on for this device.";
        subscribeBtn.hidden = true;
        unsubscribeBtn.hidden = false;
      } else if (Notification.permission === "denied") {
        statusEl.textContent = "Notifications are blocked — enable them in browser settings.";
        subscribeBtn.hidden = true;
        unsubscribeBtn.hidden = true;
      } else {
        statusEl.textContent = "Notifications are off for this device.";
        subscribeBtn.hidden = false;
        unsubscribeBtn.hidden = true;
      }
    }

    async function loadPrefs() {
      try {
        const res = await api("/chores/notification_preferences", "GET");
        const prefs = res?.prefs || {};
        kindInputs.forEach(input => {
          input.checked = prefs[input.dataset.notifyKind] !== false;
        });
      } catch (_err) {
        // First-load failure (offline, etc.) — fall back to "all on".
        kindInputs.forEach(input => { input.checked = true; });
      }
    }

    openBtn.addEventListener("click", async () => {
      openModal(modal);
      await Promise.all([refreshStatus(), loadPrefs()]);
    });

    subscribeBtn.addEventListener("click", async () => {
      subscribeBtn.disabled = true;
      try {
        await subscribeChoresPush();
        await refreshStatus();
        flash("Notifications on");
      } catch (err) {
        flash(err.message || "Couldn't enable notifications", "error");
      } finally {
        subscribeBtn.disabled = false;
      }
    });

    unsubscribeBtn.addEventListener("click", async () => {
      unsubscribeBtn.disabled = true;
      try {
        await unsubscribeChoresPush();
        await refreshStatus();
        flash("Notifications off");
      } catch (err) {
        flash("Couldn't disable: " + err.message, "error");
      } finally {
        unsubscribeBtn.disabled = false;
      }
    });

    form.addEventListener("submit", async e => {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]');
      const prefs = {};
      kindInputs.forEach(input => { prefs[input.dataset.notifyKind] = input.checked; });
      await withSavingState(submitBtn, async () => {
        try {
          await api("/chores/notification_preferences", "PATCH", { chore_notify_prefs: prefs });
          closeModal(modal);
          flash("Saved");
        } catch (err) {
          flash("Couldn't save: " + err.message, "error");
        }
      });
    });

    wireModalDismiss(modal);
  }

  // Rotate-hot-pick button (modal head). Only shown when the chore is
  // a current Hot Pick — refreshEditModalHeadActions handles visibility.
  function bindEditModalHotRotate() {
    const btn = document.querySelector("[data-edit-hot-rotate]");
    if (!btn) return;
    btn.addEventListener("click", async e => {
      e.preventDefault();
      e.stopPropagation();
      const id = parseInt(currentChoreId, 10);
      if (!id || btn.dataset.busy === "1") return;
      btn.dataset.busy = "1";
      try {
        await rotateHotPick(id);
        // The chore is no longer a hot pick — dismiss the modal so the
        // user sees the strip update.
        dismissEditModalExplicit();
      } finally {
        delete btn.dataset.busy;
      }
    });
  }

  // Sync the modal pin button to the chore the modal is currently
  // editing. Called from openEditModal and from the `dailies` store
  // notify path so a broadcast that lands while the modal is open
  // keeps the button in sync.
  function refreshEditModalPin() {
    const btn = document.querySelector("[data-edit-pin-toggle]");
    if (!btn) return;
    const id = parseInt(currentChoreId, 10);
    if (!id) { btn.hidden = true; return; }
    btn.hidden = false;
    const pinned = ChoreStore.isDaily(id);
    btn.classList.toggle("pinned", pinned);
    const label = pinned ? "Remove from Dailies" : "Pin to Dailies";
    btn.setAttribute("aria-label", label);
    btn.setAttribute("title", label);
  }

  function refreshEditModalMarkDue() {
    const btn = document.querySelector("[data-edit-mark-due-toggle]");
    if (!btn) return;
    const id = parseInt(currentChoreId, 10);
    if (!id) { btn.hidden = true; return; }
    const c = ChoreStore.get(id);
    if (!c) { btn.hidden = true; return; }
    btn.hidden = false;
    const marked = !!c.marked_due_at;
    btn.classList.toggle("marked", marked);
    const label = marked ? "Clear needs-to-get-done" : "Mark needs to get done";
    btn.setAttribute("aria-label", label);
    btn.setAttribute("title", label);
  }

  // Optimistic: stamp marked_due_at + force visibility flags so the card
  // jumps into Today immediately. Unmark waits for server payload — the
  // post-unmark visibility depends on the chore's normal schedule, which
  // we don't recompute client-side.
  //
  // Form sync: the modal also exposes Due Date as a date input bound to
  // marked_due_at. Without mirroring the change into that field, a
  // subsequent form save would overwrite the stamp we just wrote with
  // the form's stale value (or vice versa for unmark).
  async function toggleMarkDue(id, btn) {
    const c = ChoreStore.get(id);
    const wasMarked = !!c?.marked_due_at;
    btn.dataset.busy = "1";
    const formField = editForm?.querySelector('[data-field="marked_due_at"]');
    if (!wasMarked) {
      ChoreStore.patch(id, {
        marked_due_at:  new Date().toISOString(),
        marked_due_on:  todayIso(),
        today_visible:  true,
        due_today:      true,
      });
      if (formField && String(currentChoreId) === String(id)) formField.value = todayIso();
      refreshEditModalMarkDue();
    } else if (formField && String(currentChoreId) === String(id)) {
      formField.value = "";
    }
    const url = `/chores/items/${id}/mark_due`;
    const method = wasMarked ? "DELETE" : "POST";
    try {
      const data = await api(url, method, { tab_id: TAB_ID });
      if (data && data.chore) ChoreStore.upsert(data.chore);
      refreshEditModalMarkDue();
    } catch (err) {
      if (isTransientError(err)) {
        flash("Saved locally — will sync", "warn");
      } else {
        if (!wasMarked) {
          ChoreStore.patch(id, { marked_due_at: null, marked_due_on: null });
          if (formField && String(currentChoreId) === String(id)) formField.value = "";
          refreshEditModalMarkDue();
        }
        flash("Couldn't update: " + err.message, "error");
      }
    } finally {
      delete btn.dataset.busy;
    }
  }

  async function togglePinDaily(id, btn) {
    const wasPinned = ChoreStore.isDaily(id);
    btn.dataset.busy = "1";
    // Optimistic — flip the store immediately so the card moves to the
    // right section as soon as the user dismisses the modal. We don't
    // roll back on transient error; the queue + sync will reconcile.
    if (wasPinned) ChoreStore.unpinDaily(id);
    else           ChoreStore.pinDaily(id);
    refreshEditModalPin();
    const url = `/chores/items/${id}/dailies`;
    const method = wasPinned ? "DELETE" : "POST";
    try {
      const data = await api(url, method, { tab_id: TAB_ID });
      if (data && Array.isArray(data.daily_ids)) ChoreStore.setDailyIds(data.daily_ids);
    } catch (err) {
      if (isTransientError(err)) {
        flash("Saved locally — will sync", "warn");
      } else {
        // Hard error: revert the optimistic flip.
        if (wasPinned) ChoreStore.pinDaily(id);
        else           ChoreStore.unpinDaily(id);
        refreshEditModalPin();
        flash("Couldn't update Dailies: " + err.message, "error");
      }
    } finally {
      delete btn.dataset.busy;
    }
  }

  let dailiesSortable = null;
  function bindDailiesSortable() {
    if (typeof window.Sortable === "undefined") {
      setTimeout(bindDailiesSortable, 200);
      return;
    }
    const container = document.querySelector("[data-chores-dailies]");
    if (!container || dailiesSortable) return;
    dailiesSortable = window.Sortable.create(container, {
      animation: 150,
      ghostClass: "sortable-ghost",
      chosenClass: "sortable-chosen",
      dragClass: "sortable-drag",
      forceFallback: true,
      fallbackOnBody: true,
      fallbackTolerance: 0,
      delay: 250,
      delayOnTouchOnly: true,
      touchStartThreshold: 6,
      onEnd: persistDailiesOrder,
    });
  }

  async function persistDailiesOrder() {
    const container = document.querySelector("[data-chores-dailies]");
    if (!container) return;
    const ids = Array.from(container.children)
      .map(el => parseInt(el.dataset.choreId, 10))
      .filter(Boolean);
    // Local store keeps the user-visible order in sync with the DOM
    // immediately. Server confirms via the response below.
    ChoreStore.reorderDailies(ids);
    try {
      const data = await api("/chores/dailies/order", "PATCH", { ids, tab_id: TAB_ID });
      if (data && Array.isArray(data.daily_ids)) ChoreStore.setDailyIds(data.daily_ids);
    } catch (err) {
      flash("Couldn't save Dailies order: " + err.message, "error");
    }
  }

  // ============================================================
  // Chore history modal — opened by long-press in edit mode. Reads
  // the per-chore /chores/items/:id/history endpoint, which scopes
  // household-shared chores to the whole household.
  // ============================================================
  const choreHistoryModal = document.querySelector('[data-chore-history-modal]');
  const choreHistoryBody  = document.querySelector('[data-chore-history-body]');
  const choreHistoryTitle = document.querySelector('[data-chore-history-title]');
  async function openChoreHistoryModal(id) {
    if (!choreHistoryModal) return;
    const c = ChoreStore.get(parseInt(id, 10));
    if (choreHistoryTitle) choreHistoryTitle.textContent = c ? c.name : "Chore History";
    if (choreHistoryBody) choreHistoryBody.innerHTML = '<p style="color:var(--chores-muted);">Loading…</p>';
    choreHistoryModal.classList.remove("hidden");
    try {
      const data = await api(`/chores/items/${parseInt(id, 10)}/history`, "GET");
      renderChoreHistory(data);
    } catch (e) {
      if (choreHistoryBody) choreHistoryBody.innerHTML = `<p style="color:#DC2626;">${esc(e.message || "Failed to load")}</p>`;
    }
  }
  function renderChoreHistory(data) {
    if (!choreHistoryBody) return;
    const entries = data?.entries || [];
    if (entries.length === 0) {
      choreHistoryBody.innerHTML = '<p style="color:var(--chores-muted);">No history yet.</p>';
      return;
    }
    const rows = entries.map(e => {
      // Anonymous entries paint the grey "Anonymous" pill instead of
      // the recorder's username — the recorder is just who saved the
      // row, not who did the work.
      const actor = e.anonymous
        ? `<span class="chore-history-actor anonymous">Anonymous</span>`
        : (e.actor_username ? `<span class="chore-history-actor">${esc(e.actor_username)}</span>` : "");
      // Inline tag is for the cooldown-blocked "skipped" case only.
      // Anonymous completions communicate the same intent via the
      // right-side "Anonymous" actor pill — no second badge needed.
      const tag = (e.payout_skipped && !e.anonymous)
        ? ' <span class="history-tag skipped">skipped</span>'
        : "";
      const mults = [];
      if (e.hot_multiplier != null && e.hot_multiplier > 1) {
        mults.push(`<span class="history-mult hot">Hot ${esc(formatMultiplier(e.hot_multiplier))}×</span>`);
      }
      if (e.streak_multiplier != null && e.streak_multiplier > 1) {
        mults.push(`<span class="history-mult streak">Streak ${esc(formatMultiplier(e.streak_multiplier))}×</span>`);
      }
      const multBlock = mults.length ? `<div class="chore-history-mults">${mults.join("")}</div>` : "";
      const note = e.note ? `<div class="chore-history-note">${esc(e.note)}</div>` : "";
      // Row-level data-actor drives the per-entry ring color. For
      // anonymous, switch to the same grey treatment cards use.
      const rowAttr = e.anonymous
        ? 'data-actor-anonymous="true"'
        : `data-actor="${esc(e.actor_username || '')}"`;
      return `
        <div class="chore-history-row" ${rowAttr}>
          <div class="chore-history-when">${esc(e.when_label)}${tag}</div>
          <div class="chore-history-paid">${esc(formatCount(e.paid_pebbles))}p</div>
          ${actor}
          ${multBlock}
          ${note}
        </div>
      `;
    }).join("");
    choreHistoryBody.innerHTML = rows;
  }
  // Dismiss wiring (including the drag-from-inside-to-outside fix) is
  // applied to every `.chores-modal-backdrop` in the Balance section.

  // ============================================================
  // mutations — go through the store
  // ============================================================
  // Snapshot of the chore-side fields the History page needs to render
  // a pending push without a server round-trip. Stored alongside the
  // queued POST/DELETE in localStorage; never sent to the server.
  function queueMetaFor(c) {
    if (!c) return null;
    return {
      chore_id: c.id,
      chore_name: c.short_name || c.name,
      icon: c.icon || "",
      icon_kind: c.icon_kind || "empty",
      one_off: !!c.one_off,
      base_pebbles: c.reward_pebbles || 0,
    };
  }
  // Parses a chore's `notes_template` into a static-text + field-token
  // sequence plus a deduped field list. Placeholder syntax:
  //   {Label}                       → text input
  //   {Label:Numeric}               → number input
  //   {Label:Date}                  → date input
  //   {Label:Select [a, b, "c, d"]} → select; quoted options keep commas
  // Same-labeled placeholders collapse to one field; the value substitutes
  // at every occurrence in the saved note.
  function parseNoteTemplate(template) {
    const tokens = [];
    const fields = [];
    const seen = new Set();
    if (!template) return { tokens, fields };
    const re = /\{([^{}]+)\}/g;
    let last = 0, m;
    while ((m = re.exec(template)) !== null) {
      if (m.index > last) tokens.push({ kind: "text", text: template.slice(last, m.index) });
      const spec = parseNoteFieldSpec(m[1]);
      if (!seen.has(spec.key)) { seen.add(spec.key); fields.push(spec); }
      tokens.push({ kind: "field", key: spec.key });
      last = re.lastIndex;
    }
    if (last < template.length) tokens.push({ kind: "text", text: template.slice(last) });
    return { tokens, fields };
  }
  function parseNoteFieldSpec(inner) {
    const colon = inner.indexOf(":");
    let label, type = "text", options = null;
    if (colon === -1) {
      label = inner.trim();
    } else {
      label = inner.slice(0, colon).trim();
      const rest = inner.slice(colon + 1).trim();
      const lb = rest.indexOf("[");
      if (lb >= 0) {
        type = rest.slice(0, lb).trim().toLowerCase();
        const optsStr = rest.slice(lb + 1).replace(/\]\s*$/, "");
        options = parseNoteOptionList(optsStr);
      } else {
        type = rest.toLowerCase();
      }
    }
    return { key: label, label: label, type: type || "text", options: options };
  }
  function parseNoteOptionList(s) {
    const out = []; let cur = ""; let q = false;
    for (let i = 0; i < s.length; i++) {
      const ch = s[i];
      if (ch === '"') { q = !q; continue; }
      if (ch === "," && !q) { const v = cur.trim(); if (v) out.push(v); cur = ""; continue; }
      cur += ch;
    }
    const tail = cur.trim(); if (tail) out.push(tail);
    return out;
  }
  function interpolateNoteTemplate(parsed, values) {
    return parsed.tokens.map(t => {
      if (t.kind === "text") return t.text;
      const v = values[t.key];
      return v == null ? "" : String(v);
    }).join("");
  }

  // Note-prompt modal — appears on tap for any chore whose
  // notes_template carries `{...}` placeholders. Runs entirely client-
  // side; submit calls doCompleteChore so the same offline-safe queue
  // path handles the resulting POST.
  const notePromptModal  = document.querySelector('[data-note-prompt-modal]');
  const notePromptForm   = notePromptModal?.querySelector('[data-note-prompt-form]');
  const notePromptFields = notePromptModal?.querySelector('[data-note-prompt-fields]');
  const notePromptTitle  = notePromptModal?.querySelector('[data-note-prompt-title]');
  let activeNotePrompt = null;

  function renderNotePromptField(f, i) {
    const id = `note-prompt-field-${i}`;
    const keyAttr = esc(f.key);
    const typeAttr = esc(f.type || "text");
    const label = `<label class="field-label" for="${id}">${esc(f.label)}</label>`;
    let input;
    if (f.type === "select" && f.options && f.options.length) {
      const opts = ['<option value=""></option>']
        .concat(f.options.map(o => `<option value="${esc(o)}">${esc(o)}</option>`))
        .join("");
      input = `<select id="${id}" data-prompt-key="${keyAttr}" data-prompt-type="${typeAttr}">${opts}</select>`;
    } else if (f.type === "numeric" || f.type === "number") {
      input = `<input id="${id}" type="number" inputmode="decimal" data-prompt-key="${keyAttr}" data-prompt-type="${typeAttr}" autocomplete="off">`;
    } else if (f.type === "date") {
      input = `<input id="${id}" type="date" data-prompt-key="${keyAttr}" data-prompt-type="${typeAttr}" autocomplete="off">`;
    } else {
      input = `<input id="${id}" type="text" data-prompt-key="${keyAttr}" data-prompt-type="${typeAttr}" autocomplete="off">`;
    }
    return `<div class="form-section">${label}${input}</div>`;
  }
  // Map a raw form value to the type implied by the placeholder.
  // Empty strings become null so the server stores `null` rather than
  // `""` (or `NaN`/0 for numerics) — the template still interpolates
  // to an empty string at the display layer.
  function coerceNoteValue(raw, type) {
    if (raw == null || raw === "") return null;
    if (type === "numeric" || type === "number") {
      const n = Number(raw);
      return Number.isFinite(n) ? n : null;
    }
    return String(raw);
  }
  function openNotePromptModal(chore, parsed) {
    if (!notePromptModal || !notePromptForm || !notePromptFields) return;
    activeNotePrompt = { chore, parsed };
    if (notePromptTitle) notePromptTitle.textContent = chore.short_name || chore.name || "Notes";
    notePromptFields.innerHTML = parsed.fields.map((f, i) => renderNotePromptField(f, i)).join("");
    notePromptModal.classList.remove("hidden");
    scrollModalToTop(notePromptModal);
    const first = notePromptFields.querySelector("input, select, textarea");
    first?.focus();
  }
  function closeNotePrompt() {
    notePromptModal?.classList.add("hidden");
    activeNotePrompt = null;
    if (notePromptFields) notePromptFields.innerHTML = "";
  }
  notePromptForm?.addEventListener("submit", e => {
    e.preventDefault();
    if (!activeNotePrompt) { closeNotePrompt(); return; }
    const { chore, parsed } = activeNotePrompt;
    const values = {};
    notePromptFields.querySelectorAll("[data-prompt-key]").forEach(el => {
      values[el.dataset.promptKey] = coerceNoteValue(el.value, el.dataset.promptType);
    });
    const note = interpolateNoteTemplate(parsed, values);
    closeNotePrompt();
    doCompleteChore(chore, { note: note, noteValues: values });
  });
  wireModalDismiss(notePromptModal, { onCancel: closeNotePrompt, onBackdrop: closeNotePrompt });

  function completeChore(id) {
    const c = ChoreStore.get(parseInt(id, 10));
    if (!c) return;
    const template = (c.notes_template || "").toString();
    if (template) {
      const parsed = parseNoteTemplate(template);
      if (parsed.fields.length > 0) {
        openNotePromptModal(c, parsed);
        return;
      }
      // Template with no placeholders — store the literal text verbatim.
      doCompleteChore(c, { note: template, noteValues: null });
      return;
    }
    doCompleteChore(c, { note: null, noteValues: null });
  }

  async function doCompleteChore(c, opts) {
    const note = opts && opts.note;
    const noteValues = opts && opts.noteValues;
    const sid = String(c.id);
    const clickAt = new Date().toISOString();
    localClickTs.set(sid, Date.now());

    ChoreStore.patch(c.id, {
      done_count_today: (c.done_count_today || 0) + 1,
      last_completed_at: clickAt,
      last_actor_username: VIEWER_USERNAME || c.last_actor_username,
    });

    const body = { client_completed_at: clickAt, tab_id: TAB_ID };
    const overrides = {};
    if (note != null && note !== "") overrides.note = note;
    if (noteValues && Object.keys(noteValues).length > 0) overrides.note_values = noteValues;
    if (Object.keys(overrides).length > 0) body.chore_completion = overrides;

    if (!navigator.onLine || reloadPending) {
      enqueue({ url: `/chores/items/${c.id}/completion`, method: "POST",
                body: body, meta: queueMetaFor(c) });
      return;
    }

    inFlight.add(sid);
    try {
      const data = await api(`/chores/items/${c.id}/completion`, "POST", body);
      reconcile(data);
      if (data.skipped) flash(data.skipped_reason || "Cooldown — no payout", "warn");
      else if (data.paid) flash(`+${formatCount(data.paid)}p`);
      (data.achieved_goals || []).forEach(g => {
        const tail = g.pebbles ? ` +${formatCount(g.pebbles)}p` : "";
        flash(`🏆 ${g.name}${tail}`, "ok");
      });
    } catch (err) {
      if (isTransientError(err)) {
        // Network / rate-limit / upstream-503: queue so the next flush
        // (online event, Monitor reconnect, scheduled retry) sends it.
        // User never sees an "Error" flash — their tap was accepted
        // locally and will sync.
        enqueue({ url: `/chores/items/${c.id}/completion`, method: "POST",
                  body: body, meta: queueMetaFor(c) });
        setConnDot("syncing");
        scheduleQueueRetry();
      } else {
        flash("Couldn't complete: " + err.message, "error");
      }
    } finally { inFlight.delete(sid); }
  }

  // Back-off retry for the offline queue when we hit a soft failure
  // (429 / 5xx). We don't burn the CPU polling; one timer per active
  // back-off, with growing intervals capped at 60s.
  let queueRetryTimer = null;
  let queueRetryDelay = 2000;
  function scheduleQueueRetry() {
    if (queueRetryTimer) return;
    if (reloadPending) return;
    queueRetryTimer = setTimeout(async () => {
      queueRetryTimer = null;
      await flushQueue();
      if (loadQueue().length === 0) {
        queueRetryDelay = 2000;
      } else {
        queueRetryDelay = Math.min(queueRetryDelay * 2, 60000);
        scheduleQueueRetry();
      }
    }, queueRetryDelay);
  }

  // Triggered by the rotate button on the Edit Chore modal head. The
  // button is only visible when the chore is a current Hot Pick.
  // Optimistic local removal so the cell disappears immediately; the
  // Monitor "hot_picks_refreshed" broadcast triggers cold-boot sync
  // that pulls in the replacement's multiplier.
  async function rotateHotPick(id) {
    const cid = parseInt(id, 10);
    const c = ChoreStore.get(cid);
    if (!c) return;
    const prev = c.hot_multiplier;
    ChoreStore.patch(cid, { hot_multiplier: null });
    try {
      await api(`/chores/hot_picks/${cid}/rotate`, "POST", { tab_id: TAB_ID });
      flash("Swapped");
    } catch (err) {
      // On any failure path, restore the optimistic removal so the
      // user doesn't see the cell vanish in error.
      ChoreStore.patch(cid, { hot_multiplier: prev });
      if (err.status === 403) flash("Only household managers can change Hot Picks.", "error");
      else if (err.status === 404) flash("Already swapped — nothing to do.", "warn");
      else if (isTransientError(err)) flash("Couldn't swap — try again", "warn");
      else flash("Couldn't swap: " + err.message, "error");
    }
  }

  async function undoLastCompletion(id) {
    const c = ChoreStore.get(parseInt(id, 10));
    if (!c) return;
    const sid = String(id);
    const priorDoneCount = c.done_count_today || 0;
    ChoreStore.patch(c.id, {
      done_count_today: Math.max(0, priorDoneCount - 1),
    });
    localClickTs.set(sid, Date.now());
    if (!navigator.onLine || reloadPending) {
      enqueue({ url: `/chores/items/${c.id}/completion`, method: "DELETE",
                meta: queueMetaFor(c) });
      return;
    }
    inFlight.add(sid);
    try {
      const data = await api(`/chores/items/${c.id}/completion`, "DELETE");
      reconcile(data);
      flash("Undone", "warn");
    } catch (err) {
      if (isTransientError(err)) {
        enqueue({ url: `/chores/items/${c.id}/completion`, method: "DELETE",
                  meta: queueMetaFor(c) });
        setConnDot("syncing");
        scheduleQueueRetry();
      } else {
        ChoreStore.patch(c.id, { done_count_today: priorDoneCount });
        flash("Nothing to undo", "warn");
      }
    } finally { inFlight.delete(sid); }
  }

  // Apply a server payload to the store. Two shapes:
  //   * { chore: {...}, ... } — full chore JSON (mutation responses).
  //   * { chores: [...], active_chore_ids: [...], lookahead: {...} } — sync.
  function reconcile(data) {
    if (!data) return;
    if (data.chore) {
      const id = data.chore.id;
      const localMs = localClickTs.get(String(id)) || 0;
      const serverMs = data.server_ts ? new Date(data.server_ts).getTime() : Date.now();
      if (!localMs || serverMs >= localMs) ChoreStore.upsert(data.chore);
    }
    if (Array.isArray(data.chores)) {
      data.chores.forEach(c => {
        const localMs = localClickTs.get(String(c.id)) || 0;
        const serverMs = data.server_ts ? new Date(data.server_ts).getTime() :
                         c.updated_at ? new Date(c.updated_at).getTime() : Date.now();
        if (!localMs || serverMs >= localMs) ChoreStore.upsert(c);
      });
    }
    // Same invariant as the bootstrap path: `active_chore_ids` is the
    // canonical accessible set. Anything cached locally that isn't in
    // it (archived, reassigned, household-changed) is dropped. Empty
    // payloads are NEVER valid here either — a real user always has
    // *some* chores, and `chores` is incremental so empty `chores`
    // does NOT imply empty active set; the active_chore_ids array is
    // what the server is asserting authoritatively.
    if (Array.isArray(data.active_chore_ids) && data.active_chore_ids.length > 0) {
      const activeIds = new Set(data.active_chore_ids);
      ChoreStore.all().forEach(c => {
        if (!activeIds.has(c.id)) ChoreStore.remove(c.id);
      });
    }
    if (data.lookahead) ChoreStore.setLookahead(data.lookahead);
    if (Array.isArray(data.daily_ids)) ChoreStore.setDailyIds(data.daily_ids);
    if (data.archived_chore_id) ChoreStore.remove(data.archived_chore_id);

    if (data.today_earnings != null) setTodayEarnings(data.today_earnings);
    if (data.balance != null) setLifetimeBalance(data.balance);
  }

  function updateBalancePill() {
    const el = document.querySelector("[data-balance]");
    if (!el) return;
    const v = root?.dataset.balanceToday;
    if (v != null) el.textContent = formatCount(v);
  }
  // Single, intentional writer for the header pill. EVERY page shows
  // today_earnings here — never lifetime. Any handler that wants to
  // update the pill must funnel through this so the next refactor
  // can't accidentally pass lifetime back in.
  function setTodayEarnings(value) {
    if (value == null) return;
    if (root) root.dataset.balanceToday = value;
    const el = document.querySelector("[data-balance]");
    if (el) el.textContent = formatCount(value);
  }
  // Separate writer for the Balance page's lifetime card. NEVER
  // touches `[data-balance]`.
  function setLifetimeBalance(value) {
    if (value == null) return;
    if (root) root.dataset.balanceTotal = value;
    const el = document.querySelector("[data-lifetime-balance]");
    if (el) el.textContent = formatCount(value);
  }

  // ============================================================
  // sync — diff endpoint, cold boot + reconnect
  // ============================================================
  const SYNC_TS_KEY = "chores:lastSyncTs:v1";
  const SYNC_DAY_KEY = "chores:lastSyncDay:v1";
  let syncInFlight = false;
  async function fullSync({ force = false } = {}) {
    if (syncInFlight || !navigator.onLine || reloadPending) return;
    syncInFlight = true;
    setSyncBadge(true);
    try {
      const since = !force ? (localStorage.getItem(SYNC_TS_KEY) || "") : "";
      const lastDay = localStorage.getItem(SYNC_DAY_KEY);
      const localDay = currentChoreDayIso();
      // If the last successful sync was on a prior chore-day, skip
      // `since` so the server returns the full set (hot picks,
      // today_visible, done_count_today all need a clean slate).
      // The server has the same defense, but doing it client-side
      // shaves a round-trip's worth of stale-render flicker.
      const useSince = since && lastDay === localDay;
      const url = useSince ? `/chores/sync?since=${encodeURIComponent(since)}` : "/chores/sync";
      const data = await api(url, "GET");
      reconcile(data);
      if (data.server_ts) localStorage.setItem(SYNC_TS_KEY, data.server_ts);
      if (data.day_key) localStorage.setItem(SYNC_DAY_KEY, data.day_key);
      setSyncBadge(false);
      // Pair every successful sync with a shell refresh: the server
      // may have changed the underlying HTML (a new chore in the
      // bootstrap JSON, an asset URL bump, a layout tweak) and we
      // never want the cached shell lagging behind. Without this the
      // user could see the live data update but the offline-reopen
      // experience would still serve yesterday's shell.
      pingSwRefresh();
      // Off-screen views may want to re-render after a fresh sync —
      // mirror the Monitor path's bus event so any mounted view
      // reacts identically to local resyncs and remote broadcasts.
      broadcastRemoteChange("full_sync");
    } catch (e) { setSyncBadge(false, true); }
    finally { syncInFlight = false; }
  }

  // ============================================================
  // search — works against the store, both views
  // ============================================================
  function score(needle, name, aliases) {
    if (!needle) return 1;
    const n = needle.toLowerCase();
    const fields = [
      { text: (name || "").toLowerCase(), weight: 1.0 },
      ...((aliases || []).map(a => ({ text: a.toLowerCase(), weight: 0.5 }))),
    ];
    let best = 0;
    for (const { text, weight } of fields) {
      if (!text) continue;
      const idx = text.indexOf(n);
      let local = 0;
      if (idx === 0) local = 1.0;
      else if (idx > 0) local = 0.7 - Math.min(idx, 10) * 0.02;
      else if (fuzzyMatch(n, text)) local = 0.3;
      else continue;
      best = Math.max(best, local * weight);
    }
    return best;
  }
  function fuzzyMatch(needle, hay) {
    let i = 0, j = 0;
    while (i < needle.length && j < hay.length) {
      if (needle[i] === hay[j]) i++;
      j++;
    }
    return i === needle.length;
  }
  const SEARCH_EXTRA_LIMIT = 10;
  function currentSearchQuery() {
    return document.querySelector("[data-chores-search]")?.value?.trim() || "";
  }
  function applySearch(q) {
    // Filter the always-visible sections — Grid view's grid AND the
    // Today view's Dailies + Scheduled — by hiding cells that don't
    // match. data-chores-circles is legacy; the live containers are
    // now per-section (dailies / overdue).
    [
      document.querySelector("[data-chores-grid]"),
      document.querySelector("[data-chores-dailies]"),
      document.querySelector("[data-chores-today]"),
      document.querySelector("[data-chores-overdue]"),
    ].filter(Boolean).forEach(container => {
      const cards = Array.from(container.children);
      if (!q) { cards.forEach(c => c.style.display = ""); return; }
      cards.forEach(card => {
        const c = ChoreStore.get(parseInt(card.dataset.choreId, 10));
        if (!c) return;
        const s = score(q, c.short_name || c.name, c.aliases || []);
        card.style.display = s > 0 ? "" : "none";
      });
    });
    renderSearchExtra(q);
  }
  // While searching on the Today view, surface up to N matches from
  // the full Grid set that AREN'T already on screen (i.e. not in
  // Dailies and not in Scheduled). Hidden entirely when the query is
  // empty so it never adds noise to the resting Today layout.
  function renderSearchExtra(q) {
    const section = document.querySelector("[data-chores-search-extra-section]");
    const container = document.querySelector("[data-chores-search-extra]");
    if (!section || !container) return;
    if (!q) {
      section.hidden = true;
      if (container.firstChild) container.replaceChildren();
      return;
    }
    const exclude = new Set([
      ...ChoreStore.dailiesList().map(c => c.id),
      ...ChoreStore.todayList().map(c => c.id),
      ...ChoreStore.overdueList().map(c => c.id),
    ]);
    const scored = [];
    for (const c of ChoreStore.activeForGrid()) {
      if (exclude.has(c.id)) continue;
      const s = score(q, c.short_name || c.name, c.aliases || []);
      if (s > 0) scored.push({ c, s });
    }
    scored.sort((a, b) => b.s - a.s);
    const picks = scored.slice(0, SEARCH_EXTRA_LIMIT).map(x => x.c);
    section.hidden = picks.length === 0;
    reconcileExtras(container, picks);
  }
  // Local diff for the extras container — uses grid-style cards (not
  // circles) so the user can tell at a glance these aren't part of
  // today's lineup, just hits from the broader Grid set. Same
  // patch-don't-clear pattern as Views.reconcileSection.
  function reconcileExtras(container, items) {
    const desired = new Map(items.map(c => [c.id, c]));
    Array.from(container.children).forEach(child => {
      const id = parseInt(child.dataset.choreId, 10);
      if (!desired.has(id)) child.remove();
    });
    const existing = new Map();
    Array.from(container.children).forEach(child => {
      existing.set(parseInt(child.dataset.choreId, 10), child);
    });
    let cursor = container.firstElementChild;
    for (const c of items) {
      const have = existing.get(c.id);
      if (cursor && cursor === have) {
        patchGridCard(cursor, c);
        cursor = cursor.nextElementSibling;
      } else if (have) {
        container.insertBefore(have, cursor);
        patchGridCard(have, c);
      } else {
        container.insertBefore(renderGridCard(c), cursor);
      }
    }
  }
  document.querySelector('[data-chores-search]')?.addEventListener("input",
    e => applySearch(e.target.value.trim()));
  // Wire any input that has a sibling `[data-search-clear]` button: show
  // the × while the field has text, clear + refocus on click. Used by
  // the toolbar search and the History filter.
  function wireSearchClear(scope = document) {
    scope.querySelectorAll("[data-search-clear]").forEach(btn => {
      const wrap = btn.parentElement;
      const input = wrap?.querySelector("input");
      if (!input) return;
      const sync = () => { btn.hidden = !input.value; };
      sync();
      input.addEventListener("input", sync);
      btn.addEventListener("click", () => {
        input.value = "";
        input.dispatchEvent(new Event("input", { bubbles: true }));
        input.focus();
        sync();
      });
    });
  }
  wireSearchClear();

  // ============================================================
  // multiplier toggle + modal
  // ============================================================
  let multiplierActive = false;
  let multiplierTargetCard = null;
  const multiplierBtn = document.querySelector('[data-multiplier-toggle]');
  const multiplierModal = document.querySelector('[data-multiplier-modal]');
  multiplierBtn?.addEventListener("click", () => {
    multiplierActive = !multiplierActive;
    multiplierBtn.classList.toggle("active", multiplierActive);
  });
  function openMultiplierModal(card) {
    if (!multiplierModal) return;
    multiplierTargetCard = card;
    multiplierModal.querySelector('[data-multiplier-label]').textContent =
      card.dataset.choreShort || card.dataset.choreName;
    multiplierModal.querySelector('[data-multiplier-input]').value = 2;
    multiplierModal.classList.remove("hidden");
  }
  function closeMultiplierModal() {
    multiplierModal?.classList.add("hidden");
    multiplierTargetCard = null;
    multiplierActive = false;
    multiplierBtn?.classList.remove("active");
  }
  wireModalDismiss(multiplierModal, {
    onCancel:   closeMultiplierModal,
    onBackdrop: closeMultiplierModal,
  });
  multiplierModal?.querySelectorAll('[data-mult]').forEach(btn =>
    btn.addEventListener("click", () => { multiplierModal.querySelector('[data-multiplier-input]').value = btn.dataset.mult; }));
  multiplierModal?.querySelector('[data-multiplier-submit]')?.addEventListener("click", async () => {
    const n = Math.max(1, Math.min(50, parseInt(multiplierModal.querySelector('[data-multiplier-input]').value, 10) || 1));
    const card = multiplierTargetCard;
    closeMultiplierModal();
    if (!card) return;
    for (let i = 0; i < n; i++) await completeChore(card.dataset.choreId);
  });

  // ============================================================
  // edit modal
  // ============================================================
  const editModal = document.querySelector("[data-chore-modal]");
  const editForm  = editModal?.querySelector('[data-chores-form]');
  function setField(name, value) {
    const el = editForm?.querySelector(`[data-field="${name}"]`);
    if (el == null) return;
    el.value = value ?? "";
  }
  function getField(name) { return editForm?.querySelector(`[data-field="${name}"]`)?.value; }

  let currentChoreId = null;
  let modalLockedFor = null;
  const WDAY_KEYS = ["sun", "mon", "tue", "wed", "thu", "fri", "sat"];

  function setPillValue(groupKey, value) {
    const group = editForm.querySelector(`[data-pill-group="${groupKey}"]`);
    if (!group) return;
    group.querySelectorAll(".pill").forEach(p => {
      p.classList.toggle("active", String(p.dataset.value) === String(value ?? ""));
    });
    const input = editForm.querySelector(`[data-field="${groupKey}"]`);
    if (input) input.value = value ?? "";
  }
  function bindPillGroups() {
    editForm.querySelectorAll(".pill-group[data-pill-group]").forEach(group => {
      const key = group.dataset.pillGroup;
      group.addEventListener("click", e => {
        const pill = e.target.closest(".pill");
        if (!pill || pill.classList.contains("chip-day")) return;
        e.preventDefault();
        if (key === "freq") {
          if (pill.dataset.value === "weekdays") {
            setPillValue("freq", "weekly");
            syncWeekdayChips(["mon", "tue", "wed", "thu", "fri"]);
            // User-initiated freq pick auto-fills starts_on with today
            // (only when blank — never overwrites). MUST stay in this
            // click handler and NOT in syncFreqRow: programmatic
            // populate (e.g. openEditModal restoring a saved chore)
            // also runs syncFreqRow, and silently mutating
            // `starts_on` there would change the chore's due date on
            // save even though the user never touched it.
            ensureStartsOnSet();
            syncFreqRow();
            return;
          }
          setPillValue("freq", pill.dataset.value);
          if (pill.dataset.value !== "never") ensureStartsOnSet();
          syncFreqRow();
          return;
        }
        if (key === "threshold_preset") {
          setPillValue("threshold_preset", pill.dataset.value);
          syncCooldownRow();
          return;
        }
        if (key === "after_chore_when") {
          setPillValue("after_chore_when", pill.dataset.value);
          syncAfterChoreLaterRow();
          return;
        }
        setPillValue(key, pill.dataset.value);
      });
    });
    editForm.querySelector('[data-reward-quicks]')?.addEventListener("click", e => {
      const pill = e.target.closest("[data-reward]");
      if (!pill) return;
      e.preventDefault();
      const v = pill.dataset.reward;
      editForm.querySelectorAll('[data-reward-quicks] .pill').forEach(p => p.classList.remove("active"));
      pill.classList.add("active");
      const custom = editForm.querySelector('.reward-custom');
      if (v === "custom") { custom?.classList.remove("hidden"); custom?.focus(); }
      else { custom?.classList.add("hidden"); if (custom) custom.value = v; }
      updateRewardHint();
    });
    editForm.querySelector('[data-weekday-chips]')?.addEventListener("click", e => {
      const btn = e.target.closest('[data-day]');
      if (!btn) return;
      e.preventDefault();
      btn.classList.toggle("active");
      syncWeekdaysHelperHighlight();
    });
    editForm.querySelector('[data-month-day-pane]')?.addEventListener("click", e => {
      const btn = e.target.closest('[data-day]');
      if (!btn) return;
      e.preventDefault();
      btn.classList.toggle("active");
    });
    editForm.querySelector('[data-month-mode-tabs]')?.addEventListener("click", e => {
      const btn = e.target.closest('[data-month-mode]');
      if (!btn) return;
      e.preventDefault();
      const mode = btn.dataset.monthMode;
      editForm.querySelectorAll('[data-month-mode-tabs] .pill').forEach(p =>
        p.classList.toggle("active", p.dataset.monthMode === mode));
      editForm.querySelector('[data-month-day-pane]')?.classList.toggle("hidden", mode !== "day-of-month");
      editForm.querySelector('[data-month-nth-pane]')?.classList.toggle("hidden", mode !== "nth-weekday");
    });
    editForm.querySelector('[data-cooldown-amount]')?.addEventListener("input", syncCustomCooldown);
    editForm.querySelector('[data-cooldown-unit]')?.addEventListener("change", syncCustomCooldown);
    editForm.querySelector('[data-field="one_off"]')?.addEventListener("change", () => {
      syncSingleTask();
      // User-initiated single-task toggle auto-fills Due Date with
      // today (only when blank — never overwrites). Mirrors the
      // pre-marked_due_at behavior of stamping starts_on, just on
      // the new field. Edit-populate is intentionally NOT routed
      // through here: opening an existing one-off with no due date
      // should leave it blank rather than silently rewriting state
      // the chore never had.
      if (isSingleTask()) ensureMarkedDueSet();
    });
    editForm.querySelector('[data-field="starts_on"]')?.addEventListener("change", syncStartsOnDependents);
    // Parent Chore picker: turns this chore into a sub-chore. Sub-chores
    // MUST be single tasks (the server enforces it; mirror in the UI by
    // forcing the toggle on and disabling it so the user can't fight
    // a coercion they didn't initiate).
    editForm.querySelector('[data-field="parent_chore_id"]')?.addEventListener("change", syncParentChoreLock);
  }

  // Mirrors syncAnchorPickerButton — render the currently-selected
  // parent chore into the trigger button. Falls back to the "None"
  // placeholder when the hidden input is empty. Also toggles the
  // Clear chip's visibility so it only shows when a parent is set.
  function syncParentPickerButton() {
    const idEl = editForm?.querySelector('[data-field="parent_chore_id"]');
    const iconEl = editForm?.querySelector('[data-parent-picker-icon]');
    const labelEl = editForm?.querySelector('[data-parent-picker-label]');
    const clearBtn = editForm?.querySelector('[data-parent-picker-clear]');
    if (!idEl || !iconEl || !labelEl) return;
    const id = parseInt(idEl.value, 10);
    const chore = Number.isFinite(id) ? ChoreStore.get(id) : null;
    if (!chore) {
      iconEl.innerHTML = "";
      labelEl.textContent = "None";
      if (clearBtn) clearBtn.hidden = true;
      return;
    }
    iconEl.innerHTML = iconHTML(chore);
    labelEl.textContent = chore.short_name || chore.name || "—";
    if (clearBtn) clearBtn.hidden = false;
  }

  function syncParentChoreLock() {
    const idEl = editForm?.querySelector('[data-field="parent_chore_id"]');
    const oneOffCb = editForm?.querySelector('[data-field="one_off"]');
    if (!idEl || !oneOffCb) return;
    const hasParent = !!idEl.value;
    if (hasParent) {
      oneOffCb.checked = true;
      oneOffCb.disabled = true;
      syncSingleTask();
    } else {
      oneOffCb.disabled = false;
    }
  }
  function isSingleTask() { return editForm.querySelector('[data-field="one_off"]')?.checked === true; }
  function syncSingleTask() {
    // PURE UI sync — only toggles row visibility. Auto-filling
    // starts_on lives in the user-change handler instead, so opening
    // an existing single-task chore with no starts_on doesn't silently
    // stamp today's date into the form and save it back as a date the
    // chore never had.
    editForm.querySelectorAll('[data-recurring-only]').forEach(el => el.classList.toggle("hidden", isSingleTask()));
  }
  // Fill starts_on with today's date IFF it's currently blank. Called
  // when the user picks a recurrence freq so the schedule anchor isn't
  // silently empty.
  function ensureStartsOnSet() {
    const startsField = editForm.querySelector('[data-field="starts_on"]');
    if (startsField && !startsField.value) startsField.value = todayIso();
  }
  // Fill marked_due_at (the Due Date input) with today IFF blank.
  // Called when the user toggles Single Task — gives one-offs the
  // sensible default of "needs to get done today" without overriding
  // a date the user already picked.
  function ensureMarkedDueSet() {
    const dueField = editForm.querySelector('[data-field="marked_due_at"]');
    if (dueField && !dueField.value) dueField.value = todayIso();
  }
  function syncCooldownRow() {
    const preset = editForm.querySelector('[data-field="threshold_preset"]')?.value || "";
    const customRow = editForm.querySelector('[data-cooldown-custom-row]');
    const hidden = editForm.querySelector('[data-field="threshold_seconds"]');
    if (preset === "custom") { customRow?.classList.remove("hidden"); syncCustomCooldown(); }
    else if (preset === "day-end") { customRow?.classList.add("hidden"); hidden.value = "-1"; }
    else { customRow?.classList.add("hidden"); hidden.value = preset || ""; }
  }
  function syncCustomCooldown() {
    const amt = parseInt(editForm.querySelector('[data-cooldown-amount]')?.value, 10) || 0;
    const unit = editForm.querySelector('[data-cooldown-unit]')?.value || "second";
    const factor = { second: 1, minute: 60, hour: 3600, day: 86400, week: 604800 }[unit] || 1;
    const seconds = Math.max(0, amt) * factor;
    const hidden = editForm.querySelector('[data-field="threshold_seconds"]');
    if (hidden) hidden.value = String(seconds);
  }
  function setCooldownSeconds(seconds) {
    if (seconds === -1) { setPillValue("threshold_preset", "day-end"); syncCooldownRow(); return; }
    const presets = [0, 3600, 10800, 21600, 43200, 86400, 172800, 604800];
    if (presets.includes(seconds)) {
      setPillValue("threshold_preset", seconds === 0 ? "" : String(seconds));
      syncCooldownRow();
    } else {
      setPillValue("threshold_preset", "custom");
      const { amount, unit } = bestCooldownDecomposition(seconds);
      const amtEl = editForm.querySelector('[data-cooldown-amount]');
      const unitEl = editForm.querySelector('[data-cooldown-unit]');
      if (amtEl) amtEl.value = amount;
      if (unitEl) unitEl.value = unit;
      syncCooldownRow();
    }
  }
  function bestCooldownDecomposition(seconds) {
    if (seconds % 604800 === 0) return { amount: seconds / 604800, unit: "week" };
    if (seconds % 86400 === 0)  return { amount: seconds / 86400,  unit: "day" };
    if (seconds % 3600 === 0)   return { amount: seconds / 3600,   unit: "hour" };
    if (seconds % 60 === 0)     return { amount: seconds / 60,     unit: "minute" };
    return { amount: seconds, unit: "second" };
  }
  // Render the currently-selected anchor into the trigger button.
  // Falls back to a placeholder when nothing is picked.
  function syncAnchorPickerButton() {
    const idEl = editForm.querySelector('[data-anchor-chore-id]');
    const iconEl = editForm.querySelector('[data-anchor-picker-icon]');
    const labelEl = editForm.querySelector('[data-anchor-picker-label]');
    if (!idEl || !iconEl || !labelEl) return;
    const id = parseInt(idEl.value, 10);
    const chore = Number.isFinite(id) ? ChoreStore.get(id) : null;
    if (!chore) {
      iconEl.innerHTML = "";
      labelEl.textContent = "Pick a chore…";
      return;
    }
    iconEl.innerHTML = iconHTML(chore);
    labelEl.textContent = chore.short_name || chore.name || "—";
  }

  // Walks `c`'s anchor chain looking for `targetId`. Depth-bounded to
  // mirror the server validator. Returns true if cycle would result.
  function anchorChainContains(c, targetId) {
    if (!targetId) return false;
    let cursor = c;
    const seen = new Set();
    for (let i = 0; i < 32; i++) {
      if (!cursor) return false;
      if (seen.has(cursor.id)) return false;
      seen.add(cursor.id);
      const nextId = cursor.recurrence?.anchor_chore_id;
      if (!nextId) return false;
      if (nextId === targetId) return true;
      cursor = ChoreStore.get(parseInt(nextId, 10));
    }
    return false;
  }

  // Reveal the dedicated "In X day/week/month" inputs only when the
  // user picks "Later…". Pill clicks elsewhere (Today / Tomorrow)
  // collapse it.
  function syncAfterChoreLaterRow() {
    const when = getField("after_chore_when") || "today";
    editForm.querySelector('[data-after-chore-later-wrap]')?.classList.toggle("hidden", when !== "later");
  }

  function syncFreqRow() {
    const freq = getField("freq") || "never";
    editForm.querySelector('[data-weekly-wrap]')?.classList.toggle("hidden", freq !== "weekly");
    editForm.querySelector('[data-monthly-wrap]')?.classList.toggle("hidden", freq !== "monthly");
    editForm.querySelector('[data-yearly-wrap]')?.classList.toggle("hidden", freq !== "yearly");
    editForm.querySelector('[data-interval-wrap]')?.classList.toggle("hidden",
      freq !== "custom" && freq !== "relative");
    editForm.querySelector('[data-after-chore-wrap]')?.classList.toggle("hidden",
      freq !== "after_chore");
    editForm.querySelector('[data-weekdays-wrap]')?.classList.add("hidden");
    syncAfterChoreLaterRow();
    if (freq === "weekly") {
      const chips = Array.from(editForm.querySelectorAll('[data-weekday-chips] .chip-day.active'));
      if (chips.length === 0) {
        const d = parseStartsOn();
        if (d) syncWeekdayChips([WDAY_KEYS[d.getDay()]]);
      }
    }
    if (freq === "monthly") {
      const anyActive = editForm.querySelector('[data-month-day-pane] .md-chip.active');
      if (!anyActive) {
        const d = parseStartsOn();
        if (d) editForm.querySelector(`[data-month-day-pane] [data-day="${d.getDate()}"]`)?.classList.add("active");
      }
    }
    syncStartsOnDependents();
    syncWeekdaysHelperHighlight();
  }
  function syncWeekdaysHelperHighlight() {
    const weekdaysPill = editForm.querySelector('[data-pill-group="freq"] [data-value="weekdays"]');
    if (!weekdaysPill) return;
    const freq = getField("freq");
    const sel = collectWeekdays();
    const SET = ["mon", "tue", "wed", "thu", "fri"];
    weekdaysPill.classList.toggle("active",
      freq === "weekly" && sel.length === 5 && SET.every(d => sel.includes(d)));
  }
  function syncStartsOnDependents() {
    const d = parseStartsOn();
    if (!d) return;
    const monthLabel = editForm.querySelector('[data-month-day-label]');
    if (monthLabel) monthLabel.textContent = d.getDate();
    const setPos = editForm.querySelector('[data-month-set-pos]');
    if (setPos && !setPos.dataset.userTouched) setPos.value = String(Math.floor((d.getDate() - 1) / 7) + 1);
    const wday = editForm.querySelector('[data-month-wday]');
    if (wday && !wday.dataset.userTouched) wday.value = WDAY_KEYS[d.getDay()];
    const yearlyLabel = editForm.querySelector('[data-yearly-label]');
    if (yearlyLabel) {
      const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
      yearlyLabel.textContent = `${months[d.getMonth()]} ${d.getDate()}`;
    }
  }
  function parseStartsOn() {
    const v = editForm.querySelector('[data-field="starts_on"]')?.value;
    if (!v) return null;
    const parts = v.split("-").map(Number);
    if (parts.length !== 3) return null;
    return new Date(parts[0], parts[1] - 1, parts[2]);
  }
  function syncWeekdayChips(days) {
    const wrap = editForm.querySelector('[data-weekday-chips]');
    if (!wrap) return;
    Array.from(wrap.children).forEach(btn => btn.classList.toggle("active", days.includes(btn.dataset.day)));
  }
  function collectWeekdays() {
    const wrap = editForm.querySelector('[data-weekday-chips]');
    return Array.from(wrap?.querySelectorAll('[data-day].active') || []).map(b => b.dataset.day);
  }
  function selectRewardPill(amount) {
    editForm.querySelectorAll('[data-reward-quicks] .pill').forEach(p => p.classList.remove("active"));
    const exact = editForm.querySelector(`[data-reward-quicks] [data-reward="${amount}"]`);
    if (exact) {
      exact.classList.add("active");
      editForm.querySelector('.reward-custom')?.classList.add("hidden");
    } else {
      editForm.querySelector('[data-reward-quicks] [data-reward="custom"]')?.classList.add("active");
      const custom = editForm.querySelector('.reward-custom');
      if (custom) { custom.classList.remove("hidden"); custom.value = amount; }
    }
    updateRewardHint();
  }

  // Sync the helper text under the pebble pill row to the active tier.
  // Reads the description directly off the pill (data-reward-hint), so
  // there's no JS-side copy of the tier descriptions to drift. For
  // "?" (custom) the hint is BLANK — the tier descriptions only apply
  // to the canonical 1/2/3/5/10/15/20 amounts, and a custom value
  // shouldn't claim any particular meaning. Picking a numeric pill
  // restores the hint.
  function updateRewardHint() {
    const hint = editForm.querySelector('.reward-hint[data-reward-hint]');
    if (!hint) return;
    const active = editForm.querySelector('[data-reward-quicks] .pill.active');
    const v = active?.dataset.reward;
    if (v === "custom") {
      hint.textContent = "";
    } else {
      hint.textContent = active?.dataset.rewardHint || "";
    }
  }
  function todayIso() {
    const d = new Date();
    const pad = n => String(n).padStart(2, "0");
    return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`;
  }
  function scrollModalToTop(modal) {
    if (!modal) return;
    modal.scrollTop = 0;
    modal.querySelector(".chores-modal")?.scrollTo?.(0, 0);
  }

  // Icon picker — single contenteditable block + corner upload.
  // Form-agnostic icon uploader. Reads & writes the canonical icon
  // value from a hidden `[data-icon-hidden]` (or legacy
  // `[data-field="icon"]`) inside the stack. The same widget covers:
  //   * type one emoji directly into the preview
  //   * paste an image / image URL / SVG XML / data: URL
  //   * drag-drop an image file
  //   * tap the upload chip to open the file picker
  //
  // Callers wire it once per form via `bindIconUploader(form)`. The
  // setter is exposed on `stack.__setIconValue` so `fillFromExisting`
  // logic in each form can hydrate it after `form.reset()`.
  function bindIconUploader(form) {
    const stack = form?.querySelector("[data-icon-stack]");
    if (!stack) return;
    const preview   = stack.querySelector("[data-icon-preview]");
    const uploadBtn = stack.querySelector("[data-icon-upload]");
    const fileInput = stack.querySelector("[data-icon-file]");
    // The chore form uses `data-field="icon"`; the goal form uses
    // `data-icon-hidden` (it doesn't share the chore form's field
    // convention). Either is fine.
    const hidden = stack.querySelector('[data-icon-hidden]')
                || stack.querySelector('[data-field="icon"]');
    function setIconValue(v, { renderFromValue = true, source = "user" } = {}) {
      if (hidden) hidden.value = v || "";
      // `source: "user"` (default) covers typing/paste/drop/upload/picker — any
      //   direct user action seals the field against future auto-suggest.
      // `source: "suggest"` is the LLM auto-fill — it must NOT seal so that
      //   a later title edit can replace the still-untouched suggestion.
      // `source: "hydrate"` is form load (new or edit) — the caller decides
      //   the dirty state explicitly (sealed if loaded with an existing icon).
      if (source === "user") stack.__iconUserDirty = true;
      if (!renderFromValue || !preview) return;
      if (!v) { preview.innerHTML = ""; return; }
      if (v.startsWith("data:image/") || v.startsWith("http://") || v.startsWith("https://")) {
        preview.innerHTML = `<img src="${esc(v)}" alt="" loading="lazy" draggable="false">`;
      } else if (v.startsWith("<svg")) {
        preview.innerHTML = v;
      } else if (v.startsWith("ti-")) {
        preview.innerHTML = `<i class="ti ${esc(v)} icon-ti" aria-hidden="true"></i>`;
      } else {
        preview.textContent = v;
      }
    }
    stack.__setIconValue = setIconValue;
    stack.__iconUserDirty = false;
    stack.__suggestFillable = true;

    // Typed input is constrained to ONE grapheme cluster (one emoji-ish
    // glyph). Without this, typing letters into the preview showed them
    // at the preview's font-size — huge scribbles that looked broken.
    // Image / SVG / URL strings always come in via the paste/drop/file
    // path, never through typing, so clipping to one glyph is safe.
    const segmenter = (typeof Intl !== "undefined" && Intl.Segmenter)
      ? new Intl.Segmenter(undefined, { granularity: "grapheme" }) : null;
    function firstGrapheme(s) {
      if (!s) return "";
      if (segmenter) {
        for (const piece of segmenter.segment(s)) return piece.segment;
        return "";
      }
      return Array.from(s)[0] || "";
    }
    function placeCaretAtEnd(el) {
      const range = document.createRange();
      range.selectNodeContents(el);
      range.collapse(false);
      const sel = window.getSelection();
      sel?.removeAllRanges();
      sel?.addRange(range);
    }
    preview?.addEventListener("input", () => {
      const raw = (preview.textContent || "").trim();
      // Pasted SVG / URL strings are caught by the paste handler with
      // preventDefault — they never reach `input`. So anything we see
      // here is intentional keyboard typing of an emoji-or-letter glyph.
      const glyph = firstGrapheme(raw);
      if (raw !== glyph) {
        preview.textContent = glyph;
        placeCaretAtEnd(preview);
      }
      setIconValue(glyph, { renderFromValue: false });
    });
    preview?.addEventListener("paste", async e => {
      const items = Array.from(e.clipboardData?.items || []);
      const imageItem = items.find(it => it.type.startsWith("image/"));
      if (imageItem) {
        e.preventDefault();
        const file = imageItem.getAsFile();
        if (file) { const v = await readFileAsValue(file); if (v) setIconValue(v); }
        return;
      }
      const text = (e.clipboardData?.getData?.("text/plain") || "").trim();
      if (!text) return;
      if (text.startsWith("<svg") || text.startsWith("http://") || text.startsWith("https://") || text.startsWith("data:image/")) {
        e.preventDefault();
        setIconValue(text);
      }
    });
    // Image drops route through the cropper so the user lands on the
    // crop/name/bg-removal flow with the file pre-loaded — rather than
    // committing a raw data URL straight to the chore field.
    ["dragover", "drop"].forEach(evt => stack.addEventListener(evt, e => {
      e.preventDefault();
      if (evt !== "drop") return;
      const file = Array.from(e.dataTransfer?.files || []).find(f => f.type.startsWith("image/"));
      if (!file) return;
      document.dispatchEvent(new CustomEvent("chore-icon-cropper-open", {
        detail: { stack, file },
      }));
    }));
    uploadBtn?.addEventListener("click", e => { e.preventDefault(); fileInput?.click(); });
    fileInput?.addEventListener("change", async () => {
      const file = fileInput.files?.[0];
      if (!file) return;
      const v = await readFileAsValue(file);
      if (v) setIconValue(v);
      fileInput.value = "";
    });
  }
  function readFileAsValue(file) {
    return new Promise(resolve => {
      if (!file || !file.type.startsWith("image/")) return resolve(null);
      const reader = new FileReader();
      reader.onload = () => resolve(reader.result || null);
      reader.onerror = () => resolve(null);
      if (file.type === "image/svg+xml") reader.readAsText(file);
      else reader.readAsDataURL(file);
    });
  }
  function setIconField(v) {
    const stack = editForm?.querySelector("[data-icon-stack]");
    if (!stack?.__setIconValue) return;
    stack.__setIconValue(v || "", { source: "hydrate" });
    // Seal against auto-suggest only when hydrated WITH an icon already set
    // (editing a chore that already has one). Empty hydration leaves the
    // field open for the title-driven suggester to fill in on first input.
    stack.__iconUserDirty = !!v;
    stack.__suggestFillable = !v;
  }

  // ============================================================
  // Shared icon pool — emoji + Tabler icons + (future) custom icons,
  // tagged by kind. Lazy-loaded once per page; the picker AND the
  // title-driven suggester both score against this.
  //
  // MIRRORED in Ruby at `app/service/icon_pool.rb` for server-side
  // use (Jil `Icon.suggest`, etc.). If you change scoring tiers,
  // query passes, normalization, variant expansion, the irregular-
  // plural map, or stop words here, port the same change to the Ruby
  // module in the same commit. Both consume the same JSON indexes.
  //
  // Custom icons TODO: when user-uploaded icons land, fetch them
  // from `/chores/custom_icons.json` (or similar), tag with
  // `_kind: "custom"`, and append to the pool. The render path
  // already handles arbitrary value strings — only the suggester's
  // scoring needs to make sure custom-icon keywords are included.
  // ============================================================
  const IconPool = (function() {
    let GLOBAL_POOL = null;     // emoji + ti, fetched once per page
    let CUSTOM_POOL = [];       // per-household, refreshable on upload/delete
    let loadPromise = null;
    const customListeners = [];

    async function fetchJson(url) {
      // Explicit Accept: application/json so the chores SW JSON-cache
      // branch (chores_worker.js line ~301) actually persists the
      // response. Without it the picker pool — including custom icons —
      // wouldn't be available offline.
      try {
        const res = await fetch(url, {
          credentials: "same-origin",
          headers: { "Accept": "application/json" },
        });
        return res.ok ? await res.json() : [];
      } catch (_e) {
        return [];
      }
    }
    function tag(arr, kind) {
      return arr.map(r => ({ c: r.c, n: r.n, k: r.k, _kind: kind, _id: r.id }));
    }

    async function load() {
      if (!loadPromise) {
        loadPromise = (async () => {
          const [emoji, icons, custom] = await Promise.all([
            fetchJson("/emoji_index.json"),
            fetchJson("/icons_index.json"),
            fetchJson("/chores/icons.json"),
          ]);
          CUSTOM_POOL = tag(custom, "custom");
          // Emoji-first concat so default-order tiebreak prefers emoji.
          GLOBAL_POOL = tag(emoji, "emoji").concat(tag(icons, "ti"));
        })();
      }
      await loadPromise;
      return composite(); // freshly recomposed so refreshCustom() takes effect
    }

    // Composite pool: household custom icons first (so the user's own
    // uploads win ties), then emoji, then ti. Recomputed each call so
    // a refreshed CUSTOM_POOL is reflected immediately.
    function composite() {
      return CUSTOM_POOL.concat(GLOBAL_POOL || []);
    }

    // Re-fetch just the custom pool. Notifies listeners (the open
    // picker re-renders).
    async function refreshCustom() {
      const fresh = await fetchJson("/chores/icons.json");
      CUSTOM_POOL = tag(fresh, "custom");
      // Invalidate per-row score caches on touched rows next render.
      customListeners.forEach(fn => { try { fn(); } catch (_e) {} });
    }
    function onCustomChanged(fn) { customListeners.push(fn); }

    function normalize(q) {
      return (q || "").toLowerCase().replace(/[\s\-_:]+/g, "");
    }

    // English irregular plurals — folded both ways so "teeth" → "tooth"
    // AND "tooth" → "teeth" both produce the partner form.
    const IRREGULARS = {
      teeth: "tooth", mice: "mouse", geese: "goose", feet: "foot",
      knives: "knife", leaves: "leaf", lives: "life", loaves: "loaf",
      wolves: "wolf", shelves: "shelf", men: "man", women: "woman",
      children: "child", oxen: "ox", people: "person", cacti: "cactus",
    };
    const IRREGULAR_INV = Object.fromEntries(Object.entries(IRREGULARS).map(([k, v]) => [v, k]));

    function variants(q) {
      const set = new Set([q]);
      if (IRREGULARS[q]) set.add(IRREGULARS[q]);
      if (IRREGULAR_INV[q]) set.add(IRREGULAR_INV[q]);

      // Plurals
      if (q.endsWith("ies") && q.length > 4) set.add(q.slice(0, -3) + "y");
      if (q.endsWith("es")  && q.length > 3) set.add(q.slice(0, -2));
      if (q.endsWith("s")   && q.length > 2) set.add(q.slice(0, -1));
      if (q.length >= 3) { set.add(q + "s"); set.add(q + "es"); }

      // Verb forms — gerund / past-tense both directions. "loading" →
      // "load", "saving" → "save", and the inverse so a base-form query
      // can reach an icon indexed only as the gerund.
      if (q.endsWith("ing") && q.length > 4) {
        const base = q.slice(0, -3);
        set.add(base);
        set.add(base + "e");
      }
      if (q.endsWith("ed") && q.length > 3) {
        set.add(q.slice(0, -2));
        set.add(q.slice(0, -1));
      }
      if (q.length >= 3) {
        set.add(q + "ing");
        if (q.endsWith("e")) set.add(q.slice(0, -1) + "ing");
        set.add(q + "ed");
        if (q.endsWith("e")) set.add(q + "d");
      }

      return [...set];
    }

    function scoreOne(name, keys, q) {
      // Tiers:
      //   5.5 = exact name        (strongest)
      //   4.x = exact keyword
      //   3.5 = prefix on name
      //   3.x = prefix on keyword
      //   2.5 = substring on name
      //   2.x = substring on keyword
      //   0   = no match
      // Keyword matches add `0.49 / (1 + idx)` so an alias listed
      // earlier in `k` outranks the same alias at a later index without
      // crossing into the next tier above.
      if (name === q) return 5.5;
      let best = 0;
      if (name.startsWith(q))     best = 3.5;
      else if (name.includes(q))  best = 2.5;
      for (let i = 0; i < keys.length; i++) {
        const k = keys[i];
        const pos = 0.49 / (1 + i);
        if (k === q) {
          const v = 4 + pos;
          return v > best ? v : best;
        }
        if (k.startsWith(q)) {
          const v = 3 + pos;
          if (v > best) best = v;
        } else if (k.includes(q)) {
          const v = 2 + pos;
          if (v > best) best = v;
        }
      }
      return best;
    }

    function scoreRow(row, queryVariants) {
      const name = normalize(row.n);
      if (!row._nk) row._nk = (row.k || []).map(normalize);
      let best = 0;
      for (let i = 0; i < queryVariants.length; i++) {
        const s = scoreOne(name, row._nk, queryVariants[i]);
        if (s > best) best = s;
        if (best >= 5.5) break; // max possible — exact-name match
      }
      return best;
    }

    // English stop words skipped during multi-pass title scoring so
    // common filler doesn't drown out the real subject ("Take out the
    // trash" should be dominated by "trash", not "the" / "out").
    const STOPWORDS = new Set([
      "the", "a", "an", "and", "or", "to", "of", "in", "on", "at",
      "for", "with", "from", "by", "is", "are", "was", "were", "be",
      "do", "does", "did", "out", "off", "up", "down",
      "my", "your", "our", "this", "that", "these", "those",
    ]);

    // Break a free-text query into [pass_string, weight] pairs:
    //   * full normalized pass (weight = tokens.length, min 1) — so
    //     phrases that prefix-match a compound still rank strongly
    //   * each non-stopword token in position order, weight = 1-indexed
    //     position so the LAST word wins ties between single-word
    //     matches. "Water Flowers" → flowers, not water.
    function queryPasses(query) {
      const raw = (query || "").toLowerCase().trim();
      if (!raw) return [];
      const full = normalize(raw);
      const tokens = raw.split(/[^a-z0-9]+/).filter(t => t && !STOPWORDS.has(t));
      const fullWeight = Math.max(1, tokens.length);
      const passes = [];
      if (full.length >= 2) passes.push([full, fullWeight]);
      tokens.forEach((t, i) => {
        if (t.length < 2 || t === full) return;
        passes.push([t, i + 1]);
      });
      return passes;
    }

    function expandPasses(passes) {
      return passes.map(([p, w]) => [variants(p), w]);
    }

    function sumScore(row, variantSetsWithWeights) {
      let total = 0;
      for (let j = 0; j < variantSetsWithWeights.length; j++) {
        const [vs, w] = variantSetsWithWeights[j];
        total += w * scoreRow(row, vs);
      }
      return total;
    }

    // Score-sorted search over the full pool. Empty query returns
    // the pool in its native (emoji-first) order so the picker can
    // .slice(0, N) for a "show everything" view.
    async function search(query, { limit = Infinity } = {}) {
      const pool = await load();
      const passes = queryPasses(query);
      if (passes.length === 0) {
        return limit === Infinity ? pool.slice() : pool.slice(0, limit);
      }
      const variantSets = expandPasses(passes);
      const scored = [];
      for (let i = 0; i < pool.length; i++) {
        const total = sumScore(pool[i], variantSets);
        if (total > 0) scored.push([total, i, pool[i]]);
      }
      scored.sort((a, b) => b[0] - a[0] || a[1] - b[1]);
      return (limit === Infinity ? scored : scored.slice(0, limit)).map(t => t[2]);
    }

    // Highest-scoring candidate. Floor at 3 (one prefix match) so we
    // don't auto-fill on a lone substring hit.
    async function bestMatch(query) {
      const pool = await load();
      const passes = queryPasses(query);
      if (passes.length === 0) return null;
      const variantSets = expandPasses(passes);
      let bestRow = null, bestScore = 0;
      for (let i = 0; i < pool.length; i++) {
        const total = sumScore(pool[i], variantSets);
        if (total > bestScore) { bestScore = total; bestRow = pool[i]; }
      }
      return bestScore >= 3 ? bestRow : null;
    }

    return { load, normalize, variants, scoreRow, search, bestMatch, refreshCustom, onCustomChanged };
  })();

  // ============================================================
  // Unified icon picker — singleton modal driven by any
  // [data-icon-stack] that includes a [data-icon-pick] trigger.
  // Single pool of emoji + Tabler icons (no tabs — users don't care
  // about the distinction). Emoji come first when there's no search.
  // ============================================================
  (function setupIconPicker() {
    const modal = document.querySelector("[data-icon-picker-modal]");
    if (!modal) return;
    const searchEl = modal.querySelector("[data-icon-picker-search]");
    const gridEl   = modal.querySelector("[data-icon-picker-grid]");
    const emptyEl  = modal.querySelector("[data-icon-picker-empty]");
    const MAX_TILES = 240;

    function buildTile(row) {
      const v = row.c;
      const safe = esc(v);
      if (row._kind === "ti") {
        return `<button type="button" data-pick-value="${safe}" title="${esc(row.n || v)}"><i class="ti ${safe}" aria-hidden="true"></i></button>`;
      }
      if (row._kind === "custom") {
        // Custom icons are pre-cropped data URLs. Long-press / right-click
        // opens the manage menu (see manage wireup below).
        return `<button type="button" data-pick-value="${safe}" data-custom-id="${row._id}" title="${esc(row.n || "")}"><img class="icon-img" src="${safe}" alt="${esc(row.n || "")}" loading="lazy" draggable="false"></button>`;
      }
      return `<button type="button" data-pick-value="${safe}" title="${esc(row.n || "")}">${safe}</button>`;
    }

    async function render() {
      const rows = await IconPool.search(searchEl.value, { limit: MAX_TILES });
      // An empty query is a "show everything" view, not "no matches" —
      // the empty-state copy is reserved for queries that score zero.
      const hasQuery = (searchEl.value || "").trim().length > 0;
      emptyEl.classList.toggle("hidden", !hasQuery || rows.length > 0);
      gridEl.innerHTML = rows.map(buildTile).join("");
    }

    let searchTimer = null;
    searchEl?.addEventListener("input", () => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(render, 100);
    });

    gridEl?.addEventListener("click", e => {
      const btn = e.target.closest("[data-pick-value]");
      if (!btn) return;
      const value = btn.dataset.pickValue;
      const stack = modal.__activeStack;
      if (stack?.__setIconValue) {
        stack.__setIconValue(value, { source: "user" });
        stack.dispatchEvent(new CustomEvent("chore-icon-picked", {
          bubbles: true, detail: { value: value },
        }));
      }
      modal.classList.add("hidden");
    });

    document.addEventListener("click", e => {
      const trigger = e.target.closest("[data-icon-pick]");
      if (!trigger) return;
      e.preventDefault();
      const stack = trigger.closest("[data-icon-stack]");
      if (!stack) return;
      modal.__activeStack = stack;
      // Pre-fill with the form's title so the user sees relevant results
      // immediately. Selected so a single backspace clears it.
      const titleField = stack.closest("form")?.querySelector('[data-field="name"]');
      searchEl.value = (titleField?.value || "").trim();
      modal.classList.remove("hidden");
      render();
      setTimeout(() => {
        searchEl?.focus();
        searchEl?.select();
      }, 0);
    });

    // Refresh the open picker when the custom pool changes (after
    // upload, rename, delete).
    IconPool.onCustomChanged(() => {
      if (!modal.classList.contains("hidden")) render();
    });

    // Right-click (or long-press on touch) a custom tile → delete it
    // after a confirm. Rename / re-image flows live in a future
    // manage view; this is the minimal lifecycle to keep the library
    // tidy from the picker itself.
    gridEl.addEventListener("contextmenu", async e => {
      const btn = e.target.closest("[data-custom-id]");
      if (!btn) return;
      e.preventDefault();
      const id = btn.dataset.customId;
      const label = btn.title || "this icon";
      if (!window.confirm(`Delete "${label}" from your household icons?`)) return;
      const csrf = document.querySelector('meta[name="csrf-token"]')?.content || "";
      const res = await fetch(`/chores/icons/${id}`, {
        method: "DELETE",
        credentials: "same-origin",
        headers: { "Accept": "application/json", "X-CSRF-Token": csrf },
      });
      if (res.ok) await IconPool.refreshCustom();
    });

    // "+" → open the cropper modal. ChoreIconCropper handles all the
    // upload state; we just emit an open event with the originating
    // stack so the cropper can write the saved icon back into the
    // active form.
    modal.querySelector("[data-icon-picker-upload]")?.addEventListener("click", e => {
      e.preventDefault();
      const stack = modal.__activeStack;
      modal.classList.add("hidden");
      document.dispatchEvent(new CustomEvent("chore-icon-cropper-open", {
        detail: { stack: stack },
      }));
    });
  })();

  // ============================================================
  // Chore picker — same modal flavor as the icon picker, but populated
  // from ChoreStore. Reuses the `score()` ranker so search semantics
  // match the chores-grid search. Two opener modes share the modal:
  //   * [data-anchor-picker-open] — Follows-another-chore (recurrence
  //     anchor). Excludes self + any chore that would form a cycle.
  //     Writes to [data-anchor-chore-id].
  //   * [data-parent-picker-open] — Parent Chore (sub-chore opt-in).
  //     Excludes self, one-offs, and existing sub-chores (single-level
  //     only). Writes to [data-field="parent_chore_id"].
  // The mode is stashed on `modal.dataset.pickerMode` by the opener so
  // the render filter + grid-click writeback both know which is which.
  // ============================================================
  (function setupChorePicker() {
    const modal = document.querySelector("[data-chore-picker-modal]");
    if (!modal) return;
    const searchEl = modal.querySelector("[data-chore-picker-search]");
    const gridEl   = modal.querySelector("[data-chore-picker-grid]");
    const emptyEl  = modal.querySelector("[data-chore-picker-empty]");

    function mode() { return modal.dataset.pickerMode || "anchor"; }

    function passesFilter(c, selfId) {
      if (c.id === selfId) return false;
      if (mode() === "parent") {
        return !c.one_off && !c.parent_chore_id;
      }
      return !anchorChainContains(c, selfId);
    }

    function render() {
      const q = (searchEl.value || "").trim();
      const selfId = parseInt(modal.dataset.selfId || "", 10) || null;
      const candidates = ChoreStore.activeForGrid().filter(c => passesFilter(c, selfId));
      const scored = candidates
        .map(c => ({ c, s: score(q, c.short_name || c.name, c.aliases || []) }))
        .filter(x => x.s > 0)
        .sort((a, b) => b.s - a.s || (a.c.name || "").localeCompare(b.c.name || ""));
      const items = scored.map(x => x.c);
      gridEl.innerHTML = items
        .map(c => `
          <button type="button" class="chore-picker-cell" data-chore-pick-id="${c.id}">
            <span class="chore-picker-icon">${iconHTML(c)}</span>
            <span class="chore-picker-label">${esc(c.short_name || c.name)}</span>
          </button>
        `)
        .join("");
      emptyEl.classList.toggle("hidden", items.length > 0);
    }

    let inputTimer = null;
    searchEl?.addEventListener("input", () => {
      clearTimeout(inputTimer);
      inputTimer = setTimeout(render, 60);
    });

    gridEl?.addEventListener("click", e => {
      const btn = e.target.closest("[data-chore-pick-id]");
      if (!btn) return;
      const id = parseInt(btn.dataset.chorePickId, 10);
      if (mode() === "parent") {
        const hidden = editForm.querySelector('[data-field="parent_chore_id"]');
        if (hidden) hidden.value = id ? String(id) : "";
        syncParentPickerButton();
        syncParentChoreLock();
      } else {
        const hidden = editForm.querySelector('[data-anchor-chore-id]');
        if (hidden) hidden.value = id ? String(id) : "";
        syncAnchorPickerButton();
      }
      modal.classList.add("hidden");
    });

    wireModalDismiss(modal, {
      onCancel:   () => modal.classList.add("hidden"),
      onBackdrop: () => modal.classList.add("hidden"),
    });

    document.addEventListener("click", e => {
      const anchorTrigger = e.target.closest("[data-anchor-picker-open]");
      const parentTrigger = e.target.closest("[data-parent-picker-open]");
      const trigger = anchorTrigger || parentTrigger;
      if (!trigger) return;
      e.preventDefault();
      modal.dataset.pickerMode = parentTrigger ? "parent" : "anchor";
      modal.dataset.selfId = String(parseInt(currentChoreId, 10) || "");
      searchEl.value = "";
      modal.classList.remove("hidden");
      render();
      setTimeout(() => {
        searchEl?.focus();
        searchEl?.select();
      }, 0);
    });

    // Clear chip on the Parent Chore row — empties the hidden input
    // and re-syncs the trigger label + the one_off lock.
    document.addEventListener("click", e => {
      const clearBtn = e.target.closest("[data-parent-picker-clear]");
      if (!clearBtn) return;
      e.preventDefault();
      const hidden = editForm.querySelector('[data-field="parent_chore_id"]');
      if (hidden) hidden.value = "";
      syncParentPickerButton();
      syncParentChoreLock();
    });
  })();

  // ============================================================
  // Custom-icon cropper — file/paste/drop/URL source, canvas crop
  // with square overlay + zoom/pan, name + keywords, POSTs a 128px
  // WebP data URL to /chores/icons. On success notifies
  // IconPool so the picker re-renders and (optionally) writes the
  // new icon straight into the stack that triggered upload.
  // ============================================================
  (function setupIconCropper() {
    const modal = document.querySelector("[data-icon-cropper-modal]");
    if (!modal) return;

    const sourcePane  = modal.querySelector("[data-cropper-source]");
    const stagePane   = modal.querySelector("[data-cropper-stage]");
    const fileBtn     = modal.querySelector("[data-cropper-file-btn]");
    const fileInput   = modal.querySelector("[data-cropper-file]");
    const urlInput    = modal.querySelector("[data-cropper-url]");
    const sourceError = modal.querySelector("[data-cropper-error]");
    const stageError  = modal.querySelector("[data-cropper-stage-error]");
    const canvas      = modal.querySelector("[data-cropper-canvas]");
    const canvasWrap  = modal.querySelector("[data-cropper-canvas-wrap]");
    const zoomInput   = modal.querySelector("[data-cropper-zoom]");
    const resetBtn    = modal.querySelector("[data-cropper-reset]");
    const nameInput   = modal.querySelector("[data-cropper-name]");
    const keysInput   = modal.querySelector("[data-cropper-keywords]");
    const saveBtn     = modal.querySelector("[data-cropper-save]");
    const saveHint    = modal.querySelector("[data-cropper-save-hint]");
    const bgEnable    = modal.querySelector("[data-cropper-bg-enable]");
    const bgControls  = modal.querySelector("[data-cropper-bg-controls]");
    const bgThreshold = modal.querySelector("[data-cropper-bg-threshold]");
    const bgThresholdValue = modal.querySelector("[data-cropper-bg-threshold-value]");
    const bgEdges     = modal.querySelector("[data-cropper-bg-edges]");
    const previewCanvas = modal.querySelector("[data-cropper-preview]");
    const ctx = canvas.getContext("2d");

    // Stage 320×320. Crop window 192×192 centred (64px inset). Output 128×128.
    const STAGE = 320, INSET = 64, CROP = 192, OUTPUT = 128;

    let sourceImage = null;
    let activeStack = null;       // where to write the saved icon when picker invoked
    let offsetX = 0, offsetY = 0; // canvas coords of the source's top-left
    let baseScale = 1;            // "fit" scale derived from source size
    let userZoom = 1;             // multiplier from the slider

    function showError(el, msg) {
      el.textContent = msg || "";
      el.classList.toggle("hidden", !msg);
    }

    function setSaveEnabled() {
      const hasImage = !!sourceImage;
      const hasName  = (nameInput.value || "").trim().length > 0;
      saveBtn.disabled = !(hasImage && hasName);
      if (!saveHint) return;
      // Surface *why* the button is disabled so users don't stare at a
      // dead "Save icon" with no explanation.
      let msg = "";
      if (!hasImage)       msg = "Pick an image to continue";
      else if (!hasName)   msg = "Add a name to save";
      saveHint.textContent = msg;
      saveHint.classList.toggle("hidden", !msg);
    }

    function resetState() {
      sourceImage = null;
      offsetX = 0; offsetY = 0;
      baseScale = 1; userZoom = 1;
      zoomInput.value = "1";
      nameInput.value = "";
      keysInput.value = "";
      urlInput.value = "";
      bgEnable.checked = false;
      bgThreshold.value = "20";
      bgThresholdValue.textContent = "20";
      bgEdges.checked = true;
      bgControls.classList.add("hidden");
      showError(sourceError, "");
      showError(stageError, "");
      sourcePane.classList.remove("hidden");
      stagePane.classList.add("hidden");
      saveBtn.disabled = true;
      clearPreview();
    }
    function clearPreview() {
      const pctx = previewCanvas.getContext("2d");
      pctx.clearRect(0, 0, previewCanvas.width, previewCanvas.height);
    }

    function draw() {
      ctx.clearRect(0, 0, STAGE, STAGE);
      if (!sourceImage) return;
      const s = baseScale * userZoom;
      const w = sourceImage.naturalWidth * s;
      const h = sourceImage.naturalHeight * s;
      ctx.drawImage(sourceImage, offsetX, offsetY, w, h);
      schedulePreview();
    }

    function loadDataUrl(dataUrl) {
      showError(sourceError, "");
      const img = new Image();
      img.onload = () => {
        sourceImage = img;
        // Fit the image into the crop window (192px) so the visible
        // square is fully covered at the starting zoom of 1.
        const fit = Math.max(CROP / img.naturalWidth, CROP / img.naturalHeight);
        baseScale = fit;
        userZoom = 1;
        zoomInput.value = "1";
        // Center the image within the stage at the starting zoom.
        offsetX = (STAGE - img.naturalWidth * baseScale) / 2;
        offsetY = (STAGE - img.naturalHeight * baseScale) / 2;
        sourcePane.classList.add("hidden");
        stagePane.classList.remove("hidden");
        draw();
        setSaveEnabled();
        setTimeout(() => nameInput.focus(), 0);
      };
      img.onerror = () => {
        showError(sourceError, "Couldn't load that image.");
      };
      img.src = dataUrl;
    }

    function loadFile(file) {
      if (!file || !file.type.startsWith("image/")) {
        showError(sourceError, "Pick an image file.");
        return;
      }
      const reader = new FileReader();
      reader.onload = () => loadDataUrl(reader.result);
      reader.onerror = () => showError(sourceError, "Couldn't read that file.");
      if (file.type === "image/svg+xml") reader.readAsText(file);
      else reader.readAsDataURL(file);
    }

    async function loadFromUrl(url) {
      showError(sourceError, "");
      const trimmed = (url || "").trim();
      if (!trimmed) return;
      if (trimmed.startsWith("data:image/")) {
        loadDataUrl(trimmed);
        return;
      }
      // Cross-origin canvas taint protection — fetch the bytes ourselves
      // and convert to a data URL. Many image hosts don't serve CORS
      // headers; the picker has to display the result so we need to
      // own the bytes.
      try {
        const res = await fetch(trimmed, { mode: "cors" });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const blob = await res.blob();
        if (!blob.type.startsWith("image/")) throw new Error("Not an image");
        const reader = new FileReader();
        reader.onload = () => loadDataUrl(reader.result);
        reader.onerror = () => showError(sourceError, "Couldn't read URL response.");
        reader.readAsDataURL(blob);
      } catch (e) {
        showError(sourceError, "Couldn't fetch image: " + e.message);
      }
    }

    // ---- Source input wiring ----
    fileBtn.addEventListener("click", e => { e.preventDefault(); fileInput.click(); });
    fileInput.addEventListener("change", () => {
      const f = fileInput.files?.[0];
      if (f) loadFile(f);
      fileInput.value = "";
    });
    urlInput.addEventListener("keydown", e => {
      if (e.key === "Enter") { e.preventDefault(); loadFromUrl(urlInput.value); }
    });
    urlInput.addEventListener("blur", () => {
      if (urlInput.value.trim()) loadFromUrl(urlInput.value);
    });
    // Bound on the whole modal so a NEW drop replaces the already-loaded
    // image (the source pane is hidden once the stage opens). loadFile →
    // loadDataUrl resets crop/zoom/pan; name/keywords/bg settings persist.
    ["dragover", "drop"].forEach(evt => modal.addEventListener(evt, async e => {
      e.preventDefault();
      if (evt !== "drop") return;
      const f = Array.from(e.dataTransfer?.files || []).find(x => x.type.startsWith("image/"));
      if (f) loadFile(f);
    }));
    modal.addEventListener("paste", e => {
      const items = Array.from(e.clipboardData?.items || []);
      const item = items.find(it => it.type.startsWith("image/"));
      if (item) {
        e.preventDefault();
        const f = item.getAsFile();
        if (f) loadFile(f);
        return;
      }
      const text = (e.clipboardData?.getData?.("text/plain") || "").trim();
      if (text.startsWith("data:image/") || text.startsWith("http://") || text.startsWith("https://")) {
        e.preventDefault();
        loadFromUrl(text);
      }
    });

    // ---- Crop interactions ----
    zoomInput.addEventListener("input", () => {
      if (!sourceImage) return;
      const newZoom = parseFloat(zoomInput.value);
      // Anchor zoom at the centre of the crop window so the visible
      // subject stays in frame as the user zooms in or out.
      const anchorX = STAGE / 2, anchorY = STAGE / 2;
      const oldScale = baseScale * userZoom;
      const newScale = baseScale * newZoom;
      offsetX = anchorX - ((anchorX - offsetX) * (newScale / oldScale));
      offsetY = anchorY - ((anchorY - offsetY) * (newScale / oldScale));
      userZoom = newZoom;
      draw();
    });
    resetBtn.addEventListener("click", e => { e.preventDefault(); resetState(); });

    let dragging = false, dragLastX = 0, dragLastY = 0;
    canvasWrap.addEventListener("pointerdown", e => {
      if (!sourceImage) return;
      dragging = true;
      dragLastX = e.clientX;
      dragLastY = e.clientY;
      canvasWrap.setPointerCapture(e.pointerId);
    });
    canvasWrap.addEventListener("pointermove", e => {
      if (!dragging) return;
      const rect = canvasWrap.getBoundingClientRect();
      // Scale screen movement to canvas pixels so dragging feels 1:1
      // regardless of how the canvas is laid out.
      const sx = STAGE / rect.width, sy = STAGE / rect.height;
      offsetX += (e.clientX - dragLastX) * sx;
      offsetY += (e.clientY - dragLastY) * sy;
      dragLastX = e.clientX;
      dragLastY = e.clientY;
      draw();
    });
    ["pointerup", "pointercancel"].forEach(evt => canvasWrap.addEventListener(evt, e => {
      dragging = false;
      try { canvasWrap.releasePointerCapture(e.pointerId); } catch (_e) {}
    }));

    nameInput.addEventListener("input", setSaveEnabled);

    // Background-removal UI bindings — every change updates the live
    // preview. The controls panel collapses when the master toggle is
    // off so the modal stays compact in the common case.
    bgEnable.addEventListener("change", () => {
      bgControls.classList.toggle("hidden", !bgEnable.checked);
      schedulePreview();
    });
    bgThreshold.addEventListener("input", () => {
      bgThresholdValue.textContent = bgThreshold.value;
      schedulePreview();
    });
    bgEdges.addEventListener("change", schedulePreview);

    // ---- Render the cropped output, optionally clearing background ----
    // Reused for both the preview thumbnail and the save payload.
    // Background removal samples the four output corners (averaged) as
    // the bg colour, then either marks every matching pixel transparent
    // (whole-image mode) or flood-fills from the border so internal
    // matching pixels — eyes, highlights, glyph interiors — survive.
    function renderToCanvas(targetCanvas) {
      const w = targetCanvas.width, h = targetCanvas.height;
      const octx = targetCanvas.getContext("2d");
      octx.clearRect(0, 0, w, h);
      if (!sourceImage) return;
      const scale = baseScale * userZoom;
      const srcX = (INSET - offsetX) / scale;
      const srcY = (INSET - offsetY) / scale;
      const srcSize = CROP / scale;
      octx.drawImage(sourceImage, srcX, srcY, srcSize, srcSize, 0, 0, w, h);
      if (bgEnable.checked) {
        removeBackground(targetCanvas, parseInt(bgThreshold.value, 10), bgEdges.checked);
      }
    }
    function removeBackground(target, threshold, edgesOnly) {
      const w = target.width, h = target.height;
      const tctx = target.getContext("2d");
      const img = tctx.getImageData(0, 0, w, h);
      const data = img.data;
      // When the user zooms out, the cropped canvas extends past the
      // source image and the outer ring becomes transparent padding.
      // Sampling colour OR seeding the flood fill from those transparent
      // pixels would either pick a (0,0,0) "bg colour" or eat through
      // the padding-to-image transition. Walk each border pixel inward
      // along its ray until we find a pixel actually drawn from the
      // source image (alpha > 0) and treat THAT as the real edge.
      function walkInward(x, y, dx, dy) {
        while (x >= 0 && y >= 0 && x < w && y < h) {
          if (data[(y * w + x) * 4 + 3] > 0) return [x, y];
          x += dx; y += dy;
        }
        return null;
      }
      const cornerSamples = [
        walkInward(0, 0, 1, 1),
        walkInward(w - 1, 0, -1, 1),
        walkInward(0, h - 1, 1, -1),
        walkInward(w - 1, h - 1, -1, -1),
      ].filter(Boolean);
      if (cornerSamples.length === 0) {
        // Whole crop is transparent — nothing to do.
        tctx.putImageData(img, 0, 0);
        return;
      }
      let br = 0, bg = 0, bb = 0;
      cornerSamples.forEach(([x, y]) => {
        const i = (y * w + x) * 4;
        br += data[i]; bg += data[i + 1]; bb += data[i + 2];
      });
      br /= cornerSamples.length; bg /= cornerSamples.length; bb /= cornerSamples.length;
      // Threshold 0-100 → sum-of-squared-deltas budget across r,g,b.
      const t = (threshold / 100) * 255;
      const budget = t * t * 3;
      function matches(i) {
        // Already-transparent padding never matches: it has no colour
        // to compare against, and treating it as a match would let the
        // flood fill burn through the padding-to-image transition.
        if (data[i + 3] === 0) return false;
        const dr = data[i] - br;
        const dg = data[i + 1] - bg;
        const db = data[i + 2] - bb;
        return dr * dr + dg * dg + db * db <= budget;
      }
      if (edgesOnly) {
        // Flood-fill from every border pixel that matches. Internal
        // matching pixels never connected to the border stay opaque.
        const visited = new Uint8Array(w * h);
        const queue = new Int32Array(w * h);
        let head = 0, tail = 0;
        function tryPush(x, y) {
          if (x < 0 || y < 0 || x >= w || y >= h) return;
          const pi = y * w + x;
          if (visited[pi]) return;
          const i = pi * 4;
          if (!matches(i)) return;
          visited[pi] = 1;
          data[i + 3] = 0;
          queue[tail++] = pi;
        }
        // Seed at the FIRST opaque pixel along each inward ray — the
        // real image edge, which is past any transparent zoom-out ring.
        function seedRay(x0, y0, dx, dy) {
          const start = walkInward(x0, y0, dx, dy);
          if (start) tryPush(start[0], start[1]);
        }
        for (let x = 0; x < w; x++) {
          seedRay(x, 0, 0, 1);
          seedRay(x, h - 1, 0, -1);
        }
        for (let y = 0; y < h; y++) {
          seedRay(0, y, 1, 0);
          seedRay(w - 1, y, -1, 0);
        }
        while (head < tail) {
          const pi = queue[head++];
          const x = pi % w, y = (pi / w) | 0;
          tryPush(x + 1, y); tryPush(x - 1, y);
          tryPush(x, y + 1); tryPush(x, y - 1);
        }
      } else {
        for (let i = 0; i < data.length; i += 4) {
          if (matches(i)) data[i + 3] = 0;
        }
      }
      tctx.putImageData(img, 0, 0);
    }
    function renderOutput() {
      const out = document.createElement("canvas");
      out.width = OUTPUT;
      out.height = OUTPUT;
      renderToCanvas(out);
      let url = "";
      try { url = out.toDataURL("image/webp", 0.85); } catch (_e) {}
      if (!url || url.length < 64) url = out.toDataURL("image/png");
      return url;
    }
    // Debounced preview update — cheap to re-render at 96×96.
    let previewTimer = null;
    function schedulePreview() {
      clearTimeout(previewTimer);
      previewTimer = setTimeout(() => renderToCanvas(previewCanvas), 30);
    }

    saveBtn.addEventListener("click", async e => {
      e.preventDefault();
      if (saveBtn.disabled) return;
      await withSavingState(saveBtn, async () => {
        showError(stageError, "");
        const csrf = document.querySelector('meta[name="csrf-token"]')?.content || "";
        const dataUrl = renderOutput();
        try {
          const res = await fetch("/chores/icons", {
            method: "POST",
            credentials: "same-origin",
            headers: {
              "Content-Type": "application/json",
              "Accept":       "application/json",
              "X-CSRF-Token": csrf,
            },
            body: JSON.stringify({ household_icon: {
              name:       nameInput.value.trim(),
              keywords:   keysInput.value.trim(),
              image_data: dataUrl,
            } }),
          });
          if (!res.ok) {
            const body = await res.json().catch(() => ({}));
            showError(stageError, (body.errors || ["Save failed"]).join(", "));
            return;
          }
          const saved = await res.json();
          await IconPool.refreshCustom();
          // If the cropper was opened from a chore-form picker, drop the
          // freshly-saved icon straight into the form so the user lands
          // back on a populated state.
          if (activeStack?.__setIconValue) {
            activeStack.__setIconValue(saved.c, { source: "user" });
            activeStack.dispatchEvent(new CustomEvent("chore-icon-picked", {
              bubbles: true, detail: { value: saved.c },
            }));
          }
          modal.classList.add("hidden");
          resetState();
        } catch (err) {
          showError(stageError, err.message || "Save failed");
        }
      });
    });

    document.addEventListener("chore-icon-cropper-open", e => {
      activeStack = e.detail?.stack || null;
      resetState();
      modal.classList.remove("hidden");
      if (e.detail?.file) loadFile(e.detail.file);
    });

    modal.querySelectorAll('[data-action="cancel"]').forEach(b =>
      b.addEventListener("click", () => { modal.classList.add("hidden"); resetState(); }));
  })();

  // ============================================================
  // Auto-suggest an icon from the chore title via PURE-JS scoring
  // against the shared IconPool — no network.
  //
  // Lifecycle (per modal-open):
  //   * Hydration sets `stack.__suggestFillable` — true when the
  //     icon field is empty, false when an existing icon hydrated in.
  //   * focus on title  → if icon non-empty: fillable = false.
  //   * input on title  → if fillable: re-score and overwrite the
  //                       icon with the new best match (or clear if
  //                       no match qualifies). Writes go through
  //                       source: "suggest" so they don't seal
  //                       user-dirty — the next input can replace
  //                       a still-untouched suggestion.
  //   * blur on title   → if icon non-empty: fillable = false
  //                       (the auto-fill becomes the user's choice).
  //   * Any user touch of the icon cell (type/paste/upload/picker)
  //     flips user-dirty true, which also gates the suggester.
  // ============================================================
  (function setupChoreIconSuggest() {
    if (!editForm) return;
    const nameField = editForm.querySelector('[data-field="name"]');
    const stack     = editForm.querySelector("[data-icon-stack]");
    const hidden    = stack?.querySelector('[data-field="icon"]');
    if (!nameField || !stack || !hidden) return;

    // Warm the pool so the first keystroke is instant.
    IconPool.load();

    function canSuggest() {
      return stack.__suggestFillable === true && !stack.__iconUserDirty;
    }

    nameField.addEventListener("focus", () => {
      if ((hidden.value || "").trim() !== "") stack.__suggestFillable = false;
    });

    let inflight = 0;
    nameField.addEventListener("input", async () => {
      if (!canSuggest()) return;
      const title = (nameField.value || "").trim();
      const token = ++inflight;
      const match = title.length >= 2 ? await IconPool.bestMatch(title) : null;
      if (token !== inflight) return;     // a newer keystroke superseded us
      if (!canSuggest()) return;          // user touched the icon mid-flight
      const next = match ? match.c : "";
      if ((hidden.value || "") === next) return;
      stack.__setIconValue(next, { source: "suggest" });
    });

    nameField.addEventListener("blur", () => {
      if ((hidden.value || "").trim() !== "") stack.__suggestFillable = false;
    });
  })();

  // Show/hide the per-chore action buttons in the modal head (rotate
  // hot pick + anonymous completion). Both are inapplicable for a
  // brand-new chore — they only make sense once the chore exists.
  function refreshEditModalHeadActions(c) {
    const rotate = editModal?.querySelector('[data-edit-hot-rotate]');
    const anon = editModal?.querySelector('[data-edit-anonymous-complete]');
    if (rotate) rotate.hidden = !c || c.hot_multiplier == null;
    if (anon) anon.hidden = !c;
  }

  // Single source of truth for "the chore edit form is at clean
  // defaults." Used both when opening Add Chore on a previously-edited
  // modal AND at the START of every fresh openEditModal call, so no
  // value, pill `.active`, chip selection, dynamic widget, or hidden
  // helper input can leak from the previously-open chore. Adding a new
  // form field? Reset it here.
  function resetEditFormToDefaults() {
    if (!editForm) return;
    editForm.reset();
    setIconField("");
    setField("name", "");
    setField("short_name", "");
    setField("aliases_csv", "");
    setField("notes_template", "");
    setField("notes", "");
    setField("assigned_to_user_id", "");
    setField("starts_on", "");
    setField("marked_due_at", "");
    setField("parent_chore_id", "");
    syncParentPickerButton();
    syncParentChoreLock();
    selectRewardPill(1);
    setField("reward_pebbles", 1);
    setCooldownSeconds(0);
    setPillValue("freq", "never");
    setPillValue("show_on_daily_view", "when_scheduled");
    setPillValue("hot_eligibility", "when_available");
    setPillValue("sharing_mode", "household");
    setPillValue("after_chore_when", "today");
    const oneOffCb = editForm.querySelector('[data-field="one_off"]');
    if (oneOffCb) oneOffCb.checked = false;
    // Anchor picker: clear the hidden id and re-render the trigger so
    // its icon + label go back to the empty "Pick a chore…" state.
    const anchorEl = editForm.querySelector('[data-anchor-chore-id]');
    if (anchorEl) anchorEl.value = "";
    syncAnchorPickerButton();
    // After-chore "Later…" custom row inputs — form.reset already
    // restores HTML defaults, but defensive in case future markup
    // changes drop the value attributes.
    const afterInt = editForm.querySelector('[data-after-chore-interval]');
    if (afterInt) afterInt.value = "2";
    const afterUnit = editForm.querySelector('[data-after-chore-unit]');
    if (afterUnit) afterUnit.value = "day";
    // Custom/relative recurrence row.
    const interval = editForm.querySelector('[data-interval]');
    if (interval) interval.value = "1";
    const unit = editForm.querySelector('[data-unit]');
    if (unit) unit.value = "day";
    // Chip-based selections — pills handled via setPillValue above,
    // chips are independent DOM state.
    syncWeekdayChips([]);
    editForm.querySelectorAll('[data-month-day-pane] .md-chip.active').forEach(c => c.classList.remove("active"));
    editForm.querySelector('[data-month-mode-tabs] [data-month-mode="day-of-month"]')?.click();
    editForm.querySelectorAll('[data-month-set-pos], [data-month-wday]').forEach(el => {
      delete el.dataset.userTouched;
    });
    syncSingleTask();
    syncFreqRow();
    syncWeekdaysHelperHighlight();
  }

  function openCreateModal(opts = {}) {
    if (!editModal) return;
    if (modalLockedFor !== "__create__") {
      currentChoreId = null;
      resetEditFormToDefaults();
      if (opts.prefillName) setField("name", opts.prefillName);
      const oneOffCb = editForm.querySelector('[data-field="one_off"]');
      if (oneOffCb) oneOffCb.checked = !!opts.oneOff;
      syncSingleTask();
      // Brand-new single-task chores default Due Date to today —
      // the dominant "I need to do this" case. The user can still
      // edit the field to a future date or clear it. Mirrors the
      // edit-mode toggle behavior above. Edit-populate intentionally
      // does NOT auto-fill — opening an existing one-off with no
      // due date should leave it blank.
      if (opts.oneOff) ensureMarkedDueSet();
      modalLockedFor = "__create__";
    }
    editModal.querySelector('[data-modal-title]').textContent = "Add Chore";
    // No chore exists yet — nothing to pin to Dailies or mark due.
    const createPin = editModal.querySelector('[data-edit-pin-toggle]');
    if (createPin) createPin.hidden = true;
    const createMarkDue = editModal.querySelector('[data-edit-mark-due-toggle]');
    if (createMarkDue) createMarkDue.hidden = true;
    refreshEditModalHeadActions(null);
    editForm.querySelector('[data-action="archive"]')?.classList.add("hidden");
    editModal.classList.remove("hidden");
    scrollModalToTop(editModal);
    const nameField = editForm.querySelector('[data-field="name"]');
    if (nameField && !nameField.value) { nameField.focus(); nameField.select?.(); }
  }
  function openEditModal(card) {
    if (!editModal) return;
    const id = card.dataset.choreId;
    if (modalLockedFor === id) {
      currentChoreId = id;
      editModal.classList.remove("hidden");
      scrollModalToTop(editModal);
      return;
    }
    const c = ChoreStore.get(parseInt(id, 10));
    if (!c) return;
    currentChoreId = id;
    modalLockedFor = id;
    editModal.querySelector('[data-modal-title]').textContent = "Edit Chore";
    refreshEditModalPin();
    refreshEditModalMarkDue();
    refreshEditModalHeadActions(c);
    // FULL reset before populating. Prevents any UI state from the
    // previously-opened chore (anchor selection, pill `.active`,
    // chip selections, after_chore_when, etc.) from leaking through.
    resetEditFormToDefaults();
    setField("name", c.name);
    setField("short_name", c.short_name === c.name ? "" : c.short_name);
    setIconField(c.icon || "");
    setField("aliases_csv", (c.aliases || []).join(", "));
    setField("notes_template", c.notes_template || "");
    setField("notes", c.notes || "");
    const reward = c.reward_pebbles || 0;
    selectRewardPill(reward);
    setField("reward_pebbles", reward);
    const oneOffCb = editForm.querySelector('[data-field="one_off"]');
    if (oneOffCb) oneOffCb.checked = !!c.one_off;
    setPillValue("sharing_mode", c.sharing_mode || "household");
    setField("assigned_to_user_id", c.assigned_to_user_id || "");
    setPillValue("show_on_daily_view", c.show_on_daily_view || "when_scheduled");
    setPillValue("hot_eligibility", c.hot_eligibility || "when_available");
    setCooldownSeconds(c.threshold_seconds || 0);
    setField("starts_on", c.starts_on || "");
    setField("marked_due_at", c.marked_due_on || "");
    setField("parent_chore_id", c.parent_chore_id ? String(c.parent_chore_id) : "");
    syncParentPickerButton();
    syncParentChoreLock();
    const rec = c.recurrence || {};
    setPillValue("freq", rec.freq || "never");
    syncSingleTask();
    syncFreqRow();
    syncWeekdayChips(rec.by_day || []);
    editForm.querySelectorAll('[data-month-day-pane] .md-chip').forEach(c => c.classList.remove("active"));
    if (rec.freq === "monthly") {
      if (rec.by_set_pos != null) {
        editForm.querySelector('[data-month-mode-tabs] [data-month-mode="nth-weekday"]')?.click();
        const setPos = editForm.querySelector('[data-month-set-pos]');
        if (setPos) { setPos.value = String(rec.by_set_pos); setPos.dataset.userTouched = "1"; }
        const wday = editForm.querySelector('[data-month-wday]');
        if (wday && rec.by_day?.[0]) { wday.value = rec.by_day[0]; wday.dataset.userTouched = "1"; }
      } else {
        editForm.querySelector('[data-month-mode-tabs] [data-month-mode="day-of-month"]')?.click();
        Array.isArray(rec.by_month_day) && rec.by_month_day.forEach(d => {
          editForm.querySelector(`[data-month-day-pane] [data-day="${d}"]`)?.classList.add("active");
        });
      }
    }
    if (rec.freq === "after_chore") {
      const anchorEl = editForm.querySelector('[data-anchor-chore-id]');
      if (anchorEl) anchorEl.value = rec.anchor_chore_id ? String(rec.anchor_chore_id) : "";
      // Map (interval, unit) back to the When pills. Anything that
      // isn't exactly Today (0 days) or Tomorrow (1 day) folds into
      // "Later…" and the dedicated numeric/unit inputs.
      const intv = rec.interval ?? 0;
      const unit = rec.unit || "day";
      let when = "later";
      if (intv === 0 && unit === "day") when = "today";
      else if (intv === 1 && unit === "day") when = "tomorrow";
      setPillValue("after_chore_when", when);
      if (when === "later") {
        const intervalEl = editForm.querySelector('[data-after-chore-interval]');
        if (intervalEl) intervalEl.value = String(intv);
        const unitEl = editForm.querySelector('[data-after-chore-unit]');
        if (unitEl) unitEl.value = unit;
      }
      syncAnchorPickerButton();
      syncAfterChoreLaterRow();
    } else {
      if (rec.interval) editForm.querySelector('[data-interval]').value = rec.interval;
      if (rec.unit) editForm.querySelector('[data-unit]').value = rec.unit;
    }
    syncStartsOnDependents();
    editForm.querySelector('[data-action="archive"]')?.classList.remove("hidden");
    editModal.classList.remove("hidden");
    scrollModalToTop(editModal);
  }
  function dismissEditModalAccidental() { editModal?.classList.add("hidden"); }
  function dismissEditModalExplicit() {
    editModal?.classList.add("hidden");
    modalLockedFor = null;
    currentChoreId = null;
    editForm?.reset();
    setIconField("");
  }

  document.querySelector('[data-add-chore]')?.addEventListener("click", () => {
    const search = document.querySelector("[data-chores-search]");
    const prefill = search?.value?.trim() || "";
    openCreateModal({ prefillName: prefill });
    if (search) search.value = "";
    applySearch("");
  });

  // Edit mode + SortableJS
  const editModeBtn = document.querySelector('[data-edit-mode-toggle]');
  let sortableInstance = null;
  function enterEditMode() {
    editModeActive = true;
    editModeBtn.classList.add("active");
    root?.classList.add("edit-mode");
    if (typeof window.Sortable === "undefined") return;
    const grid = document.querySelector("[data-chores-grid]");
    if (!grid) return;
    sortableInstance = window.Sortable.create(grid, {
      animation: 150, ghostClass: "sortable-ghost", chosenClass: "sortable-chosen", dragClass: "sortable-drag",
      forceFallback: true, fallbackOnBody: true, fallbackTolerance: 0,
      delay: 150, delayOnTouchOnly: true, touchStartThreshold: 4,
      onEnd: persistOrder,
    });
  }
  function exitEditMode() {
    editModeActive = false;
    editModeBtn.classList.remove("active");
    root?.classList.remove("edit-mode");
    if (sortableInstance) { sortableInstance.destroy(); sortableInstance = null; }
  }
  async function persistOrder() {
    const ids = Array.from(document.querySelectorAll("[data-chores-grid] [data-chore-id]"))
      .map(c => parseInt(c.dataset.choreId, 10)).filter(Boolean);
    ChoreStore.reorder(ids);
    // Today's Today + Overdue sections mirror the global chore sort;
    // Dailies has its own user-curated order and isn't touched by a grid
    // reorder.
    reorderContainer("[data-chores-today]", ids);
    reorderContainer("[data-chores-overdue]", ids);
    try { await api("/chores/order", "PATCH", { ids, tab_id: TAB_ID }); }
    catch (e) { flash("Couldn't save order: " + e.message, "error"); }
  }
  function reorderContainer(selector, ids) {
    const el = document.querySelector(selector);
    if (!el) return;
    const byId = new Map();
    Array.from(el.children).forEach(child => {
      const idEl = child.matches("[data-chore-id]") ? child : child.querySelector("[data-chore-id]");
      if (!idEl) return;
      byId.set(parseInt(idEl.dataset.choreId, 10), child);
    });
    const frag = document.createDocumentFragment();
    ids.forEach(id => { const node = byId.get(id); if (node) { frag.appendChild(node); byId.delete(id); } });
    byId.forEach(c => frag.appendChild(c));
    el.appendChild(frag);
  }
  function applyOrderToDom(ids) {
    ChoreStore.reorder(ids);
    reorderContainer("[data-chores-grid]", ids);
    reorderContainer("[data-chores-today]", ids);
    reorderContainer("[data-chores-overdue]", ids);
  }
  editModeBtn?.addEventListener("click", () => { if (editModeActive) exitEditMode(); else enterEditMode(); });

  // Form submit
  if (editForm) { bindPillGroups(); bindIconUploader(editForm); }
  // Cancel buttons reset the form; backdrop click is treated as
  // accidental and only hides (so reopening preserves what was typed).
  // The drag-from-inside-to-outside text selection no longer dismisses.
  wireModalDismiss(editModal, {
    onCancel:   dismissEditModalExplicit,
    onBackdrop: dismissEditModalAccidental,
  });

  editForm?.addEventListener("submit", async e => {
    e.preventDefault();
    // Guard against double-tap on Save: while the request is in
    // flight, disable the button and swap its label for a spinner.
    const submitBtn = editForm.querySelector('button[type="submit"]');
    if (submitBtn?.dataset.busy === "1") return;
    if (submitBtn) {
      submitBtn.dataset.busy = "1";
      submitBtn.disabled = true;
      submitBtn.classList.add("loading");
    }
    const oneOff = isSingleTask();
    const sharingMode = getField("sharing_mode") || "household";
    const activeReward = editForm.querySelector('[data-reward-quicks] .pill.active');
    const rewardVal = activeReward?.dataset.reward;
    const customInput = editForm.querySelector('.reward-custom');
    const reward = (rewardVal && rewardVal !== "custom")
      ? parseInt(rewardVal, 10)
      : (parseInt(customInput?.value, 10) || 0);

    let recurrence = {};
    let thresholdSeconds = null;
    if (!oneOff) {
      const freq = getField("freq") || "never";
      thresholdSeconds = parseInt(editForm.querySelector('[data-field="threshold_seconds"]')?.value, 10);
      if (!Number.isFinite(thresholdSeconds) || thresholdSeconds === 0) thresholdSeconds = null;
      if (freq !== "never") {
        recurrence.freq = freq;
        if (freq === "weekly") recurrence.by_day = collectWeekdays();
        if (freq === "monthly") {
          const mode = editForm.querySelector('[data-month-mode-tabs] .pill.active')?.dataset.monthMode || "day-of-month";
          if (mode === "nth-weekday") {
            recurrence.by_set_pos = parseInt(editForm.querySelector('[data-month-set-pos]').value, 10);
            recurrence.by_day = [editForm.querySelector('[data-month-wday]').value];
          } else {
            const chips = Array.from(editForm.querySelectorAll('[data-month-day-pane] .md-chip.active'));
            const days = chips.map(c => parseInt(c.dataset.day, 10)).filter(n => !Number.isNaN(n));
            if (days.length) recurrence.by_month_day = days;
            else if (parseStartsOn()) recurrence.by_month_day = [parseStartsOn().getDate()];
          }
        }
        if (freq === "custom" || freq === "relative") {
          recurrence.interval = parseInt(editForm.querySelector('[data-interval]')?.value, 10) || 1;
          recurrence.unit = editForm.querySelector('[data-unit]')?.value || "day";
        }
        if (freq === "after_chore") {
          const when = getField("after_chore_when") || "today";
          if (when === "today") {
            recurrence.interval = 0;
            recurrence.unit = "day";
          } else if (when === "tomorrow") {
            recurrence.interval = 1;
            recurrence.unit = "day";
          } else {
            const rawInterval = editForm.querySelector('[data-after-chore-interval]')?.value;
            const parsed = parseInt(rawInterval, 10);
            recurrence.interval = Number.isFinite(parsed) ? Math.max(2, parsed) : 2;
            recurrence.unit = editForm.querySelector('[data-after-chore-unit]')?.value || "day";
          }
          const anchorId = parseInt(editForm.querySelector('[data-anchor-chore-id]')?.value, 10);
          if (Number.isFinite(anchorId) && anchorId > 0) recurrence.anchor_chore_id = anchorId;
        }
}
    }
    const payload = {
      chore: {
        name: getField("name"),
        short_name: getField("short_name"),
        icon: getField("icon"),
        reward_pebbles: reward,
        threshold_seconds: thresholdSeconds,
        one_off: oneOff,
        starts_on: getField("starts_on") || null,
        marked_due_at: getField("marked_due_at") || null,
        show_on_daily_view: getField("show_on_daily_view") || "when_scheduled",
        hot_eligibility: getField("hot_eligibility") || "when_available",
        sharing_mode: sharingMode,
        assigned_to_user_id: getField("assigned_to_user_id") || null,
        parent_chore_id: getField("parent_chore_id") || null,
        aliases: (getField("aliases_csv") || "").split(",").map(s => s.trim()).filter(Boolean),
        notes_template: getField("notes_template") || "",
        notes: getField("notes") || "",
        recurrence: recurrence,
      },
    };
    try {
      const isUpdate = !!currentChoreId;
      const url = isUpdate ? `/chores/items/${currentChoreId}` : "/chores/items";
      const data = await api(url, isUpdate ? "PATCH" : "POST", payload);
      reconcile(data);
      dismissEditModalExplicit();
      flash("Saved");
      pingSwRefresh();
    } catch (err) {
      if (isTransientError(err)) {
        flash("Server busy — try again in a moment", "warn");
      } else {
        flash("Save failed: " + err.message, "error");
      }
    } finally {
      if (submitBtn) {
        delete submitBtn.dataset.busy;
        submitBtn.disabled = false;
        submitBtn.classList.remove("loading");
      }
    }
  });

  editForm?.querySelector('[data-action="archive"]')?.addEventListener("click", async () => {
    if (!currentChoreId || !confirm("Archive this chore?")) return;
    const id = currentChoreId;
