<%# Unified chores page script — JSON-store-driven, no server HTML.
   Architecture:
     * ChoreStore (Map<id, ChoreData>) is the single source of truth.
     * Templates are pure (data → DOM) functions.
     * Views subscribe to store changes and re-render affected cards.
     * Mutations apply optimistic patches, then reconcile with server JSON.
%>
<script>
  window.__currentUserId = <%= current_user.id.to_json.html_safe %>;
</script>
<script type="module">
  // ============================================================
  // bootstrap + constants
  // ============================================================
  // Read meta dynamically on every request — the SW serves a cached
  // shell that may carry a CSRF token from weeks ago (whenever the
  // shell was first cached). Capturing once at boot would freeze that
  // stale token; reading dynamically lets refreshCsrf() heal it.
  function currentCsrf() {
    return document.querySelector('meta[name="csrf-token"]')?.content || "";
  }
  const root = document.querySelector('[data-chores-root]');
  const DAY_KEY = root?.dataset.dayKey || "";
  const CUTOFF_HOUR = parseInt(root?.dataset.cutoffHour || "4", 10);
  const VIEWER_USERNAME = root?.dataset.viewerUsername || "";
  const TAB_ID = (window.crypto?.randomUUID?.() || String(Date.now() + Math.random()));

  // Active view — `data-active-view` only exists on the unified Grid/
  // Today page. Balance and History also include this script for the
  // SW/offline-queue/modal infrastructure but skip view + store logic.
  let MODE = root?.dataset.activeView || "grid";
  const unifiedPage = !!(root && root.dataset.activeView);

  // Per-user balance cache for the header pill. Survives reloads so
  // the pill paints from localStorage instantly instead of flashing
  // a "—" placeholder while waiting for /chores/sync. Cleared only
  // by setTodayEarnings/setLifetimeBalance themselves.
  const BALANCE_LS_KEY = "chores:balance:v1";

  // localClickTs: per-chore most-recent local click epoch ms. Used to
  // discard server payloads captured before that click — protects
  // optimistic state from being clobbered by a race-stale broadcast or
  // out-of-order POST response.
  const localClickTs = new Map();

  // Absolute click-protection window: while the user is actively
  // tapping a chore (repeat-tap chores may fire 5-10 taps in rapid
  // succession), ANY incoming server data for that chore is dropped
  // entirely — even if its server_ts is newer than our tap. Otherwise
  // the ack for tap #1 (done_count=1) races the user's ongoing taps
  // (local done_count=6) and drags the count backwards, producing the
  // "numbers jitter" symptom users reported.
  //
  // Once the window closes (no taps for CLICK_PROTECTION_MS), a single
  // /chores/items/:id/state fetch is issued to converge with server
  // truth. Any drops during the window are caught up by that verify.
  const CLICK_PROTECTION_MS = 3000;
  // per-chore: { lastClickAt: epoch ms, verifyTimer: handle | null }
  const clickProtection = new Map();

  function noteClientTap(choreId) {
    const id = parseInt(choreId, 10);
    if (!id) return;
    const now = Date.now();
    const prior = clickProtection.get(id) || {};
    if (prior.verifyTimer) clearTimeout(prior.verifyTimer);
    // Legacy alias — other timestamp comparisons in reconcile still
    // read from localClickTs, so keep it in sync per-tap.
    localClickTs.set(String(id), now);
    const state = { lastClickAt: now, verifyTimer: null };
    state.verifyTimer = setTimeout(() => {
      // Fire only if no new tap arrived after this one. Any newer tap
      // would have replaced verifyTimer during clearTimeout above.
      const cur = clickProtection.get(id);
      if (!cur || cur.lastClickAt !== now) return;
      cur.verifyTimer = null;
      // Optional: skip the fetch when offline — nothing to converge
      // against. onAppWake() runs a fresh fullSync when we come back
      // and will pull the correct value then.
      if (!navigator.onLine) return;
      api(`/chores/items/${id}/state`, "GET").then(reconcile).catch(() => {});
    }, CLICK_PROTECTION_MS + 250);
    clickProtection.set(id, state);
  }

  function isChoreProtected(choreId) {
    const id = parseInt(choreId, 10);
    const state = clickProtection.get(id);
    if (!state || !state.lastClickAt) return false;
    return (Date.now() - state.lastClickAt) < CLICK_PROTECTION_MS;
  }
  // pendingMutationIds: per-chore stack of client_mutation_ids for
  // queued/flushed completes that have not been undone in this session.
  // Push on every complete enqueue, pop on every undo enqueue. The
  // popped id is the undo's target — collapses with a still-queued
  // complete (no server round-trip), or rides as `target_client_mutation_id`
  // so the server deletes exactly that row idempotently on replay.
  // Stack lives in-memory only; on cold load, undos with no popped id
  // fall back to the server's "most recent today" path.
  const pendingMutationIds = new Map();
  function pushPendingMutation(choreId, mid) {
    const arr = pendingMutationIds.get(choreId) || [];
    arr.push(mid);
    pendingMutationIds.set(choreId, arr);
  }
  function popPendingMutation(choreId) {
    const arr = pendingMutationIds.get(choreId);
    if (!arr || !arr.length) return null;
    const mid = arr.pop();
    if (!arr.length) pendingMutationIds.delete(choreId);
    return mid;
  }
  function newMutationId() {
    if (window.crypto?.randomUUID) return window.crypto.randomUUID();
    // Fallback for older WebViews: timestamp + random, collision-safe
    // enough for per-user idempotency keys.
    return `m-${Date.now()}-${Math.random().toString(36).slice(2, 12)}`;
  }

  // ============================================================
  // helpers
  // ============================================================
  function esc(s) {
    if (s == null) return "";
    return String(s).replace(/[&<>"']/g, c => (
      { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]
    ));
  }
  function formatMultiplier(n) {
    if (n == null) return "";
    const f = Number(n);
    return f === Math.floor(f) ? String(Math.floor(f)) : String(f);
  }
  // Thousands delimiter for any visible count (balance pill, etc.).
  // Mirrors Rails `number_with_delimiter` in the views so the JS-
  // updated balance never desynces visually from a server-rendered
  // page (1,234p in HTML, 1,234p after applyBalance).
  function formatCount(n) {
    if (n == null) return "";
    const f = Number(n);
    if (!Number.isFinite(f)) return "";
    return f.toLocaleString();
  }
  async function api(url, method, body) {
    // First attempt with whatever CSRF is currently in meta. If it
    // comes back 422 (stale token after a session rotation), refresh
    // the token via /chores/csrf and retry exactly once. Persistent
    // 422 after refresh means a genuine validation failure, not a
    // CSRF issue, and we surface it to the caller.
    let res = await fetch(url, {
      method,
      credentials: "same-origin",
      headers: { "Content-Type": "application/json", "Accept": "application/json", "X-CSRF-Token": currentCsrf() },
      body: body ? JSON.stringify(body) : undefined,
    });
    if (res.status === 422) {
      const fresh = await refreshCsrf();
      if (fresh) {
        res = await fetch(url, {
          method,
          credentials: "same-origin",
          headers: { "Content-Type": "application/json", "Accept": "application/json", "X-CSRF-Token": fresh },
          body: body ? JSON.stringify(body) : undefined,
        });
      }
    }
    if (!res.ok) {
      const text = await res.text();
      const err = new Error(`${res.status}: ${text}`);
      err.status = res.status;
      throw err;
    }
    return res.status === 204 ? null : res.json();
  }
  // Anything we should retry rather than surface as a "failed" flash:
  // network errors, 429 (rate-limit), 502/503/504 (upstream). The
  // offline-queue's `classify` already keeps these — this is the
  // direct-mutation path's mirror.
  function isTransientError(err) {
    if (!navigator.onLine) return true;
    if (/Failed to fetch|NetworkError/i.test(err.message || "")) return true;
    const s = err.status || parseInt(String(err.message).split(":")[0], 10);
    return s === 429 || s === 502 || s === 503 || s === 504;
  }
  function flash(msg, type = "ok") {
    const el = document.createElement("div");
    el.className = "chores-flash " + (type === "error" ? "error" : (type === "warn" ? "warn" : ""));
    el.textContent = msg;
    document.body.appendChild(el);
    requestAnimationFrame(() => el.classList.add("show"));
    setTimeout(() => { el.classList.remove("show"); setTimeout(() => el.remove(), 250); }, 2400);
  }
  // Disable a submit-style button and show the centered .loading
  // spinner (defined in chores.scss) while an async action runs.
  // Re-entrant clicks are dropped because the button is disabled.
  async function withSavingState(btn, fn) {
    if (!btn || btn.disabled) return;
    btn.disabled = true;
    btn.classList.add("loading");
    try { return await fn(); }
    finally {
      btn.disabled = false;
      btn.classList.remove("loading");
    }
  }

  // ============================================================
  // ChoreStore — the data model. Every read derives from here.
  //
  // Persistence contract:
  //   * The store NEVER drops chores on its own. The only paths that
  //     remove a chore from the store are explicit `remove(id)` calls
  //     and the `active_chore_ids` reconcile from /sync (anything
  //     locally cached but not in that authoritative id list).
  //   * `bootstrap` is ADDITIVE — it merges fresh data into the existing
  //     store, never clears it. A stale/empty cached shell can never
  //     wipe a populated UI; the worst case is "we already had these
  //     chores and now we still do."
  //   * Every mutation persists to localStorage so a fresh page load
  //     with an empty inline shell can hydrate from local first, then
  //     merge whatever the network eventually returns.
  // ============================================================
  const STORE_LS_KEY = "chores:store:v1";
  const ChoreStore = (() => {
    const map = new Map();
    let lookahead = {};
    // Ordered list of chore ids the viewer has pinned to their Dailies
    // section on Today. Independent of `today_visible` — items here are
    // purely user-curated, not derived from show_on_today_view.
    let dailyIds = [];
    let dailyIdSet = new Set();
    const subs = new Set();
    function notify(kind, id) { subs.forEach(fn => { try { fn(kind, id); } catch (e) { console.error(e); } }); }
    function rebuildDailySet() { dailyIdSet = new Set(dailyIds.map(n => parseInt(n, 10))); }
    function persist() {
      try {
        localStorage.setItem(STORE_LS_KEY, JSON.stringify({
          chores: Array.from(map.values()),
          lookahead,
          dailyIds,
        }));
      } catch (e) { /* storage full or unavailable — non-fatal */ }
    }
    // Pull last-known state from localStorage. Returns the payload or
    // null. Caller decides whether to merge it (used when the inline
    // shell JSON is empty / stale and we'd otherwise paint nothing).
    function loadPersisted() {
      try {
        const raw = localStorage.getItem(STORE_LS_KEY);
        if (!raw) return null;
        return JSON.parse(raw);
      } catch (e) { return null; }
    }
    return {
      // Server's `items` arrive in sort_order — that ordering IS
      // authoritative and must replace whatever insertion order
      // localStorage seeded via hydrateFromLocal. Map.set on an
      // existing key keeps the key's original slot, so a naive merge
      // would freeze the order at whatever localStorage had. Rebuild
      // the map: server-named ids first (in server order, merging old
      // fields with new), then any leftover cached entries appended
      // at the tail so a partial bootstrap can never drop a chore.
      // Removals are still handled separately by the prune step the
      // caller runs before bootstrap. Emits a single "reconcile"
      // notify so subscribers diff the DOM against the new order.
      bootstrap(items, look, dailies) {
        const arr = items || [];
        if (arr.length > 0) {
          const next = new Map();
          arr.forEach(c => {
            if (!c || !c.id) return;
            const existing = map.get(c.id);
            next.set(c.id, { ...existing, ...c });
          });
          map.forEach((v, k) => { if (!next.has(k)) next.set(k, v); });
          map.clear();
          next.forEach((v, k) => map.set(k, v));
        }
        if (look && Object.keys(look).length > 0) lookahead = look;
        if (Array.isArray(dailies)) {
          // Daily pins come from the server when present. An empty
          // array IS authoritative — user could have unpinned everything
          // — but a missing/undefined `dailies` arg means "don't touch
          // the existing list" (e.g. a partial bootstrap path).
          dailyIds = dailies.map(n => parseInt(n, 10)).filter(Boolean);
          rebuildDailySet();
        }
        persist();
        notify("reconcile");
      },
      hydrateFromLocal() {
        const p = loadPersisted();
        if (!p) return false;
        (p.chores || []).forEach(c => {
          if (!c || !c.id) return;
          if (!map.has(c.id)) map.set(c.id, c);
        });
        if (p.lookahead && Object.keys(lookahead).length === 0) lookahead = p.lookahead;
        if (Array.isArray(p.dailyIds) && dailyIds.length === 0) {
          dailyIds = p.dailyIds.map(n => parseInt(n, 10)).filter(Boolean);
          rebuildDailySet();
        }
        // Emit a "reconcile" notify so subscribers (Views.renderAll)
        // paint the loaded state. Without this the map gets populated
        // silently and views stay empty until the first /chores/sync
        // returns — the page looks blank on hard reload + slow/no
        // network even when localStorage holds the entire chore set.
        notify("reconcile");
        return true;
      },
      setDailyIds(ids) {
        dailyIds = (ids || []).map(n => parseInt(n, 10)).filter(Boolean);
        rebuildDailySet();
        persist();
        notify("dailies");
      },
      pinDaily(id) {
        const n = parseInt(id, 10);
        if (!n || dailyIdSet.has(n)) return;
        dailyIds.push(n);
        dailyIdSet.add(n);
        persist();
        notify("dailies");
      },
      unpinDaily(id) {
        const n = parseInt(id, 10);
        if (!dailyIdSet.has(n)) return;
        dailyIds = dailyIds.filter(x => x !== n);
        dailyIdSet.delete(n);
        persist();
        notify("dailies");
      },
      reorderDailies(ids) {
        const allowed = new Set(dailyIds);
        const next = [];
        (ids || []).forEach(id => {
          const n = parseInt(id, 10);
          if (allowed.has(n) && !next.includes(n)) next.push(n);
        });
        // Preserve any pin not present in the supplied order so we
        // don't silently drop dailies a stale client didn't know about.
        dailyIds.forEach(id => { if (!next.includes(id)) next.push(id); });
        dailyIds = next;
        rebuildDailySet();
        persist();
        notify("dailies");
      },
      isDaily(id) { return dailyIdSet.has(parseInt(id, 10)); },
      dailyIds() { return dailyIds.slice(); },
      upsert(c, { optimistic = false, authoritative = false } = {}) {
        if (!c || !c.id) return false;
        const existing = map.get(c.id);
        // Skip the updated_at guard when the caller declares the
        // payload authoritative (cold-boot full /chores/sync). Stuck
        // local state from prior sessions — partial flushes, optimistic
        // updates that never reconciled, divergence across devices —
        // can leave existing.updated_at higher than truth; the guard
        // would then make incremental syncs unable to repair it. The
        // boot full sync is the safe place to overwrite because it
        // runs AFTER hydrateFromLocal and BEFORE any user click, so
        // there's no in-flight optimistic write to clobber.
        if (!optimistic && !authoritative &&
            existing?.updated_at && c.updated_at &&
            existing.updated_at > c.updated_at) {
          // Newer local copy wins; don't overwrite.
          return false;
        }
        map.set(c.id, { ...existing, ...c });
        persist();
        notify("upsert", c.id);
        return true;
      },
      patch(id, fields) {
        const existing = map.get(id);
        if (!existing) return;
        map.set(id, { ...existing, ...fields });
        persist();
        notify("upsert", id);
      },
      remove(id) {
        if (!map.has(id)) return;
        map.delete(id);
        const n = parseInt(id, 10);
        if (dailyIdSet.has(n)) {
          dailyIds = dailyIds.filter(x => x !== n);
          dailyIdSet.delete(n);
        }
        persist();
        notify("remove", id);
      },
      // Rebuild the map in the supplied id order so any view that reads
      // chores in iteration order (Grid, Today) reflects the new sort.
      // Unknown ids are skipped; chores not in `ids` are appended in
      // their current order so they don't vanish from the views.
      reorder(ids) {
        const next = new Map();
        ids.forEach(id => {
          const key = parseInt(id, 10);
          if (map.has(key)) { next.set(key, map.get(key)); map.delete(key); }
        });
        map.forEach((v, k) => next.set(k, v));
        map.clear();
        next.forEach((v, k) => map.set(k, v));
        persist();
      },
      get(id) { return map.get(id); },
      all() { return Array.from(map.values()); },
      // Items pinned to Dailies, in the user's curated order. A pinned
      // chore stays here regardless of today_visible — only archival
      // hides it.
      dailiesList() {
        const out = [];
        dailyIds.forEach(id => {
          const c = map.get(id);
          if (c && !c.archived) out.push(c);
        });
        return out;
      },
      // Items whose schedule actually fires today (or one-offs currently
      // on Today), minus dailies. Sits between Dailies and Scheduled and
      // is hidden when empty.
      todayList() {
        return this.all().filter(c => c.due_today && c.today_visible && !c.archived && !dailyIdSet.has(c.id));
      },
      // Items that today_visible filtering would have put on the old
      // Today screen, minus dailies AND minus the new "due today"
      // section. What's left is overdue carryovers and always-on items.
      // Sorted by scheduled_due_on descending (most recent due date on
      // top); items without a derived due date sink to the bottom in
      // their existing order.
      overdueList() {
        const items = this.all().filter(c => c.today_visible && !c.archived && !dailyIdSet.has(c.id) && !c.due_today);
        return items.sort((a, b) => {
          const da = a.scheduled_due_on || "";
          const db = b.scheduled_due_on || "";
          if (da === db) return 0;
          if (!da) return 1;
          if (!db) return -1;
          return db.localeCompare(da);
        });
      },
      activeForGrid() { return this.all().filter(c => !c.archived); },
      hotPicks() {
        return this.all()
          .filter(c => c.hot_multiplier != null && !c.archived)
          .sort((a, b) => (b.hot_multiplier - a.hot_multiplier));
      },
      lookahead() { return lookahead; },
      setLookahead(l) { lookahead = l || {}; persist(); notify("lookahead"); },
      subscribe(fn) { subs.add(fn); return () => subs.delete(fn); },
    };
  })();

  // ============================================================
  // DOM builders — clone shell templates, fill with data, return
  // detached nodes. No HTML strings, no innerHTML on the consumer
  // side. Adding a new variant means editing _templates.html.erb
  // and the matching builder; consumers don't need to change.
  // ============================================================

  // Build a chore-icon node. Mirrors the server's `icon_kind` switch.
  // Returns a detached DOM element ready to insertBefore/appendChild.
  // Branches:
  //   * no icon         → icon-placeholder (📝 for one-offs, 🧹 otherwise)
  //   * data:/http(s):/ → icon-img
  //   * inline <svg>    → parsed SVG root (only path that still parses
  //                       HTML — required for user-pasted SVGs)
  //   * ti-*            → ti font-icon
  //   * fallthrough     → icon-glyph (single emoji / character)
  function buildIconNode(c) {
    const v = (c.icon || "").trim();
    if (!v) {
      const el = cloneTemplate("icon-placeholder");
      if (el) el.textContent = c.one_off ? "📝" : "🧹";
      return el;
    }
    if (v.startsWith("data:image/") || v.startsWith("http://") || v.startsWith("https://")) {
      const el = cloneTemplate("icon-img");
      if (el) el.src = v;
      return el;
    }
    if (v.startsWith("<svg")) {
      // User-pasted SVGs: parse via a throwaway template so the browser
      // sanitizes during parse. This is the only place we still touch
      // an HTML string, and it's user-supplied data, not a literal.
      const wrap = document.createElement("template");
      wrap.innerHTML = v;
      return wrap.content.firstElementChild;
    }
    if (v.startsWith("ti-")) {
      const el = cloneTemplate("icon-ti");
      if (el) el.classList.add(v);
      return el;
    }
    const el = cloneTemplate("icon-glyph");
    if (el) el.textContent = v;
    return el;
  }
  // Same as buildIconNode, but reads the server-emitted `icon_kind`
  // marker instead of inferring from the icon string. Used by the
  // Recent History list where every entry already carries `icon_kind`
  // alongside `icon`.
  function buildIconNodeFromKind(chore) {
    const v = (chore.icon || "").trim();
    const kind = chore.icon_kind;
    if (!v || kind === "empty") {
      const el = cloneTemplate("icon-placeholder");
      if (el) el.textContent = "🧹";
      return el;
    }
    if (kind === "image") {
      const el = cloneTemplate("icon-img");
      if (el) el.src = v;
      return el;
    }
    if (kind === "svg") {
      const wrap = document.createElement("template");
      wrap.innerHTML = v;
      return wrap.content.firstElementChild;
    }
    if (kind === "ti_icon") {
      const el = cloneTemplate("icon-ti");
      if (el) el.classList.add(v);
      return el;
    }
    const el = cloneTemplate("icon-glyph");
    if (el) el.textContent = v;
    return el;
  }
  // Replace the icon child(ren) inside a host element with a freshly
  // built node. Used by anchor/parent pickers + chore picker cells +
  // anywhere else a chore icon container needs to be repopulated.
  function setIconInside(hostEl, c) {
    if (!hostEl) return;
    while (hostEl.firstChild) hostEl.removeChild(hostEl.firstChild);
    const node = buildIconNode(c);
    if (node) hostEl.appendChild(node);
  }

  function hasCooldown(c) { return c.cooldown_kind === "fixed" || c.cooldown_kind === "day_reset"; }

  // State-icon classification for Today + Scheduled circles. Mirrors the
  // server's `due_today` derivation: recurring-daily chores get a Sun,
  // anything else due today (one-offs, weekly/monthly matches) gets a
  // Clock, and carryover/overdue items get an Hourglass.
  function stateIconClass(c) {
    if (!c.today_visible || c.archived) return null;
    const freq = (c.recurrence && c.recurrence.freq) || "never";
    // No schedule = no schedule state to communicate. Pinned Dailies
    // (typically freq:never), Always-shown one-offs, and Available-on-
    // cooldown items all fall through here and stay icon-less.
    if (freq === "never") return null;
    if (freq === "daily") return "fa-sun-o";
    if (c.due_today)      return "fa-clock-o";
    return "fa-hourglass-half";
  }
  // DOM builder for the state icon (Sun / Clock / Hourglass). Returns
  // a detached <i> ready to append, or null when the chore has no
  // state to communicate. The class is added separately so we never
  // template-literal a class string.
  function buildStateIconNode(c) {
    const cls = stateIconClass(c);
    if (!cls) return null;
    const el = cloneTemplate("state-icon");
    if (el) el.classList.add(cls);
    return el;
  }

  // Progress-toward-target helpers. `progress_count` is server-emitted
  // and tracks taps within the chore's current occurrence (= today for
  // daily chores). Falls back to done_count_today so older payloads
  // and optimistic patches still work.
  function progressOf(c) {
    return Math.max(0, c.progress_count != null ? c.progress_count : (c.done_count_today || 0));
  }
  function targetOf(c) {
    return Math.max(1, c.target_count || 1);
  }
  function progressRatio(c) {
    return Math.min(1, progressOf(c) / targetOf(c));
  }
  // Visual "fully done" — the celebratory done-ring animation only
  // fires when the chore has hit its daily target. For target_count=1
  // this matches the old `done_count_today > 0` behavior; for target>1
  // it waits for the final tap so the progress ring can grow visibly
  // through 1/N, 2/N, ... N/N.
  function isFullyDone(c) {
    const target = targetOf(c);
    const progress = progressOf(c);
    return progress > 0 && progress >= target;
  }
  // DOM builder for the count badge. Returns null when there's no
  // badge to show (target=1 + progress<=1 → empty slot). Otherwise
  // returns a populated <span class="count-badge"> element cloned
  // from the shared template.
  function buildCountBadgeNode(c) {
    const target = targetOf(c);
    const progress = progressOf(c);
    if (target <= 1 && progress <= 1) return null;
    const el = cloneTemplate("count-badge");
    if (!el) return null;
    el.textContent = target > 1 ? `${progress}/${target}` : `×${progress}`;
    return el;
  }


  // The three card structures used to live as JS template literals
  // (gridCardHTML / circleCardHTML / hotCellHTML). They now live as
  // server-rendered <template> elements in _templates.html.erb — see
  // cloneTemplate(name). The renderers below clone the empty template
  // and then run patchGridCard / patchCircleCard, which is the SAME
  // function that handles incremental updates. One code path, one
  // source of truth for chore-card HTML.

  function nodeFrom(html) {
    const t = document.createElement("template");
    t.innerHTML = (html || "").trim();
    return t.content.firstElementChild;
  }
  // Clone a server-rendered <template data-template="name"> from the
  // shell. THIS is the only place chore-card structural HTML enters
  // the DOM — there are no JS template literals for cards. Means a
  // markup change in _templates.html.erb takes effect for BOTH
  // initial render (clone + patcher) AND incremental update (patcher)
  // since the patcher is the only thing that touches data after clone.
  // Returns null if the template is missing so callers can no-op
  // gracefully on pages that don't render the templates partial
  // (e.g. balance/history aren't unified shells).
  function cloneTemplate(name) {
    const t = document.querySelector(`template[data-template="${name}"]`);
    if (!t || !t.content) return null;
    const root = t.content.firstElementChild;
    return root ? root.cloneNode(true) : null;
  }
  // Populate a chore card's icon slot. The template ships the .icon
  // container empty; this puts the appropriate child element inside
  // it. Centralizes the 5-way icon kind switch so each render path
  // doesn't need to know about icon variants. Pure DOM construction
  // — no innerHTML, no string parsing.
  function setCardIcon(cardEl, c) {
    const slot = cardEl.querySelector("[data-icon]");
    if (!slot) return;
    // Remove any previous icon element (preserve sibling .card-reward
    // and any countdown span the patcher may have inserted).
    Array.from(slot.children).forEach(child => {
      if (child.matches(".icon-placeholder, .icon-img, .icon-glyph, .icon-ti, svg")) {
        child.remove();
      }
    });
    const iconEl = buildIconNode(c);
    if (iconEl) {
      // Insert AFTER any .card-reward / .circle-reward (the reward
      // span is first in both card templates so the icon sits after
      // it, matching the legacy layout order).
      const reward = slot.querySelector(":scope > .card-reward, :scope > .circle-reward");
      if (reward && reward.nextSibling) slot.insertBefore(iconEl, reward.nextSibling);
      else slot.appendChild(iconEl);
    }
  }
  // Place the cooldown countdown span inside an icon slot when the
  // chore has a cooldown. Mirrors what the legacy HTML strings did
  // inline. The patchers update its text via the existing ticker;
  // this only ensures the element exists (and is removed when it
  // shouldn't).
  function setCardCountdown(cardEl, c) {
    const slot = cardEl.querySelector("[data-icon]");
    if (!slot) return;
    const existing = slot.querySelector(":scope > [data-circle-countdown]");
    if (!hasCooldown(c)) {
      existing?.remove();
      return;
    }
    if (existing) {
      existing.dataset.cooldownEnd = c.cooldown_kind === "day_reset" ? "day-end" : "";
      return;
    }
    const span = document.createElement("span");
    span.className = "circle-countdown";
    span.dataset.circleCountdown = "";
    span.dataset.cooldownEnd = c.cooldown_kind === "day_reset" ? "day-end" : "";
    slot.appendChild(span);
  }
  // Place the cooldown SVG ring inside the circle-inner of a circle
  // card. Cloned from <template data-template="circle-cooldown-ring">
  // so the SVG markup lives in the shell, not in JS.
  function setCircleCooldownRing(cardEl, c) {
    const inner = cardEl.querySelector(".circle-inner");
    if (!inner) return;
    const existing = inner.querySelector(":scope > .circle-cooldown-ring");
    if (!hasCooldown(c)) {
      existing?.remove();
      return;
    }
    if (existing) return;
    const ring = cloneTemplate("circle-cooldown-ring");
    if (!ring) return;
    // Goes BEFORE the done-ring so the cooldown overlay sits underneath.
    const doneRing = inner.querySelector(":scope > .done-ring");
    if (doneRing) inner.insertBefore(ring, doneRing);
    else inner.insertBefore(ring, inner.firstChild);
  }

  // ============================================================
  // Per-chore data attribute hydration — JS reads these for cooldowns
  // + last_completed_at without re-reading the store on every tick.
  // We set them in addition to the visible HTML so existing ticker
  // code stays cheap.
  // ============================================================
  function hydrateDataAttrs(el, c) {
    el.dataset.choreCooldown = c.threshold_seconds || 0;
    el.dataset.choreOneOff = String(!!c.one_off);
    el.dataset.lastCompletedAt = c.last_completed_at || "";
    el.dataset.doneCount = c.done_count_today || 0;
    el.dataset.choreName = c.name || "";
    el.dataset.choreShort = c.short_name || "";
    // Store the RAW ref (`hicon:<id>` or a glyph) rather than the
    // resolved icon so change-detection compares short strings instead
    // of full data URLs. Falls back to `icon` for legacy stores.
    el.dataset.choreIcon = c.icon_ref || c.icon || "";
    el.dataset.choreReward = c.reward_pebbles || 0;
    el.dataset.choreShowOnTodayView = c.show_on_today_view || "when_scheduled";
    el.dataset.choreSharingMode = c.sharing_mode || "personal";
    el.dataset.choreAssignedToUserId = c.assigned_to_user_id || "";
    el.dataset.choreStartsOn = c.starts_on || "";
    el.dataset.choreRecurrence = JSON.stringify(c.recurrence || {});
    el.dataset.choreAliases = (c.aliases || []).join("|");
    if (c.last_actor_anonymous) {
      el.dataset.actorAnonymous = "true";
      delete el.dataset.actor;
    } else {
      delete el.dataset.actorAnonymous;
      if (c.last_actor_username) el.dataset.actor = c.last_actor_username;
      else delete el.dataset.actor;
    }
  }

  // Done-ring animation bookkeeping. The keyframe runs on every fresh
  // .done element, so:
  //   * `seenDone` tracks chores we've already shown as done; re-renders
  //     of those skip the animation via the `no-animate` class so an
  //     incoming server upsert doesn't restart the draw.
  //   * `ringAnimating` blocks upsertOne while a draw is in flight so
  //     the SVG can complete; updates that arrived during the window
  //     get parked in `ringDeferred` and replayed when it ends.
  const RING_ANIM_MS = 550;
  const seenDone = new Set();
  const ringAnimating = new Set();
  const ringDeferred = new Map();

  function shouldAnimateDone(c) {
    const sid = String(c.id);
    if (!isFullyDone(c)) {
      seenDone.delete(sid);
      return false;
    }
    if (seenDone.has(sid)) return false;
    seenDone.add(sid);
    return true;
  }

  function noteRingAnimation(id) {
    const sid = String(id);
    ringAnimating.add(sid);
    setTimeout(() => {
      ringAnimating.delete(sid);
      if (ringDeferred.has(sid)) {
        const pending = ringDeferred.get(sid);
        ringDeferred.delete(sid);
        Views.upsertOne(pending);
      }
    }, RING_ANIM_MS);
  }

  // Paint partial progress directly on the done-ring's circle so the
  // partial state visually matches the completion celebration (same
  // radius, stroke-width, glow). The circle uses pathLength=100, so
  // dashoffset == (1 - ratio) * 100. When fully done, the `.done`
  // class lets the keyframe take over and run the draw animation.
  function applyProgressRing(el, c) {
    if (!el) return;
    const ring = el.querySelector('[data-ring-progress]');
    if (!ring) return;
    if (isFullyDone(c)) {
      if (targetOf(c) > 1) {
        // Multi-tap chore hit its target: continue the partial fill
        // smoothly to full instead of triggering the 100→0 keyframe
        // (which would visibly snap back to empty before redrawing).
        // patchCircleCard / initCircleCard add `.no-animate` for the
        // same reason, so the keyframe is suppressed.
        ring.style.strokeDasharray = "100";
        ring.style.strokeDashoffset = "0";
        ring.style.opacity = "1";
      } else {
        // target == 1: original binary done. Let the `.done` CSS rule
        // + keyframe own the celebratory draw.
        ring.style.strokeDasharray = "";
        ring.style.strokeDashoffset = "";
        ring.style.opacity = "";
      }
      return;
    }
    // Inline style beats both the base `.done-ring circle` CSS (which
    // hides the ring at dashoffset:100) AND the SVG presentation attrs,
    // so a 2/5 chore shows exactly 40% of the same thick ring you see
    // on a completed chore.
    const ratio = progressRatio(c);
    ring.style.strokeDasharray = "100";
    ring.style.strokeDashoffset = String(100 * (1 - ratio));
    // At ratio=0, stroke-linecap:round leaves a tiny dot at the start
    // of the path. Fade the whole ring out instead.
    ring.style.opacity = ratio > 0 ? "1" : "0";
  }

  // Apply the bits that the patchers don't touch (icon contents,
  // cooldown ring/countdown, chore-id, animation state) on top of a
  // freshly cloned blank template. After this returns, the element
  // is fully initialized and any future updates flow through the
  // patcher — same code path as a live update on an existing card.
  function initGridCard(el, c) {
    el.dataset.choreId = c.id;
    // Seed the data attrs the patcher's structural-change detector
    // reads (choreIcon, choreCooldown). Without this seed the first
    // patch() call sees "blank dataset != current chore" and triggers
    // a recursive re-render. Order: data attrs → icon DOM → patcher.
    hydrateDataAttrs(el, c);
    setCardIcon(el, c);
    setCardCountdown(el, c);
    patchGridCard(el, c);
  }
  function initCircleCard(el, c, { animate } = {}) {
    el.dataset.choreId = c.id;
    hydrateDataAttrs(el, c);
    setCircleCooldownRing(el, c);
    setCardIcon(el, c);
    setCardCountdown(el, c);
    // The keyframe-fired done state is set BEFORE patcher fills the
    // rest so the celebratory animation can attach on first paint.
    if (isFullyDone(c)) {
      el.classList.add("done");
      const skipKeyframe = targetOf(c) > 1;
      if (!animate || skipKeyframe) el.classList.add("no-animate");
    } else if (targetOf(c) > 1) {
      el.classList.add("partial");
    }
    patchCircleCard(el, c);
  }
  function renderGridCard(c) {
    const el = cloneTemplate("grid-card");
    if (!el) return null;
    initGridCard(el, c);
    return el;
  }
  function renderCircleCard(c) {
    const el = cloneTemplate("circle-card");
    if (!el) return null;
    const animate = shouldAnimateDone(c);
    initCircleCard(el, c, { animate });
    if (animate) noteRingAnimation(c.id);
    return el;
  }
  function renderHotCell(c) {
    const wrap = cloneTemplate("hot-cell");
    const inner = renderCircleCard(c);
    if (wrap && inner) wrap.appendChild(inner);
    return wrap;
  }

  // Patch-in-place updates. Replacing the DOM on every upsert blinks
  // the card (and resets the done-ring SVG mid-animation); these
  // patchers only touch the bits that actually change. If a structural
  // attribute changes (icon, cooldown threshold), they fall back to a
  // full re-render — but they preserve the existing done-ring element
  // so the animation state survives the swap.
  function structuralChange(el, c) {
    return el.dataset.choreIcon !== (c.icon_ref || c.icon || "") ||
           String(el.dataset.choreCooldown || "0") !== String(c.threshold_seconds || 0);
  }
  function preserveDoneRing(oldEl, newEl) {
    const oldRing = oldEl.querySelector(".done-ring");
    const newRingWrap = newEl.querySelector(".circle-inner");
    if (!oldRing || !newRingWrap) return;
    const newRing = newRingWrap.querySelector(".done-ring");
    if (newRing) newRing.replaceWith(oldRing);
  }
  function patchCornerBadge(el, c, { className, value }) {
    let badge = null;
    for (const child of el.children) {
      if (child.classList?.contains(className)) { badge = child; break; }
    }
    const visible = value != null && (className === "hot-badge" || value > 1);
    const rare = className === "hot-badge" && Number(value) >= 5;
    if (visible) {
      const text = `${formatMultiplier(value)}×`;
      if (badge) {
        if (badge.textContent !== text) badge.textContent = text;
        badge.classList.toggle("rare", rare);
      } else {
        // Clone the generic corner-badge template, set the class +
        // text via DOM API, insert at the start. Replaces the
        // legacy insertAdjacentHTML string interpolation.
        const node = cloneTemplate("corner-badge");
        if (node) {
          node.className = className;
          if (rare) node.classList.add("rare");
          node.textContent = text;
          el.insertBefore(node, el.firstChild);
        }
      }
    } else if (badge) {
      badge.remove();
    }
  }
  function patchHotBadge(el, c)    { patchCornerBadge(el, c, { className: "hot-badge",    value: c.hot_multiplier }); }
  function patchStreakBadge(el, c) { patchCornerBadge(el, c, { className: "streak-badge", value: c.streak_multiplier }); }
  function patchCountSlot(el, c) {
    if (!el) return;
    const existing = el.querySelector(":scope > [data-count-badge]");
    const next = buildCountBadgeNode(c);
    if (!next) {
      // No badge wanted — strip any existing one without touching the
      // slot itself (preserves siblings / animation context).
      if (existing) existing.remove();
      return;
    }
    if (existing) {
      // Patch the existing badge in place to keep DOM identity (no
      // remove+insert flicker, no CSS transition reset).
      if (existing.textContent !== next.textContent) {
        existing.textContent = next.textContent;
      }
      return;
    }
    el.appendChild(next);
  }
  function patchText(el, text) {
    if (!el) return;
    const want = text || "";
    if (el.textContent !== want) el.textContent = want;
  }
  function patchCircleCard(el, c) {
    if (structuralChange(el, c)) {
      const fresh = renderCircleCard(c);
      preserveDoneRing(el, fresh);
      el.replaceWith(fresh);
      return;
    }
    const wasDone = el.classList.contains("done");
    const isDone = isFullyDone(c);
    const skipKeyframe = targetOf(c) > 1;
    if (isDone) {
      el.classList.add("done");
      el.classList.remove("partial");
      if (wasDone || skipKeyframe) {
        // skipKeyframe: multi-tap chore continues the partial fill smoothly
        // into full via inline dashoffset instead of the 100→0 keyframe.
        el.classList.add("no-animate");
      } else {
        const animate = shouldAnimateDone(c);
        el.classList.toggle("no-animate", !animate);
        if (animate) noteRingAnimation(c.id);
      }
    } else {
      el.classList.remove("done", "no-animate");
      // See initCircleCard: `.partial` stays on at progress=0 for multi-
      // tap chores so the dashoffset transition can animate closed.
      el.classList.toggle("partial", skipKeyframe);
      shouldAnimateDone(c);
    }
    el.classList.toggle("hot", c.hot_multiplier != null);
    patchHotBadge(el, c);
    patchStreakBadge(el, c);
    patchText(el.querySelector(".circle-reward"), c.reward_label);
    patchCountSlot(el.querySelector("[data-count-slot]"), c);
    patchStateIcon(el.querySelector(".circle-inner"), c);
    patchText(el.querySelector(":scope > .title"), c.short_name);
    applyProgressRing(el, c);
    hydrateDataAttrs(el, c);
  }
  function patchStateIcon(host, c) {
    if (!host) return;
    const existing = host.querySelector(":scope > [data-state-icon]");
    const cls = stateIconClass(c);
    if (!cls) {
      if (existing) existing.remove();
      return;
    }
    if (existing) {
      // Reset to the desired Font Awesome class without disturbing the
      // shared `fa circle-state-icon` baseline classes.
      existing.classList.remove("fa-sun-o", "fa-clock-o", "fa-hourglass-half");
      existing.classList.add(cls);
    } else {
      const node = buildStateIconNode(c);
      if (node) host.appendChild(node);
    }
  }
  function patchGridCard(el, c) {
    if (structuralChange(el, c)) {
      el.replaceWith(renderGridCard(c));
      return;
    }
    el.classList.toggle("done-today", (c.done_count_today || 0) > 0);
    el.classList.toggle("hot", c.hot_multiplier != null);
    patchHotBadge(el, c);
    patchStreakBadge(el, c);
    patchText(el.querySelector(".card-reward"), c.reward_label);
    patchCountSlot(el.querySelector("[data-count-slot]"), c);
    patchText(el.querySelector(":scope > .title"), c.name);
    applyProgressRing(el, c);
    hydrateDataAttrs(el, c);
  }
  function patchHotCell(cell, c) {
    const inner = cell.querySelector(".chore-circle");
    if (inner) patchCircleCard(inner, c);
  }

  // ============================================================
  // Views — render from store. Subscribers handle granular updates.
  // ============================================================
  const Views = (() => {
    const grid       = () => document.querySelector("[data-chores-grid]");
    const dailies    = () => document.querySelector("[data-chores-dailies]");
    const today      = () => document.querySelector("[data-chores-today]");
    const todaySect  = () => document.querySelector("[data-chores-today-section]");
    const overdue    = () => document.querySelector("[data-chores-overdue]");
    const hot        = () => document.querySelector("[data-chores-hot-strip]");
    const emptyDay   = () => document.querySelector("[data-empty-dailies]");
    const emptyOver  = () => document.querySelector("[data-empty-overdue]");
    const lookCt     = () => document.querySelector("[data-chores-lookahead]");

    function appendTo(el, node) { if (el && node) el.appendChild(node); }

    // Diff a container's children against a desired list of items.
    // NEVER calls innerHTML="" — chores already on screen stay on
    // screen, even if a sync is mid-flight or failed. The only writes
    // are: patch existing nodes in place, move existing nodes to their
    // new order, append truly-new nodes, remove nodes that the store
    // says should no longer be visible.
    function reconcileSection(container, items, opts) {
      if (!container) return;
      const { keyFor, renderer, patcher } = opts;
      const desiredById = new Map(items.map(c => [c.id, c]));
      const existingByKey = new Map();
      Array.from(container.children).forEach(child => {
        const key = keyFor(child);
        if (key == null || !desiredById.has(key)) {
          // Item is no longer in this section (archived, unpinned,
          // filter flipped). Explicit DOM remove — never a clear-all.
          child.remove();
        } else {
          existingByKey.set(key, child);
        }
      });
      let cursor = container.firstElementChild;
      for (const item of items) {
        const existing = existingByKey.get(item.id);
        if (cursor && cursor === existing) {
          // Already where it belongs — patch in place.
          patcher(cursor, item);
          cursor = cursor.nextElementSibling;
        } else if (existing) {
          // Lives in this container but in the wrong position. Move it
          // to the cursor's slot (insertBefore moves rather than dupes
          // when the node is already a child).
          container.insertBefore(existing, cursor);
          patcher(existing, item);
        } else {
          // Truly new — insert at the cursor position.
          const node = renderer(item);
          if (node) container.insertBefore(node, cursor);
        }
      }
    }

    const cardKey   = el => { const v = parseInt(el?.dataset?.choreId, 10); return Number.isFinite(v) ? v : null; };
    // Hot cells wrap a chore-circle whose data-chore-id is on the
    // inner element; key by that.
    const hotKey    = el => {
      const inner = el?.querySelector?.("[data-chore-id]");
      const v = parseInt(inner?.dataset?.choreId, 10);
      return Number.isFinite(v) ? v : null;
    };
    const patchHot  = (cell, c) => {
      const inner = cell.querySelector(".chore-circle");
      if (inner) patchCircleCard(inner, c);
    };

    function renderGrid() {
      reconcileSection(grid(), ChoreStore.activeForGrid(), {
        keyFor: cardKey, renderer: renderGridCard, patcher: patchGridCard,
      });
    }
    function renderDailies() {
      const c = dailies();
      reconcileSection(c, ChoreStore.dailiesList(), {
        keyFor: cardKey, renderer: renderCircleCard, patcher: patchCircleCard,
      });
      if (emptyDay()) emptyDay().hidden = (c?.children.length || 0) > 0;
    }
    function renderToday() {
      const c = today();
      reconcileSection(c, ChoreStore.todayList(), {
        keyFor: cardKey, renderer: renderCircleCard, patcher: patchCircleCard,
      });
      const section = todaySect();
      if (section) section.hidden = (c?.children.length || 0) === 0;
    }
    function renderOverdue() {
      const c = overdue();
      reconcileSection(c, ChoreStore.overdueList(), {
        keyFor: cardKey, renderer: renderCircleCard, patcher: patchCircleCard,
      });
      if (emptyOver()) emptyOver().hidden = (c?.children.length || 0) > 0;
    }
    function renderHot() {
      const c = hot();
      if (!c) return;
      const picks = ChoreStore.hotPicks();
      reconcileSection(c, picks, {
        keyFor: hotKey,
        renderer: renderHotCell,
        patcher: patchHot,
      });
      // Section visibility — hide when no picks, show otherwise. Note
      // we DON'T innerHTML="" on the hidden branch; if picks come back
      // later we re-reveal the same DOM (or reconcile adds new cells).
      c.hidden = (c.children.length === 0);
    }
    function renderLookahead() {
      const c = lookCt();
      if (!c) return;
      const data = ChoreStore.lookahead() || {};
      const keys = Object.keys(data).sort();
      if (!keys.length) { c.hidden = true; return; }
      c.hidden = false;
      // Build the new section via cloned templates + DOM API —
      // no HTML strings, no innerHTML interpolation. Whole-section
      // rebuild is intentional: the lookahead set arrives as one
      // payload from /chores/sync, so per-day diffing isn't worth
      // the complexity vs replaceChildren of a fresh fragment.
      const frag = document.createDocumentFragment();
      const heading = cloneTemplate("lookahead-heading");
      if (heading) frag.appendChild(heading);
      keys.forEach(day => {
        const ids = data[day] || [];
        const dayObj = new Date(day + "T00:00:00");
        const dayLabel = dayObj.toLocaleDateString(undefined, { weekday: "short", month: "short", day: "numeric" });
        const dayEl = cloneTemplate("lookahead-day");
        if (!dayEl) return;
        if (!ids.length) dayEl.classList.add("lookahead-day-empty");
        const label = dayEl.querySelector(".day-label");
        if (label) label.textContent = dayLabel;
        const items = dayEl.querySelector(".day-items");
        if (items) {
          if (!ids.length) {
            const empty = cloneTemplate("lookahead-day-empty");
            if (empty) items.appendChild(empty);
          } else {
            ids.forEach(id => {
              const chore = ChoreStore.get(id);
              if (!chore) return;
              const chip = cloneTemplate("lookahead-day-chip");
              if (!chip) return;
              const iconSlot = chip.querySelector("[data-chip-icon]");
              if (iconSlot) {
                const icon = buildIconNode(chore);
                if (icon) iconSlot.appendChild(icon);
              }
              const nameEl = chip.querySelector("[data-chip-name]");
              if (nameEl) nameEl.textContent = chore.short_name || "";
              const rewardEl = chip.querySelector("[data-chip-reward]");
              if (rewardEl) rewardEl.textContent = chore.reward_label || "";
              items.appendChild(chip);
            });
          }
        }
        frag.appendChild(dayEl);
      });
      c.replaceChildren(frag);
    }

    function upsertOne(c) {
      // While the done-ring animation is drawing for this chore, park
      // the update so the SVG can finish; the animation timer replays
      // the latest deferred upsert when it fires.
      const sid = String(c.id);
      if (ringAnimating.has(sid)) {
        ringDeferred.set(sid, c);
        return;
      }

      const g = grid()?.querySelector(`[data-chore-id="${c.id}"]`);
      if (g) patchGridCard(g, c);
      else appendTo(grid(), renderGridCard(c));

      // The chore belongs to exactly ONE of the three Today-tab sections:
      //   * Dailies  if the viewer has pinned it (regardless of today_visible)
      //   * Today    if it's due_today + today_visible AND not pinned
      //   * Overdue  if it's today_visible AND not pinned AND not due_today
      // Anything else gets removed from all three so a flipped
      // today_visible/due_today doesn't leave a stale card behind.
      const isDaily = ChoreStore.isDaily(c.id) && !c.archived;
      const isToday = !!c.due_today && c.today_visible && !c.archived && !isDaily;
      const isOverdue = c.today_visible && !c.archived && !isDaily && !isToday;
      placeInSection(c, dailies(), isDaily);
      placeInSection(c, today(), isToday);
      placeInSection(c, overdue(), isOverdue);
      refreshTodayEmptyStates();

      // Hot strip — membership rotates at the 4am day boundary, so when
      // an upsert flips a chore in or out of the hot set, recompute the
      // whole strip; otherwise just patch the existing cell.
      const hotEl = hot();
      const hotCell = hotEl?.querySelector(`[data-chore-id="${c.id}"]`)?.closest(".hot-strip-cell");
      const shouldBeHot = c.hot_multiplier != null && !c.archived;
      if (hotCell && shouldBeHot) {
        patchHotCell(hotCell, c);
      } else if (hotCell || shouldBeHot) {
        renderHot();
      }
    }
    function removeOne(id) {
      document.querySelectorAll(`[data-chore-id="${id}"]`).forEach(el => {
        const cell = el.closest(".hot-strip-cell");
        (cell || el).remove();
      });
      refreshTodayEmptyStates();
    }
    function placeInSection(c, container, shouldBeIn) {
      if (!container) return;
      const existing = container.querySelector(`:scope > [data-chore-id="${c.id}"]`);
      if (shouldBeIn) {
        if (existing) patchCircleCard(existing, c);
        else appendTo(container, renderCircleCard(c));
      } else if (existing) {
        existing.remove();
      }
    }
    function refreshTodayEmptyStates() {
      if (emptyDay())  emptyDay().hidden  = (dailies()?.children.length || 0) > 0;
      if (emptyOver()) emptyOver().hidden = (overdue()?.children.length || 0) > 0;
      const section = todaySect();
      if (section) section.hidden = (today()?.children.length || 0) === 0;
    }
    function renderAll() {
      renderGrid();
      renderDailies();
      renderToday();
      renderOverdue();
      renderHot();
      renderLookahead();
    }
    return {
      renderAll, renderGrid, renderDailies, renderToday, renderOverdue, renderHot, renderLookahead,
      upsertOne, removeOne, refreshTodayEmptyStates,
    };
  })();

  ChoreStore.subscribe((kind, id) => {
    // "reconcile" replaces the old destructive "bootstrap" event.
    // Views.renderAll() now diffs the DOM against the current store
    // instead of clearing containers, so a fresh sync that overlaps
    // with what's already on screen produces no flicker and an empty
    // sync produces no blank.
    if (kind === "reconcile") Views.renderAll();
    else if (kind === "lookahead") Views.renderLookahead();
    else if (kind === "dailies") {
      Views.renderDailies();
      Views.renderToday();
      Views.renderOverdue();
      refreshEditModalPin();
    }
    else if (kind === "remove") Views.removeOne(id);
    else if (kind === "upsert") {
      const c = ChoreStore.get(id);
      if (!c) return;
      Views.upsertOne(c);
      // Keep the open edit modal's mark-due button in sync when the
      // chore the user is editing gets stamped/cleared from another tab
      // or by a household member.
      if (parseInt(currentChoreId, 10) === id) refreshEditModalMarkDue();
    }
    // Re-apply the active search after any store change: newly-rendered
    // cells need their display: filter, and the extras list needs to
    // re-pick from the updated active-for-grid set.
    const q = currentSearchQuery();
    if (q) applySearch(q);
  });

  // ============================================================
  // ticker — countdown + ago row driven by data attributes
  // ============================================================
  const RING_CIRC = 2 * Math.PI * 46;
  // Inset cooldown overlay (r=40) — different circumference so the
  // stroke-dash math has to use its own constant.
  const COOLDOWN_RING_CIRC = 2 * Math.PI * 40;

  function secondsUntilNextChoreDay(now) {
    const d = new Date(now);
    const next = new Date(d);
    next.setHours(CUTOFF_HOUR, 0, 0, 0);
    if (next.getTime() <= d.getTime()) next.setDate(next.getDate() + 1);
    return Math.max(0, Math.floor((next.getTime() - d.getTime()) / 1000));
  }
  // Local chore-day in iso format. Mirrors `ChoreDay.current` on the
  // server (shift by CUTOFF_HOUR, then take the date). Used to spot
  // SW-cached bootstrap that was generated before the 4am rollover.
  function currentChoreDayIso(now = Date.now()) {
    const shifted = new Date(now - CUTOFF_HOUR * 3600 * 1000);
    const y = shifted.getFullYear();
    const m = String(shifted.getMonth() + 1).padStart(2, "0");
    const d = String(shifted.getDate()).padStart(2, "0");
    return `${y}-${m}-${d}`;
  }

  function formatRemaining(seconds) {
    if (seconds <= 0) return "";
    const s = Math.ceil(seconds);
    if (s < 60) return ":" + String(s).padStart(2, "0") + "s";
    if (s < 5 * 60) {
      const mins = Math.floor(s / 60);
      const secs = Math.ceil(s % 60);
      return secs === 60 ? `${mins + 1}:00` : `${mins}:${String(secs).padStart(2, "0")}`;
    }
    if (s < 50 * 60) return Math.ceil(s / 60) + "m";
    if (s < 16 * 60 * 60) return Math.ceil(s / 3600) + "h";
    if (s < 28 * 86400) return Math.ceil(s / 86400) + "d";
    if (s < 23 * 30 * 86400) return Math.ceil(s / (30 * 86400)) + "M";
    return Math.ceil(s / (365 * 86400)) + "y";
  }

  function formatAgo(isoString, now = Date.now()) {
    if (!isoString) return "";
    const t = new Date(isoString).getTime();
    if (Number.isNaN(t)) return "";
    const sec = Math.max(0, Math.floor((now - t) / 1000));
    if (sec < 60) return "<1m ago";
    if (sec < 3600) return `${Math.floor(sec / 60)}m ago`;
    if (sec < 86400) {
      const h = Math.floor(sec / 3600);
      const m = Math.floor((sec % 3600) / 60);
      return m > 0 ? `${h}h ${m}m ago` : `${h}h ago`;
    }
    const d = new Date(t);
    const today = new Date(now);
    const startOfToday = new Date(today.getFullYear(), today.getMonth(), today.getDate()).getTime();
    const dayDiff = Math.floor((startOfToday - new Date(d.getFullYear(), d.getMonth(), d.getDate()).getTime()) / 86400000);
    if (dayDiff === 1) return "Yesterday";
    if (dayDiff >= 2 && dayDiff <= 6) {
      return ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"][d.getDay()];
    }
    const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
    return `${months[d.getMonth()]} ${d.getDate()}, '${String(d.getFullYear() % 100).padStart(2, "0")}`;
  }

  function updateRings(now) {
    document.querySelectorAll('[data-chore-id][data-chore-cooldown]').forEach(card => {
      const cooldown = parseInt(card.dataset.choreCooldown, 10);
      if (!cooldown) return;
      const last = card.dataset.lastCompletedAt;
      // [data-cooldown-progress] is the thin secondary overlay (only on
      // chores with a cooldown). [data-ring-progress] is now the primary
      // progress-toward-target ring and is set at render time, not here.
      const ring = card.querySelector('[data-cooldown-progress]');
      const label = card.querySelector('[data-circle-countdown]');
      if (!label && !ring) return;
      if (ring) ring.setAttribute("stroke-dasharray", COOLDOWN_RING_CIRC);

      if (cooldown === -1) {
        if (!label) return;
        // Day-reset cooldown is only ACTIVE when the most recent
        // completion is in TODAY's chore-day. Completions from any
        // prior day have already crossed the 4am boundary, so the
        // cooldown has elapsed — the ticker must leave the label
        // empty (CSS `:empty` then hides the pill entirely). Without
        // this guard, a chore completed at 5pm yesterday would tick
        // down to tomorrow's 4am and render a phantom "1d" cooldown.
        const lastMs = last ? new Date(last).getTime() : 0;
        const stillInCooldown = lastMs &&
          currentChoreDayIso(lastMs) === currentChoreDayIso(now);
        if (!stillInCooldown) {
          label.textContent = "";
          label.classList.add("elapsed");
          return;
        }
        const remainSec = secondsUntilNextChoreDay(now);
        label.classList.toggle("elapsed", remainSec === 0);
        label.textContent = remainSec === 0 ? "" : formatRemaining(remainSec);
        return;
      }

      if (!last) {
        if (ring) { ring.setAttribute("stroke-dashoffset", COOLDOWN_RING_CIRC); ring.classList.add("elapsed"); }
        if (label) { label.classList.add("elapsed"); label.textContent = ""; }
        return;
      }
      const lastMs = new Date(last).getTime();
      const remainSec = Math.max(0, Math.ceil((lastMs + cooldown * 1000 - now) / 1000));
      if (ring) {
        const progress = remainSec === 0 ? 0 : remainSec / cooldown;
        ring.setAttribute("stroke-dashoffset", COOLDOWN_RING_CIRC * (1 - progress));
        ring.classList.toggle("elapsed", remainSec === 0);
      }
      if (label) {
        label.classList.toggle("elapsed", remainSec === 0);
        label.textContent = remainSec === 0 ? "" : formatRemaining(remainSec);
      }
    });
  }
  function updateAgoRows(now) {
    document.querySelectorAll("[data-ago-row]").forEach(row => {
      const card = row.closest("[data-chore-id]");
      if (!card) return;
      const iso = card.dataset.lastCompletedAt;
      row.textContent = iso ? formatAgo(iso, now) : "";
    });
  }
  function startTicker() {
    const tick = () => {
      const now = Date.now();
      updateRings(now);
      updateAgoRows(now);
    };
    tick();
    setInterval(tick, 1000);
  }

  // ============================================================
  // gestures — tap to complete, long-press to undo, edit-mode tap to edit
  // ============================================================
  let editModeActive = false;

  function bindCardClicks() {
    [
      document.querySelector("[data-chores-grid]"),
      document.querySelector("[data-chores-dailies]"),
      document.querySelector("[data-chores-today]"),
      document.querySelector("[data-chores-overdue]"),
      document.querySelector("[data-chores-search-extra]"),
      document.querySelector("[data-chores-hot-strip]"),
    ].filter(Boolean).forEach(bindOne);
  }
  function bindOne(container) {
    const MOVE_THRESHOLD = 8, LONG_MS = 550;
    const s = { pointerId: null, card: null, startX: 0, startY: 0, startedAt: 0, moved: false, longPressFired: false, timer: null };
    function reset() {
      if (s.timer) clearTimeout(s.timer);
      s.pointerId = null; s.card = null; s.startX = 0; s.startY = 0; s.startedAt = 0;
      s.moved = false; s.longPressFired = false; s.timer = null;
    }
    container.addEventListener("pointerdown", e => {
      if (s.pointerId !== null) return;
      const card = e.target.closest("[data-chore-id]");
      if (!card) return;
      const inEditMode = editModeActive;
      if (!inEditMode) {
        const usesCircleHitbox = container.matches("[data-chores-dailies], [data-chores-today], [data-chores-overdue], [data-chores-hot-strip]");
        if (usesCircleHitbox && !e.target.closest(".circle-inner")) return;
      }

      s.pointerId = e.pointerId; s.card = card; s.startX = e.clientX; s.startY = e.clientY;
      s.startedAt = performance.now(); s.moved = false; s.longPressFired = false;
      s.timer = setTimeout(() => {
        if (!s.card || s.moved) return;
        s.longPressFired = true;
        if (inEditMode) openChoreHistoryModal(s.card.dataset.choreId);
        else undoLastCompletion(s.card.dataset.choreId);
      }, LONG_MS);
    });
    container.addEventListener("pointermove", e => {
      if (s.pointerId !== e.pointerId) return;
      if (Math.hypot(e.clientX - s.startX, e.clientY - s.startY) > MOVE_THRESHOLD) {
        s.moved = true;
        if (s.timer) { clearTimeout(s.timer); s.timer = null; }
      }
    });
    container.addEventListener("pointerup", e => {
      if (s.pointerId !== e.pointerId) return;
      const card = s.card;
      const isShortTap = !s.moved && !s.longPressFired && (performance.now() - s.startedAt) < LONG_MS;
      reset();
      if (!card) return;
      if (!isShortTap) { card.dataset.suppressClick = "1"; return; }
      // In edit mode every short tap means "edit"; the click handler
      // opens the edit modal. Never auto-complete from edit mode.
      if (editModeActive) return;
      if (multiplierActive) { openMultiplierModal(card); return; }
      if (e.shiftKey) { openEditModal(card); return; }
      completeChore(card.dataset.choreId);
    });
    ["pointercancel", "pointerleave"].forEach(evt =>
      container.addEventListener(evt, e => { if (s.pointerId === e.pointerId) reset(); }));
    container.addEventListener("click", e => {
      const card = e.target.closest("[data-chore-id]");
      if (!card) return;
      // A long-press already opened a modal (history in edit mode, undo
      // otherwise) — swallow the trailing click so the edit modal doesn't
      // also pop open behind it.
      if (card.dataset.suppressClick === "1") {
        delete card.dataset.suppressClick;
        e.preventDefault(); e.stopPropagation();
        return;
      }
      if (editModeActive) { e.preventDefault(); e.stopPropagation(); openEditModal(card); return; }
    }, true);
    container.addEventListener("contextmenu", e => {
      const card = e.target.closest("[data-chore-id]");
      if (!card) return;
      e.preventDefault();
      openEditModal(card);
    });
  }

  // ============================================================
  // Dailies — pin toggle (on the edit modal) + per-section drag reorder
  // ============================================================
  // The pin button lives in the edit modal head (left of the title), so
  // users can pin/unpin from anywhere the modal opens (Today, Grid,
  // search, history). `bindEditModalPin` wires a single listener that
  // operates on whichever chore the modal is currently editing.
  function bindEditModalPin() {
    const btn = document.querySelector("[data-edit-pin-toggle]");
    if (!btn) return;
    btn.addEventListener("click", e => {
      e.preventDefault();
      e.stopPropagation();
      const id = parseInt(currentChoreId, 10);
      if (!id || btn.dataset.busy === "1") return;
      togglePinDaily(id, btn);
    });
  }

  // Mark-due button — sibling of pin. Stamps the chore as "needs to get
  // done" so it surfaces on Today (or Scheduled/overdue across days)
  // until any ChoreCompletion clears it.
  function bindEditModalMarkDue() {
    const btn = document.querySelector("[data-edit-mark-due-toggle]");
    if (!btn) return;
    btn.addEventListener("click", e => {
      e.preventDefault();
      e.stopPropagation();
      const id = parseInt(currentChoreId, 10);
      if (!id || btn.dataset.busy === "1") return;
      toggleMarkDue(id, btn);
    });
  }

  // Anonymous completion button (modal head). Opens the sub-modal
  // for timestamp + note. Visibility is wired in refreshEditModalHeadActions.
  function bindEditModalAnonymousComplete() {
    const btn = document.querySelector("[data-edit-anonymous-complete]");
    if (!btn) return;
    btn.addEventListener("click", e => {
      e.preventDefault();
      e.stopPropagation();
      const id = parseInt(currentChoreId, 10);
      if (!id) return;
      openAnonymousModal(id);
    });
  }

  const anonymousModal = document.querySelector('[data-anonymous-modal]');
  const anonymousForm  = anonymousModal?.querySelector('[data-anonymous-form]');
  const anonymousTitle = anonymousModal?.querySelector('[data-anonymous-title]');
  const anonymousHint  = anonymousModal?.querySelector('[data-anonymous-hint]');
  const anonymousSubmit = anonymousModal?.querySelector('[data-anonymous-submit]');
  const anonymousCreditSel = anonymousModal?.querySelector('[data-anonymous-credit-user]');
  let anonymousTargetChoreId = null;
  let anonymousBaseName = "";

  // Reflect the "Credit to" selection in title/hint/submit copy so it's
  // unambiguous whose completion this is. Blank id = anonymous branch.
  function refreshAnonymousCopy() {
    if (!anonymousModal) return;
    const opt = anonymousCreditSel?.selectedOptions?.[0];
    const creditName = opt?.dataset?.username || "";
    if (creditName) {
      if (anonymousTitle) anonymousTitle.textContent = `${anonymousBaseName} — done by ${creditName}`;
      if (anonymousHint)  anonymousHint.textContent = `Credits ${creditName} with the pebbles as if they did it themselves.`;
      if (anonymousSubmit) anonymousSubmit.textContent = `Mark done for ${creditName}`;
    } else {
      if (anonymousTitle) anonymousTitle.textContent = `${anonymousBaseName} — done by someone else`;
      if (anonymousHint)  anonymousHint.textContent  = "Marks this as done so it doesn't keep coming up. Nobody in the household gets the pebbles.";
      if (anonymousSubmit) anonymousSubmit.textContent = "Mark done";
    }
  }
  anonymousCreditSel?.addEventListener("change", refreshAnonymousCopy);

  function openAnonymousModal(choreId) {
    if (!anonymousModal) return;
    anonymousTargetChoreId = choreId;
    const c = ChoreStore.get(choreId);
    anonymousBaseName = (c && (c.short_name || c.name)) || "";
    // Default the "completed at" field to NOW in local time (the input
    // expects a YYYY-MM-DDTHH:mm string without timezone).
    const tsField = anonymousModal.querySelector('[data-anonymous-completed-at]');
    if (tsField) {
      const d = new Date();
      const pad = n => String(n).padStart(2, "0");
      tsField.value = `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
    }
    const noteField = anonymousModal.querySelector('[data-anonymous-note]');
    if (noteField) noteField.value = "";
    if (anonymousCreditSel) anonymousCreditSel.value = "";
    refreshAnonymousCopy();
    anonymousModal.classList.remove("hidden");
  }
  function closeAnonymousModal() {
    anonymousModal?.classList.add("hidden");
    anonymousTargetChoreId = null;
  }
  wireModalDismiss(anonymousModal, { onCancel: closeAnonymousModal, onBackdrop: closeAnonymousModal });

  function bindAnonymousCompletionForm() {
    if (!anonymousForm) return;
    anonymousForm.addEventListener("submit", async e => {
      e.preventDefault();
      const submit = anonymousForm.querySelector('button[type="submit"]');
      const id = anonymousTargetChoreId;
      if (!id) { closeAnonymousModal(); return; }
      const tsStr = anonymousModal.querySelector('[data-anonymous-completed-at]')?.value || "";
      const note = anonymousModal.querySelector('[data-anonymous-note]')?.value || "";
      const creditUserId = anonymousCreditSel?.value || "";
      // Parse the local datetime-local string as a local-clock instant
      // (no implicit UTC interpretation) and serialize to ISO 8601.
      const dt = tsStr ? new Date(tsStr) : new Date();
      const iso = dt.toISOString();
      await withSavingState(submit, async () => {
        try {
          const data = await api(`/chores/items/${id}/anonymous_completion`, "POST", {
            client_completed_at: iso, note, credit_user_id: creditUserId, tab_id: TAB_ID,
          });
          reconcile(data);
          flash(data.credited_to ? `Marked done for ${data.credited_to.username}` : "Marked done");
          closeAnonymousModal();
          dismissEditModalExplicit();
        } catch (err) {
          flash("Couldn't save: " + err.message, "error");
        }
      });
    });
  }

  // ============================================================
  // Notification settings (Balance page)
  // ============================================================
  // Subscribe / unsubscribe to the chores push channel + per-event
  // opt-out toggles. The SW is /chores_worker.js (already registered
  // for the offline shell); push events are handled there.
  const CHORES_VAPID_PUBLIC_KEY =
    "BO7gUf6gNtfyxWRaYVjmL38uqi8TGKZZ9Fw7tEKzxCosTAtTERuv2ohHEiNB21CBs7ue5eOWMe2p4jtZjZTTAFU=";

  function urlBase64ToUint8Array(base64String) {
    const padding = "=".repeat((4 - (base64String.length % 4)) % 4);
    const base64 = (base64String + padding).replace(/-/g, "+").replace(/_/g, "/");
    const raw = window.atob(base64);
    const out = new Uint8Array(raw.length);
    for (let i = 0; i < raw.length; i++) out[i] = raw.charCodeAt(i);
    return out;
  }

  async function getChoresPushSubscription() {
    if (!("serviceWorker" in navigator) || !("PushManager" in window)) return null;
    const reg = await navigator.serviceWorker.getRegistration("/chores_worker.js")
      || await navigator.serviceWorker.getRegistration("/chores");
    if (!reg) return null;
    return reg.pushManager.getSubscription();
  }

  async function subscribeChoresPush() {
    if (!("serviceWorker" in navigator) || !("PushManager" in window)) {
      throw new Error("Push isn't supported in this browser.");
    }
    if (Notification.permission === "denied") {
      throw new Error("Notifications are blocked — enable them in your browser settings.");
    }
    const reg = await navigator.serviceWorker.getRegistration("/chores_worker.js")
      || await navigator.serviceWorker.getRegistration("/chores");
    if (!reg) throw new Error("Service worker not registered yet — reload and try again.");

    const perm = await Notification.requestPermission();
    if (perm !== "granted") throw new Error("Permission not granted.");

    const sub = await reg.pushManager.subscribe({
      userVisibleOnly: true,
      applicationServerKey: urlBase64ToUint8Array(CHORES_VAPID_PUBLIC_KEY),
    });
    const body = sub.toJSON();
    body.channel = "chores";
    const res = await fetch("/push_notification_subscribe", {
      method: "POST",
      headers: { "Content-Type": "application/json", JarvisPushVersion: "2" },
      body: JSON.stringify(body),
      credentials: "same-origin",
    });
    if (!res.ok) {
      await sub.unsubscribe();
      throw new Error("Server refused the subscription.");
    }
    return sub;
  }

  async function unsubscribeChoresPush() {
    const sub = await getChoresPushSubscription();
    if (!sub) return;
    const body = sub.toJSON();
    body.channel = "chores";
    await fetch("/push_notification_unsubscribe", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
      credentials: "same-origin",
    }).catch(() => {});
    await sub.unsubscribe();
  }

  function bindNotificationSettings() {
    const modal = document.querySelector("[data-notifications-modal]");
    const openBtn = document.querySelector("[data-open-notifications]");
    if (!modal || !openBtn) return;
    const form = modal.querySelector("[data-notifications-form]");
    const statusEl = modal.querySelector("[data-notifications-status]");
    const subscribeBtn = modal.querySelector("[data-notifications-subscribe]");
    const unsubscribeBtn = modal.querySelector("[data-notifications-unsubscribe]");
    const kindInputs = Array.from(modal.querySelectorAll("[data-notify-kind]"));

    async function refreshStatus() {
      if (!("Notification" in window)) {
        statusEl.textContent = "Push isn't supported in this browser.";
        subscribeBtn.hidden = true;
        unsubscribeBtn.hidden = true;
        return;
      }
      const sub = await getChoresPushSubscription();
      if (sub) {
        statusEl.textContent = "Notifications are on for this device.";
        subscribeBtn.hidden = true;
        unsubscribeBtn.hidden = false;
      } else if (Notification.permission === "denied") {
        statusEl.textContent = "Notifications are blocked — enable them in browser settings.";
        subscribeBtn.hidden = true;
        unsubscribeBtn.hidden = true;
      } else {
        statusEl.textContent = "Notifications are off for this device.";
        subscribeBtn.hidden = false;
        unsubscribeBtn.hidden = true;
      }
    }

    async function loadPrefs() {
      try {
        const res = await api("/chores/notification_preferences", "GET");
        const prefs = res?.prefs || {};
        kindInputs.forEach(input => {
          input.checked = prefs[input.dataset.notifyKind] !== false;
        });
      } catch (_err) {
        // First-load failure (offline, etc.) — fall back to "all on".
        kindInputs.forEach(input => { input.checked = true; });
      }
    }

    openBtn.addEventListener("click", async () => {
      openModal(modal);
      await Promise.all([refreshStatus(), loadPrefs()]);
    });

    subscribeBtn.addEventListener("click", async () => {
      subscribeBtn.disabled = true;
      try {
        await subscribeChoresPush();
        await refreshStatus();
        flash("Notifications on");
      } catch (err) {
        flash(err.message || "Couldn't enable notifications", "error");
      } finally {
        subscribeBtn.disabled = false;
      }
    });

    unsubscribeBtn.addEventListener("click", async () => {
      unsubscribeBtn.disabled = true;
      try {
        await unsubscribeChoresPush();
        await refreshStatus();
        flash("Notifications off");
      } catch (err) {
        flash("Couldn't disable: " + err.message, "error");
      } finally {
        unsubscribeBtn.disabled = false;
      }
    });

    form.addEventListener("submit", async e => {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]');
      const prefs = {};
      kindInputs.forEach(input => { prefs[input.dataset.notifyKind] = input.checked; });
      await withSavingState(submitBtn, async () => {
        try {
          await api("/chores/notification_preferences", "PATCH", { chore_notify_prefs: prefs });
          closeModal(modal);
          flash("Saved");
        } catch (err) {
          flash("Couldn't save: " + err.message, "error");
        }
      });
    });

    wireModalDismiss(modal);
  }

  // Rotate-hot-pick button (modal head). Only shown when the chore is
  // a current Hot Pick — refreshEditModalHeadActions handles visibility.
  function bindEditModalHotRotate() {
    const btn = document.querySelector("[data-edit-hot-rotate]");
    if (!btn) return;
    btn.addEventListener("click", async e => {
      e.preventDefault();
      e.stopPropagation();
      const id = parseInt(currentChoreId, 10);
      if (!id || btn.dataset.busy === "1") return;
      btn.dataset.busy = "1";
      try {
        await rotateHotPick(id);
        // The chore is no longer a hot pick — dismiss the modal so the
        // user sees the strip update.
        dismissEditModalExplicit();
      } finally {
        delete btn.dataset.busy;
      }
    });
  }

  // Sync the modal pin button to the chore the modal is currently
  // editing. Called from openEditModal and from the `dailies` store
  // notify path so a broadcast that lands while the modal is open
  // keeps the button in sync.
  function refreshEditModalPin() {
    const btn = document.querySelector("[data-edit-pin-toggle]");
    if (!btn) return;
    const id = parseInt(currentChoreId, 10);
    if (!id) { btn.hidden = true; return; }
    btn.hidden = false;
    const pinned = ChoreStore.isDaily(id);
    btn.classList.toggle("pinned", pinned);
    const label = pinned ? "Remove from Dailies" : "Pin to Dailies";
    btn.setAttribute("aria-label", label);
    btn.setAttribute("title", label);
  }

  function refreshEditModalMarkDue() {
    const btn = document.querySelector("[data-edit-mark-due-toggle]");
    if (!btn) return;
    const id = parseInt(currentChoreId, 10);
    if (!id) { btn.hidden = true; return; }
    const c = ChoreStore.get(id);
    if (!c) { btn.hidden = true; return; }
    btn.hidden = false;
    const marked = !!c.marked_due_at;
    btn.classList.toggle("marked", marked);
    const label = marked ? "Clear needs-to-get-done" : "Mark needs to get done";
    btn.setAttribute("aria-label", label);
    btn.setAttribute("title", label);
  }

  // Optimistic: stamp marked_due_at + force visibility flags so the card
  // jumps into Today immediately. Unmark waits for server payload — the
  // post-unmark visibility depends on the chore's normal schedule, which
  // we don't recompute client-side.
  //
  // Form sync: the modal also exposes Due Date as a date input bound to
  // marked_due_at. Without mirroring the change into that field, a
  // subsequent form save would overwrite the stamp we just wrote with
  // the form's stale value (or vice versa for unmark).
  async function toggleMarkDue(id, btn) {
    const c = ChoreStore.get(id);
    const wasMarked = !!c?.marked_due_at;
    btn.dataset.busy = "1";
    const formField = editForm?.querySelector('[data-field="marked_due_at"]');
    if (!wasMarked) {
      ChoreStore.patch(id, {
        marked_due_at:  new Date().toISOString(),
        marked_due_on:  todayIso(),
        today_visible:  true,
        due_today:      true,
      });
      if (formField && String(currentChoreId) === String(id)) formField.value = todayIso();
      refreshEditModalMarkDue();
    } else if (formField && String(currentChoreId) === String(id)) {
      formField.value = "";
    }
    const url = `/chores/items/${id}/mark_due`;
    const method = wasMarked ? "DELETE" : "POST";
    try {
      const data = await api(url, method, { tab_id: TAB_ID });
      if (data && data.chore) ChoreStore.upsert(data.chore);
      refreshEditModalMarkDue();
    } catch (err) {
      if (isTransientError(err)) {
        flash("Saved locally — will sync", "warn");
      } else {
        if (!wasMarked) {
          ChoreStore.patch(id, { marked_due_at: null, marked_due_on: null });
          if (formField && String(currentChoreId) === String(id)) formField.value = "";
          refreshEditModalMarkDue();
        }
        flash("Couldn't update: " + err.message, "error");
      }
    } finally {
      delete btn.dataset.busy;
    }
  }

  async function togglePinDaily(id, btn) {
    const wasPinned = ChoreStore.isDaily(id);
    btn.dataset.busy = "1";
    // Optimistic — flip the store immediately so the card moves to the
    // right section as soon as the user dismisses the modal. We don't
    // roll back on transient error; the queue + sync will reconcile.
    if (wasPinned) ChoreStore.unpinDaily(id);
    else           ChoreStore.pinDaily(id);
    refreshEditModalPin();
    const url = `/chores/items/${id}/dailies`;
    const method = wasPinned ? "DELETE" : "POST";
    try {
      const data = await api(url, method, { tab_id: TAB_ID });
      if (data && Array.isArray(data.daily_ids)) ChoreStore.setDailyIds(data.daily_ids);
    } catch (err) {
      if (isTransientError(err)) {
        flash("Saved locally — will sync", "warn");
      } else {
        // Hard error: revert the optimistic flip.
        if (wasPinned) ChoreStore.pinDaily(id);
        else           ChoreStore.unpinDaily(id);
        refreshEditModalPin();
        flash("Couldn't update Dailies: " + err.message, "error");
      }
    } finally {
      delete btn.dataset.busy;
    }
  }

  let dailiesSortable = null;
  function bindDailiesSortable() {
    if (typeof window.Sortable === "undefined") {
      setTimeout(bindDailiesSortable, 200);
      return;
    }
    const container = document.querySelector("[data-chores-dailies]");
    if (!container || dailiesSortable) return;
    dailiesSortable = window.Sortable.create(container, {
      animation: 150,
      ghostClass: "sortable-ghost",
      chosenClass: "sortable-chosen",
      dragClass: "sortable-drag",
      forceFallback: true,
      fallbackOnBody: true,
      fallbackTolerance: 0,
      delay: 250,
      delayOnTouchOnly: true,
      touchStartThreshold: 6,
      onEnd: persistDailiesOrder,
    });
  }

  async function persistDailiesOrder() {
    const container = document.querySelector("[data-chores-dailies]");
    if (!container) return;
    const ids = Array.from(container.children)
      .map(el => parseInt(el.dataset.choreId, 10))
      .filter(Boolean);
    // Local store keeps the user-visible order in sync with the DOM
    // immediately. Server confirms via the response below.
    ChoreStore.reorderDailies(ids);
    try {
      const data = await api("/chores/dailies/order", "PATCH", { ids, tab_id: TAB_ID });
      if (data && Array.isArray(data.daily_ids)) ChoreStore.setDailyIds(data.daily_ids);
    } catch (err) {
      flash("Couldn't save Dailies order: " + err.message, "error");
    }
  }

  // ============================================================
  // Chore history modal — opened by long-press in edit mode. Reads
  // the per-chore /chores/items/:id/history endpoint, which scopes
  // household-shared chores to the whole household.
  // ============================================================
  const choreHistoryModal = document.querySelector('[data-chore-history-modal]');
  const choreHistoryBody  = document.querySelector('[data-chore-history-body]');
  const choreHistoryTitle = document.querySelector('[data-chore-history-title]');
  // Placeholder rows for the per-chore history modal — cloned from the
  // shared templates so the loading/empty/error variants stay consistent
  // with the Balance Recent-History list.
  function setChoreHistoryMessage(text) {
    if (!choreHistoryBody) return;
    const node = cloneTemplate("chore-history-message");
    if (node) {
      const slot = node.querySelector("[data-history-message]");
      if (slot) slot.textContent = text;
      choreHistoryBody.replaceChildren(node);
    } else {
      choreHistoryBody.replaceChildren();
    }
  }
  async function openChoreHistoryModal(id) {
    if (!choreHistoryModal) return;
    const c = ChoreStore.get(parseInt(id, 10));
    if (choreHistoryTitle) choreHistoryTitle.textContent = c ? c.name : "Chore History";
    setChoreHistoryMessage("Loading…");
    choreHistoryModal.classList.remove("hidden");
    try {
      const data = await api(`/chores/items/${parseInt(id, 10)}/history`, "GET");
      renderChoreHistory(data);
    } catch (e) {
      setChoreHistoryMessage(e.message || "Failed to load");
    }
  }
  function renderChoreHistory(data) {
    if (!choreHistoryBody) return;
    const entries = data?.entries || [];
    if (entries.length === 0) {
      setChoreHistoryMessage("No history yet.");
      return;
    }
    const frag = document.createDocumentFragment();
    entries.forEach(e => {
      const row = cloneTemplate("chore-history-row");
      if (!row) return;
      // Row-level data-actor drives the per-entry ring color. For
      // anonymous, switch to the same grey treatment cards use.
      if (e.anonymous) row.dataset.actorAnonymous = "true";
      else if (e.actor_username) row.dataset.actor = e.actor_username;

      row.querySelector("[data-history-when]").textContent = e.when_label || "";
      // Inline tag is for the cooldown-blocked "skipped" case only.
      // Anonymous completions communicate the same intent via the
      // right-side "Anonymous" actor pill — no second badge needed.
      const skippedTag = row.querySelector("[data-history-skipped-tag]");
      if (skippedTag) skippedTag.hidden = !(e.payout_skipped && !e.anonymous);

      row.querySelector("[data-history-paid]").textContent = `${formatCount(e.paid_pebbles)}p`;

      const actor = row.querySelector("[data-history-actor]");
      if (actor) {
        if (e.anonymous) {
          actor.classList.add("anonymous");
          actor.textContent = "Anonymous";
          actor.hidden = false;
        } else if (e.actor_username) {
          actor.textContent = e.actor_username;
          actor.hidden = false;
        } else {
          actor.hidden = true;
        }
      }

      const mults = row.querySelector("[data-history-mults]");
      if (mults) {
        const pills = [];
        if (e.hot_multiplier != null && e.hot_multiplier > 1) {
          const pill = cloneTemplate("chore-history-mult-pill");
          if (pill) { pill.classList.add("hot"); pill.textContent = `Hot ${formatMultiplier(e.hot_multiplier)}×`; pills.push(pill); }
        }
        if (e.streak_multiplier != null && e.streak_multiplier > 1) {
          const pill = cloneTemplate("chore-history-mult-pill");
          if (pill) { pill.classList.add("streak"); pill.textContent = `Streak ${formatMultiplier(e.streak_multiplier)}×`; pills.push(pill); }
        }
        if (pills.length) {
          mults.replaceChildren(...pills);
          mults.hidden = false;
        } else {
          mults.hidden = true;
        }
      }

      const noteEl = row.querySelector("[data-history-note]");
      if (noteEl) {
        if (e.note) { noteEl.textContent = e.note; noteEl.hidden = false; }
        else        { noteEl.hidden = true; }
      }

      frag.appendChild(row);
    });
    choreHistoryBody.replaceChildren(frag);
  }
  // Dismiss wiring (including the drag-from-inside-to-outside fix) is
  // applied to every `.chores-modal-backdrop` in the Balance section.

  // ============================================================
  // mutations — go through the store
  // ============================================================
  // Snapshot of the chore-side fields the History page needs to render
  // a pending push without a server round-trip. Stored alongside the
  // queued POST/DELETE in localStorage; never sent to the server.
  function queueMetaFor(c) {
    if (!c) return null;
    return {
      chore_id: c.id,
      chore_name: c.short_name || c.name,
      icon: c.icon || "",
      icon_kind: c.icon_kind || "empty",
      one_off: !!c.one_off,
      base_pebbles: c.reward_pebbles || 0,
    };
  }
  // Parses a chore's `notes_template` into a static-text + field-token
  // sequence plus a deduped field list. Placeholder syntax:
  //   {Label}                       → text input
  //   {Label:Numeric}               → number input
  //   {Label:Date}                  → date input
  //   {Label:Select [a, b, "c, d"]} → select; quoted options keep commas
  // Same-labeled placeholders collapse to one field; the value substitutes
  // at every occurrence in the saved note.
  function parseNoteTemplate(template) {
    const tokens = [];
    const fields = [];
    const seen = new Set();
    if (!template) return { tokens, fields };
    const re = /\{([^{}]+)\}/g;
    let last = 0, m;
    while ((m = re.exec(template)) !== null) {
      if (m.index > last) tokens.push({ kind: "text", text: template.slice(last, m.index) });
      const spec = parseNoteFieldSpec(m[1]);
      if (!seen.has(spec.key)) { seen.add(spec.key); fields.push(spec); }
      tokens.push({ kind: "field", key: spec.key });
      last = re.lastIndex;
    }
    if (last < template.length) tokens.push({ kind: "text", text: template.slice(last) });
    return { tokens, fields };
  }
  function parseNoteFieldSpec(inner) {
    const colon = inner.indexOf(":");
    let label, type = "text", options = null;
    if (colon === -1) {
      label = inner.trim();
    } else {
      label = inner.slice(0, colon).trim();
      const rest = inner.slice(colon + 1).trim();
      const lb = rest.indexOf("[");
      if (lb >= 0) {
        type = rest.slice(0, lb).trim().toLowerCase();
        const optsStr = rest.slice(lb + 1).replace(/\]\s*$/, "");
        options = parseNoteOptionList(optsStr);
      } else {
        type = rest.toLowerCase();
      }
    }
    return { key: label, label: label, type: type || "text", options: options };
  }
  function parseNoteOptionList(s) {
    const out = []; let cur = ""; let q = false;
    for (let i = 0; i < s.length; i++) {
      const ch = s[i];
      if (ch === '"') { q = !q; continue; }
      if (ch === "," && !q) { const v = cur.trim(); if (v) out.push(v); cur = ""; continue; }
      cur += ch;
    }
    const tail = cur.trim(); if (tail) out.push(tail);
    return out;
  }
  function interpolateNoteTemplate(parsed, values) {
    return parsed.tokens.map(t => {
      if (t.kind === "text") return t.text;
      const v = values[t.key];
      return v == null ? "" : String(v);
    }).join("");
  }

  // Note-prompt modal — appears on tap for any chore whose
  // notes_template carries `{...}` placeholders. Runs entirely client-
  // side; submit calls doCompleteChore so the same offline-safe queue
  // path handles the resulting POST.
  const notePromptModal  = document.querySelector('[data-note-prompt-modal]');
  const notePromptForm   = notePromptModal?.querySelector('[data-note-prompt-form]');
  const notePromptFields = notePromptModal?.querySelector('[data-note-prompt-fields]');
  const notePromptTitle  = notePromptModal?.querySelector('[data-note-prompt-title]');
  let activeNotePrompt = null;

  // Build one note-prompt form section from a parsed field spec.
  // Returns a DOM node cloned from the type-appropriate template with
  // id / for / dataset filled in. No HTML string construction.
  function buildNotePromptField(f, i) {
    const id = `note-prompt-field-${i}`;
    const type = f.type || "text";
    let tplName = "note-prompt-field-text";
    if (type === "select" && f.options && f.options.length) tplName = "note-prompt-field-select";
    else if (type === "numeric" || type === "number") tplName = "note-prompt-field-number";
    else if (type === "date") tplName = "note-prompt-field-date";

    const node = cloneTemplate(tplName);
    if (!node) return null;
    const labelEl = node.querySelector("[data-prompt-label]");
    const inputEl = node.querySelector("[data-prompt-input]");
    if (labelEl) {
      labelEl.htmlFor = id;
      labelEl.textContent = f.label;
    }
    if (inputEl) {
      inputEl.id = id;
      inputEl.dataset.promptKey = f.key;
      inputEl.dataset.promptType = type;
      if (tplName === "note-prompt-field-select") {
        const blank = new Option("", "");
        inputEl.appendChild(blank);
        f.options.forEach(o => inputEl.appendChild(new Option(o, o)));
      }
    }
    return node;
  }
  // Map a raw form value to the type implied by the placeholder.
  // Empty strings become null so the server stores `null` rather than
  // `""` (or `NaN`/0 for numerics) — the template still interpolates
  // to an empty string at the display layer.
  function coerceNoteValue(raw, type) {
    if (raw == null || raw === "") return null;
    if (type === "numeric" || type === "number") {
      const n = Number(raw);
      return Number.isFinite(n) ? n : null;
    }
    return String(raw);
  }
  function openNotePromptModal(chore, parsed) {
    if (!notePromptModal || !notePromptForm || !notePromptFields) return;
    activeNotePrompt = { chore, parsed };
    if (notePromptTitle) notePromptTitle.textContent = chore.short_name || chore.name || "Notes";
    const frag = document.createDocumentFragment();
    parsed.fields.forEach((f, i) => {
      const node = buildNotePromptField(f, i);
      if (node) frag.appendChild(node);
    });
    notePromptFields.replaceChildren(frag);
    notePromptModal.classList.remove("hidden");
    scrollModalToTop(notePromptModal);
    const first = notePromptFields.querySelector("input, select, textarea");
    first?.focus();
  }
  function closeNotePrompt() {
    notePromptModal?.classList.add("hidden");
    activeNotePrompt = null;
    if (notePromptFields) notePromptFields.replaceChildren();
  }
  notePromptForm?.addEventListener("submit", e => {
    e.preventDefault();
    if (!activeNotePrompt) { closeNotePrompt(); return; }
    const { chore, parsed } = activeNotePrompt;
    const values = {};
    notePromptFields.querySelectorAll("[data-prompt-key]").forEach(el => {
      values[el.dataset.promptKey] = coerceNoteValue(el.value, el.dataset.promptType);
    });
    const note = interpolateNoteTemplate(parsed, values);
    closeNotePrompt();
    doCompleteChore(chore, { note: note, noteValues: values });
  });
  wireModalDismiss(notePromptModal, { onCancel: closeNotePrompt, onBackdrop: closeNotePrompt });

  function completeChore(id) {
    const c = ChoreStore.get(parseInt(id, 10));
    if (!c) return;
    const template = (c.notes_template || "").toString();
    if (template) {
      const parsed = parseNoteTemplate(template);
      if (parsed.fields.length > 0) {
        openNotePromptModal(c, parsed);
        return;
      }
      // Template with no placeholders — store the literal text verbatim.
      doCompleteChore(c, { note: template, noteValues: null });
      return;
    }
    doCompleteChore(c, { note: null, noteValues: null });
  }

  async function doCompleteChore(c, opts) {
    const note = opts && opts.note;
    const noteValues = opts && opts.noteValues;
    const clickAt = new Date().toISOString();
    noteClientTap(c.id);

    ChoreStore.patch(c.id, {
      done_count_today: (c.done_count_today || 0) + 1,
      progress_count: (c.progress_count != null ? c.progress_count : (c.done_count_today || 0)) + 1,
      last_completed_at: clickAt,
      last_actor_username: VIEWER_USERNAME || c.last_actor_username,
    });

    const mid = newMutationId();
    const body = { client_completed_at: clickAt, tab_id: TAB_ID, client_mutation_id: mid };
    const overrides = {};
    if (note != null && note !== "") overrides.note = note;
    if (noteValues && Object.keys(noteValues).length > 0) overrides.note_values = noteValues;
    if (Object.keys(overrides).length > 0) body.chore_completion = overrides;

    pushPendingMutation(c.id, mid);
    enqueue({
      kind:               "complete",
      url:                `/chores/items/${c.id}/completion`,
      method:             "POST",
      body:               body,
      meta:               queueMetaFor(c),
      client_mutation_id: mid,
    });
    flushQueue();
  }

  // Back-off retry for the offline queue when we hit a soft failure
  // (429 / 5xx). We don't burn the CPU polling; one timer per active
  // back-off, with growing intervals capped at 60s.
  let queueRetryTimer = null;
  let queueRetryDelay = 2000;
  function scheduleQueueRetry() {
    if (queueRetryTimer) return;
    if (reloadPending) return;
    queueRetryTimer = setTimeout(async () => {
      queueRetryTimer = null;
      await flushQueue();
      if (loadQueue().length === 0) {
        queueRetryDelay = 2000;
      } else {
        queueRetryDelay = Math.min(queueRetryDelay * 2, 60000);
        scheduleQueueRetry();
      }
    }, queueRetryDelay);
  }

  // Triggered by the rotate button on the Edit Chore modal head. The
  // button is only visible when the chore is a current Hot Pick.
  // Optimistic local removal so the cell disappears immediately; the
  // Monitor "hot_picks_refreshed" broadcast triggers cold-boot sync
  // that pulls in the replacement's multiplier.
  async function rotateHotPick(id) {
    const cid = parseInt(id, 10);
    const c = ChoreStore.get(cid);
    if (!c) return;
    const prev = c.hot_multiplier;
    ChoreStore.patch(cid, { hot_multiplier: null });
    try {
      await api(`/chores/hot_picks/${cid}/rotate`, "POST", { tab_id: TAB_ID });
      flash("Swapped");
    } catch (err) {
      // On any failure path, restore the optimistic removal so the
      // user doesn't see the cell vanish in error.
      ChoreStore.patch(cid, { hot_multiplier: prev });
      if (err.status === 403) flash("Only household managers can change Hot Picks.", "error");
      else if (err.status === 404) flash("Already swapped — nothing to do.", "warn");
      else if (isTransientError(err)) flash("Couldn't swap — try again", "warn");
      else flash("Couldn't swap: " + err.message, "error");
    }
  }

  async function undoLastCompletion(id) {
    const c = ChoreStore.get(parseInt(id, 10));
    if (!c) return;
    const priorDoneCount = c.done_count_today || 0;
    const priorProgress = c.progress_count != null ? c.progress_count : priorDoneCount;
    ChoreStore.patch(c.id, {
      done_count_today: Math.max(0, priorDoneCount - 1),
      progress_count: Math.max(0, priorProgress - 1),
    });
    noteClientTap(c.id);

    // The undo targets the most recent complete this session enqueued —
    // either a still-queued one (collapse, no server call) or a flushed
    // one (DELETE with target_client_mutation_id so a replay is a no-op).
    const targetMid = popPendingMutation(c.id);
    if (targetMid && collapseQueuedCompleteIfPresent(c.id, targetMid)) {
      // Local-only cancel: matching queued complete dropped before flush.
      // ChoreStore patch above already mirrors the cancel; nothing else.
      renderQueueState();
      return;
    }
    const body = { tab_id: TAB_ID };
    if (targetMid) body.target_client_mutation_id = targetMid;
    enqueue({
      kind:               "undo",
      url:                `/chores/items/${c.id}/completion`,
      method:             "DELETE",
      body:               body,
      meta:               queueMetaFor(c),
      client_mutation_id: targetMid,
    });
    flushQueue();
  }

  // Drops a queued complete with the given mutation id, if any. Returns
  // true on hit. Called by undo to collapse a complete that hasn't been
  // sent yet — avoids a round-trip the user effectively cancelled.
  function collapseQueuedCompleteIfPresent(choreId, mid) {
    const q = loadQueue();
    const idx = q.findIndex(it => it.kind === "complete" && it.client_mutation_id === mid);
    if (idx < 0) return false;
    q.splice(idx, 1);
    saveQueue(q);
    return true;
  }

  // Apply a server payload to the store. Two shapes:
  //   * { chore: {...}, ... } — full chore JSON (mutation responses).
  //   * { chores: [...], active_chore_ids: [...], lookahead: {...} } — sync.
  // Cold-start loading state. Shown ONLY when localStorage has no
  // chores AND no /chores/sync has ever validated successfully. This
  // distinguishes "first ever load, please wait" from "user truly has
  // zero chores" — the latter is a legitimate state and gets no
  // indicator. The placeholder is a sibling element; we only toggle a
  // class on it, never replace or rerender the chores containers.
  function shouldShowColdStartLoader() {
    if (!unifiedPage) return false;
    if (localStorage.getItem(SYNC_TS_KEY)) return false;
    return ChoreStore.all().length === 0;
  }
  function showColdStartLoaderIfEmpty() {
    const el = document.querySelector("[data-cold-start]");
    if (!el) return;
    el.classList.toggle("hidden", !shouldShowColdStartLoader());
  }
  function hideColdStartLoader() {
    document.querySelector("[data-cold-start]")?.classList.add("hidden");
  }

  // Strict structural validation for /chores/sync responses. We only
  // trust an envelope that proves it came from the real endpoint:
  //   * `server_ts` — required ISO timestamp. Without it we can't
  //     order writes against local clicks.
  //   * `day_key` — required ISO date. Without it we can't tell if
  //     the next incremental sync should reset for a day rollover.
  //   * `active_chore_ids` — required array. This IS the canonical
  //     accessible set. Empty is VALID (real user with no chores);
  //     non-array means "this isn't a real sync response, ignore."
  // Returns true only when every required key is present and well-
  // typed. Anything else — a 200 OK error page, a partial response,
  // a wrong-controller render — fails closed and leaves localStorage
  // untouched. Empty content from a validated envelope is still
  // honored downstream (no chores, no dailies — all legitimate).
  function validateSyncPayload(data) {
    if (!data || typeof data !== "object") return false;
    if (typeof data.server_ts !== "string" || !data.server_ts) return false;
    if (Number.isNaN(new Date(data.server_ts).getTime())) return false;
    if (typeof data.day_key !== "string" || !/^\d{4}-\d{2}-\d{2}$/.test(data.day_key)) return false;
    if (!Array.isArray(data.active_chore_ids)) return false;
    return true;
  }

  function reconcile(data, { authoritative = false } = {}) {
    if (!data) return;
    // `authoritative` = "this is the truth, replace local." Used by
    // the cold-boot full /chores/sync so stuck localStorage from a
    // previous session can't survive a page load. Skip both the
    // local-click-ts race protection AND ChoreStore.upsert's
    // updated_at guard. POST/PATCH handlers and incremental syncs
    // keep both protections — they may overlap with in-flight taps.
    if (data.chore) {
      const id = data.chore.id;
      if (authoritative) {
        ChoreStore.upsert(data.chore, { authoritative: true });
      } else if (isChoreProtected(id)) {
        // Inside the tap-protection window: drop entirely so the
        // in-progress optimistic count survives. The verify timer
        // armed by noteClientTap will fetch /state once the user
        // stops tapping and converge us with server truth then.
      } else {
        const localMs = localClickTs.get(String(id)) || 0;
        const serverMs = data.server_ts ? new Date(data.server_ts).getTime() : Date.now();
        if (!localMs || serverMs >= localMs) ChoreStore.upsert(data.chore);
      }
    }
    if (Array.isArray(data.chores)) {
      data.chores.forEach(c => {
        if (authoritative) {
          ChoreStore.upsert(c, { authoritative: true });
          return;
        }
        if (isChoreProtected(c.id)) return; // see single-chore branch above
        const localMs = localClickTs.get(String(c.id)) || 0;
        const serverMs = data.server_ts ? new Date(data.server_ts).getTime() :
                         c.updated_at ? new Date(c.updated_at).getTime() : Date.now();
        if (!localMs || serverMs >= localMs) ChoreStore.upsert(c);
      });
    }
    // `active_chore_ids` is the canonical accessible set asserted by
    // the server. Empty IS authoritative now (user really has zero
    // accessible chores — archived, removed from household, fresh
    // account). The fullSync caller gates this with
    // validateSyncPayload(), so we only reach reconcile with an empty
    // array when the server genuinely said so. POST/PATCH handlers
    // (complete/edit/archive) don't ship `active_chore_ids` at all,
    // so they skip this prune naturally via Array.isArray(undefined).
    if (Array.isArray(data.active_chore_ids)) {
      const activeIds = new Set(data.active_chore_ids);
      ChoreStore.all().forEach(c => {
        if (!activeIds.has(c.id)) ChoreStore.remove(c.id);
      });
    }
    if (data.lookahead) ChoreStore.setLookahead(data.lookahead);
    if (Array.isArray(data.daily_ids)) ChoreStore.setDailyIds(data.daily_ids);
    if (data.archived_chore_id) ChoreStore.remove(data.archived_chore_id);

    if (data.today_earnings != null) setTodayEarnings(data.today_earnings);
    if (data.balance != null) setLifetimeBalance(data.balance);
  }

  function updateBalancePill() {
    const el = document.querySelector("[data-balance]");
    if (!el) return;
    const v = root?.dataset.balanceToday;
    if (v != null) el.textContent = formatCount(v);
  }
  function readBalanceCache() {
    try { return JSON.parse(localStorage.getItem(BALANCE_LS_KEY) || "{}"); }
    catch (e) { return {}; }
  }
  function writeBalanceCache(patch) {
    try {
      const next = { ...readBalanceCache(), ...patch };
      localStorage.setItem(BALANCE_LS_KEY, JSON.stringify(next));
    } catch (e) { /* storage full / unavailable — non-fatal */ }
  }
  // Single, intentional writer for the header pill. EVERY page shows
  // today_earnings here — never lifetime. Any handler that wants to
  // update the pill must funnel through this so the next refactor
  // can't accidentally pass lifetime back in. Persists to localStorage
  // so the pill paints instantly on next load instead of flashing the
  // dash placeholder.
  function setTodayEarnings(value) {
    if (value == null) return;
    if (root) root.dataset.balanceToday = value;
    const el = document.querySelector("[data-balance]");
    if (el) el.textContent = formatCount(value);
    writeBalanceCache({ today_earnings: value });
  }
  // Separate writer for the Balance page's lifetime card. NEVER
  // touches `[data-balance]`. Same localStorage persistence pattern.
  function setLifetimeBalance(value) {
    if (value == null) return;
    if (root) root.dataset.balanceTotal = value;
    const el = document.querySelector("[data-lifetime-balance]");
    if (el) el.textContent = formatCount(value);
    const wrap = document.querySelector("[data-lifetime-balance-wrap]");
    if (wrap) wrap.classList.toggle("is-negative", Number(value) < 0);
    writeBalanceCache({ balance: value });
  }
  // Hydrate the pill + lifetime card from localStorage on boot. Runs
  // before fullSync so the first paint shows real numbers (or `—` if
  // we've never synced), never a flashing intermediate state.
  function hydrateBalanceFromLocal() {
    const cache = readBalanceCache();
    if (cache.today_earnings != null) {
      if (root) root.dataset.balanceToday = cache.today_earnings;
      const el = document.querySelector("[data-balance]");
      if (el) el.textContent = formatCount(cache.today_earnings);
    }
    if (cache.balance != null) {
      if (root) root.dataset.balanceTotal = cache.balance;
      const el = document.querySelector("[data-lifetime-balance]");
      if (el) el.textContent = formatCount(cache.balance);
      const wrap = document.querySelector("[data-lifetime-balance-wrap]");
      if (wrap) wrap.classList.toggle("is-negative", Number(cache.balance) < 0);
    }
  }

  // ============================================================
  // sync — diff endpoint, cold boot + reconnect
  // ============================================================
  const SYNC_TS_KEY = "chores:lastSyncTs:v1";
  const SYNC_DAY_KEY = "chores:lastSyncDay:v1";
  let syncInFlight = false;
  async function fullSync({ force = false } = {}) {
    if (syncInFlight || !navigator.onLine || reloadPending) return;
    syncInFlight = true;
    setSyncBadge(true);
    try {
      const since = !force ? (localStorage.getItem(SYNC_TS_KEY) || "") : "";
      const lastDay = localStorage.getItem(SYNC_DAY_KEY);
      const localDay = currentChoreDayIso();
      // If the last successful sync was on a prior chore-day, skip
      // `since` so the server returns the full set (hot picks,
      // today_visible, done_count_today all need a clean slate).
      // The server has the same defense, but doing it client-side
      // shaves a round-trip's worth of stale-render flicker.
      const useSince = since && lastDay === localDay;
      const url = useSince ? `/chores/sync?since=${encodeURIComponent(since)}` : "/chores/sync";
      const data = await api(url, "GET");
      // Hard validation gate: only a structurally-real /chores/sync
      // envelope is allowed to update local truth. A 200 OK error
      // page, a wrong-controller render, or a partial response
      // returns here without touching ChoreStore, localStorage, or
      // the sync-timestamp markers. The next fullSync tries again.
      if (!validateSyncPayload(data)) {
        setSyncBadge(false, true);
        return;
      }
      // A full pull (no `since`) is the canonical reset point —
      // apply authoritatively so stuck localStorage from prior
      // sessions can't survive. Incremental deltas (useSince=true)
      // keep the optimistic/race protections in reconcile.
      reconcile(data, { authoritative: !useSince });
      localStorage.setItem(SYNC_TS_KEY, data.server_ts);
      localStorage.setItem(SYNC_DAY_KEY, data.day_key);
      setSyncBadge(false);
      showColdStartLoaderIfEmpty();
      // Pair every successful sync with a shell refresh: the server
      // may have changed the underlying HTML (a new chore in the
      // bootstrap JSON, an asset URL bump, a layout tweak) and we
      // never want the cached shell lagging behind. Without this the
      // user could see the live data update but the offline-reopen
      // experience would still serve yesterday's shell.
      pingSwRefresh();
      // Off-screen views may want to re-render after a fresh sync —
      // mirror the Monitor path's bus event so any mounted view
      // reacts identically to local resyncs and remote broadcasts.
      broadcastRemoteChange("full_sync");
    } catch (e) { setSyncBadge(false, true); }
    finally { syncInFlight = false; }
  }

  // ============================================================
  // search — works against the store, both views
  // ============================================================
  function score(needle, name, aliases) {
    if (!needle) return 1;
    const n = needle.toLowerCase();
    const fields = [
      { text: (name || "").toLowerCase(), weight: 1.0 },
      ...((aliases || []).map(a => ({ text: a.toLowerCase(), weight: 0.5 }))),
    ];
    let best = 0;
    for (const { text, weight } of fields) {
      if (!text) continue;
      const idx = text.indexOf(n);
      let local = 0;
      if (idx === 0) local = 1.0;
      else if (idx > 0) local = 0.7 - Math.min(idx, 10) * 0.02;
      else if (fuzzyMatch(n, text)) local = 0.3;
      else continue;
      best = Math.max(best, local * weight);
    }
    return best;
  }
  function fuzzyMatch(needle, hay) {
    let i = 0, j = 0;
    while (i < needle.length && j < hay.length) {
      if (needle[i] === hay[j]) i++;
      j++;
    }
    return i === needle.length;
  }
  const SEARCH_EXTRA_LIMIT = 10;
  function currentSearchQuery() {
    return document.querySelector("[data-chores-search]")?.value?.trim() || "";
  }
  function applySearch(q) {
    // Filter the always-visible sections — Grid view's grid AND the
    // Today view's Dailies + Scheduled — by hiding cells that don't
    // match. data-chores-circles is legacy; the live containers are
    // now per-section (dailies / overdue).
    [
      document.querySelector("[data-chores-grid]"),
      document.querySelector("[data-chores-dailies]"),
      document.querySelector("[data-chores-today]"),
      document.querySelector("[data-chores-overdue]"),
    ].filter(Boolean).forEach(container => {
      const cards = Array.from(container.children);
      if (!q) { cards.forEach(c => c.style.display = ""); return; }
      cards.forEach(card => {
        const c = ChoreStore.get(parseInt(card.dataset.choreId, 10));
        if (!c) return;
        const s = score(q, c.short_name || c.name, c.aliases || []);
        card.style.display = s > 0 ? "" : "none";
      });
    });
    renderSearchExtra(q);
  }
  // While searching on the Today view, surface up to N matches from
  // the full Grid set that AREN'T already on screen (i.e. not in
  // Dailies and not in Scheduled). Hidden entirely when the query is
  // empty so it never adds noise to the resting Today layout.
  function renderSearchExtra(q) {
    const section = document.querySelector("[data-chores-search-extra-section]");
    const container = document.querySelector("[data-chores-search-extra]");
    if (!section || !container) return;
    if (!q) {
      section.hidden = true;
      if (container.firstChild) container.replaceChildren();
      return;
    }
    const exclude = new Set([
      ...ChoreStore.dailiesList().map(c => c.id),
      ...ChoreStore.todayList().map(c => c.id),
      ...ChoreStore.overdueList().map(c => c.id),
    ]);
    const scored = [];
    for (const c of ChoreStore.activeForGrid()) {
      if (exclude.has(c.id)) continue;
      const s = score(q, c.short_name || c.name, c.aliases || []);
      if (s > 0) scored.push({ c, s });
    }
    scored.sort((a, b) => b.s - a.s);
    const picks = scored.slice(0, SEARCH_EXTRA_LIMIT).map(x => x.c);
    section.hidden = picks.length === 0;
    reconcileExtras(container, picks);
  }
  // Local diff for the extras container — uses grid-style cards (not
  // circles) so the user can tell at a glance these aren't part of
  // today's lineup, just hits from the broader Grid set. Same
  // patch-don't-clear pattern as Views.reconcileSection.
  function reconcileExtras(container, items) {
    const desired = new Map(items.map(c => [c.id, c]));
    Array.from(container.children).forEach(child => {
      const id = parseInt(child.dataset.choreId, 10);
      if (!desired.has(id)) child.remove();
    });
    const existing = new Map();
    Array.from(container.children).forEach(child => {
      existing.set(parseInt(child.dataset.choreId, 10), child);
    });
    let cursor = container.firstElementChild;
    for (const c of items) {
      const have = existing.get(c.id);
      if (cursor && cursor === have) {
        patchGridCard(cursor, c);
        cursor = cursor.nextElementSibling;
      } else if (have) {
        container.insertBefore(have, cursor);
        patchGridCard(have, c);
      } else {
        container.insertBefore(renderGridCard(c), cursor);
      }
    }
  }
  document.querySelector('[data-chores-search]')?.addEventListener("input",
    e => applySearch(e.target.value.trim()));
  // Wire any input that has a sibling `[data-search-clear]` button: show
  // the × while the field has text, clear + refocus on click. Used by
  // the toolbar search and the History filter.
  function wireSearchClear(scope = document) {
    scope.querySelectorAll("[data-search-clear]").forEach(btn => {
      const wrap = btn.parentElement;
      const input = wrap?.querySelector("input");
      if (!input) return;
      const sync = () => { btn.hidden = !input.value; };
      sync();
      input.addEventListener("input", sync);
      btn.addEventListener("click", () => {
        input.value = "";
        input.dispatchEvent(new Event("input", { bubbles: true }));
        input.focus();
        sync();
      });
    });
  }
  wireSearchClear();

  // ============================================================
  // multiplier toggle + modal
  // ============================================================
  let multiplierActive = false;
  let multiplierTargetCard = null;
  const multiplierBtn = document.querySelector('[data-multiplier-toggle]');
  const multiplierModal = document.querySelector('[data-multiplier-modal]');
  multiplierBtn?.addEventListener("click", () => {
    multiplierActive = !multiplierActive;
    multiplierBtn.classList.toggle("active", multiplierActive);
  });
  function openMultiplierModal(card) {
    if (!multiplierModal) return;
    multiplierTargetCard = card;
    multiplierModal.querySelector('[data-multiplier-label]').textContent =
      card.dataset.choreShort || card.dataset.choreName;
    multiplierModal.querySelector('[data-multiplier-input]').value = 2;
    multiplierModal.classList.remove("hidden");
  }
  function closeMultiplierModal() {
    multiplierModal?.classList.add("hidden");
    multiplierTargetCard = null;
    multiplierActive = false;
    multiplierBtn?.classList.remove("active");
  }
  wireModalDismiss(multiplierModal, {
    onCancel:   closeMultiplierModal,
    onBackdrop: closeMultiplierModal,
  });
  multiplierModal?.querySelectorAll('[data-mult]').forEach(btn =>
    btn.addEventListener("click", () => { multiplierModal.querySelector('[data-multiplier-input]').value = btn.dataset.mult; }));
  multiplierModal?.querySelector('[data-multiplier-submit]')?.addEventListener("click", async () => {
    const n = Math.max(1, Math.min(50, parseInt(multiplierModal.querySelector('[data-multiplier-input]').value, 10) || 1));
    const card = multiplierTargetCard;
    closeMultiplierModal();
    if (!card) return;
    for (let i = 0; i < n; i++) await completeChore(card.dataset.choreId);
  });

  // ============================================================
  // edit modal
  // ============================================================
  const editModal = document.querySelector("[data-chore-modal]");
  const editForm  = editModal?.querySelector('[data-chores-form]');
  function setField(name, value) {
    const el = editForm?.querySelector(`[data-field="${name}"]`);
    if (el == null) return;
    el.value = value ?? "";
  }
  function getField(name) { return editForm?.querySelector(`[data-field="${name}"]`)?.value; }

  let currentChoreId = null;
  let modalLockedFor = null;
  const WDAY_KEYS = ["sun", "mon", "tue", "wed", "thu", "fri", "sat"];

  function setPillValue(groupKey, value) {
    const group = editForm.querySelector(`[data-pill-group="${groupKey}"]`);
    if (!group) return;
    group.querySelectorAll(".pill").forEach(p => {
      p.classList.toggle("active", String(p.dataset.value) === String(value ?? ""));
    });
    const input = editForm.querySelector(`[data-field="${groupKey}"]`);
    if (input) input.value = value ?? "";
  }
  function bindPillGroups() {
    editForm.querySelectorAll(".pill-group[data-pill-group]").forEach(group => {
      const key = group.dataset.pillGroup;
      group.addEventListener("click", e => {
        const pill = e.target.closest(".pill");
        if (!pill || pill.classList.contains("chip-day")) return;
        e.preventDefault();
        if (key === "freq") {
          if (pill.dataset.value === "weekdays") {
            setPillValue("freq", "weekly");
            syncWeekdayChips(["mon", "tue", "wed", "thu", "fri"]);
            // User-initiated freq pick auto-fills starts_on with today
            // (only when blank — never overwrites). MUST stay in this
            // click handler and NOT in syncFreqRow: programmatic
            // populate (e.g. openEditModal restoring a saved chore)
            // also runs syncFreqRow, and silently mutating
            // `starts_on` there would change the chore's due date on
            // save even though the user never touched it.
            ensureStartsOnSet();
            syncFreqRow();
            return;
          }
          setPillValue("freq", pill.dataset.value);
          if (pill.dataset.value !== "never") ensureStartsOnSet();
          syncFreqRow();
          return;
        }
        if (key === "threshold_preset") {
          setPillValue("threshold_preset", pill.dataset.value);
          syncCooldownRow();
          return;
        }
        if (key === "after_chore_when") {
          setPillValue("after_chore_when", pill.dataset.value);
          syncAfterChoreLaterRow();
          return;
        }
        setPillValue(key, pill.dataset.value);
      });
    });
    editForm.querySelector('[data-reward-quicks]')?.addEventListener("click", e => {
      const pill = e.target.closest("[data-reward]");
      if (!pill) return;
      e.preventDefault();
      const v = pill.dataset.reward;
      editForm.querySelectorAll('[data-reward-quicks] .pill').forEach(p => p.classList.remove("active"));
      pill.classList.add("active");
      const custom = editForm.querySelector('.reward-custom');
      if (v === "custom") { custom?.classList.remove("hidden"); custom?.focus(); }
      else { custom?.classList.add("hidden"); if (custom) custom.value = v; }
      updateRewardHint();
    });
    editForm.querySelector('[data-weekday-chips]')?.addEventListener("click", e => {
      const btn = e.target.closest('[data-day]');
      if (!btn) return;
      e.preventDefault();
      btn.classList.toggle("active");
      syncWeekdaysHelperHighlight();
    });
    editForm.querySelector('[data-month-day-pane]')?.addEventListener("click", e => {
      const btn = e.target.closest('[data-day]');
      if (!btn) return;
      e.preventDefault();
      btn.classList.toggle("active");
    });
    editForm.querySelector('[data-month-mode-tabs]')?.addEventListener("click", e => {
      const btn = e.target.closest('[data-month-mode]');
      if (!btn) return;
      e.preventDefault();
      const mode = btn.dataset.monthMode;
      editForm.querySelectorAll('[data-month-mode-tabs] .pill').forEach(p =>
        p.classList.toggle("active", p.dataset.monthMode === mode));
      editForm.querySelector('[data-month-day-pane]')?.classList.toggle("hidden", mode !== "day-of-month");
      editForm.querySelector('[data-month-nth-pane]')?.classList.toggle("hidden", mode !== "nth-weekday");
    });
    editForm.querySelector('[data-cooldown-amount]')?.addEventListener("input", syncCustomCooldown);
    editForm.querySelector('[data-cooldown-unit]')?.addEventListener("change", syncCustomCooldown);
    editForm.querySelector('[data-field="one_off"]')?.addEventListener("change", () => {
      syncSingleTask();
      // User-initiated single-task toggle auto-fills Due Date with
      // today (only when blank — never overwrites). Mirrors the
      // pre-marked_due_at behavior of stamping starts_on, just on
      // the new field. Edit-populate is intentionally NOT routed
      // through here: opening an existing one-off with no due date
      // should leave it blank rather than silently rewriting state
      // the chore never had.
      if (isSingleTask()) ensureMarkedDueSet();
    });
    editForm.querySelector('[data-field="starts_on"]')?.addEventListener("change", syncStartsOnDependents);
    // Parent Chore picker: turns this chore into a sub-chore. Sub-chores
    // MUST be single tasks (the server enforces it; mirror in the UI by
    // forcing the toggle on and disabling it so the user can't fight
    // a coercion they didn't initiate).
    editForm.querySelector('[data-field="parent_chore_id"]')?.addEventListener("change", syncParentChoreLock);
  }

  // Mirrors syncAnchorPickerButton — render the currently-selected
  // parent chore into the trigger button. Falls back to the "None"
  // placeholder when the hidden input is empty. Also toggles the
  // Clear chip's visibility so it only shows when a parent is set.
  function syncParentPickerButton() {
    const idEl = editForm?.querySelector('[data-field="parent_chore_id"]');
    const iconEl = editForm?.querySelector('[data-parent-picker-icon]');
    const labelEl = editForm?.querySelector('[data-parent-picker-label]');
    const clearBtn = editForm?.querySelector('[data-parent-picker-clear]');
    if (!idEl || !iconEl || !labelEl) return;
    const id = parseInt(idEl.value, 10);
    const chore = Number.isFinite(id) ? ChoreStore.get(id) : null;
    if (!chore) {
      while (iconEl.firstChild) iconEl.removeChild(iconEl.firstChild);
      labelEl.textContent = "None";
      if (clearBtn) clearBtn.hidden = true;
      return;
    }
    setIconInside(iconEl, chore);
    labelEl.textContent = chore.short_name || chore.name || "—";
    if (clearBtn) clearBtn.hidden = false;
  }

  function syncParentChoreLock() {
    const idEl = editForm?.querySelector('[data-field="parent_chore_id"]');
    const oneOffCb = editForm?.querySelector('[data-field="one_off"]');
    if (!idEl || !oneOffCb) return;
    const hasParent = !!idEl.value;
    if (hasParent) {
      oneOffCb.checked = true;
      oneOffCb.disabled = true;
      syncSingleTask();
    } else {
      oneOffCb.disabled = false;
    }
  }
  function isSingleTask() { return editForm.querySelector('[data-field="one_off"]')?.checked === true; }
  function syncSingleTask() {
    // PURE UI sync — only toggles row visibility. Auto-filling
    // starts_on lives in the user-change handler instead, so opening
    // an existing single-task chore with no starts_on doesn't silently
    // stamp today's date into the form and save it back as a date the
    // chore never had.
    editForm.querySelectorAll('[data-recurring-only]').forEach(el => el.classList.toggle("hidden", isSingleTask()));
  }
  // Fill starts_on with today's date IFF it's currently blank. Called
  // when the user picks a recurrence freq so the schedule anchor isn't
  // silently empty.
  function ensureStartsOnSet() {
    const startsField = editForm.querySelector('[data-field="starts_on"]');
    if (startsField && !startsField.value) startsField.value = todayIso();
  }
  // Fill marked_due_at (the Due Date input) with today IFF blank.
  // Called when the user toggles Single Task — gives one-offs the
  // sensible default of "needs to get done today" without overriding
  // a date the user already picked.
  function ensureMarkedDueSet() {
    const dueField = editForm.querySelector('[data-field="marked_due_at"]');
    if (dueField && !dueField.value) dueField.value = todayIso();
  }
  function syncCooldownRow() {
    const preset = editForm.querySelector('[data-field="threshold_preset"]')?.value || "";
    const customRow = editForm.querySelector('[data-cooldown-custom-row]');
    const hidden = editForm.querySelector('[data-field="threshold_seconds"]');
