  const streakBonusKindHints = {
    chore_streak:   "Triggers when this chore has been completed N days in a row.",
    daily_pebbles:  "Triggers when today's earned pebbles reach N. Applies to all chores. Day starts 4am",
    weekly_pebbles: "Triggers when this week's earned pebbles reach N. Week starts Sunday.",
