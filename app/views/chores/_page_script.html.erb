  goalForm?.addEventListener("submit", async e => {
    e.preventDefault();
    const submitBtn = goalForm.querySelector('button[type="submit"]');
    const id = goalForm.elements["goal_id"].value;
    const fd = new FormData(goalForm);
    const kind = fd.get("kind");
    const payload = {
      chore_goal: {
        name:            fd.get("name"),
