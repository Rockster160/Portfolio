  function fillGoalForm(p) {
    if (!goalForm) return;
    goalForm.elements["goal_id"].value         = p.id;
    goalForm.elements["name"].value            = p.name || "";
    goalForm.elements["description"].value     = p.description || "";
    goalForm.elements["kind"].value            = p.kind;
    applyGoalPills(p.scope_mode, p.tracking_mode);
    goalForm.elements["target_value"].value    = p.target_value ?? 100;
    goalForm.elements["awarded_pebbles"].value = p.awarded_pebbles ?? 0;
    goalForm.elements["link_url"].value        = p.link_url || "";
    // The image input is the shared icon-stack widget — set via the
    // exposed __setIconValue so the preview re-renders with the right
    // representation (emoji vs <img> vs inline SVG).
    const stack = goalForm.querySelector("[data-icon-stack]");
    stack?.__setIconValue?.(p.image_url || "");
    const choreSelect = goalForm.elements["chore_id"];
    if (choreSelect && p.chore_id) choreSelect.value = p.chore_id;
    updateGoalKindUI();
    updateGoalScopeHint();
    updateGoalTrackingHint();
