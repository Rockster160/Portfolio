  // ============================================================
  // Modal dismiss helper (Balance + global)
  // ============================================================
  // closeOnBackdropClick used to fire on any backdrop *click*, but the
  // click event resolves at the lowest common ancestor of mousedown +
  // mouseup. A text-selection drag that began inside the modal but
  // released on the backdrop would therefore fire `click` on the
  // backdrop and dismiss the modal mid-action. Gate dismissal on both
  // pointerdown AND pointerup landing on the backdrop itself.
  function openModal(el) { el?.classList.remove("hidden"); }
  function closeModal(el) { el?.classList.add("hidden"); }
  function wireModalDismiss(modal, opts = {}) {
    if (!modal) return;
    const onCancel   = opts.onCancel   || (() => closeModal(modal));
    const onBackdrop = opts.onBackdrop || (() => closeModal(modal));
    modal.querySelectorAll('[data-action="cancel"]').forEach(b =>
      b.addEventListener("click", onCancel));
    // Backdrop dismissal requires BOTH the pointer-down AND the
    // pointer-up to land on the backdrop itself — anything else (a
    // drag from inside out, a press on the backdrop that ends inside
    // the modal, a text-selection that crosses the edge) is rejected.
    let downOnBackdrop = false;
    let upOnBackdrop = false;
    modal.addEventListener("pointerdown", e => { downOnBackdrop = e.target === modal; });
    modal.addEventListener("pointerup",   e => { upOnBackdrop   = e.target === modal; });
    modal.addEventListener("click", e => {
      if (e.target === modal && downOnBackdrop && upOnBackdrop) onBackdrop();
      downOnBackdrop = false;
      upOnBackdrop = false;
    });
  }
  // Apply the safe dismiss pattern to every modal on the page. The
  // edit-chore and quick-multiplier modals need state-reset callbacks
  // on dismissal — those are bound explicitly below; everything else
  // gets the default "just hide" behavior here.
  const SPECIALIZED_MODAL_SELECTORS = ['[data-chore-modal]', '[data-multiplier-modal]', '[data-note-prompt-modal]'];
  document.querySelectorAll('.chores-modal-backdrop').forEach(m => {
    if (SPECIALIZED_MODAL_SELECTORS.some(sel => m.matches(sel))) return;

    wireModalDismiss(m);
  });

