  if (!navigator.onLine) setConnDot("offline");

  // ============================================================
  // confetti — goal-achieved celebration
  // ============================================================
  // Popover-based so pieces render in the browser's top layer and sit
  // above open <dialog> modals. Falls back to a max-z fixed overlay on
  // engines that don't support the popover API. Never blocks input:
  // pointer-events on the overlay is `none`.
  function showConfetti() {
    const overlay = document.createElement("div");
