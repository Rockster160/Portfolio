<div id="chore-edit-modal" class="chores-modal-backdrop hidden" data-chore-modal>
  <div class="chores-modal chore-edit-modal">
    <div class="modal-head">
      <button type="button" class="pin-toggle" data-edit-pin-toggle aria-label="Pin to Dailies" title="Pin to Dailies" hidden>
        <i class="fa fa-thumb-tack" aria-hidden="true"></i>
      </button>
      <h3 data-modal-title>Add Chore</h3>
      <button type="button" class="modal-close" data-action="cancel" aria-label="Close">×</button>
    </div>

    <%# Password manager bypass: every input carries the well-known
      ignore attributes. %>
    <form class="chore-form basic" data-chores-form autocomplete="off" novalidate data-form-type="other">

      <%# ----- Identity: icon + names -----
        The preview block is the SINGLE affordance:
          * Type emoji directly into it (contenteditable).
          * Paste an image / image URL / SVG / Genmoji.
          * Tap the small upload chip in the corner for the file
            picker (or drag-drop an image onto the block).
        Hidden `data-field="icon"` carries the canonical value:
        emoji string, data URL, external URL, or inline SVG. %>
      <div class="form-section identity-row">
        <div class="icon-cell" data-icon-stack>
          <button type="button" class="icon-upload-btn" data-icon-upload title="Upload image">
            <i class="fa fa-camera" aria-hidden="true"></i>
          </button>
          <div class="icon-preview" data-icon-preview contenteditable="true" spellcheck="false"
               role="textbox" aria-label="Icon — type emoji, paste image, or tap upload"></div>
          <input type="file" accept="image/png,image/jpeg,image/svg+xml,image/webp,image/gif"
                 data-icon-file hidden>
          <input type="hidden" data-field="icon" value="">
        </div>
        <div class="identity-names">
          <label class="field-label">Name</label>
          <input type="text" data-field="name" placeholder="Brush Teeth" required
                 autocomplete="off" autocorrect="off" autocapitalize="words" spellcheck="false"
                 data-1p-ignore="true" data-lpignore="true" data-bwignore="true" data-form-type="other">
          <input type="text" data-field="short_name" placeholder="Short label (Brush)"
                 autocomplete="off" autocorrect="off" autocapitalize="words" spellcheck="false"
                 data-1p-ignore="true" data-lpignore="true" data-bwignore="true" data-form-type="other">
        </div>
      </div>

      <div class="form-section">
        <label class="field-label">Aliases</label>
        <input type="text" data-field="aliases_csv" placeholder="floss, toothpaste"
               autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
               data-1p-ignore="true" data-lpignore="true" data-bwignore="true" data-form-type="other">
      </div>

      <%# Completion-time notes. Plain text is stored verbatim on the
        ChoreCompletion. `{Label}` / `{Label:Numeric}` /
        `{Label:Select [a, b, "c, d"]}` placeholders trigger a prompt
        modal on click — fields render in order, values interpolate
        into the saved note, and raw inputs are persisted in
        completion.metadata["note_values"]. %>
      <div class="form-section">
        <label class="field-label">Completion Notes</label>
        <textarea data-field="notes_template" rows="2"
                  placeholder='e.g. Fed Whisper {Food Type:Select [Beef, Chicken, "Turkey, Shredded"]} with {Kibble Ounces:Numeric}oz kibble'
                  autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
                  data-1p-ignore="true" data-lpignore="true" data-bwignore="true" data-form-type="other"></textarea>
        <span class="field-hint">Use <code>{Label}</code>, <code>{Label:Numeric}</code>, or <code>{Label:Select [a, b, "c, d"]}</code> to prompt for input on completion.</span>
      </div>

      <%# ----- Pebbles ----- %>
      <div class="form-section">
        <label class="field-label">Pebbles</label>
        <div class="pill-group reward-quicks" data-reward-quicks>
          <% [1, 2, 3, 5, 10, 15].each_with_index do |amount, i| %>
            <button type="button" class="pill <%= "active" if i == 0 %>" data-reward="<%= amount %>"><%= amount %>p</button>
          <% end %>
          <button type="button" class="pill" data-reward="custom">?</button>
        </div>
        <input type="number" data-field="reward_pebbles" min="0" value="1" class="hidden reward-custom"
               autocomplete="off" placeholder="Custom amount"
               data-1p-ignore="true" data-lpignore="true" data-bwignore="true" data-form-type="other">
      </div>

      <%# ----- Sharing (default Household) ----- %>
      <div class="form-section">
        <label class="field-label">Sharing</label>
        <div class="pill-group" data-pill-group="sharing_mode">
          <button type="button" class="pill" data-value="personal">Personal</button>
          <button type="button" class="pill active" data-value="household">Household</button>
        </div>
        <input type="hidden" data-field="sharing_mode" value="household">
      </div>

      <%# ----- Assignee (independent of sharing mode) ----- %>
      <div class="form-section">
        <label class="field-label">Assigned to</label>
        <div class="assignee-row">
          <select data-field="assigned_to_user_id" data-1p-ignore="true" data-lpignore="true">
            <option value="">Anyone</option>
            <% (defined?(assignable_users) ? assignable_users : [current_user]).each do |u| %>
              <option value="<%= u.id %>">
                <%= u.username %><%= " (me)" if u.id == current_user.id %>
              </option>
            <% end %>
          </select>
        </div>
      </div>

      <%# ----- Show on Today View (button order per spec) ----- %>
      <div class="form-section">
        <label class="field-label">Show on Today View</label>
        <div class="pill-group" data-pill-group="show_on_daily_view">
          <button type="button" class="pill" data-value="always">Always</button>
          <button type="button" class="pill" data-value="when_scheduled_and_available">Scheduled or Available</button>
          <button type="button" class="pill active" data-value="when_scheduled">When Scheduled</button>
          <button type="button" class="pill" data-value="when_available">When Available</button>
          <button type="button" class="pill" data-value="never">Hidden</button>
        </div>
        <input type="hidden" data-field="show_on_daily_view" value="when_scheduled">
      </div>

      <%# ----- Single Task toggle (default off). When ON the schedule
        block collapses to just Due Date. ----- %>
      <div class="form-section toggle-row">
        <label class="toggle">
          <input type="checkbox" data-field="one_off">
          <span class="toggle-slider"></span>
          <span>
            <strong>Single Task?</strong>
          </span>
        </label>
      </div>

      <%# ----- Due Date (starts_on) — base for schedules + first
        appearance for single tasks. ----- %>
      <div class="form-section">
        <label class="field-label">Due Date</label>
        <input type="date" data-field="starts_on" class="add-date"
               autocomplete="off" data-1p-ignore="true" data-lpignore="true">
      </div>

      <%# ----- Cooldown ----- %>
      <div class="form-section" data-recurring-only>
        <label class="field-label">Cooldown</label>
        <div class="pill-group" data-pill-group="threshold_preset">
          <button type="button" class="pill active" data-value="">None</button>
          <button type="button" class="pill" data-value="3600">1h</button>
          <button type="button" class="pill" data-value="10800">3h</button>
          <button type="button" class="pill" data-value="21600">6h</button>
          <button type="button" class="pill" data-value="43200">12h</button>
          <button type="button" class="pill" data-value="86400">1d</button>
          <button type="button" class="pill" data-value="172800">2d</button>
          <button type="button" class="pill" data-value="604800">1w</button>
          <button type="button" class="pill" data-value="day-end">End of day</button>
          <button type="button" class="pill" data-value="custom">Custom…</button>
        </div>
        <input type="hidden" data-field="threshold_preset" value="">
        <div data-cooldown-custom-row class="cooldown-custom-row hidden">
          <span class="field-hint">Every</span>
          <input type="number" min="1" value="1" data-cooldown-amount class="cooldown-amount"
                 autocomplete="off" data-1p-ignore="true" data-lpignore="true">
          <select data-cooldown-unit class="cooldown-unit">
            <option value="second">seconds</option>
            <option value="minute">minutes</option>
            <option value="hour">hours</option>
            <option value="day" selected>days</option>
            <option value="week">weeks</option>
          </select>
        </div>
        <input type="hidden" data-field="threshold_seconds" value="">
      </div>

      <%# ----- Repeats ----- %>
      <div class="form-section" data-recurring-only>
        <label class="field-label">Repeats</label>
        <div class="pill-group" data-pill-group="freq">
          <button type="button" class="pill active" data-value="never">Never</button>
          <button type="button" class="pill" data-value="daily">Daily</button>
          <button type="button" class="pill" data-value="weekdays">Weekdays</button>
          <button type="button" class="pill" data-value="weekly">Weekly</button>
          <button type="button" class="pill" data-value="monthly">Monthly</button>
          <button type="button" class="pill" data-value="yearly">Yearly</button>
          <button type="button" class="pill" data-value="custom">Every X (from start date)</button>
          <button type="button" class="pill" data-value="relative">Every X (from last done)</button>
        </div>
        <input type="hidden" data-field="freq" value="never">

        <%# Weekly chips %>
        <div data-weekly-wrap class="repeat-detail hidden">
          <span class="field-hint">On:</span>
          <div data-weekday-chips class="pill-group">
            <% [[:sun,"S"],[:mon,"M"],[:tue,"T"],[:wed,"W"],[:thu,"T"],[:fri,"F"],[:sat,"S"]].each do |k, l| %>
              <button type="button" class="pill chip-day" data-day="<%= k %>"><%= l %></button>
            <% end %>
          </div>
        </div>

        <%# Monthly: chip grid OR nth-weekday %>
        <div data-monthly-wrap class="repeat-detail hidden">
          <div class="month-mode-tabs pill-group" data-month-mode-tabs>
            <button type="button" class="pill active" data-month-mode="day-of-month">Days of month</button>
            <button type="button" class="pill" data-month-mode="nth-weekday">Nth weekday</button>
          </div>
          <div data-month-day-pane class="month-day-chips">
            <% (1..31).each do |day| %>
              <button type="button" class="md-chip" data-day="<%= day %>"><%= day %></button>
            <% end %>
            <button type="button" class="md-chip md-chip-last" data-day="-1">Last</button>
          </div>
          <div data-month-nth-pane class="nth-weekday-row hidden">
            <span class="field-hint">The</span>
            <select data-month-set-pos>
              <option value="1">first</option>
              <option value="2">second</option>
              <option value="3">third</option>
              <option value="4">fourth</option>
              <option value="-1">last</option>
            </select>
            <select data-month-wday>
              <option value="mon">Monday</option>
              <option value="tue">Tuesday</option>
              <option value="wed">Wednesday</option>
              <option value="thu">Thursday</option>
              <option value="fri">Friday</option>
              <option value="sat">Saturday</option>
              <option value="sun">Sunday</option>
            </select>
            <span class="field-hint">of the month</span>
          </div>
        </div>

        <%# Custom / Relative — interval + unit %>
        <div data-interval-wrap class="repeat-detail hidden">
          <span class="field-hint">Every</span>
          <input type="number" min="1" value="1" data-interval class="interval-input"
                 autocomplete="off" data-1p-ignore="true" data-lpignore="true">
          <select data-unit class="unit-select">
            <option value="day">days</option>
            <option value="week">weeks</option>
            <option value="month">months</option>
          </select>
        </div>

        <%# Yearly hint %>
        <div data-yearly-wrap class="repeat-detail hidden">
          <span class="field-hint">Every year on <strong data-yearly-label>—</strong></span>
        </div>

        <%# Daily / Weekdays — no extra fields beyond the helper note %>
        <div data-weekdays-wrap class="repeat-detail hidden">
          <span class="field-hint">Mon–Fri only.</span>
        </div>
      </div>

      <div class="form-actions">
        <button type="button" class="danger hidden" data-action="archive">Archive</button>
        <button type="button" class="ghost" data-action="cancel">Cancel</button>
        <button type="submit" class="primary">Save</button>
      </div>
    </form>
  </div>
</div>

<%# Add/Edit Goal modal — kind selector unlocks the kind-specific
  config inputs and updates the target/label as the user types. %>
<div id="chore-goal-modal" class="chores-modal-backdrop hidden" data-goal-modal>
  <div class="chores-modal">
    <div class="modal-head">
      <h3 data-goal-modal-title>Add Goal</h3>
      <button type="button" class="modal-close" data-action="cancel" aria-label="Close">×</button>
    </div>
    <form class="chore-form basic" data-goal-form autocomplete="off" data-form-type="other">
      <input type="hidden" name="goal_id" value="">

      <%# Icon + identity at the top, mirroring the chore form. Hidden
        `image_url` field travels with the icon-stack; the chore-form
        layout keeps the icon flush-left and stacks name/description
        to its right. %>
      <div class="form-section identity-row">
        <div class="icon-cell" data-icon-stack>
          <button type="button" class="icon-upload-btn" data-icon-upload title="Upload image">
            <i class="fa fa-camera" aria-hidden="true"></i>
          </button>
          <div class="icon-preview" data-icon-preview contenteditable="true" spellcheck="false"
               role="textbox" aria-label="Image — type emoji, paste image or URL, or tap upload"></div>
          <input type="file" accept="image/png,image/jpeg,image/svg+xml,image/webp,image/gif"
                 data-icon-file hidden>
          <input type="hidden" name="image_url" data-icon-hidden value="">
        </div>
        <div class="identity-names">
          <label class="field-label">Name</label>
          <input type="text" name="name" required autocomplete="off" autocapitalize="words"
                 data-1p-ignore="true" data-lpignore="true" data-bwignore="true">
          <input type="text" name="description" placeholder="Description (optional)" autocomplete="off">
        </div>
      </div>

      <div class="form-section">
        <label class="field-label">Kind</label>
        <select name="kind">
          <option value="pebbles">Pebbles</option>
          <option value="total_completions">Total Chore Completions</option>
          <option value="chore_completions">Specific Chore Completions</option>
          <option value="chore_streak">Specific Chore Streak</option>
        </select>
        <div class="field-hint" data-goal-kind-hint></div>
      </div>
      <div class="form-section" data-goal-field="chore_id" hidden>
        <label class="field-label">Chore</label>
        <select name="chore_id">
          <% (@household_chores || []).each do |c| %>
            <option value="<%= c.id %>"><%= c.name %></option>
          <% end %>
        </select>
      </div>
      <div class="form-section">
        <label class="field-label" data-goal-target-label>Target</label>
        <input type="number" name="target_value" min="1" value="100" required autocomplete="off">
      </div>
      <div class="form-row">
        <div class="form-section">
          <label class="field-label">Scope</label>
          <select name="scope_mode">
            <option value="relative">Since goal created</option>
            <option value="cumulative">Lifetime</option>
          </select>
          <div class="field-hint" data-goal-scope-hint></div>
        </div>
        <div class="form-section" data-goal-field="tracking_mode" hidden>
          <label class="field-label">Counts</label>
          <select name="tracking_mode">
            <option value="earned">Earned — withdrawals are ignored</option>
            <option value="saved">Saved — withdrawals subtract</option>
          </select>
        </div>
      </div>
      <div class="form-section">
        <label class="field-label">Reward URL (optional)</label>
        <input type="url" name="link_url" autocomplete="off">
      </div>
      <div class="form-section">
        <label class="field-label">Reward Pebbles on Completion (optional)</label>
        <input type="number" name="awarded_pebbles" min="0" value="0" autocomplete="off">
      </div>
      <div class="form-actions">
        <button type="button" class="ghost" data-action="cancel">Cancel</button>
        <button type="submit" class="primary">Save</button>
      </div>
    </form>
  </div>
</div>

<%# Multiplier modal — shared so Grid + Today both open the multi-tap
  flow from the same `×` toolbar button. %>
<div id="chore-history-modal" class="chores-modal-backdrop hidden" data-chore-history-modal>
  <div class="chores-modal chore-history-modal">
    <div class="modal-head">
      <h3 style="margin:0;" data-chore-history-title>Chore History</h3>
      <button type="button" class="modal-close" data-action="cancel" aria-label="Close">×</button>
    </div>
    <div class="chore-history-body" data-chore-history-body>
      <p style="color:var(--chores-muted);">Loading…</p>
    </div>
  </div>
</div>

<%# Note prompt modal — opened on tap for any chore whose notes_template
  contains `{...}` placeholders. JS builds the field rows from the parsed
  template; submit interpolates values into the saved note and queues the
  completion via the same offline-safe path as a plain tap. %>
<div id="chore-note-prompt-modal" class="chores-modal-backdrop hidden" data-note-prompt-modal>
  <div class="chores-modal chore-note-prompt-modal">
    <div class="modal-head">
      <h3 data-note-prompt-title>Notes</h3>
      <button type="button" class="modal-close" data-action="cancel" aria-label="Close">×</button>
    </div>
    <form class="chore-form basic" data-note-prompt-form autocomplete="off" novalidate data-form-type="other">
      <div class="note-prompt-fields" data-note-prompt-fields></div>
      <div class="form-actions">
        <button type="button" class="ghost" data-action="cancel">Cancel</button>
        <button type="submit" class="primary">Save</button>
      </div>
    </form>
  </div>
</div>

<div id="chore-multiplier-modal" class="chores-modal-backdrop hidden" data-multiplier-modal>
  <div class="chores-modal chore-multiplier-modal">
    <div class="modal-head">
      <h3>How many?</h3>
      <button type="button" class="modal-close" data-action="cancel" aria-label="Close">×</button>
    </div>
    <p class="multiplier-target" data-multiplier-label></p>
    <div class="multiplier-quicks pill-group" data-multiplier-quicks>
      <% [2, 3, 4, 5, 10].each do |n| %>
        <button type="button" class="pill" data-mult="<%= n %>"><%= n %>×</button>
      <% end %>
    </div>
    <input type="number" min="1" value="2" data-multiplier-input class="multiplier-input">
    <div class="form-actions">
      <button type="button" class="ghost" data-action="cancel">Cancel</button>
      <button type="button" class="primary" data-multiplier-submit>OK</button>
    </div>
  </div>
</div>

<%# Manage Streak Bonus modal — create/edit a ChoreStreakBonus. Kind
  drives the chore-picker visibility and the levels-table header labels.
  Multipliers are integers only. %>
<div id="streak-bonus-modal" class="chores-modal-backdrop hidden" data-streak-bonus-modal>
  <div class="chores-modal">
    <div class="modal-head">
      <h3 data-streak-bonus-modal-title>Add Streak Bonus</h3>
      <button type="button" class="modal-close" data-action="cancel" aria-label="Close">×</button>
    </div>
    <form class="chore-form basic" data-streak-bonus-form autocomplete="off">
      <input type="hidden" name="streak_bonus_id" value="">
      <div class="form-section">
        <label class="field-label">Name</label>
        <input type="text" name="name" required>
      </div>
      <div class="form-section">
        <label class="field-label">Kind</label>
        <select name="kind">
          <% ChoreStreakBonus::KIND_LABELS.each do |k, label| %>
            <option value="<%= k %>"><%= label %></option>
          <% end %>
        </select>
        <div class="field-hint" data-streak-bonus-kind-hint></div>
      </div>
      <div class="form-section" data-streak-bonus-field="chore_id" hidden>
        <label class="field-label">Chore</label>
        <select name="chore_id">
          <% (@household_chores || []).each do |c| %>
            <option value="<%= c.id %>"><%= c.name %></option>
          <% end %>
        </select>
      </div>
      <div class="form-section">
        <label class="field-label">Levels</label>
        <div class="multiplier-level-headers">
          <div data-level-threshold-header>Threshold</div>
          <div>× Multiplier</div>
          <div>+ Bonus pebbles</div>
          <div></div>
        </div>
        <div class="multiplier-level-rows" data-level-rows></div>
        <button type="button" class="btn ghost" data-add-level>+ Add level</button>
      </div>
      <div class="form-actions">
        <button type="button" class="ghost" data-action="cancel">Cancel</button>
        <button type="submit" class="primary">Save</button>
      </div>
    </form>
  </div>
</div>

<template data-level-row-template>
  <div class="multiplier-level-row">
    <input type="number" name="config[levels][][threshold]" placeholder="At" min="0" required>
    <input type="number" name="config[levels][][multiplier]" placeholder="× mult" step="1" min="1" value="1">
    <input type="number" name="config[levels][][bonus_pebbles]" placeholder="+ bonus" min="0" value="0">
    <button type="button" class="btn ghost icon" data-remove-level aria-label="Remove"><i class="fa fa-times"></i></button>
  </div>
</template>
