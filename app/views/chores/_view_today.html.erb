<%# Today view container — scheduled-today circles + filtered upcoming. %>
<div class="chores-view view-today" data-view="today">
  <% if chores.empty? %>
    <p style="color:var(--chores-muted);">Nothing scheduled for today. Nice.</p>
  <% end %>

  <div class="chores-circles-wrap">
    <div class="chores-circles" data-chores-circles>
      <% chores.each do |chore| %>
        <%= render "circle_card",
                   chore: chore,
                   done_count: @completions_today[chore.id].to_i,
                   last_completion: @last_completion_by_chore[chore.id],
                   hot: @hot_picks[chore.id] %>
      <% end %>
    </div>
  </div>

  <% upcoming_entries = lookahead.values.flatten.any? ? lookahead : {} %>
  <% if upcoming_entries.any? %>
    <h3 class="lookahead-heading">Upcoming</h3>
    <% upcoming_entries.keys.sort.each do |day| %>
      <% items = upcoming_entries[day]; next if items.empty? %>
      <div class="lookahead-day">
        <div class="day-label"><%= day.strftime("%a %b %-d") %></div>
        <div class="day-items">
          <% items.each do |c| %>
            <span class="day-chip"><%= chore_icon_inline(c, fallback: false) %> <%= c.display_short_name %> <strong><%= c.reward_label %></strong></span>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
