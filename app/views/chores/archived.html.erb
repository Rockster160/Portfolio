<% content_for :title, "Archived Chores" %>

<div class="chores-archived-page" style="max-width: 900px; margin: 20px auto; padding: 0 16px;">
  <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:12px;">
    <h1 style="margin:0;">Archived Chores</h1>
    <%= link_to "← Back to History", chores_history_path, class: "btn ghost" %>
  </div>

  <form method="get" action="<%= chores_archived_path %>" class="basic" style="margin:0 0 14px 0;">
    <input type="text" name="q" value="<%= @q %>"
           placeholder="Filter… e.g. plunge, archived_at<2026-07-22, reward>3"
           autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
           style="width:100%; padding:8px 10px;">
  </form>

  <% if @archived_chores.empty? %>
    <p class="dim">
      <% if @q.present? %>
        No archived chores match <code><%= @q %></code>.
      <% else %>
        No archived chores.
      <% end %>
    </p>
  <% else %>
    <p class="dim" style="margin:0 0 10px;">
      <%= @total_count %> archived · page <%= @page %> of <%= @total_pages %>
    </p>

    <ul class="archived-list" style="list-style:none; padding:0; margin:0;">
      <% @archived_chores.each do |chore| %>
        <li data-chore-id="<%= chore.id %>" style="border:1px solid #2a3350; border-radius:8px; padding:12px 14px; margin-bottom:10px; background:#101527;">
          <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap;">
            <div style="flex:1; min-width:200px;">
              <div style="font-size:16px; font-weight:600;">
                <%= chore_icon_inline(chore) %>
                <%= chore.name %>
                <% if chore.short_name.present? && chore.short_name != chore.name %>
                  <span class="dim" style="font-weight:normal;">(<%= chore.short_name %>)</span>
                <% end %>
              </div>
              <div class="dim" style="font-size:12px; margin-top:4px;">
                #<%= chore.id %> ·
                <%= chore.one_off? ? "one-off" : "recurring" %> ·
                <%= chore.reward_pebbles %>p ·
                <% if chore.parent_chore_id %>
                  sub-chore of <strong><%= chore.parent_chore&.name || "?" %></strong> ·
                <% end %>
                archived <%= chore.archived_at.strftime("%b %-d, %Y %l:%M%P %Z").squeeze(" ") %>
              </div>
            </div>
            <%= form_with url: chore_routes_unarchive_path(chore), method: :post, local: true, class: "basic", data: { turbo: false } do %>
              <button type="submit" class="primary">Unarchive</button>
            <% end %>
          </div>

          <details style="margin-top:10px;">
            <summary style="cursor:pointer; color:#8FB4FF;">Edit</summary>
            <%= form_with url: chore_routes_item_path(chore), method: :patch, local: true, class: "basic", data: { turbo: false } do |f| %>
              <div style="display:grid; grid-template-columns: max-content 1fr; gap:8px 12px; margin-top:10px; align-items:center;">
                <label>Name</label>
                <%= f.text_field :name, value: chore.name, name: "chore[name]" %>

                <label>One-off</label>
                <div>
                  <%= f.check_box :one_off, { checked: chore.one_off?, name: "chore[one_off]" }, "1", "0" %>
                  <span class="dim" style="font-size:12px;">Uncheck to make this a recurring chore (or recurring sub-chore).</span>
                </div>

                <label>Parent chore</label>
                <select name="chore[parent_chore_id]" data-parent-select data-current="<%= chore.parent_chore_id %>">
                  <option value="">— none (top-level) —</option>
                </select>

                <label>Reward</label>
                <%= f.number_field :reward_pebbles, value: chore.reward_pebbles, min: 0, name: "chore[reward_pebbles]", style: "max-width:100px;" %>
              </div>
              <div style="margin-top:10px; text-align:right;">
                <button type="submit" class="primary">Save</button>
              </div>
            <% end %>
          </details>
        </li>
      <% end %>
    </ul>

    <% if @total_pages > 1 %>
      <nav style="display:flex; gap:8px; align-items:center; justify-content:center; margin:16px 0;">
        <% if @page > 1 %>
          <%= link_to "‹ Prev", chores_archived_path(page: @page - 1, q: @q.presence), class: "btn ghost" %>
        <% end %>
        <span class="dim">Page <%= @page %> / <%= @total_pages %></span>
        <% if @page < @total_pages %>
          <%= link_to "Next ›", chores_archived_path(page: @page + 1, q: @q.presence), class: "btn ghost" %>
        <% end %>
      </nav>
    <% end %>
  <% end %>
</div>

<%# Parent list emitted ONCE; a small script populates each row's select on
    page load, avoiding N×M option-tag duplication as archived rows grow. %>
<script id="archived-parent-options" type="application/json">
  <%= raw @possible_parents.map { |p|
    { id: p.id, name: p.name.to_s }
  }.to_json %>
</script>

<script>
  (function () {
    var raw = document.getElementById("archived-parent-options");
    if (!raw) return;
    var options;
    try { options = JSON.parse(raw.textContent); } catch (e) { return; }

    document.querySelectorAll("select[data-parent-select]").forEach(function (sel) {
      var current = sel.dataset.current || "";
      var choreId = sel.closest("li")?.dataset.choreId || "";
      options.forEach(function (opt) {
        if (String(opt.id) === choreId) return; // never self as parent
        var el = document.createElement("option");
        el.value = String(opt.id);
        el.textContent = opt.name;
        if (String(opt.id) === current) el.selected = true;
        sel.appendChild(el);
      });
    });
  })();
</script>
