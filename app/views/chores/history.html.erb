<% content_for :title, "Chores · History" %>
<%= render "shell_head" %>

<div class="chores-page" data-chores-root data-mode="history">
  <%= render "header", balance: @balance, scope: :total %>

  <%# Search form — submission is intercepted by JS and re-issued as a
      JSON fetch + pushState so the page never fully reloads. The form
      still has a real action so a no-JS environment falls back to the
      legacy round-trip. %>
  <form class="history-search" data-history-search action="<%= chores_history_path %>" method="get">
    <div class="search-wrap" style="flex:1;">
      <input type="text" name="q" value="<%= @q %>" data-history-q
             placeholder="Filter… e.g. notes:test, time>2026-05-01, amount>1, Cat"
             autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false">
      <button type="button" class="search-clear" data-search-clear aria-label="Clear" <%= 'hidden' if @q.blank? %>>×</button>
    </div>
  </form>

  <%# Pending pushes — queued completions/undos that haven't synced.
      Read from localStorage on load. Each row is editable (same modal
      as History) or deletable directly out of the queue. NO auto-flush
      runs while this page is open — the user can curate the queue
      without it racing them. %>
  <div data-pending-section hidden>
    <div class="section-heading">
      <h3 class="pending-heading">
        <i class="fa fa-clock-o" aria-hidden="true"></i>
        Pending — <span data-pending-count>0</span>
        <span class="dim" style="font-size:12px;font-weight:normal;">(not sending while you're here)</span>
      </h3>
      <button type="button" class="section-reload" data-pending-reload
              title="Reload pending list" aria-label="Reload pending list">
        <i class="fa fa-refresh" aria-hidden="true"></i>
      </button>
    </div>
    <div class="history-list" data-pending-list></div>
  </div>

  <div class="section-heading">
    <h3>History</h3>
    <button type="button" class="section-reload" data-history-reload
            title="Reload history" aria-label="Reload history">
      <i class="fa fa-refresh" aria-hidden="true"></i>
    </button>
  </div>

  <div class="history-summary" data-history-summary hidden>
    <span class="history-summary-left dim" data-summary-left></span>
    <span class="history-summary-mid" data-summary-mid></span>
    <span class="history-summary-right dim" data-summary-right></span>
  </div>

  <div class="history-list" data-history-list>
    <div class="history-row history-loading" data-history-loading>
      <span class="dim">Loading history…</span>
    </div>
  </div>

  <nav class="history-pager" data-history-pager hidden>
    <button type="button" class="btn ghost" data-page="first">« First</button>
    <button type="button" class="btn ghost" data-page="prev">‹ Prev</button>
    <span class="history-pager-pos">Page <span data-page-cur>1</span> / <span data-page-total>1</span></span>
    <button type="button" class="btn ghost" data-page="next">Next ›</button>
    <button type="button" class="btn ghost" data-page="last">Last »</button>
  </nav>

  <div id="completion-edit-modal" class="chores-modal-backdrop hidden" data-completion-modal>
    <div class="chores-modal">
      <div class="modal-head">
        <h3 style="margin:0;" data-modal-title>Edit Completion</h3>
        <button type="button" class="modal-close" data-modal-cancel aria-label="Close">×</button>
      </div>
      <div class="completion-details">
        <div class="detail-row" data-modal-subject-row>
          <span class="detail-label" data-modal-subject-label>Chore</span>
          <span><span data-modal-icon></span> <span data-modal-name></span></span>
        </div>
        <div class="detail-row completion-only">
          <span class="detail-label">Base reward</span>
          <span><span data-modal-base>0</span>p</span>
        </div>
        <div class="detail-row completion-only">
          <span class="detail-label">Multipliers</span>
          <div class="mult-pills">
            <button type="button" class="mult-pill" data-mult-edit="hot" title="Tap to set hot multiplier">
              Hot <strong data-mult-display-hot>1</strong>×
            </button>
            <button type="button" class="mult-pill" data-mult-edit="streak" title="Tap to set streak multiplier">
              Streak <strong data-mult-display-streak>1</strong>×
            </button>
            <input type="hidden" data-modal-hot-mult value="1">
            <input type="hidden" data-modal-streak-mult value="1">
          </div>
        </div>
        <div class="detail-row completion-only" data-modal-skipped-row hidden>
          <span class="detail-label">Skipped</span>
          <span data-modal-skipped-reason></span>
        </div>
        <hr style="border:0;border-top:1px solid #1F2A44;margin:8px 0;">
        <div class="detail-row">
          <span class="detail-label">When</span>
          <input type="datetime-local" data-modal-completed-at class="modal-input">
        </div>
        <div class="detail-row" data-modal-amount-row>
          <span class="detail-label" data-modal-amount-label>Paid pebbles</span>
          <input type="number" min="0" data-modal-amount class="modal-input" style="max-width:80px;text-align:right;">
        </div>
        <div class="detail-row" style="flex-direction:column;align-items:stretch;gap:4px;">
          <span class="detail-label">Note</span>
          <textarea data-modal-note rows="2" class="modal-input" placeholder="(optional)"></textarea>
        </div>
      </div>
      <div class="form-actions">
        <button type="button" class="danger" data-modal-delete>Delete</button>
        <button type="button" class="ghost" data-modal-cancel>Cancel</button>
        <button type="button" class="primary" data-modal-save>Save</button>
      </div>
    </div>
  </div>
  <%= render "templates" %>
</div>

<% content_for :after_body do %>
  <%# page_script runs on every chores view so the offline queue,
      Monitor subscription, and sync dot stay alive consistently.
      Inside page_script, `data-mode === "history"` short-circuits the
      auto-flush so pending pushes don't ship while the user is
      curating them. History rows themselves refetch ONLY on explicit
      user action (reload button, page/filter change, navigation) —
      Monitor broadcasts do not trigger a refetch on this view, which
      keeps typing in-edit safe and the request rate low. %>
  <%= render "page_script", mode: "history" %>
  <script type="module">
    // ===========================================================
    // History page — fully JS-driven. The server ships an empty
    // shell, JS fetches /chores/history.json on load and on every
    // pagination/filter change, and the same template renders both
    // committed entries and pending (queued) pushes. The offline
    // queue is read from localStorage; it is NOT flushed while this
    // page is open (page_script — which owns the flush loop — does
    // not load here).
    // ===========================================================

    // Read CSRF dynamically — the SW-cached shell may carry a token from
    // whenever the shell was first cached. refreshCsrf() heals it after
    // the first 422 by fetching a fresh token off the live session.
    function currentCsrf() {
      return document.querySelector('meta[name="csrf-token"]')?.content || "";
    }
    async function refreshCsrf() {
      try {
        const res = await fetch("/chores/csrf", { credentials: "same-origin", headers: { Accept: "application/json" }, redirect: "manual" });
        if (!res.ok) return null;
        const data = await res.json();
        if (data?.token) {
          const meta = document.querySelector('meta[name="csrf-token"]');
          if (meta) meta.content = data.token;
          return data.token;
        }
      } catch (e) {}
      return null;
    }
    const QUEUE_KEY = "chores:offline_queue:v2";
    // History entries are NEVER cached client-side: this list is
    // audit-style and must always reflect the live DB. Every visit,
    // every broadcast, every refocus shows a spinner and fetches
    // fresh. The shell ships pre-cached by the SW so the page itself
    // never blanks out; only the content area swaps loading → entries.

    const root = document.querySelector('[data-chores-root]');
    const listEl = document.querySelector("[data-history-list]");
    const summaryEl = document.querySelector("[data-history-summary]");
    const pagerEl = document.querySelector("[data-history-pager]");
    const pendingSection = document.querySelector("[data-pending-section]");
    const pendingList = document.querySelector("[data-pending-list]");
    const pendingCount = document.querySelector("[data-pending-count]");
    const searchForm = document.querySelector("[data-history-search]");
    const qInput = document.querySelector("[data-history-q]");
    const clearBtn = qInput?.parentElement?.querySelector("[data-search-clear]");
    const modal = document.querySelector('[data-completion-modal]');

    let state = { page: 1, q: "", total_pages: 1 };
    let currentEditTarget = null; // { kind: "committed" | "pending", row }

    // ---------- utils ----------
    function esc(s) {
      return String(s ?? "").replace(/[&<>"']/g, c => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
      }[c]));
    }
    function formatCount(n) {
      const f = Number(n);
      return Number.isFinite(f) ? f.toLocaleString() : "";
    }
    function formatMult(v) {
      const f = Number(v);
      if (!Number.isFinite(f)) return "1";
      return f === Math.floor(f) ? String(Math.floor(f)) : String(f);
    }
    function pluralize(n, single, plural) {
      return `${n} ${n === 1 ? single : (plural || single + "s")}`;
    }
    function truncate(s, n) { return s.length > n ? s.slice(0, n - 3) + "..." : s; }
    // Notes rarely get past 120 chars; clipping at 40 lopped off the
    // useful half of nearly every realistic note. The row's flex layout
    // already wraps long text — the truncate is only a hard ceiling.
    const NOTE_LIMIT = 120;
    function toLocalInputValue(isoString) {
      if (!isoString) return "";
      const d = new Date(isoString);
      const pad = n => String(n).padStart(2, "0");
      return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
    }
    function formatWhenLabel(isoString) {
      const d = new Date(isoString);
      const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
      let h = d.getHours();
      const ampm = h >= 12 ? "pm" : "am";
      h = h % 12; if (h === 0) h = 12;
      const m = String(d.getMinutes()).padStart(2, "0");
      return `${months[d.getMonth()]} ${d.getDate()} ${h}:${m}${ampm}`;
    }
    function iconHTML(chore) {
      const v = (chore?.icon || "").trim();
      const kind = chore?.icon_kind;
      if (!v || kind === "empty") return `<span class="icon-placeholder">🧹</span>`;
      if (kind === "image")   return `<img class="icon-img" src="${esc(v)}" alt="" loading="lazy">`;
      if (kind === "svg")     return v;
      if (kind === "ti_icon") return `<i class="ti ${esc(v)} icon-ti" aria-hidden="true"></i>`;
      return `<span class="icon-glyph">${esc(v)}</span>`;
    }
    async function api(url, method, body) {
      let res = await fetch(url, {
        method,
        credentials: "same-origin",
        headers: { "Content-Type": "application/json", "Accept": "application/json", "X-CSRF-Token": currentCsrf() },
        body: body ? JSON.stringify(body) : undefined,
      });
      if (res.status === 422) {
        const fresh = await refreshCsrf();
        if (fresh) {
          res = await fetch(url, {
            method,
            credentials: "same-origin",
            headers: { "Content-Type": "application/json", "Accept": "application/json", "X-CSRF-Token": fresh },
            body: body ? JSON.stringify(body) : undefined,
          });
        }
      }
      if (!res.ok) throw new Error(`${res.status}: ${await res.text()}`);
      return res.status === 204 ? null : res.json();
    }
    function flash(msg, type = "ok") {
      const el = document.createElement("div");
      el.className = "chores-flash " + (type === "error" ? "error" : (type === "warn" ? "warn" : ""));
      el.textContent = msg;
      document.body.appendChild(el);
      requestAnimationFrame(() => el.classList.add("show"));
      setTimeout(() => { el.classList.remove("show"); setTimeout(() => el.remove(), 250); }, 2400);
    }
    // Disable a submit-style button and show the centered .loading
    // spinner (defined in chores.scss) while an async action runs.
    // Re-entrant clicks are dropped because the button is disabled.
    async function withSavingState(btn, fn) {
      if (!btn || btn.disabled) return;
      btn.disabled = true;
      btn.classList.add("loading");
      try { return await fn(); }
      finally {
        btn.disabled = false;
        btn.classList.remove("loading");
      }
    }

    // ---------- offline queue (read-only on this page) ----------
    function loadQueue() {
      try { return JSON.parse(localStorage.getItem(QUEUE_KEY) || "[]"); }
      catch (e) { return []; }
    }
    function saveQueue(q) {
      localStorage.setItem(QUEUE_KEY, JSON.stringify(q));
      // Notify page_script so the header badge count updates in the
      // same page (storage events only fire cross-tab).
      window.dispatchEvent(new CustomEvent("chores:queue_changed"));
    }

    // ---------- templates ----------
    function committedRowHTML(entry) {
      if (entry.kind === "withdrawal") {
        const note = entry.note ? `<span class="history-note">— ${esc(truncate(entry.note, NOTE_LIMIT))}</span>` : "";
        return `
          <div class="history-row"
               data-kind="withdrawal"
               data-withdrawal-id="${entry.id}"
               data-amount="${entry.amount_pebbles}"
               data-created-at="${esc(entry.created_at)}"
               data-note="${esc(entry.note || "")}">
            <span class="history-when-name">
              <span class="history-when">${esc(entry.when_label)}</span> ·
              <span class="history-icon">🪙</span>
              <span class="history-name">Withdraw</span>
              ${note}
            </span>
            <span class="history-amount-cell">
              <span class="history-amount" style="color:#FCA5A5;">−${formatCount(entry.amount_pebbles)}p</span>
              <button type="button" class="history-edit" data-edit-withdrawal title="Edit">
                <i class="fa fa-pencil" aria-hidden="true"></i>
              </button>
            </span>
          </div>`;
      }
      if (entry.kind === "transfer") {
        // Outgoing transfers are editable + deletable by the sender;
        // incoming transfers are read-only here (the recipient never
        // had agency over creating them).
        const outgoing = entry.direction === "outgoing";
        const peer = entry.counterparty_username || "someone";
        const verb = outgoing ? `Sent to ${peer}` : `From ${peer}`;
        const sign = outgoing ? "−" : "+";
        const colour = outgoing ? "#FCA5A5" : "#34D399";
        const note = entry.note ? `<span class="history-note">— ${esc(truncate(entry.note, NOTE_LIMIT))}</span>` : "";
        const editBtn = outgoing ? `
              <button type="button" class="history-edit" data-edit-transfer title="Edit">
                <i class="fa fa-pencil" aria-hidden="true"></i>
              </button>` : "";
        return `
          <div class="history-row"
               data-kind="transfer"
               data-transfer-id="${entry.id}"
               data-direction="${esc(entry.direction)}"
               data-peer="${esc(peer)}"
               data-amount="${entry.amount_pebbles}"
               data-created-at="${esc(entry.created_at)}"
               data-note="${esc(entry.note || "")}">
            <span class="history-when-name">
              <span class="history-when">${esc(entry.when_label)}</span> ·
              <span class="history-icon">🤝</span>
              <span class="history-name">${esc(verb)}</span>
              ${note}
            </span>
            <span class="history-amount-cell">
              <span class="history-amount" style="color:${colour};">${sign}${formatCount(entry.amount_pebbles)}p</span>
              ${editBtn}
            </span>
          </div>`;
      }
      const note = entry.note ? `<span class="history-note">— ${esc(truncate(entry.note, NOTE_LIMIT))}</span>` : "";
      const hotPill = (entry.hot_multiplier > 1)
        ? `<span class="history-mult hot">Hot ${esc(formatMult(entry.hot_multiplier))}×</span>` : "";
      const streakPill = (entry.streak_multiplier > 1)
        ? `<span class="history-mult streak">Streak ${esc(formatMult(entry.streak_multiplier))}×</span>` : "";
      // "skipped" (cooldown) and "anonymous" (done by someone outside
      // the household) are distinct states — render them differently
      // so the user can scan History without having to open each row.
      const amt = entry.anonymous
        ? `<span class="history-amount" style="color:#94A3B8;">(anonymous)</span>`
        : (entry.payout_skipped
            ? `<span class="history-amount" style="color:#9CA3AF;">(skipped)</span>`
            : `<span class="history-amount" style="color:#34D399;">+${formatCount(entry.paid_pebbles)}p</span>`);
      return `
        <div class="history-row"
             data-kind="completion"
             data-completion-id="${entry.id}"
             data-chore-id="${entry.chore.id}"
             data-chore-name="${esc(entry.chore.short_name || entry.chore.name)}"
             data-paid="${entry.paid_pebbles}"
             data-base="${entry.base_pebbles}"
             data-completed-at="${esc(entry.completed_at)}"
             data-note="${esc(entry.note || "")}"
             data-hot="${entry.hot_pick ? "true" : "false"}"
             data-hot-multiplier="${entry.hot_multiplier}"
             data-streak-multiplier="${entry.streak_multiplier}"
             data-skipped="${entry.payout_skipped ? "true" : "false"}"
             data-skipped-reason="${esc(entry.skipped_reason || "")}"
             data-chore-icon="${esc(entry.chore.icon || "")}"
             data-chore-icon-kind="${esc(entry.chore.icon_kind || "empty")}">
          <span class="history-when-name">
            <span class="history-when">${esc(entry.when_label)}</span> ·
            <span class="history-icon">${iconHTML(entry.chore)}</span>
            <span class="history-name">${esc(entry.chore.short_name || entry.chore.name)}</span>
            ${hotPill}
            ${streakPill}
            ${note}
          </span>
          <span class="history-amount-cell">
            ${amt}
            <button type="button" class="history-edit" data-edit-completion title="Edit completion #${entry.id}">
              <i class="fa fa-pencil" aria-hidden="true"></i>
            </button>
          </span>
        </div>`;
    }

    function pendingRowHTML(item, idx) {
      const meta = item.meta || {};
      const body = item.body || {};
      const choreName = meta.chore_name || `Chore #${meta.chore_id ?? "?"}`;
      const chore = { icon: meta.icon, icon_kind: meta.icon_kind };
      const ts = body.client_completed_at || item.queued_at;
      const whenLabel = ts ? formatWhenLabel(ts) : "pending";
      const note = body.note ? `<span class="history-note">— ${esc(truncate(body.note, NOTE_LIMIT))}</span>` : "";
      const hotMultVal    = parseFloat(body.hot_multiplier ?? 1) || 1;
      const streakMultVal = parseFloat(body.streak_multiplier ?? body.total_multiplier ?? 1) || 1;
      const hotPill    = hotMultVal    > 1 ? `<span class="history-mult hot">Hot ${esc(formatMult(hotMultVal))}×</span>` : "";
      const streakPill = streakMultVal > 1 ? `<span class="history-mult streak">Streak ${esc(formatMult(streakMultVal))}×</span>` : "";
      const actionLabel = item.method === "DELETE" ? "Undo" : "Complete";
      const actionClass = item.method === "DELETE" ? "pending-undo" : "pending-complete";
      const amt = item.method === "DELETE"
        ? `<span class="history-amount" style="color:#9CA3AF;">undo</span>`
        : `<span class="history-amount" style="color:#FACC15;">+${formatCount(meta.base_pebbles ?? 0)}p</span>`;
      const editBtn = item.method === "DELETE" ? "" : `
        <button type="button" class="history-edit" data-edit-pending title="Edit">
          <i class="fa fa-pencil" aria-hidden="true"></i>
        </button>`;
      return `
        <div class="history-row pending-row ${actionClass}" data-pending-index="${idx}">
          <span class="history-when-name">
            <span class="history-when">${esc(whenLabel)}</span> ·
            <span class="history-icon">${iconHTML(chore)}</span>
            <span class="history-name">${esc(choreName)}</span>
            <span class="history-tag pending">${actionLabel}</span>
            ${hotPill}
            ${streakPill}
            ${note}
          </span>
          <span class="history-amount-cell">
            ${amt}
            ${editBtn}
            <button type="button" class="history-edit" data-delete-pending title="Remove from queue">
              <i class="fa fa-times" aria-hidden="true"></i>
            </button>
          </span>
        </div>`;
    }

    // ---------- rendering ----------
    function renderPending() {
      const q = loadQueue();
      if (q.length === 0) {
        pendingSection.setAttribute("hidden", "");
        pendingList.innerHTML = "";
        return;
      }
      pendingSection.removeAttribute("hidden");
      pendingCount.textContent = String(q.length);
      pendingList.innerHTML = q.map(pendingRowHTML).join("");
    }

    function renderHistory(data) {
      const { entries = [], total_count = 0, total_pages = 1,
              page_completions = 0, page_withdrawals = 0, page_transfers = 0,
              from = 0, to = 0, page = 1 } = data || {};
      state.total_pages = total_pages;
      state.page = page;

      if (total_count === 0) {
        summaryEl.removeAttribute("hidden");
        summaryEl.querySelector("[data-summary-left]").innerHTML = "No matching history.";
        summaryEl.querySelector("[data-summary-mid]").innerHTML = "";
        summaryEl.querySelector("[data-summary-right]").innerHTML = "";
      } else {
        summaryEl.removeAttribute("hidden");
        // Transfers join completions + withdrawals in the summary,
        // shown only when at least one is on this page — keeps the
        // line short when transfers aren't being used.
        const parts = [
          `${pluralize(page_completions, "completion")}`,
          `${pluralize(page_withdrawals, "withdrawal")}`,
        ];
        if (page_transfers > 0) parts.push(`${pluralize(page_transfers, "transfer")}`);
        summaryEl.querySelector("[data-summary-left]").textContent =
          `Showing ${parts.join(", ")}`;
        summaryEl.querySelector("[data-summary-mid]").innerHTML =
          `Page <strong>${page}</strong> of <strong>${total_pages}</strong>`;
        summaryEl.querySelector("[data-summary-right]").innerHTML =
          `${formatCount(from)}&ndash;${formatCount(to)} / ${formatCount(total_count)}`;
      }

      if (entries.length === 0) {
        listEl.innerHTML = total_count === 0
          ? ""
          : `<div class="history-row history-loading"><span class="dim">No entries on this page.</span></div>`;
      } else {
        listEl.innerHTML = entries.map(committedRowHTML).join("");
      }

      if (total_pages > 1) {
        pagerEl.removeAttribute("hidden");
        pagerEl.querySelector("[data-page-cur]").textContent = page;
        pagerEl.querySelector("[data-page-total]").textContent = total_pages;
        pagerEl.querySelector('[data-page="first"]').classList.toggle("disabled", page === 1);
        pagerEl.querySelector('[data-page="prev"]').classList.toggle("disabled", page === 1);
        pagerEl.querySelector('[data-page="next"]').classList.toggle("disabled", page === total_pages);
        pagerEl.querySelector('[data-page="last"]').classList.toggle("disabled", page === total_pages);
      } else {
        pagerEl.setAttribute("hidden", "");
      }

      // Header pill: ALWAYS today_earnings on every page. Never
      // balance. The lifetime number lives on the Balance page card,
      // not in the pill.
      if (data.today_earnings != null) setTodayEarnings(data.today_earnings);
    }

    // Single writer for the header pill on this page. Module-scoped
    // so a careless `[data-balance].textContent = lifetime` can't
    // sneak back in.
    function setTodayEarnings(value) {
      if (value == null) return;
      const el = document.querySelector("[data-balance]");
      if (el) el.textContent = formatCount(value);
    }

    function setLoadingPlaceholder() {
      listEl.innerHTML = `<div class="history-row history-loading" data-history-loading><i class="fa fa-spinner fa-pulse"></i> <span class="dim">Loading history…</span></div>`;
      summaryEl.setAttribute("hidden", "");
      pagerEl.setAttribute("hidden", "");
    }
    function setOfflinePlaceholder(msg) {
      const text = msg || "Offline — history will load when you're back.";
      listEl.innerHTML = `<div class="history-row history-loading"><span class="dim">${esc(text)}</span></div>`;
      summaryEl.setAttribute("hidden", "");
      pagerEl.setAttribute("hidden", "");
    }

    async function fetchHistory({ push = true } = {}) {
      const params = new URLSearchParams();
      if (state.page > 1) params.set("page", state.page);
      if (state.q) params.set("q", state.q);
      const qs = params.toString();
      const url = qs ? `/chores/history.json?${qs}` : "/chores/history.json";

      if (push) {
        const visibleQs = new URLSearchParams();
        if (state.page > 1) visibleQs.set("page", state.page);
        if (state.q) visibleQs.set("q", state.q);
        const visible = visibleQs.toString();
        const next = visible ? `/chores/history?${visible}` : "/chores/history";
        history.pushState({ page: state.page, q: state.q }, "", next);
      }

      // Always dump current content and show the spinner — no
      // client-side cache for history entries by design. The pending
      // pushes section above stays as-is throughout (it lives in
      // localStorage and is independent).
      setLoadingPlaceholder();

      try {
        const data = await api(url, "GET");
        renderHistory(data);
      } catch (e) {
        setOfflinePlaceholder();
      }
    }

    // ---------- pagination + filter ----------
    pagerEl.addEventListener("click", e => {
      const btn = e.target.closest("[data-page]");
      if (!btn || btn.classList.contains("disabled")) return;
      const dir = btn.dataset.page;
      let next = state.page;
      if (dir === "first") next = 1;
      else if (dir === "prev") next = Math.max(1, state.page - 1);
      else if (dir === "next") next = Math.min(state.total_pages, state.page + 1);
      else if (dir === "last") next = state.total_pages;
      if (next === state.page) return;
      state.page = next;
      fetchHistory();
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    searchForm.addEventListener("submit", e => {
      e.preventDefault();
      state.q = qInput.value.trim();
      state.page = 1;
      if (clearBtn) clearBtn.hidden = !state.q;
      fetchHistory();
    });
    clearBtn?.addEventListener("click", () => {
      qInput.value = "";
      state.q = "";
      state.page = 1;
      clearBtn.hidden = true;
      fetchHistory();
    });
    window.addEventListener("popstate", e => {
      const url = new URL(location.href);
      state.q = url.searchParams.get("q") || "";
      state.page = parseInt(url.searchParams.get("page") || "1", 10) || 1;
      qInput.value = state.q;
      if (clearBtn) clearBtn.hidden = !state.q;
      fetchHistory({ push: false });
    });

    // ---------- modal: committed + pending share the same UI ----------
    function setMultPill(kind, value) {
      const v = Number.isFinite(value) ? value : 1;
      modal.querySelector(`[data-modal-${kind}-mult]`).value = v;
      modal.querySelector(`[data-mult-display-${kind}]`).textContent = formatMult(v);
      // Hot pill > 1 reads as the "active hot pick" — green tint to
      // match the chore-card hot-badge styling. Total pill stays neutral.
      if (kind === "hot") {
        const btn = modal.querySelector('[data-mult-edit="hot"]');
        if (btn) btn.classList.toggle("active", v > 1);
      }
    }
    modal.querySelectorAll('[data-mult-edit]').forEach(btn => {
      btn.addEventListener("click", () => {
        const kind = btn.dataset.multEdit;
        const current = modal.querySelector(`[data-modal-${kind}-mult]`).value;
        const label = kind === "hot" ? "Hot" : "Streak";
        const raw = prompt(`${label} multiplier:`, current);
        if (raw == null) return;
        const next = parseFloat(raw);
        if (!Number.isFinite(next) || next < 0) { flash("Bad multiplier", "error"); return; }
        setMultPill(kind, next);
      });
    });

    function openCommittedModal(row) {
      currentEditTarget = { kind: "committed", row };
      const ds = row.dataset;
      modal.querySelector('[data-modal-title]').textContent = "Edit Completion";
      modal.querySelector('[data-modal-subject-label]').textContent = "Chore";
      modal.querySelector('[data-modal-name]').textContent = ds.choreName;
      modal.querySelector('[data-modal-base]').textContent = ds.base || "0";
      modal.querySelector('[data-modal-completed-at]').value = toLocalInputValue(ds.completedAt);
      modal.querySelector('[data-modal-amount]').value = ds.paid || "0";
      modal.querySelector('[data-modal-amount-row]').removeAttribute("hidden");
      modal.querySelector('[data-modal-amount-label]').textContent = "Paid pebbles";
      setCompletionOnlyVisible(true);
      setMultPill("hot",    parseFloat(ds.hotMultiplier    || "1"));
      setMultPill("streak", parseFloat(ds.streakMultiplier || "1"));
      modal.querySelector('[data-modal-note]').value = ds.note || "";
      const skippedRow = modal.querySelector('[data-modal-skipped-row]');
      if (ds.skipped === "true") {
        skippedRow.removeAttribute("hidden");
        modal.querySelector('[data-modal-skipped-reason]').textContent = ds.skippedReason || "Cooldown";
      } else {
        skippedRow.setAttribute("hidden", "");
      }
      // Clone the icon HTML from the source row so a giant data: URL
      // never lands as raw textContent.
      const sourceIcon = row.querySelector(".history-icon");
      const modalIcon = modal.querySelector('[data-modal-icon]');
      if (modalIcon) modalIcon.innerHTML = sourceIcon ? sourceIcon.innerHTML : "🧹";
      modal.classList.remove("hidden");
    }

    // Hide completion-only rows (base reward, multipliers, skipped)
    // when editing a withdrawal/transfer — those fields are
    // chore-specific and have no analogue here.
    function setCompletionOnlyVisible(visible) {
      modal.querySelectorAll(".completion-only").forEach(el => {
        if (visible) el.removeAttribute("hidden");
        else         el.setAttribute("hidden", "");
      });
    }

    function openWithdrawalModal(row) {
      currentEditTarget = { kind: "withdrawal", row };
      const ds = row.dataset;
      modal.querySelector('[data-modal-title]').textContent = "Edit Withdrawal";
      modal.querySelector('[data-modal-subject-label]').textContent = "Type";
      const modalIcon = modal.querySelector('[data-modal-icon]');
      if (modalIcon) modalIcon.textContent = "🪙";
      modal.querySelector('[data-modal-name]').textContent = "Withdrawal";
      modal.querySelector('[data-modal-completed-at]').value = toLocalInputValue(ds.createdAt);
      modal.querySelector('[data-modal-amount]').value = ds.amount || "0";
      modal.querySelector('[data-modal-amount-row]').removeAttribute("hidden");
      modal.querySelector('[data-modal-amount-label]').textContent = "Amount";
      modal.querySelector('[data-modal-note]').value = ds.note || "";
      setCompletionOnlyVisible(false);
      modal.classList.remove("hidden");
    }

    function openTransferModal(row) {
      currentEditTarget = { kind: "transfer", row };
      const ds = row.dataset;
      const outgoing = ds.direction === "outgoing";
      modal.querySelector('[data-modal-title]').textContent = "Edit Transfer";
      modal.querySelector('[data-modal-subject-label]').textContent = outgoing ? "Sent to" : "From";
      const modalIcon = modal.querySelector('[data-modal-icon]');
      if (modalIcon) modalIcon.textContent = "🤝";
      modal.querySelector('[data-modal-name]').textContent = ds.peer || "";
      modal.querySelector('[data-modal-completed-at]').value = toLocalInputValue(ds.createdAt);
      modal.querySelector('[data-modal-amount]').value = ds.amount || "0";
      modal.querySelector('[data-modal-amount-row]').removeAttribute("hidden");
      modal.querySelector('[data-modal-amount-label]').textContent = "Amount";
      modal.querySelector('[data-modal-note]').value = ds.note || "";
      setCompletionOnlyVisible(false);
      modal.classList.remove("hidden");
    }

    function openPendingModal(row) {
      const idx = parseInt(row.dataset.pendingIndex, 10);
      const q = loadQueue();
      const item = q[idx];
      if (!item) { flash("Pending item is gone", "warn"); renderPending(); return; }
      currentEditTarget = { kind: "pending", idx };
      const meta = item.meta || {};
      const body = item.body || {};
      modal.querySelector('[data-modal-title]').textContent = "Edit Pending Push";
      modal.querySelector('[data-modal-subject-label]').textContent = "Chore";
      modal.querySelector('[data-modal-name]').textContent = meta.chore_name || `Chore #${meta.chore_id ?? "?"}`;
      modal.querySelector('[data-modal-base]').textContent = String(meta.base_pebbles ?? 0);
      setCompletionOnlyVisible(true);
      modal.querySelector('[data-modal-completed-at]').value =
        toLocalInputValue(body.client_completed_at || item.queued_at);
      const hotMult0    = parseFloat(body.hot_multiplier    ?? "1") || 1;
      const streakMult0 = parseFloat(body.streak_multiplier ?? body.total_multiplier ?? "1") || 1;
      const base = parseInt(meta.base_pebbles ?? 0, 10) || 0;
      const computedPaid = Math.round(base * hotMult0 * streakMult0);
      modal.querySelector('[data-modal-amount-row]').removeAttribute("hidden");
      modal.querySelector('[data-modal-amount-label]').textContent = "Paid pebbles";
      modal.querySelector('[data-modal-amount]').value =
        body.paid_pebbles != null ? String(body.paid_pebbles) : String(computedPaid);
      setMultPill("hot",    hotMult0);
      setMultPill("streak", streakMult0);
      modal.querySelector('[data-modal-note]').value = body.note || "";
      modal.querySelector('[data-modal-skipped-row]').setAttribute("hidden", "");
      const sourceIcon = row.querySelector(".history-icon");
      const modalIcon = modal.querySelector('[data-modal-icon]');
      if (modalIcon) modalIcon.innerHTML = sourceIcon ? sourceIcon.innerHTML : "🧹";
      modal.classList.remove("hidden");
    }

    function closeModal() {
      modal.classList.add("hidden");
      currentEditTarget = null;
    }
    modal.querySelectorAll('[data-modal-cancel]').forEach(el => el.addEventListener("click", closeModal));
    modal.addEventListener("click", e => { if (e.target === modal) closeModal(); });

    listEl.addEventListener("click", e => {
      const completionEdit = e.target.closest("[data-edit-completion]");
      if (completionEdit) { openCommittedModal(completionEdit.closest("[data-completion-id]")); return; }
      const withdrawalEdit = e.target.closest("[data-edit-withdrawal]");
      if (withdrawalEdit) { openWithdrawalModal(withdrawalEdit.closest("[data-withdrawal-id]")); return; }
      const transferEdit = e.target.closest("[data-edit-transfer]");
      if (transferEdit) { openTransferModal(transferEdit.closest("[data-transfer-id]")); return; }
    });
    pendingList.addEventListener("click", e => {
      const editBtn = e.target.closest("[data-edit-pending]");
      if (editBtn) { openPendingModal(editBtn.closest("[data-pending-index]")); return; }
      const delBtn = e.target.closest("[data-delete-pending]");
      if (delBtn) {
        const row = delBtn.closest("[data-pending-index]");
        const idx = parseInt(row.dataset.pendingIndex, 10);
        const q = loadQueue();
        const removed = q.splice(idx, 1)[0];
        saveQueue(q);
        renderPending();
        flash(removed?.method === "DELETE" ? "Cancelled undo" : "Removed pending push", "warn");
      }
    });

    modal.querySelector('[data-modal-save]').addEventListener("click", async (e) => {
      if (!currentEditTarget) return;
      const saveBtn = e.currentTarget;
      const note = modal.querySelector('[data-modal-note]').value;
      const completedLocal = modal.querySelector('[data-modal-completed-at]').value;
      const hotMult    = parseFloat(modal.querySelector('[data-modal-hot-mult]').value);
      const streakMult = parseFloat(modal.querySelector('[data-modal-streak-mult]').value);
      const completedIso = completedLocal ? new Date(completedLocal).toISOString() : null;

      // Withdrawal + transfer share the same body shape (amount,
      // note, created_at). The When field reuses the completed-at
      // input but is sent as `created_at` since that's what those
      // models store the timestamp under.
      if (currentEditTarget.kind === "withdrawal" || currentEditTarget.kind === "transfer") {
        const row = currentEditTarget.row;
        const amount = parseInt(modal.querySelector('[data-modal-amount]').value, 10);
        if (Number.isNaN(amount) || amount <= 0) { flash("Bad amount", "error"); return; }
        const key = currentEditTarget.kind === "withdrawal" ? "chore_withdrawal" : "chore_transfer";
        const idField = currentEditTarget.kind === "withdrawal" ? "withdrawalId" : "transferId";
        const path = currentEditTarget.kind === "withdrawal" ? "withdrawals" : "transfers";
        const payload = { [key]: { amount_pebbles: amount, note: note } };
        if (completedIso) payload[key].created_at = completedIso;
        await withSavingState(saveBtn, async () => {
          try {
            const data = await api(`/chores/${path}/${row.dataset[idField]}`, "PATCH", payload);
            if (data?.today_earnings != null) setTodayEarnings(data.today_earnings);
            await fetchHistory({ push: false });
            flash("Saved");
            closeModal();
          } catch (err) { flash("Save failed: " + err.message, "error"); }
        });
        return;
      }

      if (currentEditTarget.kind === "pending") {
        const q = loadQueue();
        const item = q[currentEditTarget.idx];
        if (!item) { closeModal(); renderPending(); return; }
        const paid = parseInt(modal.querySelector('[data-modal-amount]').value, 10);
        if (Number.isNaN(paid) || paid < 0) { flash("Bad amount", "error"); return; }
        item.body = item.body || {};
        item.body.note = note;
        item.body.hot_multiplier = Number.isFinite(hotMult) ? hotMult : 1;
        item.body.streak_multiplier = Number.isFinite(streakMult) ? streakMult : 1;
        item.body.paid_pebbles = paid;
        if (completedIso) item.body.client_completed_at = completedIso;
        saveQueue(q);
        renderPending();
        flash("Saved");
        closeModal();
        return;
      }

      // committed
      const row = currentEditTarget.row;
      const amount = parseInt(modal.querySelector('[data-modal-amount]').value, 10);
      if (Number.isNaN(amount) || amount < 0) { flash("Bad amount", "error"); return; }
      const payload = {
        chore_completion: {
          paid_pebbles: amount,
          note: note,
          hot_multiplier: Number.isFinite(hotMult) ? hotMult : 1,
          streak_multiplier: Number.isFinite(streakMult) ? streakMult : 1,
        },
      };
      if (completedIso) payload.chore_completion.completed_at = completedIso;
      await withSavingState(saveBtn, async () => {
        try {
          const data = await api(`/chores/completions/${row.dataset.completionId}`, "PATCH", payload);
          // Header pill stays today_earnings. No fallback to lifetime —
          // a missing today_earnings would mean a server bug, surface
          // it rather than mask it with the wrong number.
          if (data?.today_earnings != null) setTodayEarnings(data.today_earnings);
          // Refetch the current page so the row sorts to its new position
          // if the timestamp changed — cheaper than reconciling in place.
          await fetchHistory({ push: false });
          flash("Saved");
          closeModal();
        } catch (err) { flash("Save failed: " + err.message, "error"); }
      });
    });

    modal.querySelector('[data-modal-delete]').addEventListener("click", async (e) => {
      if (!currentEditTarget) return;
      const delBtn = e.currentTarget;
      if (currentEditTarget.kind === "pending") {
        const q = loadQueue();
        const removed = q.splice(currentEditTarget.idx, 1)[0];
        saveQueue(q);
        renderPending();
        flash(removed?.method === "DELETE" ? "Cancelled undo" : "Removed pending push", "warn");
        closeModal();
        return;
      }
      if (currentEditTarget.kind === "withdrawal" || currentEditTarget.kind === "transfer") {
        const row = currentEditTarget.row;
        const idField = currentEditTarget.kind === "withdrawal" ? "withdrawalId" : "transferId";
        const path = currentEditTarget.kind === "withdrawal" ? "withdrawals" : "transfers";
        const prompt = currentEditTarget.kind === "withdrawal"
          ? "Delete this withdrawal? Balance will be recomputed."
          : "Delete this transfer? Both balances will be refunded.";
        if (!confirm(prompt)) return;
        await withSavingState(delBtn, async () => {
          try {
            const data = await api(`/chores/${path}/${row.dataset[idField]}`, "DELETE");
            if (data?.today_earnings != null) setTodayEarnings(data.today_earnings);
            await fetchHistory({ push: false });
            flash("Removed", "warn");
            closeModal();
          } catch (err) { flash("Delete failed: " + err.message, "error"); }
        });
        return;
      }
      const row = currentEditTarget.row;
      if (!confirm("Delete this completion? Balance will be recomputed.")) return;
      await withSavingState(delBtn, async () => {
        try {
          const data = await api(`/chores/completions/${row.dataset.completionId}`, "DELETE");
          if (data?.today_earnings != null) setTodayEarnings(data.today_earnings);
          await fetchHistory({ push: false });
          flash("Removed", "warn");
          closeModal();
        } catch (err) { flash("Delete failed: " + err.message, "error"); }
      }, "Deleting…");
    });

    // ---------- explicit reload only ----------
    // History entries load ONCE on page navigation, then stay
    // exactly as rendered. Auto-refresh (Monitor broadcasts, focus,
    // online events) was too aggressive — it reloaded mid-edit
    // while users were typing notes. The reload buttons below are
    // the only refresh path; navigating away and back is the other.
    document.querySelector("[data-history-reload]")
      ?.addEventListener("click", () => fetchHistory({ push: false }));
    document.querySelector("[data-pending-reload]")
      ?.addEventListener("click", () => renderPending());
    // Cross-tab queue edits: a pending push edited/removed in
    // another tab fires a `storage` event here. Re-render so the
    // local pending list stays in sync — this is a passive read
    // from localStorage, not a network call, so it can't disturb
    // an in-progress edit.
    window.addEventListener("storage", e => {
      if (e.key === QUEUE_KEY) renderPending();
    });

    // ---------- boot ----------
    const initUrl = new URL(location.href);
    state.q = initUrl.searchParams.get("q") || "";
    state.page = parseInt(initUrl.searchParams.get("page") || "1", 10) || 1;
    qInput.value = state.q;
    if (clearBtn) clearBtn.hidden = !state.q;
    renderPending();
    fetchHistory({ push: false });
  </script>
<% end %>
