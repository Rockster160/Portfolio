<% content_for :title, "Chores · Today" %>
<% content_for :head do %>
  <link rel="manifest" href="/chores.webmanifest">
  <meta name="theme-color" content="#00102B">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
<% end %>
<% content_for :viewport_tag do %>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
<% end %>

<div class="chores-page" data-chores-root data-mode="today"
     data-day-key="<%= @day.iso8601 %>"
     data-cutoff-hour="<%= ChoreDay::CUTOFF_HOURS %>">
  <%= render "header", balance: @balance, scope: :today %>

  <%= render "hot_strip", hot_picks: @hot_picks, chores: @scheduled_today %>

  <%= render "toolbar", search_placeholder: "Filter today..." %>

  <% if @scheduled_today.empty? %>
    <p style="color:var(--chores-muted);">Nothing scheduled for today. Nice.</p>
  <% end %>

  <div class="chores-circles-wrap">
  <div class="chores-circles" data-chores-circles>
    <% @scheduled_today.each do |chore|
         actor = @completion_actor_by_chore[chore.id]
         actor_label = (actor && actor.id != current_user.id) ? actor.username : nil %>
      <%= render "circle_card",
                 chore: chore,
                 done_count: @completions_today[chore.id].to_i,
                 last_completion: @last_completion_by_chore[chore.id],
                 hot: @hot_picks[chore.id],
                 actor_label: actor_label %>
    <% end %>
  </div>
  </div>

  <%= render "modals" %>

  <div id="chore-multiplier-modal" class="chores-modal-backdrop hidden" data-multiplier-modal>
    <div class="chores-modal" style="width:min(320px,92vw);text-align:center;">
      <h3 style="margin:0 0 8px;">How many?</h3>
      <p style="color:var(--chores-muted);margin:0 0 12px;" data-multiplier-label></p>
      <div class="reward-quicks" style="justify-content:center;" data-multiplier-quicks>
        <% [2, 3, 4, 5, 10].each do |n| %>
          <button type="button" data-mult="<%= n %>"><%= n %>×</button>
        <% end %>
      </div>
      <input type="number" min="1" value="2" data-multiplier-input
             style="width:80px;margin-top:10px;padding:8px;border-radius:6px;border:1px solid #334155;background:#00102B;color:#ECF0F1;text-align:center;">
      <div class="form-actions" style="justify-content:center;">
        <button type="button" class="ghost" data-action="cancel">Cancel</button>
        <button type="button" class="primary" data-multiplier-submit>OK</button>
      </div>
    </div>
  </div>

  <% if @lookahead.values.flatten.any? %>
    <h3 style="margin-top:24px;">Next 7 days</h3>
    <% @lookahead.keys.sort.each do |day| %>
      <% items = @lookahead[day]; next if items.empty? %>
      <div class="lookahead-day">
        <div class="day-label"><%= day.strftime("%a %b %-d") %></div>
        <div class="day-items">
          <% items.each do |c| %>
            <span class="day-chip"><%= c.icon.presence || "🧹" %> <%= c.display_short_name %> <strong><%= c.reward_label %></strong></span>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>

<% content_for :after_body do %>
  <%= render "page_script", mode: "today" %>
<% end %>
