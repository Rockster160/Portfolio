<div class="modal settings-modal" id="quick-actions-settings" tabindex="-1">
  <div class="close"><i class="ti ti-fa-close"></i></div>
  <div class="modal-content">
    <div class="settings-section">
      <div class="section-title">Widgets</div>
      <div class="settings-actions">
        <a href="#" class="btn" data-mode="add">Add</a>
        <a href="#" class="btn" data-mode="edit">Edit</a>
        <a href="#" class="btn" data-mode="move">Move</a>
        <a href="#" class="btn" data-mode="delete">Delete</a>
      </div>
    </div>

    <div class="settings-section">
      <div class="section-title">Notifications</div>
      <div class="notification-row">
        <span class="notification-status" data-status="unknown">
          <span class="status-dot"></span>
          <span class="status-text">Checking&hellip;</span>
        </span>
        <button type="button" class="btn" id="register-notifications-btn">Register</button>
      </div>
    </div>
  </div>
</div>
