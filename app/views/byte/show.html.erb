<%= meta_title "Byte", include_name: false %>
<%= meta_description "Direct chat channel to your automations." %>
<%= content_for(:favicon) { render "byte/favicon" } %>
<%= content_for(:meta) do %>
  <%# interactive-widget=resizes-content: Android Chrome shrinks the layout %>
  <%# viewport when the soft keyboard opens so 100dvh + fixed positioning %>
  <%# both react. iOS Safari 16+ does this on its own via dvh units. %>
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, interactive-widget=resizes-content">
  <%# Shell validation marker for the service worker. Only pages that %>
  <%# carry this meta are cached as the Byte shell — a stray error page %>
  <%# or auth interstitial without it never poisons the SW cache. %>
  <meta name="byte-shell" content="ok">
  <%# Deploy version. Changes only on server revisions, unlike the shell %>
  <%# HTML itself which fluctuates every request via the dynamic bootstrap %>
  <%# JSON. The SW compares THIS across revalidates to decide whether an %>
  <%# update is genuinely available — otherwise the reload "!" would %>
  <%# retrigger on every stale-while-revalidate cycle. %>
  <meta name="byte-version" content="<%= COMMIT_SHA %>">
<% end %>
<%= content_for(:head_before_scripts) do %>
  <script>
    // Byte lives on its own subdomain (byte.lvh.me in dev, byte.ardesian.com
    // in prod). The app-wide ActionCable meta tag points at a fixed dev host
    // (ws://localhost:3141/cable), so on a subdomain the WS handshake is
    // cross-origin and the session cookie doesn't travel with it — the
    // connection fails silently. Rewrite the meta to a same-host URL BEFORE
    // application.js parses.
    (function() {
      var meta = document.querySelector('meta[name="action-cable-url"]');
      if (!meta) return;
      var proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
      meta.setAttribute('content', proto + '//' + location.host + '/cable');
    })();
  </script>
<% end %>

<div class="byte-app"
     data-monitor-channel="byte"
     data-messages-url="<%= byte_message_history_path %>"
     data-send-url="<%= byte_messages_path %>"
     data-csrf-url="<%= byte_csrf_path %>"
     data-conversations-url="<%= byte_conversations_path %>"
     data-claude-sessions-url="<%= byte_claude_sessions_path %>"
     data-initial-conversation-id="<%= @conversation.id %>">
  <header class="byte-header">
    <%# Drawer trigger — sits before the avatar so it lands in the natural %>
    <%# top-left slot the user's thumb reaches for. %>
    <button type="button" class="byte-drawer-toggle" data-byte-drawer-toggle title="Conversations" aria-label="Open conversations">
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
        <path fill="currentColor" d="M3 6h18v2H3zm0 5h18v2H3zm0 5h18v2H3z"/>
      </svg>
    </button>
    <span class="byte-avatar">
      <%= image_tag "byte_favicon/byte.png", alt: "Byte" %>
    </span>
    <span class="byte-title">
      <span class="byte-title-row">
        <span class="byte-name" data-byte-convo-name><%= @conversation.display_name %></span>
        <span class="byte-mode-chip" data-byte-mode-chip data-mode="<%= @conversation.mode %>"><%= @conversation.mode %></span>
      </span>
      <span class="byte-status" data-byte-status>connecting…</span>
    </span>
    <%# Quiet syncing / offline badge. Empty when idle; the service %>
    <%# worker fills it via shell_synced / shell_sync_failed messages. %>
    <span class="byte-sync-badge" data-byte-sync data-state=""></span>
    <%# Reload — always tappable to force a hard refresh, and lights up %>
    <%# with a "!" badge when the SW has staged a new shell version. %>
    <button type="button" class="byte-reload-btn" data-byte-reload title="Reload" aria-label="Reload">
      <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
        <path fill="currentColor" d="M17.65 6.35A7.958 7.958 0 0 0 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35Z"/>
      </svg>
    </button>
    <button type="button" class="byte-notify-toggle" data-byte-notify title="Enable notifications" aria-label="Toggle notifications">
      <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
        <path fill="currentColor" d="M12 22a2.4 2.4 0 0 0 2.4-2.4H9.6A2.4 2.4 0 0 0 12 22Zm6.6-6v-5a6.6 6.6 0 1 0-13.2 0v5L3 18.4V19h18v-.6Z"/>
      </svg>
    </button>
  </header>

  <%# Slim strip under the header showing the effective cwd for the %>
  <%# current conversation. Blank when unknown; the Mac fills it in on %>
  <%# the first `cd` or shell run and pushes updates via broadcast. %>
  <div class="byte-pwd-bar" data-byte-pwd data-visible="<%= @conversation.metadata['cwd'].present? %>">
    <span class="byte-pwd-icon" aria-hidden="true">›</span>
    <span class="byte-pwd-path" data-byte-pwd-path><%= short_home(@conversation.metadata['cwd']) %></span>
  </div>

  <main class="byte-thread" data-byte-thread aria-live="polite" aria-relevant="additions">
    <%# Older-history loading indicator. Hidden by default; JS toggles %>
    <%# when a paginated fetch is in flight or "no more" is confirmed. %>
    <div class="byte-thread-loader" data-byte-loader hidden>loading…</div>
  </main>

  <%# Floating jump-to-newest. Visible while user is scrolled off the %>
  <%# bottom; the count reflects messages received while scrolled up. %>
  <button type="button" class="byte-jump-btn" data-byte-jump aria-label="Jump to newest">
    <span class="byte-jump-arrow" aria-hidden="true">↓</span>
    <span class="byte-jump-count" data-byte-jump-count></span>
  </button>

  <template data-byte-message-tpl>
    <article class="byte-msg">
      <div class="byte-msg-attachments" data-attachments></div>
      <%# Collapsible thoughts (Claude's intermediate reasoning + tool %>
      <%# uses). Hidden entirely for non-Claude messages. %>
      <details class="byte-msg-thoughts" data-thoughts hidden>
        <summary data-thoughts-summary>Thinking</summary>
        <div class="byte-msg-thoughts-body" data-thoughts-body></div>
      </details>
      <div class="byte-msg-body" data-body></div>
      <div class="byte-msg-meta">
        <time data-time></time>
        <span class="byte-msg-state" data-state></span>
      </div>
    </article>
  </template>

  <form class="byte-composer" data-byte-composer autocomplete="off" data-mode="<%= @conversation.mode %>">
    <%# Single mode-adaptive avatar to the left of the input: %>
    <%#   Claude  → Byte image %>
    <%#   Jarvis  → Ardesian favicon (proxy for the Jarvis mark) %>
    <%#   Bash    → `$` in lime monospace %>
    <%# CSS on `.byte-composer[data-mode="…"]` toggles which child is visible. %>
    <span class="byte-composer-avatar" data-byte-composer-avatar>
      <img class="byte-composer-avatar-img byte-composer-avatar-claude"
           src="<%= asset_path('byte_favicon/byte.png') %>" alt="Byte">
      <img class="byte-composer-avatar-img byte-composer-avatar-jarvis"
           data-byte-composer-avatar-jarvis src="" alt="Jarvis">
      <span class="byte-composer-avatar-bash">$</span>
    </span>
    <textarea
      class="byte-input"
      data-byte-input
      rows="1"
      placeholder="Say something to Byte…"
      autocapitalize="sentences"
      spellcheck="true"
    ></textarea>
    <button type="submit" class="byte-send" data-byte-send aria-label="Send">
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
        <path fill="currentColor" d="M3.4 20.6 22 12 3.4 3.4l-.1 6.7L17 12 3.3 13.9Z"/>
      </svg>
    </button>
  </form>
</div>

  <%# Slide-in conversations drawer + backdrop. Hidden by default; %>
  <%# .open on both elements when active. %>
  <aside class="byte-drawer" data-byte-drawer aria-hidden="true">
    <div class="byte-drawer-header">
      <span class="byte-drawer-title">Conversations</span>
      <button type="button" class="byte-drawer-close" data-byte-drawer-close aria-label="Close">×</button>
    </div>
    <button type="button" class="byte-new-convo" data-byte-new-convo>+ New conversation</button>
    <ul class="byte-convo-list" data-byte-convo-list></ul>
  </aside>
  <div class="byte-drawer-backdrop" data-byte-drawer-backdrop aria-hidden="true"></div>

  <%# New-conversation dialog. Native <dialog> for accessibility + %>
  <%# built-in dismiss behaviour. %>
  <dialog class="byte-modal" data-byte-new-modal>
    <form class="byte-modal-form basic" data-byte-new-form method="dialog" autocomplete="off">
      <h3 class="byte-modal-title">New conversation</h3>
      <label class="byte-modal-label">
        Name
        <input type="text" class="byte-modal-input" name="name" placeholder="Optional (defaults to mode name)">
      </label>
      <label class="byte-modal-label">
        Mode
        <select class="byte-modal-input" name="mode">
          <option value="claude" selected>Claude — AI conversation</option>
          <option value="bash">Bash — shell commands, no prefix</option>
          <option value="jarvis">Jarvis — automation commands</option>
        </select>
      </label>
      <div class="byte-modal-actions">
        <button type="button" class="byte-modal-btn" data-byte-new-cancel>Cancel</button>
        <button type="submit" class="byte-modal-btn byte-modal-btn-primary">Create</button>
      </div>
    </form>
  </dialog>

  <%# Per-conversation menu (rename/archive/adopt Claude session). %>
  <dialog class="byte-modal" data-byte-convo-menu>
    <div class="byte-modal-form basic">
      <h3 class="byte-modal-title" data-byte-menu-title>Conversation</h3>
      <div class="byte-menu-list">
        <button type="button" class="byte-menu-btn" data-byte-menu-rename>Rename…</button>
        <button type="button" class="byte-menu-btn" data-byte-menu-adopt>Adopt Claude session…</button>
        <button type="button" class="byte-menu-btn byte-menu-btn-danger" data-byte-menu-archive>Archive</button>
      </div>
      <div class="byte-modal-actions">
        <button type="button" class="byte-modal-btn" data-byte-menu-close>Close</button>
      </div>
    </div>
  </dialog>

  <%# Adopt-session picker. Populated from the Mac's /byte/claude_sessions. %>
  <dialog class="byte-modal byte-modal-wide" data-byte-adopt-modal>
    <div class="byte-modal-form basic">
      <h3 class="byte-modal-title">Adopt Claude session</h3>
      <p class="byte-modal-hint" data-byte-adopt-hint>Loading…</p>
      <ul class="byte-adopt-list" data-byte-adopt-list></ul>
      <div class="byte-modal-actions">
        <button type="button" class="byte-modal-btn" data-byte-adopt-close>Close</button>
      </div>
    </div>
  </dialog>

<script id="byte-bootstrap" type="application/json">
  <%= raw JSON.generate(
    conversation:  @conversation.as_wire,
    conversations: @conversations.map(&:as_wire),
    messages:      @messages.map(&:as_wire),
  ) %>
</script>
