<%= meta_title @page.name, include_name: false %>

<div class="wide-container">
  <h1 style="text-align: center;"><%= @page.name %></h1>
  <div class="tag-list">
    <% @page.tags.each do |tag| %>
      <span class="tag"><%= tag.name %></span>
    <% end %>
  </div>
  <hr>
  <%= Markdown.new(@page.content).to_html %>
</div>
