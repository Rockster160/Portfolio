{
  "host": "0.0.0.0",
  "port": 4443,
  "log_level": "info",
  "json_log_enable": true,
  "namespace": "tesla_telemetry",
  "tls": {
    "ca_file":     "/opt/fleet-telemetry/src/config/files/prod_ca.crt",
    "server_cert": "/etc/letsencrypt/live/ardesian.com/fullchain.pem",
    "server_key":  "/etc/letsencrypt/live/ardesian.com/privkey.pem"
  },
  "records": {
    "alerts":       ["logger"],
    "errors":       ["logger"],
    "V":            ["logger"],
    "connectivity": ["logger"]
  }
}
